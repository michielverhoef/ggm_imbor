          <ownedComment xmi:type="uml:Comment" xmi:id="attr_c6bf7785ee155ce595f84040170ea942_c" body="Aanduiding van de door PostNL vastgestelde code behorende bij een bepaalde combinatie van een naam openbare ruimte en een huisnummer waarbinnen het object zich bevindt. nan"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="attr_a50ac514b3125a7bbd9c9d5afa31a192" name="straatnaam" type="prim_80355477ab9e51caaf39900ac7afbff0">

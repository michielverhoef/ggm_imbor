      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_4926f285320c409a99c7126e3ca0f7cb" name="enum_ReclamebordVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_65cab72973ed4fc8830a143b5874a580" name="Billboard">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_80f8e309a2b84e4099eee5e156e59eb9" body="Groot formaat reclamebord langs belangrijke doorgaande wegen en drukke verkeersaders."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4d3105b10ffa4630812e1f4599045274" name="Digitale billboard">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_45c2df58957f4b778e58b38ef8f429d3" body="Een elektronisch LCD- of LED-beeldscherm van grote omvang dat vaak op grote hoogte wordt geplaatst in de binnenstad of langs (snel)wegen en digitaal wordt voorzien van afbeeldingen en deze vertoont aan voorbijgangers voor reclamedoeleinden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a8573ec504374ec3be87255d0debf090" name="Digitale mupi">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c798cc161f9848e4a73e2608057a56cd" body="Een digitaal beeldscherm van ongeveer vier vierkante meter in oppervlakte dat dicht bij de grond langs wegen wordt geplaatst en digitaal wordt voorzien van afbeeldingen en deze vertoont aan voorbijgangers voor reclamedoeleinden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8cc52b2c753949dbbee4569f081c27b6" name="Lichtbak">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4e99844968924c468f379431fa28a892" body="Een rechthoekige bak met minstens één doorzichtige zijde, waarin zich een of meerdere lampen bevinden en die voorzien is van een reclame-uiting."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_54044f96eabb4c188a448d1d5fce4945" name="Mupi">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c15d3dadc8de448da574b8d0f7645ab4" body="De afkorting van &apos;Mobilier Urbain à Publicité Illuminé&apos;: het is een reclamebord die van binnenuit verlicht wordt, zodat deze 24 uur per dag zichtbaar is. De reclame-uiting heeft meestal een formaat van 1185 mm bij 1750 mm en kan enkelzijdig of dubbelzijdi"/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_64fb7a0f6a13467dbf744a93d5882e05" name="enum_ReduceringVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d96f5b4603dd4659a825f8c9d63ce2e1" name="Reducering fijnstof">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4ae257e3188945f9b1cacc7a53ec385a" body="Functionele ruimte die een voorziening bevat om verspreiding van fijnstof te verminderen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e5c0a744cc9f4b84ac966be53c5e510a" name="Reducering geluid">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ace91af4460c4798a9eca789b733b4e4" body="Functionele ruimte die een voorziening bevat om geluidshinder in de buitenlucht te verminderen."/>

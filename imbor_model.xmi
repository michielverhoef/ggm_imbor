        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_685c1fb309194ababb2d8ac150db5cb9" name="Blindengeleideroute">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ad77af5f3ff84459a5595b5230b32cff" name="Europese route (E-route)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5809f610be7c4d809160b67dea9285db" body="Weg, door de letter E en enkele cijfers aangeduid, die worden toegekend door de Europese economische commissie van de Verenigde Naties (UNECE). Het netwerk doorkruist Europa en overbrugt nationale grenzen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_dc49a7483c244bda9a7486256deca87a" name="Fietsroute">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2ae6d11b6cab4aa4aa70ff727cfa16d7" body="(Hoofd)route ingericht voor de verschillende soorten langzaam verkeer."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5d6a0117b70b4a81b204c72724d02774" name="Fietsroute: hoofdfietsroute">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bece444835564ce991ac43e153618a69" body="De primaire, bewegwijzerde ofwel beschreven of anderszins gefaciliteerde route, die men fietst als recreatieve-toeristische activiteit, voor woon-werk verbindingen of voor andere verplaatsingsdoeleinden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bfa07d33f59b4a38bc91c90fa5fc4714" name="Fietsroute: subroute">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ea7511927cc841eb97469146f8daeae3" body="De secundaire, bewegwijzerde ofwel beschreven of anderszins gefaciliteerde route, die men fietst als recreatieve-toeristische activiteit, voor woon-werk verbindingen of voor andere verplaatsingsdoeleinden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_252e1f35eb994489a90ff2fab8c1bb77" name="Huisvuilophaalroute">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c958ef3a9d9643e69337d35810eb8648" body="Geplande af te leggen weg voor het legen van huisvuilcontainers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bdb5022a655345e49950ee5f93e279dd" name="Inspectielooproute">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5ad6d4fde15b4ef8a00620b562996ea8" body="Geplande af te leggen weg voor het controleren van de kwaliteitstoestanden van bepaalde objecten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_645f3236e2e8436c96f6565003c8ba19" name="Omleidingsroute (incidenteel)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2afb5fa7423041f2871ccf24f430a405" body="Tijdelijke route aangegeven met tijdelijke (bewegwijzerings)borden bij geheel of gedeeltelijke afsluitingen van de gangbare route."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_84b2996257d84b319a692c4fdb11b12f" name="Ontsluitingsroute">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_013a15451cc04ba9ae1b674d59ca5f49" body="De verbindingsroute tussen de parkeergarage en de hoofdwegenstructuur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_19d76ac5e74a4e2c98e71e57c7ebecea" name="OV-route">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6ecfba5bee69413cbb14ba1183cd5a59" body="Lijn die een bus of tram volgt door de stad en het buitengebied."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e42840c87a444d9f9d2a35fe72ed22e1" name="OV-route: hoofdroute (regionaal)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fee85513f48e4d989f480cdd0b191132" body="De primaire, op regionaal niveau gelegen, geplande af te leggen weg te gebruiken voor personenvervoer dat openbaar toegankelijk is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_34c3f1afde364eda8a770f1faeafa6ea" name="OV-route: subroute (stad)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_310b9dde66534e9095069a0f5dd20506" body="De secundaire, op het niveau van individuele steden gelegen, geplande af te leggen weg te gebruiken voor personenvervoer dat openbaar toegankelijk is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d94cce870dd44ed2a1554c85bb2517d0" name="Permanente omleidingsroute (U-route)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_78262cbbe8d8477ba8492c98abd2c260" body="Een geplande af te leggen weg voor het geval snelwegen worden afgesloten, door bijvoorbeeld wegwerkzaamheden of calamiteiten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5160e6d754cf4e699bff97713138df20" name="Route exceptioneel vrachtverkeer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8c51b9c5d21b4037a461c9485409f75c" body="Een geplande af te leggen weg voor vervoer van goederen dat qua afmetingen (lengte, breedte, hoogte) en-of massa de Regeling Voertuigen niet naleeft."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e5ae9b853303465c85691fcef0bb63eb" name="Route gevaarlijke stoffen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cf7e1d3dd5cd4695ac300940ffce77da" body="Geplande af te leggen weg te gebruiken door voertuigen die materialen die zijn aangemerkt als gevaarlijk vervoeren."/>

      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_f8dd20a3cf55444c89e3d929c154ee81" name="enum_OpstelplaatsVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4717d729afaf474daf32dfdc87a5ba97" name="Brandweeropstelplaats">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a8c17d56b49c40c0947cbaa23a83163a" body="Een conform het wettelijke bouwbesluit aangegeven plaats nabij een personenverblijf waar brandweervoertuigen kunnen parkeren en die een efficiënte toegang tot een bluswatervoorziening mogelijk maakt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e68109d29e6b423c9d20fbc9fd66320d" name="Containeropstelplaats">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aadbcc61b87a418594fc431d558a9028" body="Een locatie die is aangewezen als plaats waar containers van grotere omvang neergezet mogen worden om geleegd te worden door een vuilophaaldienst."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b40505b3ae6b43ed8e0c3581b56cda30" name="Opstelplaats open water">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bd49148896cb46daa223c3d3d11b6e4d" body="Het object wordt gebruikt als secundaire bluswatervoorziening, in de vorm van een locatie waar brandweervoorzieningen water kunnen putten uit een partij oppervlaktewater."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0f60db68f4614fd9aae412ca3188e59f" name="Pompopstelplaats">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bfd50384abb04e769b75f60f6384b1e7" body="Het object wordt gebruikt als locatie waar een pomp water voort kan pompen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7f6bfd82302a4a86ab4751681fb6e867" name="Vuilcontainerplaats">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b54022fada6542e4b01beb9555010a23" body="Een afbakening in het terrein voor het plaatsen van de vuilcontainers langs de straat."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_27c578a63a444ac4860f0adfec2b65ce" name="enum_OpzetstukVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d7316eeb484b4f18b0049c6745276d91" name="Knieopzetstuk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_07d0a38db79c458cb9e5580cb2019c8f" body="Een op een paal te monteren opzetstuk in de vorm van een naar boven wijzende holle buis met een rechte hoek ten behoeve van de aansluiting van verkeerslantaarns."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_280e212c7b37496892d5aaaa8533adf8" name="Opzetstuk drievoudig">

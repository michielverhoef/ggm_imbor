      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_d3adc63e07cc4095a8e7e0d73d030a81" name="enum_OnderlichtVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f3be7109c90e4ac0ac147e04e4e71405" name="Driekleurig fietslicht">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8cc5d45fb3fb4460b0bd88378532d5cd" body="Verkeerslantaarn ten behoeve van de regulering van het fietsverkeer, met lampen in drie verschillende kleuren voor verkeerssignalering: groen, oranje en rood."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a6e210957ab74361959972d76b9ac81d" name="Driekleurig fietslicht met AFTG-armatuur (Alle Fietsers Tegelijk Groen)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_707686ac301c4fbfb203f98959afc700" body="Verkeerslantaarn ten behoeve van de regulering van het fietsverkeer, met lampen in drie verschillende kleuren voor verkeerssignalering: groen, oranje en rood, en een armatuur dat door middel van vier pijlen aangeeft dat alle verkeersrichtingen aan fietser"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_58843ddd2920421bb55e96fece7d965e" name="Driekleurig fietslicht met fietserherkenningarmatuur">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_99afb8e86c464ab7813ff91866579ba3" body="Verkeerslantaarn ten behoeve van de regulering van het fietsverkeer, met lampen in drie verschillende kleuren voor verkeerssignalering: groen, oranje en rood, en een armatuur dat aangeeft dat er binnen de verkeersregelinstallatie een bewegingssensor aanwe"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7e701660daed4d9d8077ceb7c2a5cce8" name="Driekleurig fietslicht met groenvoorspeller">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_160026105ce046e6a19eb98bd0d0eaca" name="Driekleurig fietslicht met regensensorarmatuur">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5a27c531145c4ffe8c487a719b23ecb2" body="Verkeerslantaarn ten behoeve van de regulering van het fietsverkeer, met lampen in drie verschillende kleuren voor verkeerssignalering: groen, oranje en rood, en een armatuur met de tekst &apos;regensensor&apos; dat een indicatie is voor de aanwezigheid van een reg"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_598a777c615141e69ceb36843b4e73ad" name="Rechtsaf voor fietsers op eigen risico">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b1a1650b1bc344999aa57423e778037d" body="Een onderlicht dat aangeeft dat fietsers ook bij rood licht rechtsaf mogen slaan op eigen risico"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c8d9d0978c8b429aa9de4f53c8454e5e" name="Rechtsaf voor fietsers vrij">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5365c019743f44f5877bbe8d4fdbb5e9" body="Een onderlicht dat aangeeft dat fietsers ook bij rood licht rechtsaf mogen slaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_47023f78042e4c10b57250ff5fb9da72" name="Snelste fietsroutearmatuur">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_efdd467163c1488bb09c86c4f55d6df5" body="Een dynamische wegwijzer die, bestaande uit vier pictogramarmaturen, fietsers een indicatie geeft van richting om een kruispunt te traverseren die in het licht van de huidige verkeerssituatie de snelste is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9cccd76780ab420cb1a782e6c03f491a" name="Tweekleurig fietslicht">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_64cd5407d34f43a98c5eb862f0456c7f" body="Verkeerslantaarn ten behoeve van de regulering van het fietsverkeer, met lampen in twee verschillende kleuren voor verkeerssignalering: groen en rood."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6373c47d74f24169a2d33215e33f334b" name="Verkeerssituatie met fietsers in de voorrang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_69533a70fd094dff9768b67152fb43ec" body="Een onderlicht dat (tekstueel) kenbaar maakt dat er sprake is van prioriteit voor de vervoersbeweging van fietsers."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c097434d5bda4412ab065ccd9a50503c" name="enum_OnverhardVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a2d932af7d7642e691551df2648f3782" name="Mulchlaag">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9b10bbcc8a534f34b5169c379a437012" body="Een laag organisch materiaal waarmee de bodem rondom planten en struiken bedekt kan worden, die beschermt tegen warmte, kou en onkruid en daarnaast een bodem rijk aan voedingsstoffen creëert."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e8ca5cbe4dc74d30819d036fc7a8a2f4" name="Open grond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6259f4add7cc46fe86b93b3ac2ba7742" body="Type van onverhard waarvan het oppervlak bestaat uit onbegroeide grond, niet zijnde zand of zwarte grond."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bc2e262b8388427dbf61dfe76b0a649f" name="Zand">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2bc684a7c4484aaf8a0fa6293257f4cc" body="Onverhard object bestaande uit zeer kleine stukjes steenl korrels die in grootte variëren tussen 63 micrometer en 2 millimeter. Het is een zacht, hard, los of korrelig materiaal en een van de meest voorkomende natuurlijke stoffen op aarde."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_84494d3259854d8ba116c18d2cd7d912" name="Zwarte grond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a6cded738e1b45739e7efa888de8a90f" body="Type van onverhard, waarvan het oppervlak bestaat uit zeer donkere grond."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_871e5b7f8a98425daafcd037195b3140" name="enum_OpenbareRuimteLabelVerschijningsvorm">

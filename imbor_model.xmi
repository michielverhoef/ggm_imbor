      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_ccd40d5c3b3247598da3882937872631" name="enum_RietlandVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_55e698b811e74d0782a42b6432a136ae" name="Rietkraag">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1bcec302b0ce4dd4bc278c3545f65d2a" body="Een vorm van begroeiing waarbij riet een oever begrenst."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9f242dc976ad432db34c660c0e1464bd" name="Rietvegetatie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ca32a8779f654cf0ba97aee54822cf32" body="Een vegetatie met als hoofdsoort een of meerdere soorten riet, kan zowel een natte als een droge ondergrond hebben."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3729302599a240a58e8a43ff25a99969" name="Veenmosrietland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f2ed15904a3a45f49e8df1054a22bd3c" body="Een vrij ijle rietlaag met een door veenmossen gedomineerde ondergroei, met soorten als ronde zonnedauw en varens zoals kamvaren."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_eb6ef1745b6941d7bbf433e928a41e1b" name="enum_RijbaanVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9df72ca4f3bb4b15924f282817e23840" name="Busbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_03ef9a3f711c4b54ae2f1fe7fb73a5fc" body="Rijbaan bestemd voor autobussen ten behoeve van het openbaar vervoer en andere erop toegelaten motorvoertuigen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_be005d7aeac94c5aa6b0e9c012955724" name="Dynamische busbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e4aeaf81ca5a4888b74ca964fa7394cf" body="Een busbaan die door het overige verkeer gebruikt kan worden wanneer er geen bussen rijden en waar bussen dikwijls vanaf een normale rijbaan op invoegen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9bff2df53afb478dbefc529eeb023a35" name="Hoofdrijbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0b62549a02284455aeb1d0c54f07756c" body="Rijbaan of rijbanen op de hoofdbaan, die bestemd is zijn voor het doorgaand snelverkeer, en waarop eventueel ook langzaam verkeer wordt toegelaten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1f65e39e376d4d82b084f4bc585d7a79" name="Parallelweg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5c143095964d407e9bc25ea4686f98ac" body="Verkeersbaan voor gemengd lokaal verkeer die naast een hoofdbaan loopt, waarbij plaatselijk uitwisseling van verkeer met die hoofdbaan mogelijk is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_006db987fec7407bb06ee197af8dd2cc" name="Rangeerbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_04052ba1b84b4cb184ec77cdab1e3d48" body="Verkeersbaan ter plaatse van een knooppunt of aansluiting, evenwijdig lopend aan een hoofdbaan en beginnend en eindigend op die hoofdbaan, en waarop invoeg-, uitrij- en weefbewegingen kunnen plaatsvinden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2c0e4763a6a843a7ab077106eb2c0025" name="Rotondebaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3c3d9494a34949579a5da474df250342" body="Rondgaande hoofdbaan op een verkeersplein."/>
        </ownedLiteral>

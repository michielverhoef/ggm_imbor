        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ecbf1ddb7e1a470e9d6e3e0b6b473be9" name="Woordmarkering: schoolzone">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_686bc2be6ee544aa99a6723d5be8a5fc" body="Wegmarkering die het begin van een schoolzone aangeeft, een zone waar men veel kinderen rondom de weg kan verwachten en een lagere snelheid gepast is, aangeduid door een markering in de vorm van het woord &apos;schoolzone,&apos; van onder en van boven voorzien van "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3335bf90d13246bd948e8886cc389958" name="Woordmarkering: stop">

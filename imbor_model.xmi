        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3ea3483d2575449e81cb0ace87ab5f07" name="Opzetstuk viervoudig">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1db1d9a7f77f451ca6016a5808369532" name="Opzetzetstuk tweevoudig">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c708070ad5814b8ba1834f29fcebd969" name="Verlengstuk">

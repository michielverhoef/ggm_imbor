      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_ae6215694be44ba8acc11c671d4acf73" name="enum_DuikerVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7bd3271ca36548b0af08ac7e29f1dcec" name="Koppelduiker">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ffedc5d219dd4475afa8a2e2c596f1a2" body="Een duiker waarvan de elementen worden samengehouden door een voorspanning zonder aanhechting."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_77e8c38d6fb74b19a691166be18a3ee6" name="Rubberringduiker">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f864fc382632432d86b84bbf0e176cbb" body="Duiker waarvan de elementen aaneengeschakeld zijn door rubberen ringen die op het ene uiteinde van de duiker zitten, in het andere uiteinde van het opeenvolgende element te schuiven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_df48e3980abe472993b07892796f4417" name="Spanduiker">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4d575aeb531849afb1b1c311f15c322c" body="Duiker waarvan de elementen tegen elkaar gespannen worden door kabels die door de elementen zijn geregen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_b5011f6dbd354a008254e83516415c5b" name="enum_DuinVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2c583935586947d4993733292602955a" name="Gesloten duinvegetatie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6104119fdfb941088fbb8867ddb6f77e" body="Duin met een overwegend opgaande vegetatie van struiken en bomen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d09b2240b38044c8aa277e60afa86a88" name="Open duinvegetatie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_28c69b3851884cec877a5ca379201bdc" body="Duin met een overwegend grasachtige vegetatie."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_5d6deec5e5504eb9bec7ff07f8271b3d" name="enum_EducatietoestelVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f38662cc746d48ee8feccd8cd680f3f2" name="4op1rij spelpaneel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_54ccbe8f52334340b34a7c8bf4ad35bc" body="Een educatietoestel in de vorm van een bord, waarop het spel 4op1rij gespeeld kan worden.."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_401b751931aa4234a455d4d66596ecb9" name="Boter-kaas-eieren">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_81a6a8d88b184ef58f8622699ad5f52e" body="Een speeltoestel bestaande uit een bord waarop met ronde tekens en kruistekens spelletjes met kruisjes en rondjes gespeeld kunnen worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1869dea3c6b14de2bf301696ea13f6a5" name="Puzzelbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1e6eb10d41934d51a9d627a3391c0554" body="Een sociaal spel bestaande uit een speelpaneel met daarop een puzzelspel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_dcb485cd62c2462e889cbfb21713367e" name="Schoolbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_96c2c2d1e21b44e291b455dc4fa95970" body="Bord welke buiten als educatief speeltoestel wordt gebruikt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_51382cd0ba80406580e9a1353246589f" name="Telraam">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f9761323670046a7adeaf540b4137d12" body="Een speeltoestel in de vorm van een abacus: een voorloper van de rekenmachine die gebruikt kan worden bij het uitvoeren van rekensommen door kralen in verticale of horizontale richting te schuiven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3ceca142df514d2cb1cda7c3155e200a" name="Zonnebloem">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c12dd580915a4df3a3b8d7f91ddcc529" body="Toestel gaat draaien wanneer zon schijnt."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_5114afd1d6f9420cb0f69a676ba4a6b5" name="enum_ElektronischToestelVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5298596138b24dcea012866a94862d48" name="Audionetic">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f35c11fffd904d48b108f7ee66893407" body="Een interactief audiopunt. Deze wordt geactiveerd door een aantal malen op het voetpedaal te trappen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fc2471219fe140e2a2302c2ed7529538" name="Geluidsboog">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a7248d4769d74648bd63a1cf89159819" body="Een elektronisch toestel bestaande uit een boog en een interactieve ondergrond die groepsspellen omtrent de geluiden die de boog maakt, faciliteert."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_379748a40bc94cfab70712c47d5aaf10" name="enum_ElementenverhardingFormaat">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a3c0fd39b8044344b38a3fa6cb7e2504" name="Dikformaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f35bd185ad29459797198089ff21c369" body="Een straatsteen van bepaalde afmeting: een klinker van dit formaat is 20 tot 21 centimeter lang en 6,5 tot 7 centimeter breed. Er gaan 72 van dergelijke klinkers in een vierkante meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c134e633191245e394396021864ade78" name="Dikformaat kant">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9acd8cfd77ff4b3d8b37b8ef7f2a0762" body="Een straatsteen van bepaalde afmeting: een klinker van dit formaat is 20 tot 21 centimeter lang en 6,5 tot 7 centimeter breed. Het woord &apos;kant&apos; betekent dat de stenen in een legverband liggen waarbij de individuele stenen op hun zijkant liggen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_346a3e026bd14e9ca40320d5060fa8f8" name="Dikformaat plat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b103e52c9f3344819182109c38ff65cf" body="Een straatsteen van bepaalde afmeting: een een klinker van dit formaat is 20 tot 21 centimeter lang en 6,5 tot 7 centimeter breed. Het woord &apos;plat&apos; betekent dat de stenen in een legverband liggen waarbij de individuele stenen op hun rug liggen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4a0aeb9235e54035add2fe9012e3f397" name="Dubbel keiformaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_450bd32563e74cdea35d31ad74ccc8a4" body="Een straatsteen van bepaalde afmeting: een een steen van dit formaat is 20 centimeter lang, 20 centimeter breed en 8 centimeter dik."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f933df25567b47bb9edbaa283db7966c" name="Friese steen">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f3eaebc17352400db0de8e95607d04fa" name="Gitruit">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bb170ed0cd774e23bcfe85e3a576ce0d" body="Tegel met een geruit oppervlak verdeeld in een even aantal vierkanten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c936a56280da431f9c4ec695578da6ff" name="Grootformaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ccfbef41cfac4e3bbbe82fe98f546011" body="Straatsteen die de eigenschappen van andere straatstenen kan hebben, maar een maat groter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_876193710b484623a27094ef57d23070" name="Keiformaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3fe0e38c014745b59137a450da9198e6" body="Een straatsteen van bepaalde afmeting: een klinker van dit formaat is 20 centimeter lang en 10 centimeter breed. Er gaan een 45 van deze klinkers in een vierkante meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_10e24a63a4b44cfab52b929c1a0ad6fa" name="Keiformaat kant">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_68db4aa532554a5e9f350ee1f800f727" body="Een straatsteen van bepaalde afmeting: een klinker van dit formaat is 20 centimeter lang en 10 centimeter breed. De term &apos;kant&apos; betekent dat de stenen in een legverband liggen waarbij de individuele stenen op hun zijkant liggen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d88811d114954afda1832c74b49afc21" name="Keiformaat plat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_20fb593199884cd6a90e3cd879de47e8" body="Een straatsteen van bepaalde afmeting: een klinker van dit formaat is 20 centimeter lang en 10 centimeter breed. Het woord &apos;plat&apos; betekent dat de stenen in een legverband liggen waarbij de individuele stenen op hun rug liggen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_12c92a64af2946118ca1267901baab14" name="Kesselformaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2b59d190b56444e78d987b93f8c6856e" body="Een specifiek soort gebakken straatsteen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_eb710962656343a28ebdce1b8e7158bd" name="Langformaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_38f6ce81990541e1b1280f593a4939e8" body="Een gestandaardiseerde maat voor de gebakken straatsteen met een lengte van 24 cm en een breedte van 8 cm."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8f12927897b34326bf221da0c0740851" name="Lingeformaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_79cf82e0909d4011b8581d1340ebcf27" body="Een straatsteen van bepaalde afmeting: een klinker van dit formaat is 24 centimeter lang en 12 of 8 centimeter breed."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9695dcbcfc744453aa00c7c8e67719e6" name="Noppen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cc947ea2ed7b4a0387c46ca5e03bd9cd" body="Tegels met meerdere, regelmatig verdeelde kleine bollingen aan het oppervlak, die toepassingen kennen zoals het waarschuwen van voetgangers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b3860e124c8f4ff790e848ec6f1e029d" name="Ribbels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_43e17d5faf4045d1b94603159dfba47c" body="Tegels met een golvend reliëf aan het oppervlak, die toepassingen kennen zoals het geleiden van blinden en slechtzienden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b89dbdf93bfe4227be588f4462358e24" name="Secubricblok">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b3377751f9274f92b81f61b82897a4e3" name="Taludblok">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_52c2285ac98f44f3ae65b46e1f3f29fa" name="Visbek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_794910eabd634c06aa84bba17f7e994b" body="Tegels voorzien van twee evenwijdige zijden met twee inkepingen die vergeleken kunnen worden met een vissenbek."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_032bcafc48a94fadab6c61ac916e87eb" name="Waalformaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3fbaeefacb69490caef8ebc97cec0a7f" body="Een straatsteen van bepaalde afmeting: een klinker van dit formaat is 21 centimeter lang en 5 centimeter breed. Er gaan een 100 van dergelijke klinkers in een vierkante meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_09947453f49b40d1a349c8508aeb64e9" name="Zeskant">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_940586a8b00e47bb9ac02088ea18503b" body="Straatsteen die niet rechthoekig is, maar zeshoekig."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_8c9d98d0556d42a5a0e7ccddc1d6bf71" name="enum_ElementenverhardingLegverband">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ceacbace027247219492a00ae44962c4" name="Blokverband">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_30ddb601d4a549d884a494afdf9119b1" body="Een legverband dat ontstaat wanneer er een aantal vierkanten worden gecreëerd van twee of meer tegels. De stenen worden doorgaans horizontaal gelegd, maar kunnen ook verticaal, diagonaal of verspringend worden gelegd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d926c5fa42214e51986ee23839968d8d" name="Elleboogverband">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_12bc8e59e02e4559839f91f231304c08" body="Legverband waarbij de klinkers recht op de opsluitrand en rijrichting zijn gelegd. Dit maakt de plaatsing eenvoudiger dan het visgraat- en keperverband. De bestrating is zowel liggend als staand."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_264a93e8d4854b5fb2b6361c799cf2c5" name="Halfsteensverband">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c050a522e2dc46f79363887bfc680d42" body="Dit legverband kan zeer gemakkelijk en snel worden gelegd door zijn eenvoudige karakter. De bestrating wordt recht op het oppervlak geplaatst waarbij steeds een halve steen verspringt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_60d27461a8354ca9b6e277bfe76a24d0" name="Halfsteensverband (haaks)">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_169fbdbdf63d4708b09842f627a58161" name="Halfsteensverband stroomlagen">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b580ed2b5d374698964f0182956cd777" name="Keperverband">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2e713af15e414d448514c21cb53cd719" body="Een legverband dat gelijk is aan het visgraatverband, maar dan 90 graden gedraaid. Het wordt vaak gebruikt bij drukke straten vanwege de zeer hoge belastbaarheid van de stenen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_23aeba629e8d4c248b32291aeb63ec91" name="Molenwiekverband">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fc35141cea9a4e82a3b698b065ef185e" body="Een legverband dat ontstaat doordat vier langwerpige stenen om één vierkante steen worden geplaatst. De middelste steen heeft vaak een andere kleur dan de langwerpige stenen. Doordat het eindresultaat op de wieken van een molen lijkt wordt dit legverband "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_981d35ea8a58402992db904765e0464e" name="Op de kop">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_21b5151dc2b9452584a8951433630fe5" name="Visgraatverband">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_42731a71a90746a6ab92844742b83f8e" body="Een legverband dat erg stabiel en zeer geschikt voor intensief gebruik is. De bestrating wordt bij een dit legverband in een hoek van 45 graden ten opzichte van elkaar gelegd. Het wordt vaak toegepast bij straatstenen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_eaaa9abf6ba94587a771429991419193" name="enum_ElementenverhardingVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b7c877a0099f4d87b6daa4664c99b96c" name="Aquaflow stenen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a4cd81c7a9874aabadcc26337512f67e" body="Waterdoorlatende steen"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_46bf2e6353c5480da2f0aafe4bdf311e" name="Basaltblok">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dbf3ebd680d34aa59d9041a8575f3d25" body="Oppervlakteverharding bestaande uit elementen van een donkergrijs of zwart, vulkanisch stollingsgesteente dat gevormd wordt door de stolling van lava."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_828fdd0ef1e84086b7827c2431c10388" name="Bedrijfsvloerplaat">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_853462a7df1547669136820cda569f57" name="Betonelement">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a1c05884937f4c2b81332ed667f7e3f9" body="Geprepareerde elementen van beton (bijvoorbeeld stelconplaten)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_24e5dc73844443a09de652890da03542" name="Betonstraatstenen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9237ae7e566b49dcafd1b49164b9deba" body="Elementenverharding gemaakt van betonstraatstenen. Straatsteen die als goedkope vervanging van de gebakken klinkers is ontwikkeld."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d24dd1128c844f45933fe5a346385bf2" name="Betontegels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_53907461335f4cf1a4d3df780e5188c6" body="Type van elementenverharding, betonstraatstenen: vlak bestaande uit betonstenen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3c984610949048deafd7ed70e8eafb04" name="Blindengeleidetegels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_de5f82f569434847a9e1eee45222eb29" body="Type gedetailleerd van elementenverharding, tegels. Speciale stenen en tegels helpen personen met een visuele beperking. Het bovenvlak is voorzien van noppen, ribbels of van een zacht materiaal (bijv. rubber)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_657605c246e1417b91e51cfcf7c5f84e" name="Drempelblok">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dbe5c7a5f48d491dbaca96fae6099b05" body="Een betonelement in de vorm van een schuin oplopend schuin oplopend blok."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_66a24a0c5e2c4548b71f7c0a81e1e6a4" name="Gemengde bestrating">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_35e85ba0a39044528b5730a313372614" body="Type gedetailleerd van elementenverharding, sierbestrating: vlak bestaande uit verschillende soorten elementen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ae103fff8ec744f98be9f11cb04244c7" name="Glaselement">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8790317d638f476286fef9ee8d1d5fba" body="Type van elementenverharding bestaande uit platen of blokken gemaakt van glas."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6b7c8e2ba4ad4e86acc266453fe2e3f3" name="Gras- en grindtegels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5974b1a4bc694055954d8c6af48ceeac" body="Type gedetailleerd van elementenverharding, tegels."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0954be76b32443e9a35af5a39fe62875" name="Grasbetonstenen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_876a338b9b6942a699c7b485282cf264" body="Elementenverharding bestaande uit elementen van beperkte afmetingen die ten behoeve van de doorgroei van grassen en kruiden. Tussenruimten zijn voorzien van openingen of de elementen zijn met tussenruimten aangebracht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e03f2e9d83bd4158aa9fcb5a0ae415d2" name="Greenflow doorgroeibare klinker">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c9d9b6b0713942e6a5955ea9874b08bd" name="Grindtegels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b1bbc364c7d1486f846bb60c0d391671" body="Type gedetailleerd van elementenverharding, tegels. Extra sterke betontegel met grindafwerking."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e5883451c84e4138a27f9f6662e04947" name="Hardstenen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8b7c4fff7d114f69aa3399a0a7e8f86c" body="Elementenverharding gemaakt van natuursteen in de vorm van kalksteen met een overwegend blauwgrijze kleur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ca3bd6d2609d43d4929587cffe31680e" name="Houten element">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6eb2e86c399f4dcca3241f38b0fab808" body="Verharding bestaand uit planken, platen of blokken gemaakt van hout."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d898e4123c6b44e7bf31711443701b01" name="Hydro Lineo">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ae3896abfde342afb675b0a4517a13fb" body="Hydro Lineo is een waterdoorlatende klinker om mee te ontharden en te vergroenen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0d95e2bed058461a971522075cd72c66" name="Inritblok">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1f60203131d941eab45fd26f96f4d38e" body="Deels rechte, deels schuin aflopende betonnen blokken die de buitenzijde van de inritband vormen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7b118d0de8a1473f9997c9f349675f5d" name="Keien">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2a05aba04e244c709d803017971df96c" body="Type gedetailleerd van elementenverharding, natuursteen: vlak bestaande uit grove stenen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bfeab524ca7040df99627ea0a23b0902" name="Leistenen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8e8edeaed1c545239a665ea5d2f16f3e" body="Elementenverharding gemaakt van een natuursteen waaruit leien gekliefd worden. dit type steen ontstaat door metamorfose (omvorming) van kleisteen wat weer uit klei is gevormd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3fc23217a21c466ca2cfd5d7013b6b85" name="Metalen element">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_19f783be74c445eeb9b232006b1d3b32" body="Verharding bestaand uit platen, blokken of anderssoortige elementenverharding van metaal."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b3dc7feb973d4de5a2659d75133eb0a0" name="Natuursteentegels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ea138d68faed49789a0f07872bee8dcf" body="Type gedetailleerd van elementenverharding, tegels. Vlak gevuld met tegels die zijn vervaardigd uit een steensoort die in de natuur wordt aangetroffen"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8e00643e0079475ab22ce6d3d900fd79" name="Natuurstenen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_75899ddd0c9e4883814091336efb16b0" body="Type van elementenverharding, verharding bestaande uit elementen van een steensoort die in de natuur wordt aangetroffen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_782c910a513b496da5d7e759574c3e5a" name="NCB stenen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1d508b4201c04a9ab8c036e99ee79e97" body="NCB steen, ook wel bekend als NCB klinker in de volksmond, zijn waterpasserende betonstenen met een open ruimte van maar liefst 42%. Dit bevordert grasgroei en infiltratie van (hemel)water."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_46e6ee407ef84849b1188ebc926cc014" name="Rubber grastegels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a65196ae4eaf4c3c905ed3e5e1a8562a" body="Type gedetailleerd van elementenverharding, tegels. Rubberen grastegels worden vaak gebruikt om kwetsbare delen bij speelplekken te beschermen tegen kuilvorming."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1df570e17c314d82ab0ce0a20560cd85" name="Rubbertegels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7b29cb48305c4b669ce5fde5e9fceedc" body="Type gedetailleerd van elementenverharding, tegels. Een type tegel, ook wel veiligheidstegel genoemd, dat haar schokabsorberende eigenschappen ontleent aan aan de materialisatie van rubber."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bdc93c8557e5408baf73a0b1ca78a832" name="Sierbestrating">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8a10149634134cf992bcaea6b687baa5" body="Bestrating uitgevoerd in verschillende bestratingsverbanden en -materialen, of in een sierverband, die vooral wordt toegepast uit esthetische overwegingen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_83025791cf9f40898fd943ab17ec6dd6" name="Straatbakstenen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4a671a918f154debbfadabcf181da160" body="De formele benaming uit NEN-EN1344. In de CROW Systematiek Wegbeheer wordt dit ‘gebakken klinkers’ genoemd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ef17f77b74df45719c93bf6b254a3319" name="Tegels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ed6882cf97e046318eecffb61c80abd7" body="Bestrating van platte vaak vierkante stenen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fe4fe1ce7a794b73ba0120b81ea091f4" name="Voegstenen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_506caf825b4e4518981aab8eb9f23d08" body="Type gedetailleerd van elementenverharding, betonstraatstenen; betonnen stenen met een kleine voegruimte zodat die ingestrooid of opgevuld kunnen worden met voegmiddelen zoals zand om te voorkomen dat onkruid tussen de stenen door opkomt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4d559a38862049669680779339356f6c" name="Zandstenen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3a9242bb81be400aaf6ac89ad4e78bbf" body="Type extra gedetailleerd van verhardingsobject, elementenverharding, natuursteen: een vlak bestaande uit (elementen van) een natuur- en sedimentgesteente van kwartskorrels die met elkaar verbonden zijn door een bindmiddel (leem, kalk e.d.)."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_7c86465f2e284e2bbf6ea6815149f07a" name="enum_ElementenverhardingVoegvulling">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d836ab4a40784ce79315d9b299e01553" name="Grasbetonsteen met grond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f1924ca75ebc4c8a918b9fa42b1c3354" body="Grasbetonstenen gevuld met grond."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2734e297373f4de588d7a2155dd46820" name="Grasbetonsteen met split">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e6170f5c3cfc4ff7a9deff7bb986b1c0" body="Grasbetonstenen gevuld met split."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_fc587a4f9b1a495aa30fa06cb00c0082" name="enum_ElementenverhardingWaterdoorlatendheid">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3de24dada82a4100946ee05a39980131" name="Geen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_96f65e5dc5b54316a0db55cab4caa53d" body="De waarden uit de suggestielijst of vaste lijst van het attribuut zijn niet van toepassing bij dit specifieke object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_de1ab8db2dd34833ab9d43a197ab3cda" name="Waterdoorlatende verharding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ec011599f0d84a4eb052f67563d95453" body="Aaneengesloten verharding waarbij de porositeit van de afzonderlijke elementen een poreus oppervlak realiseert."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7bbfe33c8123480bbc4f5deb25e36fc5" name="Waterpasserende en -doorlatende verharding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_94bc663c01794f48bff376cda9bba2a6" body="Aaneengesloten verharding waarbij de porositeit van de afzonderlijke elementen een poreus oppervlak realiseert en waar er tevens ook in het verharde oppervlak voorzieningen aangebracht zijn om water sneller af te voeren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9a35e56b440d4a278afc9b10655a11bf" name="Waterpasserende verharding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fa9b92ba1e0d414ea3f73fa1a56bde7b" body="Aaneengesloten verharding waarbij de voegen van de verharding een poreus oppervlak realiseren."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_79db7826be3d49a1a269819553d05288" name="enum_FaunarasterVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_51518675e6b541f99c6f9152fe5e95c5" name="Hoog faunaraster">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_490e505a3a484768a2a1e236199cfc1a" body="Een afscheiding van circa 100 tot 250 cm hoogte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_90ac8421ead54047bfdc9f70355aeff9" name="Laag faunaraster">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a48ddc6c5118467ebb3a0850ad208ec8" body="Een afscheiding van circa 50 tot 100 cm hoog."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_67b5c62979be4019926959f8765fea87" name="enum_FaunatunnelVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e85cdcc1606e4598bb9639582aec1aae" name="Faunatunnel groot">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7d30bea4a33e417f9c8352ddbb46acb3" body="Een onderdoorgang die als doel het opheffen van infrastructurele barrières en het mogelijk maken van de migratie van middelgrote tot grote fauna tussen of binnen leefgebieden en populaties heeft."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3e927401bdc8458987da78768a1009fa" name="Faunatunnel klein">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7d950b319ff5428e8411653316fc34dc" body="Een onderdoorgang die als doel het opheffen van infrastructurele barrières en het mogelijk maken van de migratie van kleine tot middelgrote fauna tussen of binnen leefgebieden en populaties heeft."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_9f076419cfc64164b8c16c6034b9207d" name="enum_FaunaUittreedplaatsVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_591a134fb43c4d2f9d61cffe07c6289a" name="Fauna-uittreedplaats groot wild">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d34d52cd49cf4d5f8da3c95661330a5a" body="Een voorziening waarmee fauna vanuit oppervlaktewater het land op kan komen zodat de fauna minder risico loopt op verdrinking of minder belemmerd wordt in zijn bewegingen en migraties."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e2ef5defaff24765907e6eadf507ca61" name="Fauna-uittreedplaats watervogels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2c3b92c760bd4ae8a2fda8c074a3122d" body="Een voorziening waarmee vogels vanuit oppervlaktewater het land op kunnen komen zodat vogels minder risico lopen op verdrinking of minder belemmerd worden in hun bewegingen en migraties."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_808c757a24ac48d8af9cb31d1fa2e252" name="enum_FietspadAan-OfVrijliggend">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f91042049d3246099649558dfe3278f3" name="Aanliggend fietspad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dfd497bbc83c45a58327b7bb134fcaec" body="Fietspad dat door een zeer smalle tussenberm is gescheiden van de naastgelegen rijbaan dan wel geheel verhoogd langs die rijbaan is uitgevoerd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_88e52e43b40544e8b267b5cde0470408" name="Opvangfietspad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_465e2279b9a846ba88fe8e25a1d221a1" body="Vrijliggend fietspad van beperkte lengte, bij een gelijkvloers kruispunt van rijbanen of een aansluiting van rijbanen, dat een verbinding vormt tussen de rijbaan voor gemengd verkeer en de voor fietsers bedoelde oversteekplaats, of andersom."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bfa8a22aa3614cdcb6e7f66b4717596e" name="Vrijliggend fietspad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_72f3ef388d7943aaa0f073eaeffe6c63" body="Fietspad dat hetzij parallel loopt met de naastgelegen rijbaan en daarvan door een tussenberm wordt gescheiden, hetzij een geheel eigen tracé volgt."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_a169681b62fd4f7c86c582d19046a090" name="enum_FietspadVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fd5e6edc98ce474d988309a3493cb768" name="Fiets-/bromfietspad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3297ed872b934bb6977f146c8e5d832c" body="Fietspad, aangeduid door bord G12a (gewijzigd RVV 1990), en toegestaan voor fietsers, snorfietsers en bromfietsers (toegepast in situaties waarin het ongewenst is dat bromfietsers gebruikmaken van de rijbaan voor snelverkeer)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_66a0bfe14dbd49d2845e3fd0fff25396" name="Onverplicht fietspad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c9de9606c836428dada5b1286bcb1ee4" body="Fietspad, aangeduid door bord G13 (RVV 1990), en toegestaan voor fietsers en voor snor- en bromfietsers met uitgeschakelde motor."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2f4d607f86ee429d86d07fdcb6a78d9c" name="Utilitair fietspad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a62ded3abc2b43699685c2bfa83b4178" body="Een fietspad dat dagelijks gebruikt wordt voor de verplaatsing van fietsers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9d6e493bcf764a69898f0d124f5e61b7" name="Verplicht fiets-/bromfietspad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_22bc563c1e694ca992910571edfa3da1" body="Een pad dat aangeduid wordt met het bord G12a, oftewel een pad waar verplicht gebruikgemaakt moet worden van een (brom)fiets."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_894c52614e1c473a83dab2b7bf550243" name="Verplicht fietspad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dcfeba37116e4fbb90a77e68890ef05b" body="Fietspad, aangeduid door bord G11 (RVV 1990), en toegestaan voor fietsers en snorfietsers."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_12bbf79717fe42c2a1c358be8bfef38c" name="enum_FitnesstoestelVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3156fddd7f2f4b1fa890a5b604d75535" name="Airwalker">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bf440573f1e540308c2a582e008d2355" body="Een fitnesstoestel bestaande uit twee beweegbare delen om de voeten in te plaatsen, waarmee loopbewegingen in de lucht uitgevoerd kunnen worden, en een stang of ander aangrijppunt, zodat men zich kan ondersteunen tijdens het gebruik."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_63082332d1e241f0a4605f9310189a98" name="Balance beam">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_abd38241994e4ef4a280fd8447049f99" body="Een fitnesstoestel bestaande uit een balk om op te balanceren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_acf525a5898f4efcaf354d2deb4318f0" name="Balansvorm">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e3fbb000ac434707a6a0ba4804101235" body="Een behendigheidstoestel bestaande uit een bepaalde vorm die is bedoeld om het evenwicht op te bewaren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3257c93a7b994c35873fc39406246b57" name="Body Flexer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_60fa0c67a85f47e7b81b41da07711850" body="Een paal met handvatten en aan de onderkant een uitstekend, rond platform bedoeld om op te staan en het lichaam daarbij te strekken en te draaien."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_415deb69f86c4992a8c7b5248a57570c" name="Buik- en rugsteun">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_81702a6e975e4fe5af1c62641ffab9fb" body="Een duikelrek voor fitnessdoeleinden dat fungeert als steun voor de buik en de rug om bepaalde oefeningen beter te kunnen uitvoeren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_46f4084c798f4f5ca5caf779c8b18590" name="Chest Press">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_54e874b4acaf4c9c99137212ab183c93" body="Een fitnesstoestel dat bestaat uit een zit- of rugsteun en is bedoeld voor bankdrukken. Kan ook de vorm hebben van een apparaat waarmee aan een gewicht getrokken wordt met de armen via twee aangrijppunten waardoor de borstspieren getraind worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_79a023322d93455586e80ecac859e427" name="Chin up">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4f1eed7e3fa94551b2e72480e88135e4" body="Een frame met een stang bedoeld voor optrekoefeningen, waarbij men met spierkracht zichzelf met de kin tot boven de stang moet verheffen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a8dacfe7123b4dd89aa1e005b4953cdb" name="Combinatie fitnesstoestel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_629ed858456841d8a198f269905d1802" body="Een fitnesstoestel dat een integrale combinatie van meerdere fitnessonderdelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6228a1252e984275bf6eb4aa46ed7a6a" name="Crosstrainer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9238760a35b144f98df6fc6ae2de943f" body="Een apparaat waarmee het hele lichaam getraind wordt, namelijk door loopbewegingen met de benen en trekbewegingen met het bovenlichaam te maken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_61afa22f69b7408f890f74cff3c32f31" name="Dip Bar">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2c56c04e4ab34dacac7ae8a99e731bcb" body="Fitnesstoestel bestaande uit twee evenwijdige staven waartussen men &apos;dips&apos; kan uitvoeren, oefeningen waarbij het lichaamsgewicht door de triceps of de borstspieren op en neer bewogen wordt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_68c2cd061d8f4ba19a2137744a6d28d8" name="Double Chest Press">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8c21b53c76fc43d1af85cb41dc74f99e" body="Een fitnesstoestel bestaande uit een paal met twee Chest Press voorzieningen, een apparaat waarmee aan een gewicht getrokken wordt met de armen via twee aangrijppunten waardoor de borstspieren getraind worden: één met zitelement en rugleuning en één zonde"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3aed972968ce46158a655f82eb55baea" name="Double Overhead Ladder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4e9551ee352048a996e615559d97664b" body="Een constructie bestaande uit twee evenwijdige enterrekken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f83a6b5d384c4b52b08e8f69a47c9c09" name="Drievoudig duikelrek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1a123ce6f0104299a11e247ad2365ea9" body="Drie aaneengesloten in de grond gemonteerde beugels waarop recreatieve draai- en duikelbewegingen uitgevoerd kunnen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5f63c088a1ab4135b46658b389a9f245" name="Drievoudig duikelrek gebogen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_503035e05e904846aa1c79b4ec289b3f" body="Drie gebogen en aaneengesloten in de grond gemonteerde beugels waarop recreatieve draai- en duikelbewegingen uitgevoerd kunnen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cbbcf68add804f3097d40783454bd031" name="Drievoudig duikelrek zigzag">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_419f69665c494a9096e34256517de287" body="Drie aaneengesloten in de grond gemonteerde beugels waarop recreatieve draai- en duikelbewegingen uitgevoerd kunnen. Het eerste deel staat haaks in richting op het tweede deel en het derde deel staat eveneens haaks in richting op het tweede deel, maar dan"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_86454330d1824da5a87746bf37325ac2" name="Duikelrek fitness">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_06f1afb0c07949cd81bad3597982252f" body="Een enkele of complexere in de grond gemonteerde beugel waarop sportieve conditieoefeningen of oefeningen gericht op krachttraining gedaan kunnen worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f07eeed72202458ea5a0d4fc6012cfb8" name="Enterladder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c1f7dd532e3a4960b9edf4e415e057df" body="Een horizontale ladder die bevestigd is tussen twee punten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3092cd177522464d925a70d6a47618ca" name="Fitness Bike">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a11d07d5bebf42078333c3936f2fe482" body="Een toestel met trappers en een draaiende as bedoeld voor het trainen van de beenspieren als cardio-oefening."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_92642541942946d2b54e4878a7d41ce4" name="Fitnessbank">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b779755be81c46ae973bab3ae4c5b76e" body="Type gedetailleerd van een sporttoestel, fitnesstoestel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f07a742edd6a408988e97c8714c72784" name="Flex Wheel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_83bce03f4d104b088224ea3a10755785" body="Een fitnesstoestel bestaande uit een wiel aan een paal dat men met beide handen vastpakt en heen en weer draait om de armen en het bovenlichaam te trainen en te strekken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d02ca9c3204847c7bf1faa68c15da72d" name="Hand Bike">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_daf266a6178f45fe8f6d7ca13063b468" body="Een toestel met trappers die met de hand aangedreven dienen te worden en een draaiende as bedoeld voor het trainen van de armspieren als cardio-oefening."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2d54c75557d94563bae77163b52db776" name="Hangelduo">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_974a0961432a4ab89497abb873fd5810" body="Een frame met daarboven twee evenwijdige enterrekken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_24d7a8f75588458484072a69e4f9d0e7" name="Hangtouwen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f4ac98f57f8a43089489cd4cce68b542" body="Een frame met aan de bovenkant twee evenwijdig gespannen touwen waarmee duikel- en fitnessoefeningen gedaan kunnen worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0e27ddc4990a475da81af28a426f71ef" name="Hellende enterladder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f20c901597d74fc5921be9153a684ef7" body="Twee buizen met daartussen klimsporten die onder een bepaalde hoek zijn geplaatst."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d4558ecf67874a699953b1515e39d6a6" name="Hellingklimmer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_eed5ca12f13840eb900eb1acb8523a29" body="Een touw of andersoortige verbinding tussen twee palen die op verschillende hoogtes zijn geplaatst (bijvoorbeeld op een talud) bedoeld om de gebruiker houvast te geven bij het (sportief) beklimmen van de helling."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b5a854dcea264eeeaa4218bd2413b24c" name="Hobbelbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_751999203e4e4f1bb9b15230474aa304" body="Twee evenwijdige duikelrekken met daartussen (hangende) elementen die hobbelen en wiebelen wanneer men eroverheen loopt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9ad7fca63e5e47a8a87033b361721b31" name="Horden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_19aa1d29090d435190327e7fe1c3ef3c" body="Een reeks balken of staven op een bepaalde hoogte bedoeld als uitdaging om overheen te springen en als atletiekonderdeel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_463d0aa752074eaea136897e83493dcf" name="Hurdles">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d1a479624c6c4d458af7041459c3752a" body="Een lage verzameling horden bedoeld als fitnessoefening voor behendigheid en cardio."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a3ff6ed4ff5e4c8fadf9d326f4dccf31" name="Jump pod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ed14981bcf734908a13c17ea924aae65" body="Een knopachtig fitnesstoestel dat bedoeld is om op en af te springen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_63bbb7d4872246e9a10891cde55c36d9" name="Klimgordijn">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_989cf16770b14b419baa398cd4f7a072" body="Een toestel bestaande uit een frame dat een horizontale balk draagt, met tussen die balk en de grond verticale gespannen touwen of kettingen, met daaraan verschillende (sportieve) klimuitdagingen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_91bdd0b23c5844d0b93e1bc2d61d52c5" name="Klimnet met duikelrekken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b05ab5d87b884e91a93909a09919eb27" body="Een netwerk van touw of kunststof opgesteld zodat er in geklommen kan worden met daaraan verbonden één of meer in de grond gemonteerde beugel bestaande waarop recreatieve draai- en duikelbewegingen uitgevoerd kunnen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7d7d9c86e2d542cdab896d1d08349d86" name="Klimschans">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fe57229837a94ab4935f05c1899d3b7a" body="Een toestel met een hellend vlak waartegen gebruikers op kunnen klimmen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8053a82ff917469ea485a1af04f7f279" name="Ladder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d3b00a71946747819e64c82cc7eae29d" body="Klimgereedschap bestaande uit een paar spijlen met daartussen meerdere sporten voor voetondersteuning."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5ef38cf5634e41e1bb1105368c6a20dc" name="Log hop">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9ba8722f4cb84a67a9d21ec1ad6c9bf2" body="Een fitnesstoestel bestaande uit vier palen of balken waarbij het de bedoeling is om springend van de ene paal of balk naar de andere te bewegen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_849492c7adc44665b04536fa0fcb4d75" name="Magnetic bells">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_60767a2d4390477c9e3d75d4f71e7c00" body="Een fitnesstoestel bestaande uit staven met daaromheen gewichten die ten behoeve van gewichtheffen langs de staven op en neer bewogen kunnen worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7a8bf8a75f2f4cf29cd172ff2a3306b2" name="Multi net">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ab7765991adf4a49bed99f357ee243c6" body="Een fitnesstoestel bestaande uit een (diagonaal) opgesteld klimnet voor sportief gebruik."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1d9f1365c7544a868b478015a63ec59c" name="Netbrug oversteek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_53fd940ce3074009a46b7a101b487d30" body="Een fitness duikelrek dat bestaat uit een frame met daarbinnen twee touwen. De touwen vormen de balanceeruitdagingen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4d4b0fd05ebf4dd182e61472a604d14c" name="Opdrukken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_20c2e99dbe034fa892e21cd343dcd12a" body="Een fitness duikelrek dat geschikt is voor opdrukoefeningen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7faece482f4842c180fe31bb4796cf15" name="Optrekken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dab3a79c189e46078db7c966e9870948" body="Een fitness duikelrek dat geschikt is voor optrekoefeningen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_311205c2120040d59396e5f9742ef826" name="Overhead Ladder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_271b7335eba24c3aa72b89679d8d74cb" body="Een frame met een horizontaal bevestigd enterrek bedoeld voor sportoefeningen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0aa54a24cbe64f3299115c402c5c5d0d" name="Parallel bars">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6989074c48da4448a67a1640a4153dd4" body="Een fitnesstoestel bestaande uit een frame van parallel geplaatste metalen staven waar men onder andere opdruk-, dip- en rekoefeningen kan doen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c5d979bf94ca4e7eb948bd01bd6b8534" name="Power Bike">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_469a843abf5044b9bb62c5feb5b49db3" body="Een toestel met trappers en een draaiende as bedoeld voor het trainen van de beenspieren als cardio-oefening."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_57fa1675ed4d4b38a50c4e5a7b8d0dfd" name="Pull up bars">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9e66670b8a594934af9904fae9fb4ff5" body="Een frame met een staaf op of boven hoofdhoogte om optrekoefeningen mee te doen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b0a50d2e445242b5993875342c950ee0" name="Push up bars">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_423d18ff725847beba27bda903ad6fda" body="Twee in de grond of aan een frame bevestigde handvatten die vastgepakt kunnen worden om opdrukoefeningen te kunnen doen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b0eb25ad300249739c4fd1d85d74b321" name="Push up bars met paal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_428dae80ff0543888799024ba0c49f74" body="Twee aan een paal bevestigde handvatten die vastgepakt kunnen worden om opdrukoefeningen te kunnen doen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3b96d04095a847beae41a0dba13d6272" name="Rek- en strekbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cd58beda699146a993e0ed6cf45a7b59" body="Een frame waarmee rek- en strekoefeningen gedaan kunnen worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a18cd27bfcd5405fbc4a209a96c154e9" name="Ringenrek met balanceertouw">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6b16e5c8467d4349950073ca29e02c7b" body="Fitness duikelrek dat bestaat uit een frame met bovenin hangende ringen en onderin een touw waarover al balancerend gelopen kan worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d907e8dbc6cc4001ae2039eb65cfbe29" name="Sit up bench">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dd2817f0493246c1842d42bec8f05bc9" body="Een bank die als zit- en rugsteun fungeert zodat sit ups ten behoeve van het trainen van de buikspieren uitgevoerd kunnen worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0c0fcf33719e48ae90ee89ca00be9b22" name="Slinger-klim-entercombi">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0c0b33d1cb3745bdb2de25a0093571aa" body="Een klimtoestel met als onderdeel een enterrek en toestelonderdelen om slingerende bewegingen mee te maken, zoals een los touw."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_adf3f770906f4175877f33601953d35e" name="Squat en Shoulder Press">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b29b2b96e1a5460f874ca87f398ca448" body="Een paal met een grote uitstekende hendel waarmee squatoefeningen en schouderduwoefeningen uitgevoerd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3c24897ea49b44258eeba7488c70839d" name="Step">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_255a8d8af72641318f6b37333f332be7" body="Een fitnesstoestel bestaande uit een opstap van bepaalde hoogte waarmee veel verschillende oefeningen gedaan kunnen worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_26f02e3d824b430ca734bffabe544cac" name="Steunbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_398b008ac8ed4229a4666f9981dd1ca8" body="Een frame dat als steun dient bij het uitvoeren van fitnessoefeningen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_25b95da3238f44dc87726acc42766e75" name="Steunsprong">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4cff2b72b6ee4857a8360ea86f06973b" body="Een fitnesstoestel om een turnoefening uit te voeren waarbij men zich met twee handen afzet op het toestel en de benen zijdelings over het toestel zwaait."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2cefb44fc1044c87b260607af5c99ff2" name="Stretch Bar">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4f641e4d2b0949eb8c7862ea5762523d" body="Een fitnesstoestel bestaande uit een verticaal opgesteld rek met meerdere sporten die zijn bedoeld als aangrijppunt voor rek- en strekoefening."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fa45d7219b36448b989dfa15b904f7bd" name="Suspension trainer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f9f01c22116c482e8f92a0ce2cda2af4" body="Een fitnesstoestel bestaande uiteen frame met aan touwen of kabels hangende handvatten waarmee men oefeningen met het eigen lichaamsgewicht kan doen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d8230a3126414d33bfc0a76996975e73" name="Swing">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e40b385f42c7448ca66ed6dd4513f2ae" body="Een fitnesstoestel bestaande uit een voetenschommel waarbij men de flexibiliteit van de heupen traint door van links naar rechts te schommelen met het onderlijf."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8f0f75d912bb4ebebec3d09c04aacb4d" name="Triple Bars">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_94afcc2b09ae476bab47d4e1d9912a91" body="Een fitnesstoestel bestaande uit een frame van drie parallel geplaatste metalen staven waar men onder andere opdruk-, dip- en rekoefeningen kan doen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f654eb9a7dfc4187af1fc19d62566354" name="Turnparcours">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_70bdedb946134d1089a6c9340f7d9a5f" body="Duikelrekcombinaties ten behoeve van de sport turnen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8543f290d1a849e39203c30557e04d37" name="Twist">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a4a544d8fde24d0a8923d81f989faf0c" body="Een fitnesstoestel bestaande uit een cirkelvormig, draaiend plateau waarmee men de buikspieren kan trainen door heen en weer te draaien met het onderlijf."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ea60495f31e441da84db6aa5901c1197" name="Upperbody Trainer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3943f256ab094165b9cb3825d832ac25" body="Een fitnesstoestel bestaande uit een paal met een horizontale aangrijpstang, bedoeld om optrekoefeningen mee te doen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a525668b002340ad839db1cbfbcaa3ef" name="Upright Row en Press Down">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b16db19ed6054ba8a156395d16e9cdc9" body="Een fitnesstoestel bestaande uit een robuuste paal met aan beide zijden twee staven die afwisselend opgetild en naar beneden geduwd moeten worden om de armspieren te trainen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a2eab61e2ed54976acdd75db76bbd6c9" name="Wall">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c24dc4d7c5a349e8a0a10d7cc8c1909c" body="Een fitnesstoestel bestaande uit een klimmuur voor sportieve doeleinden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bbe4d191d50b45e2a2fd2eb7cb9fe048" name="Wiebelbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f649134eccde47c3bb16c9303952dfaa" body="Een behendigheidstoestel dat bestaat uit een beloopbare brug die heen en weer beweegt en als zodanig een balanceeruitdaging vormt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_40ce0dac2b4b4a789b767f0f04907798" name="Wiebelloop">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a8fb9aab2ccd4ceeb563258e019937c3" body="Een duikelrek bestaande uit twee evenwijdige balken met daartussen aan kettingen of touwen hangende balken die het lopen een wiebelende beweegervaring maken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d4d69900014441aab0a376f8be6f18d5" name="Wobble">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_03c4777073094f8e822c7b2f51c8387d" body="Een fitnesstoestel dat bestaat uit een cirkelvormige instabiele ondergrond die erg geschikt is voor balanceeroefeningen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_659926a71d984722933577c969448b03" name="Zesvoudig duikelrek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_95748b5729b145d3b7b5db30a07f3971" body="Zes aaneengesloten in de grond gemonteerde beugels waarop recreatieve draai- en duikelbewegingen uitgevoerd kunnen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_b1a7bf1479a045f196a4c962aa879859" name="enum_FloraEnFauna-InformatieBeschermdeFloraEnFaunaGedetailleerd">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d364bf48ab3f473b895eefa6fc848ee5" name="Aardbeivlinder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b253d2a1cd184ea59f7a57975ca203c1" body="Pyrgus malvae, een dagvlinder uit de familie Hesperiidae. De bovenkant van de vleugels van dit kleine dikkopje is donkerbruin met veel scherp afgezette, witte vlekken; langs de achterrand van zowel de voor- als de achtervleugel bevindt zich een rij kleine"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ad1417e9c13f46d8a8e3a13be318a5db" name="Aardmuis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5656a2d436d94dc0800a6a45d4a15d10" body="Microtus agretis, behoort tot de familie van woelmuizen. De aardmuis heeft een grijs- tot kastanjebruine vacht op zijn rug en zijn buik is (crème)grijs. De haren zijn verschillend van lengte en hebben donkere punten. De vacht maakt een ruige, borstelige i"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b2b799c10439464494d3345f349e3d93" name="Adder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5f8e196494ab48eb82c337716bb1c418" body="Vipera berus, de enige giftige slang in Nederland. Te herkennen aan de koperbruine tot rode ogen met een verticale pupil, de wat uitstekende schub boven het oog en het meestal donkere zigzagpatroon op de rug."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0e5e4a2b6373434b9f8ad149f4dc1046" name="Akkerboterbloem">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_614491ee68b64c2ea817efcdfa27406b" body="Ranunculus arvensis, de bloem heeft een vezelige wortel, waaruit een rechtopstaande, meestal vertakte, rijk bebladerde, gladde, glanzende en lichtgroene stengel komt. De wortelbladen zijn langgesteeld, soms ongedeeld, meestal 3-delig met lijn-lancetvormig"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e2408e3a9cb14849a17f5063c2dced32" name="Akkerdoornzaad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5b1fd64c55b94213ada6608a4920ffae" body=" Torilis arvensis, de stengels dragen veerdelige bladeren met hun schede verspreid en aan de toppen van de stengels ontwikkelen zich de schermvormige bloeiwijzen met witte bloemen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4b657f6a1cc6467891ac2b53ae81c97b" name="Akkerogentroost">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_efcd1de540964a8287055591391d457b" body="Odontites vernus subsp. Vernus, akkerkruid, dat zich van zijn andere ondersoort Rode ogentroost onderscheidt door de veel fijnere bouw en structuur. De rechtopstaande planten vertakken niet tot veel minder dan de andere ondersoort en de takken staan niet "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5a57ca0aa03848a4aa935352d450a2fd" name="Alpenwatersalamander">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3a4d9ade3e774dadbf53f53fac88b06f" body="Ichthyosaura alpestris, de alpenwatersalamander is een middelgrote soort en een van de kleurrijkste watersalamanders. Een typisch kenmerk is de helder oranje gekleurde, ongevlekte buik."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3c7917ef2bc1410087090ed7569fd941" name="Amfibiën">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4ec78a3bf542410db044c4dc3eefb9f9" body="Een klasse van dieren die tot de gewervelden behoren en een naakte, gladde huid hebben en zowel in het water als op het land leven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bb3d184b752e4451a6a86b6cf05e5809" name="Beekdonderpad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_317295a2b089496497f0e300bedbad4c" body="Cottus rhenanus, een bodemvis met een brede afgeplatte kop, zeer grote bek, grote borstvinnen en los van elkaar staande buikvinnen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_61a017b156734439bfacade73683af45" name="Beekkrombout">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a3e5b75503784fe5958cb0ae828e5425" body="Gomphus vulgatissimus, een donker getekende, plomp gebouwde rombout, die voorkomt bij beken en riviertjes."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_36096c73a67447fab1a1cafdd294050c" name="Beekprik">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_763a47d5e9d24ac785062dcc3e8af4ae" body="Lampetra planeri, volwassen beekprikken hebben lichtgele tot zilverkleurige flanken en een ronde zuigbek met stompe tandjes."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6fb1d3298a194faa9674d4f2c812fa02" name="Beklierde ogentroost">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_38b4eea75b034a0192aec929cb602147" body="Euphrasia officinalis, een eenjarige plant, die 10-25 cm hoog wordt en bezet is met veel lange klierharen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fe7b81b5d34d431785560c67abbd836d" name="Berggamander">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ad684d76e7544ddab3251572e13ce21e" body="Teucrium montanum, een groenblijvende dwergstruik met een diep groeiend wortelstelsel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2ccd903230624be986ea989aeb72edc6" name="Bergnachtorchis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_756e31b27a964d699869b0d732f369af" body="Platanthera chlorantha, de knollen zijn meest langwerpig-spilvormig met korte, meest spits uitlopende bijwortels. De stengel is stijf rechtopstaand en draagt aan zijn voet lancetvormige, bruinrode scheden en 2-3 grote bladen, die uit een sterk versmalde v"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0718b8c2c7c849558602275b5af6975f" name="Blaasvaren">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a631253b32ce46759a5225864b08e7bc" body="Cystopteris fragilis, een klein varentje waarvan in de winter de bladeren afsterven. In de zomer is het een frisgroen plantje dat wel wordt aangezien voor een jong exemplaar van een grotere varensoort."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_39e221e4b89942988e559b6c77c461ea" name="Blauw guichelheil">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_02eb56937a13440dae34144b38eded98" body="Anagallis arvensis s. foemina, een teer kruid dat liggende stengels heeft met kleine tegenoverstaande bladeren en opvallend helder blauwe bloemen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_37a778940d5a47699c716d5a78bc8dd6" name="Bokkenorchis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_89bee303553349679cd23ee04436db6d" body="Himantoglossum hircinum, de bloemen van deze plant ruiken als een bok. De plant wordt 30-100 cm hoog en heeft een grote lang-ovale knol."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b38e2d1dad44420db62f4952e764a526" name="Boomkikker">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aef4c270441841bc8ba6c435272b0e97" body="Hyla arborea: Een lichtgroene kikker met zwarte strepen aan de zijkanten van het lijf. Een boombewonende soort die zich ophoudt tussen het gebladerte en de enige die voorkomt in Nederland."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4f4c5526f90b4d1b890127fdc6242615" name="Boommarter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4e31b91e94f14949b7447140fbc83092" body="Martes martes, dit zoogdier heeft de grootte van een huiskat maar bezit veel kortere poten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f9644bf8f79c4dc68726ede6f92f328d" name="Bosbeekjuffer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_badabcd088d64b0fb4a86436d24ec32c" body="Calopteryx virgo, forse juffers met zeer brede vleugels en een dicht netwerk van vleugeladers. De mannetjes hebben een blauw metaalglanzend lichaam en vrijwel geheel zwarte vleugels met een blauwe glans."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4c841c3ecff8454dbdb9ef2853aff7e7" name="Bosboterbloem">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_65794cb7334a4f4caa4cccd5f658ab7a" body="Ranunculus polyanthemos subsp. nemorosus, de kelkbladen zijn groen, eirond, toegespitst, de kroonbladen goudgeel, omgekeerd eirond, aan de top iets naar binnen gebogen, bijna schijnbaar hartvormig, doch met een kort, omgeslagen spitsje."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0482fc9243b6455b88b6b6c0f909134f" name="Bosdravik">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_45911d930ff64ecd8ceff9fa870735e4" body="Bromopsis ramosa subsp. benekenii, een gras uit het geslacht vaste dravik. Het groeit op lichte plekken in bossen, en gaat achteruit als bossen dichter en donkerder worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bd93e9fa79344733bdb1dd963b5839d0" name="Bosmuis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_da1721d833c642bf926290ab3a9678ca" body="Apodemus sylvaticus, deze ware muis heeft een geel- tot donkerbruine rug en een witte tot grijze buik."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_50de4bcd251a4bb783b46e5cd9bfd8e7" name="Bosparelmoervlinder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_386537163eb7412badef39d1171a7a3f" body="Melitaea athalia, deze soort heeft op de bovenkant, net als de westelijke parelmoervlinder, grote oranje velden centraal op de vleugel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fd655b49edd34909be617f67ed5a3d97" name="Brave hendrik">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_990d9ef613094621bc31bce9f8b0187f" body="Blitum bonus-henricus, een zeer zeldzame plant met groenige bloemen, stevige bladeren en geschikt voor een vochtige, zeer voedselrijke groeiplaats in de zon of halfschaduw."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fdf47987921f4fa8ba9db8f7d73fd04e" name="Brede wolfsmelk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ee95ac7a1fc8473986b096bb57f0e3db" body="Euphorbia platyphyllos, de plant heeft een geelachtig groene kleur en heeft een stengel die dicht bij de grond vertakt met bladeren die aan de voorkant fijn gezaagd zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c5873fc5a64a4a4c8a04c79791e54a07" name="Breed wollegras">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_669d212d52fb4a67a4f5cb2003464fbe" body="Eriophorum latifolium, een vaste, pollenvormende plant zonder wortelstokken. De 2-6 mm brede bladeren zijn V-vormig en hebben een driekantige top."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b956323374854b168b07684a5d5000c4" name="Bruin dikkopje">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1b08141ed5cb42889044b3f34d16506a" body="Erynnis tages, een bruine, licht gespikkelde vlinder die voorkomt in voornamelijk droge graslanden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_75e94047aae343e0a7eaa6609e055cff" name="Bruine eikenpage">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3789edb14d0e445ca42351a6c3ebd3aa" body="Satyrium ilicis, een vrij zeldzame standvlinder die lokaal voorkomt op de hogere zandgronden in het binnenland, de duinen en Zuid-Limburg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d97203766fce44a8a2f582b5564d2838" name="Bruine kikker">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_885ffa47e24444e49c29db86406f2c66" body="Rana temporaria, de kikker is een relatief grote, gedrongen kikker met een grote, platte kop en een relatief stompe snuit. De kikker wordt gemiddeld 7 tot 9 centimeter lang."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bfa914c49e77462080dd0f3bd3b67d9b" name="Bruinrode wespenorchis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3d4f9136f27a46528abc113049b5ffac" body="Epipactis atrorubens, deze plant is naar boven op zijn stengel behaard, met eerder langgerekte bladeren en roodachtige bloemen. Zij heeft een vrij dikke, meestal bijna horizontale wortelstok, meestal met vele wortels."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_49d5cbcb5fe64e998f9d0b4c4e4c4d83" name="Bunzing">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7cc63ee438cb4861ad916b024c6606ec" body="Mustela putorius, Deze marterachtige heeft een kop-romp lengte van 33-45 cm, een donkerbruine vacht met een geel, geelwitte of lichtbruine ondervacht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c36e786e981641799c91aafb7ec27c70" name="Damhert">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_eaafc7d156f74fc5a098b6e5eb03e902" body="Dama dama, dit hert staat wat formaat betreft tussen ree en edelhert in. De kleur van zijn vacht is oorspronkelijk roodbruin, zwart of gevlekt, maar er komen (ook binnen één roedel) veel kleurvarianten en zelfs effen zwart en geheel witte exemplaren voor."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_290356581cb744298b9d9f465154815b" name="Das">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_36bc8d7f700043c39388bda4b8374eba" body="Meles meles: Een grijsgekleurde viervoeter en alleseter, met een wit-zwart gestreepte kop, dat &apos;s nachts op zoek gaat naar voedsel en leeft in een burcht, die van generatie op generatie wordt gebruikt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a06863dedbcd4ecc90b7bc814e2dfb05" name="Dennenorchis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ce0be58c4de242259414cabc87fde7e2" body="Goodyera repens, de plant heeft kruipende wortelstokken met uitlopers en kan zich goed vegetatief verbreiden. De bladen zijn eirond tot langwerpig eirond, en hebben een opvallend nervenpatroon dat enigszins vlekkerig aandoet met overlangse nerven en dwars"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4940ce4efb4e40a0a88fc8f98309bb84" name="Donker pimpernelblauwtje">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_baa3173869f64d3a80b9dace89395a87" body="Phengaris nausithous: Een dagvlinder met een voorvleugellengte van 17 mm. Bij de mannetjes zijn de vleugels blauw met eventueel bruine of zwarte spikkels. De vrouwtjes hebben bruine vleugels met blauwe spikkels."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9284fcde9fe14beebadc401b02a6a834" name="Donkere waterjuffer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c89264dff19a45a99a30f06e0f3fabae" body="Coenagrion armatum, deze juffer is tussen de 31 en 34 millimeter lang. De soort is zeer donker gekleurde maar heeft contrasterende lichte delen aan het begin en aan het einde van het achterlijf."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5e3f239598be452598256fa9c818b5d2" name="Dreps">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5d7d7b8af559400eb89d5b86a2a897ae" body="Bromus secalinus, deze op de Rode lijst staande plant wordt 0,4-1 m hoog. De bladeren zijn kaal of verspreid behaard evenals de bladscheden, die vrij ver uit elkaar staande nerven hebben."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_64ce1ba66c6a45f58ac05eba1a4f41e7" name="Duinparelmoervlinder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2acbda8679164e70a1770ef8f04c0dc9" body="Fabriciana niobe, de bovenkant van de vleugels is oranje met zwarte vlekken en stippen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_987909ab88e242268c7f4fd24624db74" name="Dwergmuis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_13427fbd72d840949f9450b77411f455" body="Micromys minutus, dit is met een kop-romp lengte van 50-80 mm het kleinste knaagdier van Europa. De dwergmuis heeft een geel- tot oranjebruine vacht met witte buik."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_08baef11f0b34ee48d96f3c70bd018cc" name="Dwergspitsmuis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d49dba78ea9944c8aeb7ad75b818231a" body="Sorex minutus, dit zoogdier heeft een donkerbruine vacht op de rug en flanken en een grauwwitte vacht op de buik."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f10aabfb2f2d4a588f969b4f68708db0" name="Echte gamander">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0895b20cf57d4017aab9d5c9b3a58e96" body="Teucrium chamaedrys, een wintergroen struikje dat ongeveer 40 tot 50 cm hoog wordt en bloeit met lichtroze bloemetjes in de periode juni-september."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_289e3c91d6544a84807237054ee55168" name="Edelhert">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e47ab6bf68c5489a9ae39d8f215a9357" body="Cervus elaphus, het grootst op het land levende zoogdier van Nederland en na de eland de grootste soort uit de familie van de hertachtigen in Europa."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3e94e71b6ddf41b68d8893344e1ef801" name="Eekhoorn">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_68274317ac7b4534bb963c1f07d65c0d" body="Sciurus, een boombewonend knaagdier die opvalt door de grote pluimstaart en gepluimde oren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1498de7a8d7a469eadf83fac51f6ef51" name="Egel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bd91877ee82a4292b87bdf52bbd86617" body="Erinaceus europaeus, een algemene soort met een met stekels bedekte rug en bovenzijde van de kop."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_13b55a18922141f3b716c4ce90a51e18" name="Eikelmuis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_83cdbe34400a4ac48f7d9e53a993dacb" body="Eliomys quercinus, behoort tot de slaapmuizen en heeft een opvallend maskerachtige tekening op het gezicht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_15eeb1a739164f8d9cb75de1528592d5" name="Elrits">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6d148d5f9c624fdfba19931dd3a93452" body="Phoxinus phoxinus, Een klein langgerekte vis met een stompe kop en eindstandige bek. De rug is vaak donkerolijfgroen met onregelmatige vlekken op de flanken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_678ee6a448354e7e9f11791f2f839aa1" name="Europese rivierkreeft">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e799700ef8814bb2a994938afc2f7ce2" body="Astacus astacus, de enige rivierkreeft die inheems is in Nederland. Door omstandigheden vrijwel helemaal verdwenen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0e7b992b4fc640fbb328aadd2e18ea66" name="Franjegentiaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b8456dcd1f374b3ea705d72ab11e7ab7" body="Gentianopsis ciliata, Een tweejarige of vaste plant, die behoort tot de gentiaanfamilie. 8-25 cm hoog met een enkele blauwe bloem."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4c04d4b9c09146d5a64f24ac479834d4" name="Geelgroene wespenorchis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_419a56f35c6045ef8551c1c4d61661b4" body="Epipactis meulleri, Een vaste plant behorend tot de Orchideeënfamilie. De plant wordt 25-70 cm hoog met geelachtig groene bloemen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e76c795b154d48e08811452b6cbb5481" name="Gentiaanblauwtje">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fcd0fd144c394c089fde59cf87a57e35" body="Maculinea alcon, een sterk bedreigde vlinder. Komt nog voor op enkele heideterreinen met klokjesgentiaan, de voedselplant van de rups."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_40c78403a8ff4702b1826783d4ac1322" name="Geplooide vrouwenmantel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c4a583d733d540ad982f4cde28011ef4" body="Alchemilla subcrenata, een kruidachtige vaste plant behorend tot de rozenfamilie. De plant heeft gekartelde bladeren die tot 15 cm breed zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d3c02a869c904fa78c36cf02666b1792" name="Gestippelde alver">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d48d90d79ba34a69acc9258ceaeae241" body="Alburnoides bipunctatus, een vis uit de familie van de karperachtigen. Maximaal 15 cm lang. Heeft een zwarte naar beneden gebogen, gepigmenteerde zijlijn en een oranje vlekje bij de aanzet van de borstvin."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c56016f3974a435d9acf9b6e72d0f2e4" name="Getande veldsla">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ad3901511f1d4c0b84723900ab03ed71" body="Valerianella dentata, een eenjarig akkergewas uit de kamperfoeliefamilie. De plant bereikt een hoogte van 10 to 40 cm. De bladrozet heeft spatelvormige gaafrandige bladen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f46f6986df1c4b989c993764c4a006e7" name="Gevlekt zonneroosje">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aaaf8683842e49c3a59d96220eb2cc74" body="Tuberaria guttata, een eenjarige plant behorend tot de zonneroosjesfamilie. De plant wordt 5-40 cm hoog en heeft gele bloemen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_52f78bfade8c4acbb4016b89c8c1446b" name="Gevlekte glanslibel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2e15ac1a1d924c07bee2f51597716bff" body="Somatochlora flavomaculata, een insect uit de familie van de glanslibellen. Voornamelijk (donker) groen met een rij gele vlekjes aan de zijkant van het achterlijf."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d36811f59d014addb4fc1f84917da57b" name="Gewone bosspitsmuis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2e823bfb7c804d3eaf85281ab86eb017" body="Sorex araneus, een algemene muizensoort. De vacht is meestal donkerbruin en op de buik grijzig wit. 55-85 mm lang."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5282454c1ac24d3d8b8ef35af951d173" name="Gewone bronlibel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d99bfe9f202b46ba9ed6f392d18a1e0b" body="Cordulegaster boltonii, een insect uit de familie bronlibellen. De grootste die in Nederland voorkomt maar erg zeldzaam. Voornamelijk zwart met gele strepen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2e1bd414e5a34d7f943db2dc1427bfc5" name="Gewone pad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bceb03aef51a42f98aa62158b5986be4" body="Bufo bufo, een kikker uit de familie echte padden. Heeft een onopvallende bruine kleur en een gemiddelde lengte van 6 tot 13 centimeter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_47827aafbed34865a71618ac42ba2ecc" name="Gewone zeehond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_eeba5cfa6aa74d549942c1e1e26ef3df" body="Phoca vitulina, een zeeroofdier uit de familie zeehonden. Kleur varieert van grijs tot donkerbruin of zelfs zwart met meestal donkere vlekken. Het dier wordt 120 tot 190 cm lang."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d7bbf51a1b1b475d92f7436b0c22e4ae" name="Glad biggenkruid">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f95f8111d65046afafef9c572d967411" body="Hypochaeris glabra, een eenjarige plant uit de composietenfamilie. De plant wordt 7-40 cm hoog en heeft gele lintbloemen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a23a5b2cbb2147d29efb3484f933a219" name="Gladde zegge">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2826cdbea4b449259dd7e07828640433" body="Carex laevigata, een overblijvend kruid uit de cypergrassenfamilie. De plant wordt 50-100 cm hoog en heeft gesteelde aartjes."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0ebb6e90b39541e08b7563780b150bb5" name="Grijze zeehond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_32d0687855ce45c79b0c02bba86cc504" body="Halichoerus grypus, een zeeroofdier uit de familie zeehonden. De dieren zijn van andere zeehonden te onderscheiden door hun rechte snuit. Het dier wordt 165 tot 330 cm lang. "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d1a234e2b6d14ad3ba4634b29086c9c2" name="Groene nachtorchis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bc38cf87cddc496a948fba386166dba9" body="Dactylorhiza viridis, een voorzomerbloeier uit de orchideeënfamilie. De plant wordt 6-30 cm hoog en heeft groene tot licht roodbruine bloemen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fb37630879ea4fe5b04af74b7fbcab50" name="Groensteel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c5afb7ba07134c61a0972bcffb753b81" body="Asplenium viride, een varen uit de streepvarenfamilie. Een overblijvende plant die 10-35 cm hoog wordt. De plant heeft enkel geveerde bladeren en een groene bladspil en bladsteel.  "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b80b077a9f954aa6a2db14c2ea9f8cf9" name="Groot spiegelklokje">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_197f16b05cd7482e8bd2e66886709b49" body="Legousia speculum-veneris, een eenjarige plant die behoort tot de klokjesfamilie. De plant wordt 10-40 cm hoog en heeft paarse bloemen.  "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_111c93dec99145f8ac36a31da290f035" name="Grote bosaardbei">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6542f0ffab6c4918a9bfae7be1e0fcec" body="Fragaria moschata, een vaste plant die behoort tot de rozenfamilie. Een aardbeisoort die 10-40 cm hoog kan worden met witte bloemen.  "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bb829c95674947a88134e2477c5983c8" name="Grote bosmuis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ff9ed3265d5c4471bc10da0108cb6527" body="Apodemus flavicollis, een ware muis die zich kenmerkt door grote ogen en oren, en een puntihe snuit. De muis heeft een voornamelijk bruine- met aan de onderzijde witte vacht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6a5e64339b7248fca9699a9e661d5161" name="Grote leeuwenklauw">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_072bfb4209354dd7be616a2814cc1521" body="Aphanes arvensis, een eenjarige plant uit de rozenfamilie. De plant wordt 2-20 cm hoog en heeft behaarde, drielobbige en getande bladeren met een iets blauwgroene kleur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d41e0203687a44c899a6621dd7cc7ca7" name="Grote modderkruiper">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d05f0f0382e549dd9aaba328d283aff9" body="Misgurnus fossilis, een langgerekte spoelvormige vis met een donkerbruine grondkleur, een geeloranje buik en zwarte lengtestrepen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9296fdee261b4b75a270a37eacb4ee8b" name="Grote parelmoervlinder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_16f99c8b23b6465dbd1ea4466602caeb" body="Speyeria aglaja, een relatief grote vlinder van 23 tot 29 mm. Heeft een zwart lijf met duidelijke rode vlekken langs de flanken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_425eeb5216f94bb8b78015f433d6a8f3" name="Grote vos">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b0dfd2e52770403e8f1bf84e7c2edcc1" body="Nymphalis polychloros, een vlinder van 27 tot 32 mm. Het stippenpatroon op de vleugels vormt een Y-vormig figuur als men deze met lijnstukken zou verbinden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f06fbd4d72a64603877e0ab00c12ddd7" name="Grote vuurvlinder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bc97552db06a4e6c872e4c97b83a08d1" body="Lycaena dispar, een vlinder van 27 tot 32 mm uit de Lycaenidae familie. Voornamelijk oranjerode vleugels waarbij de achtervleugels van het vrouwtje donkerder zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_73860971706549a39e5617a2de142a24" name="Grote weerschijnvlinder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e0d76beae8904d37a284a36b129b3202" body="Apatura iris, een vlinder van 31 tot 40 mm. De vleugels zijn voornamelijk bruin maar de vleugels van het mannetje kunnen iriseren naar een blauwe kleur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b31996e3adcb4a76b5274d8a70855e43" name="Gulden sleutelbloem">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_72eb8816f33b4a309aa715be23d0c683" body="Primula veris: Een plant met gele bloemen en een oranjekelk die voorkomt in bossen en weilanden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_53d11a9cf1624157b1ce2da89a3edac2" name="Haas">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f773c74fc32540ca89142a2ffae8b6d1" body="Lepus europaeus, dit zoogdier lijkt oppervlakkig op een konijn maar is groter en heeft in verhouding grotere oren en langere ledematen met zwarte uiteinden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0a2d80f0be8647b4ba64f835fea5cd4b" name="Hazelworm">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4e80f36a391242bea3c3572166a935a3" body="Anguis fragilis, een pootloze hagedis die een lengte van 45 cm kan bereiken. Te onderscheiden van een slang door zijn stijve voortbeweging en tond die niet sterk gevorkt is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4c17d0da3f024f1ab7227dd39642517b" name="Hermelijn">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_227ccbc940044d51bf94b3b3b47d46be" body="Mustela erminea, een klein zoogdier uit de familie van de marterachtigen. Het dier heeft een langgerekt lichaam met een kastanjebruine vacht en een gelig witte buikzijde."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d4c82c4401d04f079d74085a6458ab27" name="Honingorchis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0ad44c048faa4cbd91309eb36c073a07" body="Herminium monorchis, een vaste plant uit de orchideeënfamilie. De plant wordt 8-30 cm hoog en bloeit in juni en juli met honing geurende, groengele bloemen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_77eee3e030c84e6695ac439b3ad7d609" name="Hoogveenglanslibel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5c47c762d2014fcf80c646364df07b92" body="Somatochlora arctica. een middelgroot insect behorend tot de glanslibellen. Heeft voornamelijke groene kleuren met eenachterlichaam dat meestal zwart lijkt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f37dfbc1c0034576a0341de6c70e8a64" name="Huisspitsmuis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9b341d39a2b04b5c88375c14682d0a39" body="Crocidura russula, een zeer algemene soort met een grijze tot bruine vacht met op de staart lange witte haren. De oorschelpen steken buiten de vacht en zijn duidelijk zichtbaar."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c2375aaa69b240d1addcda5783a2bfdc" name="Iepenpage">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bbf72cffa9554d5b9e207abe05b2fb18" body="Satyrium w-album, een kleine onopvallende vlinder met donkerbruine vleugels. Op de onderkant van de achtervleugel is een duidelijke witte W gevormd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d2135362fd58447c847cc61ebfb969cb" name="Kalkboterbloem">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_da9710bce3e9485c90cf70fc0b823f1c" body="Ranunculus polyanthemos subsp. polyanthemoides, een vaste plant uit de ranonkelfamilie. De plant wordt 30-90 cm hoog en heeft tamelijk smalle bladslippen. Staat op de Rode Lijst."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c7549f3e7e1a4141989b01ef58ef0cc5" name="Kalketrip">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8aa8065c349b406a91e1ee68e769340e" body="Centaurea calcitrapa, een eenjarige of tweejarige plant uit de composietenfamilie. De plant wordt 15-60 cm hoog en vormt een bladrozet. De bovenste bladeren hebben een stekelige punt.  "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9b70cb2ee63d439480a2a42ea5b3f2cc" name="Karthuizeranjer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ad322cbc29bf48b0b368285616cf9dc6" body="Dianthus carthusianorum, een vaste plant uit de anjerfamilie. Kartuizer monniken kweekten de soort vanwege de saponinen en als middel tegen reuma."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_78872614d1d24064be266e1fd56ec6d4" name="Karwijselie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b961385dd1c54936bb469bde241634da" body="Selinum carvifolia, een tweejarige plant die behoort tot de schermbloemenfamilie. De plant wordt 30-90 cm hoog en heeft een gevleugelde en kantige stengel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c616a165970c456cbd3fd8c2f39f7a44" name="Kempense heidelibel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_32098d57dc4f442b8cd2c85991b2c6d6" body="Sympetrum depressiusculum, een insect uit de familie van de korenbouten. De libel is voornamelijk oranjerood en heeft zwarte poten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_381f0191a3be45a48bea61df23366a96" name="Kleine ereprijs">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_73aef5ac5a6f48c5881fae6ac9d51b4a" body="Veronica verna, een eenjarige plant die behoort tot de weegbreefamilie. De plant wordt 2-15 cm hoog, heeft voornamelijk veerdelige bladeren en blauwe bloempjes."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9431b26fe49b47eea0dc3e5cafee0c9e" name="Kleine heivlinder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_18deba4bba5c4238817df6c92e71a30b" body="Hipparchia statilinus, een dagvlinder uit de subfamilie Satyrnae met een spanwijdte van 21 tot 25 mm. Het insect heeft zwartgrijs tot donkerbruine vleugels."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6a5f86712d344beeb043bc403c94e60b" name="Kleine ijsvogelvlinder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3e676796b558449897b2f163fa2f5fa1" body="Limenitis camilla, een vlinder uit de onderfamilie Limenitidinae met een spanwijdte van 22 tot 29 mm. Het insect heeft bruine vleugels met witte vlekken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1356b1a4923e4336afa2553063e9ff75" name="Kleine Schorseneer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cf226bf496a248c2b96ade39ef30de43" body="Scorzonera humilis, een vaste plant uit de composietenfamilie. De plant wordt 5-50 cm hoog en heeft gele lintbloemen in hoofdjes."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3c6673e9b28447dd979d420b9bb93462" name="Kleine watersalamander">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f90f09aa14484cedb177b647144de0e4" body="Lissotriton vulgaris, een amfibie uit de familie van de echte salamanders. Bereikt een lichaamslengte tot ongeveer 10 cm inclusief staart en heeft een bruine kleur met donkere vlekken en strepen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e85655d27998486fb28367fd16136b83" name="Kleine wolfsmelk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2020882a35db4b718ba6a9b89dcaf768" body="Euphorbia exigua, een giftige, eenjarige plant die behoort tot de wolfsmelkfamilie. De plant wordt 7-25 cm hoog en heeft geel-groenachtige bloempjes."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bc572d82588145d8989bc7f155075cf1" name="Kluwenklokje">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ef243e33ede74bba9d18fdadb4004935" body="Campanula glomerata, een vaste plant uit de klokjesfamilie. De plant wordt 30 tot 60 centimer hoog en heeft blauwpaarse bloemen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1f3da3473e0c4b81a2e7b725ce5a46fc" name="Knollathyrus">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1b75122f7bbc4f6c92afd681d77bd1be" body="Lathyrus linifolius, een vaste plant die behoort tot de blinderbleomenfamilie. De plant wordt 15-40 cm hoog en roze bloemen die later blauw verkleuren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5d254aebddfe4504a28ddd946510c7d5" name="Knolspirea">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7604368500974b22a4ae111f8a26cf38" body="Filipendula vulgaris, een vaste plant uit de rozenfamilie. De plant wordt 30-60 cm hoog en heeft roomwitte, van onder puperroze, bloemen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_da6365aebba34d2abca31855906ae520" name="Kommavlinder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dac4318c6d414a0bbde51e95c8aaa8f8" body="Hesperia comma, een dagvlinder uit de dikkopjesfamilie. Het insect heeft een spanwijdte van 28-31 mm en is te herkennen aan de witte, kommavormige vlekken aan de onderkant van de vleugels."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5611347d926f4d8086e409e6c3d30a11" name="Konijn">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6a24b95ec8f64427bb1a2a07bcc572a5" body="Oryctolagus cuniculus, een zoogdier uit de familie van de hazen. Het knaagdier heeft langwerpige oren en een kop-romplengte van 25-50 cm."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1f7122f94e4649279916a78d719e2154" name="Korensla">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7ba4c3830eb34cf6ac2324af584fecf1" body="Arnoseris minima, een eenjarige plant uit de composietenfamilie. De plant wordt 6-30 cm hoog en heeft goudgele lintbloemen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_747e70844a3940ae9679531f09b8548f" name="Kranskarwij">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_38761660d6f54d56a8ef7feb8cf947f2" body="Trocdaris verticillatum, een overblijvende plant uit de schermbloemenfamilie. De plant wordt 30-60 cm hoog en de wit of roze bloemen staan in afgeplatte schermen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4f3c4bb2f3a64081a3c9f0cfa69ca548" name="Kruiptijm">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_56fa949ad91f4b2f8a4b07c8e1686d4d" body="Thymus praecox, een vaste plant die behoort tot de lipbloemenfamilie. De plant wordt 5-10 cm hoog, heeft sterk geurende, roodpaarse bloemen en vormt een tamelijk losse zode."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d73bd7c9af5745cd9fc9f012ab348853" name="Kwabaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8441b55e88a54208a048325ff4683edc" body="Lota lota, de enige zoetwatervis uit de familie van de kabeljauwen. Het lichaam is langgerekt en cilindervormig met een groenbruine kleur, gemarmerde tekening en twee rugvinnen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cdc6cdc8767d4ef9be8221f895daceeb" name="Lange zonnedauw">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_69706b2bf6d847498146072ff12fc1c8" body="Drosera anglica, een overblijvende, vleesetende plant uit de zonnedauwfamilie. De plant wordt 5-20 cm hoog en heeft bladeren met talrijke, kleverige, klierweefsel bevattende, haardunne rode tentakels waarmee de plant kleine insecten vangt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_711b0c957c674481bfd09da2f9a6f205" name="Levendbarende hagedis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_96cf2a3666904827bce05b621154b01b" body="Zootoca vivipara, een reptiel uit de familie van echte hagedissen. Het dier bereikt een maximale lengte van 18 cm en kenmerkt zichzelf door de eierlevendbarende voortplanting."/>
        </ownedLiteral>

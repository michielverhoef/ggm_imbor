        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_02627b93a4f4400dbd1eb15480d56c31" name="OnbegroeidTerreindeel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_629374853ec44e97bef9badc6b4dfe82" body="	Kleinste functioneel onafhankelijk stukje van een terrein, dat er binnen het objecttype Terrein van NEN 3610 wordt onderscheiden, zonder aaneengesloten vegetatie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cf1fa82e664342f28b7c524c76d53fb4" name="OndersteunendWegdeel">

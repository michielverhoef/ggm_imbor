      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_901fd961ccdc478db1e74dcc09fde9d8" name="enum_VerhardingTypeRijstrook">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4c005a965d794b7bad0a3f9b75025ddb" name="Afvallende rijstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b2eb4e4425f14f698db528d60451a99f" body="Rijstrook die zich afsplitst van de hoofdrijbaan en overgaat in een rijstrook van de afbuigende rijbaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8dccb695a8a5409d9e7a6e70029f852a" name="Bijkomende rijstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_441bb8b128824f668725a9e460244e5e" body="Een rijstrook die aan de linkerzijde van een rijbaan wordt toegevoegd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_91ef4e62c4034883bc7572d910812110" name="Fietsstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f30b46de261e4df0b84ec7b50c8bb8cc" body="RVV1990: Door doorgetrokken of onderbroken strepen gemarkeerd gedeelte van de rijbaan waarop afbeeldingen van een fiets zijn aangebracht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9c4ac9fdcea44bf18b4e81b07bd26d17" name="Inhaalstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_039b36c3bb604f55a6066deec27d045e" body="Rijstrook van beperkte lengte, in rijrichting gezien gelegen aan de linkerzijde van een doorgaande rijstrook, en bedoeld om motorvoertuigen gelegenheid te geven langzaam rijdende voertuigen in te halen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_69812d08e4864346bb8ce59a101863b8" name="Inspectiestrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_736743c4ede74779847ce887c32103c1" body="Gedeelte van een inspectievak, gezien in de breedte, dat in een gang wordt beoordeeld."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fc8adb2c5b1c4541b320ca1a030b7db2" name="Invoegstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_681d207befc04ec7a0c1e43dbcc05525" body="Een rijstrook met een beperkte lengte ter plaatse van een convergentiepunt, die grenst aan een doorgaande rijstrook van een rijbaan en, in rijrichting gezien, begint bij de spitse punt van het puntstuk."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_83ebbeaa3f004026a9f50c4b14e3b4e0" name="Landbouwpasseerstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5ff52dce27954ccb92f18954d6ec360e" body="Een plaatselijke verbreding van de verharding waar ruimte wordt geboden om een tegemoetkomend voertuig te laten passeren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fe01410db7ac41ec8707daacaa42afeb" name="Opgeblazen FietsOpstelStrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_061b416f84db483ba94661382efc4721" body="Een vak voor fietsers vóór de automobilisten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c679037e6ca4444db46b0cc19c643737" name="Opstelstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_767fb6cb541c4948803fe84bd2313ed0" body="Gedeelte van een rijbaan dat is ingericht voor het opstellen van verkeer in de aangegeven richting dat moet wachten op doorgang."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cae0d95e00544d16a917e6fbda56ffc5" name="Opstelstrook: linksaf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_67f97affebb24c9e8be101a465270339" body="Rijstrook in een opstelvak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7a0f5995c9ce4fde8763fd910ad35f6e" name="Opstelstrook: rechtdoor">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7a94ae8960c34570a4e7fea776855557" body="Rijstrook in een opstelvak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_86fb26f2188b4485886c068871b4b0f0" name="Opstelstrook: rechtdoor + linksaf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_68db95566a324bb4babe46a306bc30a0" body="Rijstrook in een opstelvak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0daab426ec0e491e95a98ca35dc6530c" name="Opstelstrook: rechtdoor + rechtsaf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fd6ec4ca6f974a4cbd200f5df6bed100" body="Rijstrook in een opstelvak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8cdfdf75f3b04278b45011591a1c8177" name="Opstelstrook: rechtsaf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d07b5852616b4f60a97c11f12d3e2393" body="Rijstrook in een opstelvak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_15159350c860489d895117d74276f58c" name="Plusstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_170c90e504de4afca607f96619bb5f3e" body="Een extra linker rijstrook op de autosnelweg in Nederland die mogelijk is gemaakt door het smaller maken van de oorspronkelijke rijstroken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8ae868343f5c430dac3bb18106431db9" name="Rabatstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_687feb91e59c42768ae6f7be8542a72c" body="Brede kantopsluiting op hetzelfde niveau als, maar in een andere uitvoering dan, het verhardingsoppervlak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7a38a41b6dbd4f3d8ce18a0ddcfb9ea2" name="Rammelstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_178cee484d074fb0b729e74ffea4fc3d" body="Verharde strook op en/of in de bochten van aansluitingen op een rotonde waar lange vrachtwagens over mogen rijden wanneer de bochten te krap zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d3c5fafed03d41d6800df72f19352df0" name="Redresseerstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fdff8ae987f0412c9047e9ff565e4aa9" body="Verharde strook van beperkte breedte, gelegen naast de rijbaan, en bedoeld om weggebruikers gelegenheid te geven hun koers te corrigeren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_edf0e23e100047dfb511454afa01820e" name="Rijstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_54a9ce4862264992a4e0ae885a1dc117" body="Begrensd gedeelte van de rijbaan dat voldoende breed is voor een rij van het voor dat gedeelte bestemde verkeer."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_593ea60b601640a9b2c58b395ee81cbb" name="Spitsstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b6889ffcbcaf4b9681fcb35baf336f56" body="Rijstrook die alleen tijdens een spitsperiode toegankelijk is voor verkeer."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_11bb69039229417d99f291ec6d1ea349" name="Suggestiestrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_910067d6c74b42d1be9ed3077bb04a64" body="Door wegmarkering en/of kleur en/of materiaal aangegeven visuele wegversmalling (niet verplichte rijstrook bestemd voor fietsers en ander langzaam verkeer)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_086726a8e5ac4b03ac81d31c76b3b174" name="Uitrijstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5d5b3bcc7092480b8ceca38e0f235974" body="Een rijstrook met een beperkte lengte ter hoogte van een divergentiepunt, die grenst aan een doorgaande rijstrook van een rijbaan en in rijrichting gezien eindigt bij de spitse punt van het puntstuk."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2ec7354c4e594302b8f3d6273fa90493" name="Uitstapstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ed4094c6b8ee43d4ac8a448d271131b5" body="Een strook ten behoeve van het uit de auto stappen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5bc211e61e0d4e258ad5eb120f1c576c" name="Uitwijkstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_611d7def8c15431a86f21a01174d0cd3" body="Een verharde strook gelegen naast de rijloper en bedoeld om elkaar tegemoetkomende weggebruikers gelegenheid te geven te passeren en ruimte biedt voor corrigerende bewegingen buiten de rijloper."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b1493f2e2f3c46dd8a0b49a47083d117" name="Verhoogde fietsstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b99b98c515e943fdb44bd8764ae0cd0d" body="Een voor fietsers gereserveerd onderdeel van de rijbaan met een verhoogde ligging ten opzichte van de rest van de omliggende weg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c2b978ef3a9645dc9d4c8cd41d043edf" name="Vluchthaven">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9da0fca61c4f401ab40c1733162a741d" body="Verharde strook van beperkte lengte langs de rijbaan, waarop in geval van nood mag en kan worden gestopt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_974dc0131c824f63b8c0f45d48543046" name="Vluchtstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a6ed4bc1d1564db694d4ac8dfc89f00b" body="Verharde strook langs een rijbaan van een stroomweg, waarop uitsluitend in bijzondere gevallen of in geval van nood mag worden gereden of gestopt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_242d9f71e753497497d1f2225837ce47" name="Voetstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9d0acad58c69449b8b1a5142f8df6f20" body="gedeelte van verkeersbaan bestemd voor voetgangers. (Bron: RWS)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0dd226a6ff1d457ea2d316b33393155d" name="Weefstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_955db433dcb448878a39a86891c16f8d" body="Rijstrook die behoort tot die rijstroken in een weefvak die minimaal vereist zijn om te kunnen weven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c28f9ab0f2a640caaf67551f5f1027aa" name="Zijstrook">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a98e10aed0014bf8a44227b95aafccac" body="Een extra verharde strook op en onder kunstwerken en in tunnels tussen de vluchtzone (of alleen de redresseerstrook) en de wand of de opstaande kant van een kunstwerk of de zijkant van een afschermingsvoorzieningsconstructie."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_3b50eb9476c74029983e47b13c21adb6" name="enum_VerhardingVoeg">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_518122cb42e842f2893fa69ec1634d1a" name="Constructievoeg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e6c479ce6a004325b23dd5bc49c14711" body="Naad of onderbreking aan het oppervlak van een constructie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8fa2f6265e52471abf5c6a7f08b2d5b9" name="Krimpvoeg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4ea11ec0a3ef4e7f950960cec9eed196" body="Een insnijding die zowel het uitzetten als krimpen van een constructie faciliteert."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a932728af98c4556bdf4acf3b0331bdc" name="Onbekend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_08ff23f0e3e042aeae454933be4cc8ea" body="Bij deze waarde moet nader onderzoek uitwijzen of welke attribuutwaarde van toepassing is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e7f164a314874c17a0538a0a31bdebae" name="Overgangsvoeg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8892f8853ba142db8d0a3908b4c0622c" body="Een naad of onderbreking in een betonconstructie waarbij twee verschillende soorten constructie in elkaar overgaan: een bijzondere vorm van de uitzetvoeg die wordt toegepast bij overgangen en aansluiting op bestaande of andere typen verhardingen, material"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_87a58a3d6ed94e77a90e8114f78c1ae2" name="Uitzetvoeg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6081917767c14f308f2cd1d12550ae94" body="Een insnijding die zowel het uitzetten van een constructie faciliteert."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_242df9835e1741cb9882ed2865777d2f" name="enum_VerkeersaansluitingVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b1b1142b932043368d9e8b0035d884d1" name="Gecombineerd haarlemmermeer-halfklaverblad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_355867c4e25b49ab98711c9fcfa77adc" body="Een combinatie van een haarlemmermeeraansluiting, zijnde een aansluiting waarbij de afritten en de opritten van de kruisende wegen parallel liggen aan de hoofdweg, en een halfklaverbladaansluiting, waarbij twee bovenliggend kruisende wegen boven- en onder"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_396a28b4cf9946989b10c56be35d2999" name="Haarlemmermeer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e9fb630da5424e3c9196ad7be915bfb2" body="Een aansluiting waarbij de afritten en de opritten van de kruisende wegen parallel liggen aan de hoofdweg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c7b7b85359494e02b4b5cef2f183fcdc" name="Halfklaverblad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7bbd717bdb784cecbc1d8f5b54eaacb7" body="Een aansluiting waarbij twee bovenliggend kruisende wegen boven- en onderin één diagonaal van de kruising verbonden zijn door een verbindingsweg toe en een verbindingsweg af."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5373c86d37d647a4bb0a600ab5205c10" name="Trompetaansluiting">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f7b1694827774a73b2e0fdebb0d63d40" body="Een type knooppunt van twee autowegen of autosnelwegen, waarbij van en naar alle richtingen verkeer uitwisselbaar is. Dit type aansluiting komt uitsluitend voor aan het begin of einde van één van de twee kruisende wegen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_a51bd2db81b147b991a905f2f91e865e" name="enum_VerkeersbordBordcode">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a240b4ecb8914eaeaa7935aaf020f168" name="A0110">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_de583714fb1d4ba386d275aaf4e051c1" body="Maximumsnelheid 10 km per uur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_738749b998bf44508f65343a66e89666" name="A01100">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8ed1ddf8f5304d819c01965e833f4eaa" body="Maximumsnelheid 100 km per uur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_94aabe9215554860b0f5903656563ab5" name="A01100f">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5c5c1187a0864cacb6c879fd20642fa6" body="Maximumsnelheid 100 km per uur, fluorescerend."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3d98cf7f11cf4a58894300343a29003c" name="A01100s">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_95213899ab604c0ab278da18b6fadd97" body="Maximumsnelheid 100 km per uur, zwarte achtergrond."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c3b0bd4f8fa3452d9037246a644cb91e" name="A01120">

      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_2ea02a79d9924b09a97f1d231e9d8eb2" name="enum_GroeiplaatsGroeiplaatsinrichting">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2987e6dd287e450db5c20fad4d749485" name="(Lokale) bodem | humeus zand 5 tot 8%">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e84a4cccce58465c85e94f1f07bfcd98" name="(Lokale) bodem | humusarm zand &lt; 2,5%">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8809318806074ebaa70b54c4a7d8a40e" name="(Lokale) bodem | humusrijk zand 8 tot 15%">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e3434313ef6045d4a7ffe04a5b91045c" name="(Lokale) bodem | humusrijk zand 8%">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d38b5f8be770461db66f50ead0b9f654" name="(Lokale) bodem | klei">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a5c2afee6a1e4c7aacb4c69dcce5a28e" body="Natuurlijke bodem die voornamelijk bestaat uit gronddeeltjes kleiner dan 2 micrometer."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3570c1a6c2de425f94b90cc7f2739949" name="(Lokale) bodem | matig humeus zand 2,5 tot 5%">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_265d53f164cb4ce5a5cbed87aca2afa5" name="(Lokale) bodem | matig humeus zand 5%">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4cdf0245f8e94991a4d9822faf5472e2" name="(Lokale) bodem | veen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_66c45a1d0839418383bf4536f16606e0" body="Natuurlijke bodem opgebouwd uit gehumificeerd plantaardig materiaal. Deze natte, sponsachtige grondsoort is gevormd foor afgestorven planten in moerassen en later bewaard gebleven onder natte, zuurstofarme omstandigheden."/>
        </ownedLiteral>

      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_237b3a69d45d4628b90ec29c6dd6599c" name="enum_OppervlaktewaterBevaarbaarheidklasse">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_66ad2f39cd9e4a25b87f14945c31489e" name="0 - M0">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dbecbdfeaaf94da59ca741b22bfdfe64" body="Kleinere vaartuigen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f3206af91bd1491cb4c0fe0d12c4f123" name="I - M1">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2dae33c3ab434097b9fc2e0fd2a9b70b" body="Spits. De spits is een vrachtschip waarvan de afmetingen zijn afgeleid van de maten van de sluizen en kanalen in Frankrijk."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ad3d1b4ac08146258889b5a1947436bb" name="II - M2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_05a6334a568d4f4ebf05ddc41d15c24d" body="Kempenaar. De kempenaar is een vrachtschip dat speciaal gebouwd is om de smalle en relatief ondiepe kanalen in Zuid-Nederland en Noordoost-België te bevaren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e71165f13e26448d918046ebcf1c1e65" name="III - M3">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_714cc09d3b934305a6d5d5d6b7d4c940" body="Hagenaar."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e8312caa0e55410486a54f7320ea5aa8" name="III - M4">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7f423c55c35d4135a98ae55906ccbe70" body="Dortmund-Eemskanaalschip. Een Dortmunder ook wel Dortmund-Eemskanaalschip is een vrachtschip dat gebouwd is voor de maten van het Dortmund-Eemskanaal (DEK) en andere kanalen in Noord-Duitsland."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a96d8baa7c894128bc67b8b612397016" name="III - M5">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5f049ecb8ea944e5aa46cba91bd543fa" body="Verl. Dortmund-Eemskanaalschip."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ad977554b71c48b186e6422f93f281c5" name="IVa - M6">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4f207158c0da40a7b9ab9a97f6ba4859" body="Rijn-Hernekanaalschip. Het Rijn-Hernekanaalschip, ook wel Rhein-Herne, is een binnenvaartschip ontworpen voor de maten van het Rijn-Hernekanaal (RHK), maar komt op de meeste grote vaarwegen in Europa voor."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2b829aef6ffc4e9f8ade74bad07f7796" name="IVa - M7">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_929aca2062364664ad0cb4cb4f88d36f" body="Verl. Rijn-Hernekanaalschip."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_252972eb51914fa59150899e0c78c468" name="RA">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_da97492bc408489d98d39bbc8c461f9b" body="Open boot."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7649f1b2422c41b49465862b5e028f98" name="RB">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b1e1fe1391a34198906ec813801b5295" body="Kajuitmotorboot."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ace727d17657420b81516d4a2ce430d3" name="RC">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e8abfaf880264b3fb8023ab2a1359b6d" body="Motorjacht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1651c4ecefce4bcdaf4aac53af82b8c8" name="RD">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6eaaa6148b1d4f4c8e4d3a2ce4cfd645" body="Zeiljacht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_caf30345ae5d41d2b8ec354a2418709e" name="Va - M8">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5cc22a84663a4ff084342187dc551f0a" body="Groot Rijnschip. Een groot rijnschip, ook wel rijnaak genoemd, is een binnenschip dat is ontworpen voor waterwegen die men sinds 1992 indeelt in CEMT-klasse V."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0eb599b1e17a4c19a87f246329b9ad37" name="Va - M9">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_37aecb3399254b4699c211fe4c4345ef" body="Verl. Groot Rijnschip."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ed8d8e9d9bae4b2a8221eb713e5a0e3c" name="Vb">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f41dab42fa924248a98e3cd08fcc837a" body="Duwkonvooi met 1×2 bakken in de lengte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d9f9c6719a914299bea51c904be7ee25" name="VIa - M10">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b0bd48109db948b4bb0d2af637a2ee3b" body="Maatgevend schip. In de waterbouwkunde is het maatgevende schip het schip dat de haven nog &quot;net&quot; moet kunnen binnenlopen. Het toelaten van grotere schepen in de haven is niet mogelijk of zou gevaarlijk zijn, bijvoorbeeld wegens de te kleine kielspeling of"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e51cb5abe4c349be938f02af48090cdb" name="VIa - M11">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_61a387c2f8514e189e621f0b0c64786c" body="Maatgevend schip. In de waterbouwkunde is het maatgevende schip het schip dat de haven nog &quot;net&quot; moet kunnen binnenlopen. Het toelaten van grotere schepen in de haven is niet mogelijk of zou gevaarlijk zijn, bijvoorbeeld wegens de te kleine kielspeling of"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8174fb4a6a934607a2a7d216b87cfbdc" name="VIa - M12">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2b32f428916549f98ca016befb7b06be" body="Rijnmax schip."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_57bbcee0671c412a97c129917a2e1fda" name="Vib">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_af9192c55c164a65aec3761be473221f" body="Duwkonvooi met 2×2 bakken naast elkaar."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_388cb934106f47c9851cd982de2b19b8" name="Vic">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1feb60bf80094d07a3a8e12389ce6c46" body="Duwkonvooi met 3x2 bakken naast elkaar."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_822e3db92fd5491288a1abafc741d2b0" name="VIIa">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5f6887a97dcb47a196708c1c273c7249" body="Duwkonvooi met 2×3 bakken naast elkaar."/>
        </ownedLiteral>
      </packagedElement>

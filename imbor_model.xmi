      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_67ae16eba8484cc58c848042b74a7397" name="enum_ToegangspoortVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_452f001266744c03afb76f29a6ff3c08" name="Draaihek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_01446b1a0c1c43bf845dc3c038ea53c6" body="Poort of die volgens de as aan het ene uiteinde naar binnen toe kan draaien."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_25fef3a2aac64924b43f66251eae2fc8" name="Klaphek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_84d5e6319a264c3ea9cc56cc3b5afbd6" body="Een poort die een persoon tegelijk toegang biedt, vaak gemaakt van houten planken en middels scharnieren bevestigd in een hek of omheiningsconstructie, al dan niet van een andere soort dan het hek zelf."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_41f6fade14964f44ae09ef60fa6572f0" name="Schuifhek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3ace325f5c244e4ba665b62af146077e" body="Een poort die voorzien is van een schuifmechanisme."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f4db64170939453fa6444226f5b8051c" name="Vouwhek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e2e0a555181e4fa597abcfc7f0f6aaec" body="Een hek bestaande uit meerdere scharnierende panelen dat zich (mechanisch) ontvouwt om toegang te beperken of opvouwt om toegang te geven."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_0799ea0d0b164f4e8fe9dfa2fd237a9a" name="enum_TunnelgangVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_afd02bdd40e84c6db7877b7d78142292" name="Dienstgang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_535731275cb54e75a57141e5929b2a9f" body="Een gang in de lengterichting van de tunnel, meestal boven en/of onder een vluchtgang."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4dce8703689941f7b8bc01085697529f" name="Dwarsgang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_914b96cccab6488cbea2b0e8f4689910" body="Een gang tussen twee tunnelbuizen in, om van de ene naar de andere buis te komen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f62f265770344c13bb1af5d952987ef1" name="Technische gang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5b901194ab744ccbb3e0f393eeff329b" body="Een gang voor toegang tot de technische ruimten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5d82a26b6f04483f9ef17b3a181eb144" name="Vluchtgang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f5160b746789426ea99eaaa6ef5f713d" body="Een gang in de lengterichting van de tunnel, achter de vluchtdeuren van de tunnelbuis, die leidt naar een veilige plek."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_e5ad97c260474bb784cdd522971d6965" name="enum_TunnelVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_95dd8871f2404a60b39c6f155de7358b" name="Afgezonken tunnel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_709099fb25c04873b21b404016c1b7c8" body="Een tunnel die in segmenten wordt opgebouwd op een droogdok, waarna het droogdok wordt afgezonken en de tunneldelen naar hun plek worden gesleept en worden neergelaten en verbonden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5062afdc2ea84f808f5703bfd9250708" name="Geboorde tunnel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5a2f8cb6a6d34730b33e1ecd8a19b4ef" body="Tunnel die is vervaardigd door te graven met een tunnelboormachine."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d613f1c8ab8845a59bae05f1f7d5eb64" name="Gegraven tunnel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_97159b767f194fb79d7a7753a262c0e4" body="Een tunnel die is vervaardigd met behulp van machinale graafmiddelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fee43b6d603b491da2e940ca2ead632c" name="Microtunneling">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d9ad1124dbfc4323b5a0249adbe7c188" body="Een tunnel die is vervaardigd door vooraf gefabriceerde tunnelelementen in door tunnelboormachines gegraven holtes te schuiven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e2a616f3d82744daa904790705442601" name="Opbouwputtunnel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_be61dbd612014246b639ebfab0c9e36b" body="Een tunnel die is vervaardigd is door een bouwput af te graven, daar de tunnel in op te bouwen en vervolgens de bouwput te dempen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ae94fe23b33341c994187cf6bbe0e30a" name="V-polder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0164ffff54ef44d882669e3a763fe675" body="Verdiepte infrastructuur, zoals spoorlijnen of wegen, die zijn aangelegd door damwanden onder een hoek in de grond aan te brengen zodat deze een V vormen, die waterdicht is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1f67226be9654c1ebfa051197b08d72c" name="Wanden dak methode tunnel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_01cfa65cf0fa4715ac4082c38323431c" body="Tunnel die is vervaardigd door eerst de wanden van de tunnel in de grond aan te brengen en vervolgens het dak, zodat het terrein op het maaiveld zijn functie weer kan hervatten, waarna de grond onder het dak wordt uitgegraven om de tunnel te vervolmaken."/>
        </ownedLiteral>
      </packagedElement>

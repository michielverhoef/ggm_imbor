        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_534457fe3a194ab7ab3eae24de5949ae" name="Rechthoekig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6532bdfb60dd4083ac253dcacfd1324f" body="Een vierhoek met louter rechte hoeken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_59ec00b08e4f44efb301969ef4a6c245" name="Rond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c4f3f1ffc5004f3a8ebb6d2518a4cf22" body="Cirkelvormig en zonder hoeken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d71535a99fb54f64b0ed9306cd677131" name="Vierkant">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e8e5b871f2a74bb4a43a18b5e1debe8d" body="Een vierhoek met louter rechte hoeken, waarbij alle zijden dezelfde lengte hebben."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_594e04e9c79248b3aca1985226b67c8d" name="Vijfhoekig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b9b5eacf762e4e80ac8e5b1498441bfd" body="Het object heeft de vorm van meetkundig object dat vijf hoeken heeft."/>
        </ownedLiteral>

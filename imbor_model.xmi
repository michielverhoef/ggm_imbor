        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6f400344b9244f21b144b7812c3e9c82" name="Calamiteitendoorsteek autosnelweg (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e381935d36ff498296b362bc9ebee1a4" body="Een calamiteitendoorsteek of CADO (van een autosnelweg) heeft tot doel het verkeer op een rijbaan via een doorsteek van de weg te kunnen geleiden in geval van een calamiteit of werkzaamheden op de rijbaan. Een tweede doel is het faciliteren van toegang to"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_837c6498d801470a9792fc26756220d7" name="Calamiteitendoorsteek autoweg (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_721b2b612aba4179b485dd6a9b6dba36" body="Een calamiteitendoorsteek of CADO (van een autoweg) heeft tot doel het verkeer op een rijbaan via een doorsteek van de weg te kunnen geleiden in geval van een calamiteit of werkzaamheden op de rijbaan. Een tweede doel is het faciliteren van toegang tot ri"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f7f503e08ad341d39c867433e22f0112" name="Fietspad (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3143125d98a6487daba36c0b7cb204c8" body="Weg uitsluitend bestemd voor fietsers en/of bromfietsers of een deel van een weg bestaande uit een oranjekleurige verhardingstrook met daarop een wit rijwielsymbool. (bron: CROW)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_856abb4f68414f48bfe9e9154cd3e672" name="Inrit (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_53dcac6f85bb4e7da834568ace8909b5" body="Toegangswegen oprijlanen en dergelijke met een verkeersfunctie die leiden naar afgelegen erven en terreinen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_eae2730d789047c496f23c0e5e3f4101" name="OV-baan (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1431a0b8a30c41cfbc79100fde77f798" body="Wegdeel dat uitsluitend is bestemd en gemarkeerd voor openbaar vervoer en afgescheiden is van de andere wegdelen niet uitsluitend door markering. (bron: BGT)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9b9cf38a24824f8b890c40e76168eb79" name="Overweg (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_566b2c4ee0f3454b87752cd47e01fd3d" body="Een gelijkvloerse kruising van een wegdeel en een wegdeel type ov-baan met spoor type trein of sneltram. (bron: BGT)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ab7d40dfadc34521a63f63da3abdb720" name="Parkeervlak (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aec198925ab74e528cf8edbd97dde08e" body="Wegdeel bestemd voor het parkeren van motorvoertuigen. (bron: IMGEO 1.0)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3778c8e855324095bdee019463f040fe" name="Rijbaan autosnelweg (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2dee37e17db74196adb1dd2b5cd46c85" body="Wegdeel dat onderdeel is van een weg uitsluitend bestemd voor snelverkeer en met gescheiden rijbanen en ongelijkvloerse kruisingen. (bron: BGT)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_92ee0776c96d458789ed5295991bb360" name="Rijbaan autoweg (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3c35ba20396c44cd88281f7040d249fa" body="Wegdeel dat onderdeel is van een weg uitsluitend bestemd voor snelverkeer. (bron: BGT)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2d31152cc8b44aec9f4bd25c0338198e" name="Rijbaan lokale weg (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c4df1f5d592e4302b928ceb3e81b241a" body="Wegdeel dat onderdeel is van een weg van lokaal belang. (bron: BGT)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1013a77811de4c2184c93dadceb7e131" name="Rijbaan regionale weg (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_71c1e029f621459a9d302535217f8be1" body="Wegdeel dat onderdeel is van een weg die een verbinding vormt tussen bewoonde oorden of tussen wijken binnen een dorp of stad waarbij er een, meestal fysieke, scheiding is tussen langzaam verkeer en snelverkeer. (bron: BGT+CROW)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_aa1f9a50332f4456928345cf53ddaeee" name="Ruiterpad (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_df39c0e0126e4542b2a9dcbb50cd79d0" body="Een wegdeel primair aangelegd voor het gebruik door ruiters. (bron: BGT)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9b31c023f1704d2fb5f84c1ac3c95b00" name="Speelondergrond (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9359534478944438916e5ef8680fb5f7" body="Een speelondergrond is de ondergrond waarop een speeltoestel staat of hiermee duurzaam verbonden is. Het kan een verharding zijn, een groenvoorziening of een waterpartij. Vaak is de speelondergrond valdempend, wat betekent dat het schokken van vallen verm"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_01bd9af1aadd464fac30d76bdfa385e8" name="Spoorbaan (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7e91cb1dd5474d0f8f6e93fe60ec3f36" body="Gebaand gedeelte voor het verkeer over rails. (bron: NEN 3610)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b34c1577820f49688d68490c15e8482b" name="Sportondergrond (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_272fd1dfb6124604a6e0d25ea25cd166" body="Een sportondergrond is de fysieke oppervlakte waarop een sport wordt beoefend. Het kan een grasmat, een atletiekbaan, een zaalvloer, of een andere specifieke ondergrond zijn die is ontworpen voor een bepaalde sport of activiteiten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a2d1587d5a8b45ffba61348cb8ee99fd" name="Verbindingsweg autosnelweg (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_44db6fb6376b4bdf953021b0f5b29afa" body="Een verbindingsweg bij een autosnelweg, is (in principe) een eenrichtingsweg, gelegen binnen een knooppunt of aansluiting, die onderdeel is van de wijze waarop de ongelijkvloersheid is gerealiseerd. (bron: wegenwiki.nl)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_51d5e6d7f4ae4d76b0e1c4f199f930ae" name="Verbindingsweg autoweg (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1629f5586b0248758f6ad6a058fc42f0" body="Een verbindingsweg bij een autoweg, is (in principe) een eenrichtingsweg, gelegen binnen een knooppunt of aansluiting, die onderdeel is van de wijze waarop de ongelijkvloersheid is gerealiseerd. (bron: wegenwiki.nl)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_23dcd1c0af22411ab3094d2463fd5d85" name="Verbindingsweg regionale weg (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2c5e8ad4c9e546f78ad63bde38f297fe" body="Een verbindingsweg bij een regionale weg, is (in principe) een eenrichtingsweg, gelegen binnen een knooppunt of aansluiting, die onderdeel is van de wijze waarop de ongelijkvloersheid is gerealiseerd. (bron: wegenwiki.nl)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cb5cde374a6f479d954e5b20ffa56897" name="Verkeersdrempel lokale weg (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bb907ab093074bbcbecda1c2fcd12b85" body="Verhoging in een lokale rijbaan, bedoeld om het gemotoriseerde verkeer met een lage snelheid te laten rijden. (bron: NEN 2660)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0d36c95327744eb783d343d335d09477" name="Verkeersdrempel regionale weg (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9755ebc58c50488dadd8ca043fe6fef1" body="Verhoging in een regionale rijbaan, bedoeld om het gemotoriseerde verkeer met een lage snelheid te laten rijden. (bron: NEN 2660)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_212bf46b5b824a7aa6d39cb8aec1dc8c" name="Verkeerseiland (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b47f511c3a7843b395f5741fffdfadff" body="Ondersteunend wegdeel van beperkte omvang, uitgevoerd als verhoging of wegmarkering, dat wordt omsloten door wegdelen en ten doel heeft verkeersstromen te scheiden. (bron: CROW)"/>
        </ownedLiteral>

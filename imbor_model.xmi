<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.1" xmlns:uml="http://schema.omg.org/spec/UML/2.1" xmlns:xmi="http://schema.omg.org/spec/XMI/2.1">
  <xmi:Documentation exporter="Lovable" exporterVersion="1.0"/>
  <uml:Model xmi:type="uml:Model" xmi:id="model_root" name="IMBOR Model">
    <packagedElement xmi:type="uml:Package" xmi:id="pkg_root" name="IMBOR">
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_526c3b842c2444078cdb61373093bc29" name="enum_AansluitvoorzieningTypeOverspanningsbeveiliging">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_56d19f7de3464d34aee7c5ed5c3eece7" name="DC-uitvoering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_32eea14bf4a443f5bbe15c81f6b8232e" body="Een overspanningsbeveiliging op basis van gelijkstroom, wat in het Engels aangeduid wordt met &apos;DC&apos;."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9f29b6dbd2ad4fcc86b5417fa6613322" name="Enkelvoudige overspannings- en lekstroomzekering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_15da518d57b54c05abef5bdaea49da7c" body="Een overspanningsbeveiliging op basis van een extra zekering tegen lekstroom, elektronische spanning die wordt doorgelaten door een materiaal, en een overspanningszekering, een bescherming tegen een spanning over apparaat hoger dan de toegestane nominale "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ee5183a69ead4b8eb03c451c7db8575b" name="Enkelvoudige overspanningszekering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_725f7a5f1ab94a05b8bddd5549f6c93a" body="Een overspanningsbeveiliging op basis van een overspanningszekering, een bescherming tegen een elektronische spanning over apparaat hoger dan de toegestane nominale spanning."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_17b753f4893b41a9b23f576101bd2975" name="Meervoudige overspannings- en lekstroomzekering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_210a0de38a9948d781ce76636117e51a" body="Een overspanningsbeveiliging op basis van meerdere extra zekeringen tegen lekstroom (elektronische spanning die wordt doorgelaten door een materiaal) en overspanningszekeringen (bescherming tegen een spanning over apparaat hoger dan de toegestane nominale"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_392df0b1f1174d47a3b8bab7b1688948" name="Meervoudige overspanningszekering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fdb52640212c46d0bb463de0fed2d2f9" body="Een overspanningsbeveiliging op basis van meerdere overspanningszekeringen, die beschermen tegen een elektronische spanning over apparaat hoger dan de toegestane nominale spanning."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5fe248ece7b24679b15a900f2e082f7e" name="Modulair voor sturing en elektronica">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_030aeb635d3c4092b23af68c7b14e4ed" body="Een overspanningsbeveiliging die opgedeeld is in verschillende onderdelen (modules): een aparte module ten behoeve van de aansturing van het te beveiligen apparaat en een aparte module ten behoeve van elektronica van het apparaat."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_2e15ead5e0754311a5ce4602c62cc5cf" name="enum_AansluitvoorzieningVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5db0d48dcd664815bf266e59b303e53e" name="Aansluitvoorziening in mast">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4376a82680d94557a9b1268854e70218" body="Een aan een mast bevestigd kast(je) voor de aansluiting van de grondkabel om objecten in de openbare ruimte van stroom te voorzien."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_89dd08a3dc114ccfb0961cbfe083b455" name="Aansluitvoorziening op muur">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d052c870ed2b4008bb8883d614474f13" body="Een aan een muur bevestigd kast(je) voor de aansluiting van de grondkabel om objecten in de openbare ruimte van stroom te voorzien."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_1209b9435c0a40f5b858bd8f15176e7c" name="enum_AbriVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c8551880eab04c52ad2cf5e906e56d19" name="Abri-met detectie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_80bb6ffea6f441bb85d57bb67b1aba41" body="Een abri met ingebouwde, dan wel aangebouwde detectoren die actief kunnen worden in verschillende scenario&apos;s, bijvoorbeeld als er glasbreuk wordt gedetecteerd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_47f4ed419ae9463492c0f527b13cbd60" name="Abri-met informatievoorziening">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f960dc8075b942ca9dcd05bcc1e784bb" body="Een abri met ingebouwd, dan wel aangebouwd scherm, bord, of paneel waarmee de reiziger geïnformeerd wordt over reistijden, routes, reclame of andere zaken."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_dac1d9283071443c9c3ce9283e359c89" name="enum_ActieveWegmarkeringVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_51ceb1dc26194d3a9c380d871809b32e" name="Actieve wegmarkering - bedraad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b0621f92755c47ec9ba6d81e7c7ac7f9" body="In of op het wegdek aangebrachte lichtelementen die met draden aangesloten zijn op een elektriciteitsvoeding of een andere installatie en die voor de weggebruiker bij duisternis het verloop van de weg zichtbaar maken, ook buiten het bereik van koplampen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a6874ee60a524caca14d7d654bbda70f" name="Actieve wegmarkering - onbedraad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_66090df7da584161b209f98a378d4696" body="In of op het wegdek aangebrachte lichtelementen die niet met draden aangesloten zijn op een elektriciteitsvoeding of een andere installatie en die voor de weggebruiker bij duisternis het verloop van de weg zichtbaar maken, ook buiten het bereik van koplam"/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_1d3d19cc38dc4318a90762cf1ed3779e" name="enum_AfsluiterVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_24b5abfac82744d1826a75df80586c84" name="Afsluiter beregeningsleiding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7107684a239e4dcf93352db0f55ca764" body="Een mechaniek om de doorstroming van een beregeningsleiding te regelen, door het openen of sluiten van een of meer doorstroomopeningen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_92582c1221d44999a1e3743fc59feee0" name="Afsluiter gasleiding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_49fc8b9bdf91451f92233ff7de9a06cf" body="Een mechaniek om de doorstroming van een gasleiding te regelen, door het openen of sluiten van een of meer doorstroomopeningen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ae89e99dac8f4ed78d0e2d45b6fb58ce" name="Afsluiter rioolleiding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_189f8ee5466c466085ed416321d5c0ab" body="Een mechaniek om de doorstroming van een rioolleiding te regelen, door het openen of sluiten van een of meer doorstroomopeningen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b5e32c0bb7974fb0ae7de59748f0cd1b" name="Afsluiter waterleiding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_10bb655118484b23952d0174e82a1770" body="Een mechaniek om de doorstroming van een waterleiding te regelen, door het openen of sluiten van een of meer doorstroomopeningen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_a2bda0bc16f2498ab4f680353077d663" name="enum_AfsluitpaalVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6bf78c3aa8a34db590dad51340337b7b" name="Anti-aanrijpaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_46d960ca700545ac83ce827629c43ce9" body="Voorziening in de vorm van een paal die een kunstwerk of wegmeubilair moet beschermen tegen beschadiging door aanrijdingen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_656fb870cc2e4264beecad8d36e922bf" name="Anti-ramkraakpaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_00b02019d8d44586b21ab15422308cc5" body="Voorziening die een gebouw of ander object moet beschermen tegen ramkraken door aanrijdingen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_44027a76a68e468d98339607ddae086a" name="Inklapbare paal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0e96685afcac422fade43c4a6de37cf8" body="Langwerpig voorwerp van bijvoorbeeld hout, ijzer, steen dat in de grond staat en inklapbaar is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7c418313f4ee4975a601baa85d86d712" name="Vaste trottoirpaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9d1439da30674c37ab432001d9ed8252" body="Een permanent aangebrachte afsluitpaal op een stoep die dient om fout parkeren op de stoep tegen te gaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cf02f8c1d8c4444d91d2f22768f69fcc" name="Verwijderbare afsluitpaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9581e45deb0e44f999dbe446551ec6f1" body="Verwijderbare paal in de grond om de weg of een gedeelte hiervan af te sluiten."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_647d84efc6814c6a86b7fe259ac6117d" name="enum_AfvalbakTypeAfval">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0d3ac60a9c5540efa3e330184d46657b" name="Bedrijfsafval">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_83ad104609524090bb579bcf538bf36c" body="Diverse soorten bedrijfsspecifiek afval, dat dikwijls afzonderlijk opgehaald en apart verwerkt moet worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_60f9d8cc64eb4d29ac174843f00aa445" name="GFT-afval">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f1d2a40f591041fb80c6cf30975bebde" body="Etensresten zoals overblijfselen van groente en fruit en tuinafval, zoals kleine takken, gras en onkruid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d16944c74c544f98a950be204d5b858c" name="Glasafval">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e2638172a25b401aad4f6e73408f60cf" body="Glasresten en consumptieverpakkingen van huishoudelijke oorsprong."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0c7fa68e9e6140caa643cf2fe28b7571" name="Luiers en incontinentiemateriaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d8e205795778428c8eca8518e232fdea" body="Afval in de vorm van incontinentieafval van kinderen die gescheiden ingezameld worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b05e581b48744c4f828b5c7ac8d7d20e" name="Papier">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f38d6f35ad004b9eb27913fe19c87ed9" body="Afval bestaande uit papier of karton, materialen die gebruikt worden voor o.a. schrijfwaar en verpakkingsmateriaal."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1de9de3817e240cd852c1f65e99cbe8b" name="PMD">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7b9c4495ddfe4fb298d5d1e28ad072cb" body="Het afval van plastic flessen en flacons, metalen verpakkingen en drankkartons of plastic verpakkingen, metalen verpakkingen en drinkpakken"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9f9a5b54538943d2a3227e01920dc13f" name="Restafval">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7c0fbdaac0b948c5bec587e66577635b" body="Alle niet-recyclebare resten van huishoudelijk afval."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_06fd67185cae4d0ca9d41fbb673c2f69" name="Textielafval">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7a8c9fc7a1e2490696d51ba98522333d" body="Als afval opgegeven kledingstukken en schoeisel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_51c5d04d79dd48a4a7ff48562e855beb" name="Zwerfafval">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a4f9bc5ffe9a4f55bc7de85b04d50d22" body="Afval dat onachtzaam op willekeurige plekken in de openbare ruimte is gedeponeerd of zou worden zonder het bestaan van deze afvalbakken of containers."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_f68ec8c3a12d4a96ac824ab87fa886a4" name="enum_AfvalbakVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_798247f7a3804d73ae584534771c3943" name="Adoptiebak">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2878cfb6e59e4632b3ae2fb04bef698f" body="Een afvalbak die geleegd wordt door vrijwilligers als burgerinitiatief om de lokale omgeving schoon te houden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5d48b560d6554861881f93fd08a7f917" name="Afvalbak met bovenkap">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e6929dc39da3469a990c67ccc9f75de2" body="Inzamelobject voor afval in de openbare ruimte dat handmatig kan worden leeggemaakt, voorzien van overkapping aan de bovenzijde van de bak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1a419995b39d49d498be322cff29f0ae" name="Afvalbak met omhulsel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d3c0fadad68e4fa19079986f6d62a757" body="Inzamelobject voor afval in de openbare ruimte dat handmatig kan worden leeggemaakt met een ombouw om de daadwerkelijke bak heen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_273caa2a21fd4aef836e914064b5c504" name="Afvalbak met omlijsting">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2188f0d48c474ce0b59751efadcf4179" body="Inzamelobject voor afval in de openbare ruimte dat handmatig kan worden leeggemaakt, omlijst door een bepaalde constructie, zoals een buis."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7da4efe92cef4d51a4ddbf4e505b8468" name="Driedelige bak">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_482f6d5750654ef0bb7f0a3bb7e38e7e" body="Afvalbak die uit drie delen bestaat om meerdere typen afval te kunnen inzamelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_615a9371c6f841569c6dc5044a411a9e" name="Dubbele bak">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6370b403ecbe47bd9380666f7bf3edd7" body="Constructie bestaande uit twee bakken voor afval, al dan niet ten behoeve van het scheiden van verschillende afvalsoorten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ae41604a9f234207bee7fa58d38cb8a5" name="Enkele bak">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4f02e7b007fc4a63b4649fdb6a5aa0ac" body="Een afvalbak met één inwerpcomponent."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2a545e5e66674ccbbf1c588d01398f8f" name="Hondenpoepbak">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7f917757c03749548d7648c53167018b" body="Bak die hondenbezitters de gelegenheid biedt om hondenpoep op een nette manier op te ruimen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ad20b86a699f4672bae51c1a85c4556c" name="Minicontainer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_00945d10286e4d61b78f88ea08ce78e2" body="Boven- of ondergrondse bak van kleine afmetingen voor de inzameling van afvalstoffen die duurzaam met de aarde verbonden is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fb82a881b91f4e63bbb61f62b903ef1c" name="Persbak">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7a7af1a1c915469382733def4be7e8e8" body="Een afvalbak met een voorziening die het ingeworpen afval samendrukt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_012dde71eb534506afa5f9b84d255966" name="Uitneembare afvalbak">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_98fedf9d1c1e4f0a9689f037e769423b" body="Inzamelobject voor afval in de openbare ruimte dat handmatig kan worden leeggemaakt en een inwendige bak heeft die verwijderd kan worden uit de behuizing."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_e0f5b6b3cba74b9bb581109866bc5426" name="enum_AgrarischGraslandVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_33b23b389dde4fd6a80a10d753918a8e" name="Weide">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9751672dea71442c855a64ff576fd6ac" body="Stuk opengrasland dat gebruikt wordt om vee te laten grazen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_009bd09071ee46619c340781763bb64a" name="Weidevogelgrasland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_895a10e04eea4320ac4fa86d5d1911f2" body="Nat en vochtig grasland met primair een weidevogeldoelstelling."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_d0f9c3b3f6074ebbae71008ebf99f0a5" name="enum_AkoestischeSignaalgeverVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9ad8d4bf4f514ff188941640cacb8c87" name="Buspieper">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d0cec19948c34720afb567b9c343bd33" body="Een akoestische signaalgever die een piepend signaal afgeeft aan nabije verkeersdeelnemers vanwege een naderende openbaar vervoer bus."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_146383b5ae8c4b1cb317c568f07c6853" name="Elektronische blindentikkers">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_33aac77ae8484bbc9285f5fade7a959d" body="Akoestische signaalgevers die de toestand van een verkeersregelinstallatie of een verkeerslantaarn communiceren met blinden of slechtzienden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6ac7ef39e73a41a58712a6b439b34058" name="Mechanische blindentikkers">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7223770fe57d4805af60a5705792583b" body="Een akoestische signaalgever die blinden en slechtzienden informeert over de toestand van een oversteekplaats door een metaalachtig, tinkend geluid in lange of korte intervallen te laten klinken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0bddd07c2b6a4908bbdbe27e0a1dd465" name="Trambel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_adcbc6c6f87345a4818ffce02b4b4f5e" body="Een akoestische signaalgever om voetgangers en fietsers te waarschuwen voor naderende trams."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_56831b33d9764cc2aa85555aeb369882" name="enum_ApparaatFysiekeAansluiting">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_849864cd04c84bf2b3e2947b6d618546" name="CEE-form">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0eee369cdc234928bd508ca1d731b503" body="Een CEE stekker is een gestandaardiseerde elektrische connector die gebruikt wordt voor zware toepassingen. Deze stekkers zijn specifiek ontworpen om te voldoen aan de eisen van industriële en commerciële omgevingen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a85468cc67b54f6eb05a73c08e146100" name="Custom">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8ef5d9cd67704ec6bfd64823aeeb356a" body="De fysieke aansluiting van het apparaat is maatwerk dat niet volgens een aansluitingsstandaard is ingericht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3944a40342b3400f831bcd51738c6fe7" name="F-connector">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_932e6750723f4c7982b35e68a9adc45b" body="Een aansluitingscomponent voor een coaxkabel op een antenne, een versterker, een modem of een ander object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a97c8cc7b95b4a7495e022bdc41b2110" name="Intern">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5e90a637f00e405c8454d86db4d9da6e" body="De fysieke aansluiting is een inwendig onderdeel van het object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6379591d8132419ab0d26a6b2a79d883" name="N-connector">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8c20e943bd7b4abfac050baa109a95db" body="Een weerbestendig aansluitingsstuk met schroefdraad om coaxkabels te bevestigen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d953c138c2f74de99517e73397d1e5dd" name="NEMA">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7f66d950c95949fda2b09442b02b6249" body="Aangesloten door middel van een walstroomstekker."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_89d1b4a4db794c239f6954e4b0d45c83" name="Schuko">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4aad9dfa2fe94d4ab6f502eab596f416" body="Schuko is een type stekker en stopcontact dat veel wordt gebruikt in Europa, met name in Nederland en Duitsland. Het is een afkorting van het Duitse woord &quot;Schutz-Kontakt&quot;, wat &quot;beschermingscontact&quot; betekent, verwijzend naar de aardingspennen. Schuko-stop"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ba123997261947d3af1ca1bf5eede46c" name="SMA">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_103c807805c542ecabb18c6922fb9903" body="Een aansluiting in de vorm vaan coaxkabel met twee gelijkvormige stekkers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_173d7f34469348c0b820ff4684bd99cc" name="u-FL">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_08fe26ec31c440de8f40d70d1c857056" body="Een zeer kleine F-connector voor signalen met een hoge frequentie van tot wel 6 GHz."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ef803d80f339489ab526615539ca18f5" name="Vaste aansluiting">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4761803a32854c5d8990cc01f4d0eaf0" name="Zhaga">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_143275ab44184ff0a3e5498a46cc9a19" body="De connector is gefabriceerd door de gelijknamige fabrikant."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_61704e7c32064590821e0754de88a18d" name="enum_APV-BordVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_76a404f4d1874a14afad8ae2c8cf2aab" name="Aanlijnplicht">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ffce2f3a5f1247fd908b61025b488ed5" body="Een bord dat een algemene plaatselijke verordening aangeeft met betrekking tot het verplicht aanlijnen van honden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b479b7d48f0644168a8584adb9f016c4" name="Aanlijnplicht en opruimplicht">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e1718302543d4359accc915fb8779d42" body="Een bord dat een algemene plaatselijke verordening aangeeft met betrekking tot het verplicht aanlijnen van honden en het verplicht opruimen van hondenuitwerpselen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f47a13eb8d894062a68eeeb4404c6f6f" name="Afvalbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a5a05e243b2c46b58b1b8942fab38ce4" body="Een bord dat een algemene plaatselijke verordening aangeeft met betrekking tot afval in de openbare ruimte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5a49cb156bd34af78f1ec8498d3ae8f4" name="Alcoholverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3c9cb83e3cd640e9b61effaa5f9d5acb" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot het nuttigen van alcoholhoudende dranken in de openbare ruimte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8ba0f21767704189bb704691205ebcf8" name="APV-zone">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ba35c3b74f4f4d75b6abdbdab95915b3" body="Bord dat het begin van een zone aanduidt waar een algemene plaatselijke verordening geldt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2ab4bcbe267049fea9d3f45b27a64f50" name="Barbecueverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2b01c3b31edf4dc1b9fe2b43786f3723" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot het gebruiken van barbecues en andere met vuur roosterende voorzieningen in de openbare ruimte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e2e94bd7e44c4b4c9d15491741aa9338" name="Bedrijventerrein">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c8ab2905eb4d4d889bfcdd02a7877a7e" body="Een gebied waarop gebouwen ten behoeve van ondernemingen, zoals bedrijfslocaties en -loodsen gevestigd zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_97c2085f70964531b9ecfc3817c84dc7" name="Blowverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5378ee5dd57d402590e50e073ad6460f" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot het gebruiken van joints en andere wiethoudende producten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9abff45c4031448bb6925f422c72ec05" name="Buurtregel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a510045c39c144da81bcf8a9dc2ca721" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot afspraken en voorschriften die gelden in de openbare ruimte van een buurt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e54a70cd11ca45098e128f5894ec613b" name="Containeropstelplaatsbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0a5580f71e82416eb398708edcfc10ae" body="Bord met op de locatie die is aangewezen als plaats waar (huisvuil)containers neergezet mogen worden om geleegd te worden door een vuilophaaldienst."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_de0a72a1a10a41468e701a44add09964" name="Genotsmiddelenverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4970956dfdee4d0f8f254421ee243a44" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot het nuttigen van bedwelmende middelen, zoals alcohol of andere drugs."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3fdd0f4954124e7f9b8c76d63e04a95e" name="Hangverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e805dc0942054204aba5633d695a93b6" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot het voor langere tijd samenkomen van jongeren op een bepaalde locatie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3b39a81339fb4c1ebd44d6b28d96d567" name="Hondentoiletbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_69f1251628c74d158123634a3d5213c2" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot het wel of niet toestaan van poepende honden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a13b74c97a1e46f59495e63fe0846f1a" name="Hondenverbodsbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_21de3877785a42d682554fdca0ea3687" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot de aanwezigheid van honden in de openbare ruimte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_391844727b324f15ba88b31dce557bac" name="Losloopgebied">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e11bc74f407d49c7a7b284b9869f97fe" body="Omgeving waar honden niet verplicht aangelijnd moeten blijven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_84ad78031c5c47d787f9069bd0ab1612" name="Loslooproutebord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_68f866ca828e4060bd846b2865ba3c7e" body="	Bord om aan te geven dat hondenbezitters een route kunnen volgen waarin honden los mogen lopen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_31408240088d42318fc0aeebea74acd9" name="Muziekverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_099f66ad196246d696a933259cdcd806" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot het afspelen van (luide) muziek in de openbare ruimte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_827bf139a3474c509afa744151e58e55" name="Natuurbeschermingsverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_85be9b1280f4431c8d45707734197c1e" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot het behoud van groenvoorzieningen en andere objecten die tot de natuur gerekend worden in de openbare ruimte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cf37574178cb4d718252ca1b278a6bb1" name="Opruimplicht">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_35ae0b515b6a40cc9c201df4634d7d5d" body="Een bord dat een algemene plaatselijke verordening aanduidt met betrekking tot het verplicht opruimen van hondenuitwerpselen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_44834d01a06a46ddaf3abd8d23e663c2" name="Overnachtingsverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0a9e623507c84d2f8d9453eea0112eec" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot het doorbrengen van de nacht en het slapen, in welke vorm dan ook, in de openbare ruimte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_76567e07175445b69d3b127c8538dbbd" name="Plak- en kladverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6963b952c719478db94a0f315f5664c3" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot het aanbrengen van affiches, posters, verf, graffiti en andere bekledingen op objecten in de openbare ruimte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b43aa7f32d3c4691bcd9fe030d85eb96" name="Rijwielplaatsingsverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_db57cee77473475eadc95e451440e5c9" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot het plaatsen van fietsen, personenauto&apos;s, brommers etc. in de openbare ruimte buiten de daarvoor bestemde vakken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bf56d48dc8094d34b509751440eb09bf" name="Samenscholingsverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4c5c1ad5f6c0436a9508385e787bc908" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot een beperking van het aantal mensen dat in de openbare ruimte mag samenkomen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2811a853552f4013bb1029b7f7621c91" name="Scheepvaartverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_02cc63051d5f4dfe9275c2a14bd58351" body="Een bord dat aangeeft dat er volgens een algemeen plaatselijke verordening geen watervoertuigen over het aangeduide water mogen voortbewegen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a023a56a4c27444aad48f1a1e4b7dd3a" name="Tijdelijke APV">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_212a03eab93a48c28af228216154ed97" body="Een bord dat een tijdelijk ingestelde, algemene plaatselijke verordening weergeeft."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3eb6d709d9a7457799447ccd1361e5bb" name="Tippelzone">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c2931c7bd85b435286fea29872734788" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot de tijden waarop tippelen is toegestaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_41beb423ce5841debbb8bcc86fe37e84" name="Toegangsverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_da0803e6953a4735bed68c6f623f8e85" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot de aanwezigheid van mensen in een bepaalde deel van de openbare ruimte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_73e805fa8637486abac931465eb36648" name="Verboden voor hondenbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_433b9d2e34cd44048a32a050eaaa825d" body="Bord om aan te geven waar de aanwezigheid van honden verboden is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c4142b5080f443b286a8230496e0cf22" name="Verkoopverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_867688ea575242849b8d9a088b3b6651" body="Bord dat een algemene plaatselijke verordening kenbaar maakt met betrekking tot het verhandelen van goederen in de openbare ruimte."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_85ca81f9b63c4836870960db5dfc86df" name="enum_AquaductVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_598645d3e0464af1b5861754fd84a35e" name="Water over water">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1c22e796b53f4c36b60ac7416c24d071" body="Kunstwerk waarmee een watergang door een bakvormige constructie over een andere watergang wordt geleid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ac56b39520704d11b8f8fae821a10275" name="Water over weg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_128841808abd48539300eab5b06dff84" body="Kunstwerk waarmee een watergang door een bakvormige constructie over een weg wordt geleid."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_adce703015e343439ae7a6f760b69175" name="enum_ArmatuurIK-waarde">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3b74e2881892453a841340a998e8f5bb" name="IK00">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3a49d8d718274b5b9869cb63e358ac76" body="Geen weerstand."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_052f1647d17842ebad3ad6ff6a44b2b1" name="IK01">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8b7f2e5b509f427ea805b9865f1af5ec" body="Weerstand tegen schokken tot 0,15J."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6b2abe900ea8411e82d3e7dadd7f71d2" name="IK02">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_653c800178a448e980b022e4f910039f" body="Weerstand tegen schokken tot 0,2J (open armatuur)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7e3cbfba814345908c5ffd37f2645e85" name="IK03">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ac53450153f7466781b682b77017d07d" body="Weerstand tegen schokken tot 0,35J (armatuur met Acrylaat afscherming)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_eade218818b042f68bb02939d5ddc7f1" name="IK04">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e65db2d5a77146d2bdd3ea9b9caaefe8" body="Weerstand tegen schokken tot 0,5J."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_be0a2b0eac00470ba3c7c8dd7e96ef71" name="IK05">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c341d26b50644187932cd8d75dc133b4" body="Weerstand tegen schokken tot 0,7J (open armatuur met versterkte optiek, bijvoorbeeld een raster)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8e7824a5f3e64b1bb50c0cfb93d857df" name="IK06">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d38b166fef604b099745b796d108fc36" body="Weerstand tegen schokken tot 1J."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_73180f2f081843fca1bc0fb30b320f6a" name="IK07">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cdcd4cbdf1b04b89b6d52b9445c15814" body="Weerstand tegen schokken tot 2J."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_275c93152d704d88825b05cf04808e1a" name="IK08">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4223df92a86840dc848c1b9a176c209f" body="Weerstand tegen schokken tot 5J (armatuur met polycarbonaat of gehard glas afscherming)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_02d3c3a76c314b36ad17b33084ef631d" name="IK09">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_60b5855d312247bd840d5245fd99310d" body="Weerstand tegen schokken tot 10J."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5c64bfc9cb03416ea8c3d991887be163" name="IK10">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ee284daea83846a49063c549eb6e30ed" body="Weerstand tegen schokken tot 20J (versterkt armatuur dat als vandaalbestendig wordt geïnterpreteerd)."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_1beed26070cc4ea6bc3b395e5f2b144f" name="enum_ArmatuurInOfOpbouw">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bc2c335ccde34c43a12d45b891a2bd17" name="Inbouw">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f9052601c5d04bacbecf7007a07c33ff" name="Opbouw">
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c95313301df848e4817fbeed27e8121c" name="enum_ArmatuurIP-waarde">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_47af1f289dc24f2bb2ed564c9118535e" name="IP20">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cd06dfe990cd4abfbcfb61fcdf85a283" body="Bescherming tegen objecten &gt; 12mm en geen bescherming tegen water."/>

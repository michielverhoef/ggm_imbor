        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="attr_cfb758998730413e91b70ff34c9c6bc4" name="WIBON-thema" type="enum_33b0989d5f4443c5ae5608fc149d8db0">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8902ccbed061421293ff76e447d0d2ab" body="Het thema geeft aan welk type leiding het betreft en welke functie de leidingen hebben. Bijvoorbeeld: datatransport, gas lage druk, laagspanning, riool etc. Opmerking: signaleringskabels die data vervoeren vallen onder datatransport."/>
        </ownedAttribute>
      </packagedElement>

          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_99ade72783ea4615ba177bd0b716efa7" body="Matrixbord maximum snelheid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a9babdf9dbf44018bff0980ac4d38c9f" name="ES02">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8beb3395eb544a20a72960670366d493" body="Matrixbord file."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_981d9a1c3aec423ba04a138f137b4d51" name="ES03">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_660bd1718c55459eb359bb6294cc0ba0" body="Matrixbord einde van alle op een elektronisch signaleringsbord aangegeven verboden en adviezen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a01494f068b54d8aa24ea2651393a3b3" name="ES04">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_58add9f23f6c46519190eb70afd2aa8a" body="Matrixbord naar rechts."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_248dce5bdcdb4393831a267ffe9d331d" name="ES05">

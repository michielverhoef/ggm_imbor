      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_f2377074045041759c89aec99c79b256" name="enum_MechanischeAfsluiterStandaardAfsluiterstand">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4f4e283ca2cd4f7fa851d055a742b378" name="Dicht">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4b361a1455904af6ad46e8127d9987f5" body="De actuele stand van de afsluiter is gesloten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a4eb09e943624327b9c8026d08063cfe" name="Open">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_89e7eeb5133d45f98d66e14cd4bae3ea" body="De actuele stand van de afsluiter is niet gesloten."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_0eb9f1007a76404e9d72f7724b028b02" name="enum_ModaliteitInformatieModaliteit">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ec9606a13ea8492b80193daa1a3cb626" name="Autobus">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9f2a5dcce93b45a494f84b990a9c1dca" body="Motorvoertuig, ingericht voor het vervoer van meer dan acht personen, de bestuurder daaronder niet begrepen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0f7e7b703aa9494eb1f7ac034745de77" name="Bromfietser">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_60b8a0180e4c4937a98ebd594c303ab2" body="Een tweewielig motorvoertuig dat is ontstaan als gemotoriseerde fiets en geleidelijk is ontwikkeld tot tussenvorm van de fiets en de motor."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9f4ba41ef933467e97095c3a70fa832c" name="Bus">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cd3ccd04d80d4f54b2d878aedcd29159" body="Voertuig ingericht voor het vervoer van personen, met meer dan acht zitplaatsen, de bestuurderszitplaats niet meegerekend, niet zijnde een motorrijtuig met beperkte snelheid of gehandicaptenvoertuig."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_49c71d020970493cadddb6de551a8192" name="Exceptioneel transport">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_61ad1836bbc94d99a171c7aa63853c8f" body="Vervoer van goederen dat qua afmetingen (lengte, breedte, hoogte) en/of massa de regelgeving voor het wegvervoer niet naleeft. Indien zulk transport wil plaatsvinden, dient een vergunning of ontheffing aangevraagd te worden bij de overheid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3add8c1dc13345308a2d567c930179a5" name="Fiets">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_23b8cd26d4854c989f8e82fe2a024b2f" body="Doorgaans een door spierkracht aangedreven, tweewielig voertuig met een zadel, een stuur en een trapas die een van de wielen aandrijft."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1f5fcfb090994489a9b6d8e9007554de" name="Gehandicaptenvoertuig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7b55c81f40144334b7ec4ab2f3c64649" body="Voertuig dat is ingericht voor het vervoer van een gehandicapte, niet breder is dan 1,10 meter en niet is uitgerust met een motor, dan wel is uitgerust met een motor waarvan de door de constructie bepaalde maximumsnelheid niet meer dan 45 km/h bedraagt, ("/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_32cae991193b4198ad8c136370d705ec" name="Hulpverleningsvoertuig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_28ed0e724286448cb1b8975fface74ab" body="Voertuig behorende tot een hulpdienst, zoals de politie, de brandweer of ambulances van veilgheidsregio&apos;s."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2dfe8b019fab42e3ba34f5b5691ab0b5" name="Landbouw- of bosbouwtrekker">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0b5a082535144a2f905b3d5c53d953f3" body="Motorvoertuig, niet ingericht voor het vervoer van personen, waarvan de toegestane maximum massa meer bedraagt dan 3500 kg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7b7826a992e749d9a1e43c8001d87255" name="Langere en Zwaardere Vrachtautocombinatie (LZV)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_51b52e2258e4428493b028d6f34e8df1" body="Vrachtwagen die meer vracht kan en mag vervoeren dan een gewone vrachtautocombinatie. Een LZV is maximaal 25,25 meter lang en 60 ton zwaar."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9d3e54e5c3f141c3819dadbd08349399" name="Licht motorvoertuig (lv)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e1000e82ccd9461b824750f9d5b8cf6a" body="Motorvoertuigen op drie of meer wielen, met uitzondering van de in categorie mv en categorie zv bedoelde motorvoertuigen, noodzakelijk voor berekening geluid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6f07587a60aa4b16b928e41aa32e74c9" name="Licht wegverkeer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a5300e8413d246d6a833d60c9066ee00" body="Personenauto’s, bestelauto’s en motoren, noodzakelijk voor berekening luchtkwaliteit."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8a8464ac254b49fe9a8ab57edc23932e" name="Lightrail">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_76b497a716a54e40a56a74896fed040e" body="Spoorvervoersysteem dat hogere snelheden kan bereiken dan een tram, maar minder vervoerscapaciteit heeft dan een metro."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e09b0d8c322c40d79268b6123191c665" name="Metro">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_caff895e16e040baa3419886c0a706b3" body="Systeem van hoogwaardig, collectief openbaar railvervoer dat beschikt over een geheel eigen baan, waarvan grote delen zich ondergronds en/of op viaducten bevinden en dat een uitgestrekt stedelijk gebied bedient."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_75412612458f4c989598ffe29e10ff41" name="Middelzwaar motorvoertuig (mv)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d1c3bfc89ab442829384b93c761effbd" body="Gelede en ongelede autobussen, alsmede andere motorvoertuigen die ongeleed zijn en voorzien van een enkele achteras waarop vier banden zijn gemonteerd, noodzakelijk voor berekening geluid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6eb9e37153254e2f9487cca44823c584" name="Middelzwaar wegverkeer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_43b9b5512b764966b2b44d2a44b12c71" body="Vrachtauto’s &lt; 20 ton GVW nb. Bussen maken geen deel uit van deze categorie, noodzakelijk voor berekening luchtkwaliteit."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_217b0981458142d0952fd4433600b4ad" name="Motorfiets">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_257bf4b9f0464217b3e2879204e2a678" body="Motorvoertuig op twee wielen al dan niet met zijspan- of aanhangwagen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a229ac96df5644b3b93788b683395812" name="Personenauto">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f06257705d824358ab7ce28849ecccea" body="Voertuig op vier of meer wielen, niet zijnde een motorrijtuig met beperkte snelheid of gehandicaptenvoertuig, ingericht voor het vervoer van personen, met niet meer dan acht zitplaatsen, de bestuurderszitplaats niet meegerekend. In ieder geval wordt een d"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3bf93bca4b514015b0ce4c27bd4f97f7" name="Tram">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aca201e9edd34b9ebf44c0a166d4434a" body="Een voertuig dat gebruikmaakt van rails die veelal binnen de openbare weg liggen, waardoor een het deelneemt aan het openbare verkeer."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_50bfe5acaac24d478e0218ee74bec37b" name="Trein">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1210bd8549ef4da4ae4266df01ee55f7" body="Een combinatie van voertuigen die wordt voortbewogen over een netwerk van rails: het spoorwegennet."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_378217e13f98447db7902f655d768b26" name="Voetganger">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d09afb6224ef407cbaf4094dc9f2e0a7" body="Een persoon die te voet aan het verkeer deelneemt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c279cf3dd6c148db95ce90990891589f" name="Vrachtauto">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_915e7fafc8be40f782a4598e4d7e3554" body="Motorvoertuig, niet ingericht voor het vervoer van personen, waarvan de toegestane maximum massa meer bedraagt dan 3500 kg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_435734fe488c468786c0e3c793daab08" name="Zwaar motorvoertuig (zv)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_59511795bcd54d7084b376fc7010f521" body="Gelede motorvoertuigen, alsmede motorvoertuigen die zijn voorzien van een dubbele achteras, met uitzondering van autobussen, noodzakelijk voor berekening geluid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_09025bf0a4414c308e13f44659394bca" name="Zwaar wegverkeer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b8eaae3194314313afa178b9274bf462" body="Vrachtauto’s &gt; 20 ton GVW en trekkers, noodzakelijk voor berekening luchtkwaliteit."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_762b2854662042f7a3bda0f31a65cb97" name="enum_MoerasVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_47657cee0dac46068301c9f72f24f589" name="Grote zeggenvegetatie">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_59d4778649fe4c84917ac6da68f72d24" name="Natte ruigte">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_51e096639f82467e96111332d73b75fd" name="Riet- en biezenverlandingsvegetatie">
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_4f5e1808770a4df6a31e3c87a017896f" name="enum_Monument-InformatieTypeMonument">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2c71713234ae4f99b3e2a77f4773bc20" name="Beschermd stadsgezicht">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ece1ce3c06084100bbd873696e44da47" body="Een samenhangende groep van objecten en gebouwen in een stad die van overheidswege beschermd wordt door de Nederlandse Monumentenwet."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d64b47f4625745b29b7ac847e0481503" name="Geen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_29fe487708094051980cee1a1d80f609" body="De waarden uit de suggestielijst of vaste lijst van het attribuut zijn niet van toepassing bij dit specifieke object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_edb0b15cd3a54226a1c21573dfeb361a" name="Gemeentelijk monument">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_450c7a6f60e349c5ba3a657aeed7747e" body="Een bouwwerk, archeologische vindplaats of landschappelijke structuur die op grond van een gemeentelijke monumentenverordening bescherming geniet vanwege bijzondere cultuurhistorische of architectonische waarde."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_44d924bebd6a47748f79b6151c7e691c" name="Rijksmonument">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_af2066c5c7eb4629bc0fa18e6b807115" body="Een zaak die van algemeen belang is wegens de schoonheid, de betekenis voor de wetenschap of de cultuurhistorische waarde. (Beschermd vanwege de Erfgoedwet.)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6439c9b0441e4a30a7f34211a2cbc869" name="Werelderfgoed">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_88963e5821764201ba71b71bd2b67530" body="Cultureel en natuurlijk erfgoed dat wordt beschouwd als onvervangbaar, uniek en eigendom van de hele wereld, en waarvan het van groot belang wordt geacht om te behouden."/>
        </ownedLiteral>

          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a6a1b7e9eec74ba780c9e4d0ff36a0bb" body="Klimtoestel in de vorm van een kubus, vaak met klimrekken en -variaties als zijden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f13cccd874cf42e89d6d3ed33d07ff61" name="Klimlabyrint">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3f0df5848c4646528dd4500ae4808be5" body="Een klimtoestel bestaande uit meerdere, creatief verbonden en uit elkaar geplaatste palen, bedoeld om de gebruiker uit te dagen via welke weg het toestel te beklimmen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a417a5b988be4411bf7da69b76df79ba" name="Klimpaal">

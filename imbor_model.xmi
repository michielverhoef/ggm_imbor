      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_26cea0671d554201a0f11c0d8b3c63aa" name="enum_LichtbronOptieksoort">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_48c7ccab86594fbaba72cb1bc25922ac" name="Lens">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1c8c3ff90dd94dbfb0fdf623e4678f3b" body="Het binnen het object geproduceerde licht wordt middels glas met een gebogen oppervlak uit het object gezonden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2087083f50554989a015b770fca236be" name="Spiegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bed45bee8ec848dbbc049b841a03f8d2" body="De wijze waarop het licht uit de lichtbron wordt verspreid is via een oppervlak dat licht weerkaatst zonder verstrooiing."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c32ba8c6b1344a06bd1031e23620c522" name="enum_LichtsturingAansturingsprotocol">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7c4f4b59e7a4492baa63278e2e32059c" name="(can)bus">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d835aff072184937878d087cb95ada07" body="CAN is een afkorting van &apos;controller area network.&apos; CAN-bus is een vorm van seriële dataoverdracht door een kabel volgens een bepaald protocol, maar zonder tussenkomst van een computer."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5189fa61a64e44e688dda3a1ce3f9c6e" name="0-10V">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_84f26abd63ad46efb6fb46d206decfc4" body="De klasse met als ondergrens een spanning van nul Volt en als bovengrens een spanning van tien Volt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_77260e08e2b1413ca8010610f7787f9f" name="4-20mA">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_061a02f026784b2d8b0914a86cc35dd6" body="Een 4-20 mA stroomlus is een tweedraads elektrische verbinding, gevoed door een constante spanning van (maximaal 24 V) en aangesloten op een omvormer die een te meten grootheid omzet in een gelijkstroom tussen 4 en 20 mA."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_70d5b4723d8147e79612189362763592" name="Dali">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f033a76ceba74bb7abf640599aea7854" body="Een afkorting voor &apos;Digital Adressable Lighting Interface,&apos; een digitaal systeem voor verlichting en energiebesparing waarbij de verschillende componenten met elkaar communiceren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1bb02f107cdb47389f4d763be24d318e" name="DMX">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fd5ecab1a83d46469386649063af2431" body="De taal waarmee verlichting en effecten kunnen communiceren met elkaar en/of een lichtsturing."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_e7843ee35fc34c8fa1210985df2492d8" name="enum_LichtsturingIntelligentie">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_89224ea671ec493baaa301a4ea935215" name="Alleen met dataverbinding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e45e82db676c4d49bdde913ab10a2ca1" body="De aard van de kunstmatige intelligentie van het object is gebaseerd op een dataverbinding en er is geen sprake van een kunstmatig intelligent object zonder die dataverbinding."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1fbef314249f4aa585d94ba014cb42b9" name="Lokaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bed2d091239e44c7b6b47222fc30388f" body="Alleen de directe omgeving van het object waarvoor de communicatieapparatuur communiceert wordt bij de werking van het object betrokken."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_5e7e5393986a4e8da883e7fec810d767" name="enum_LichtsturingInterneSensor">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0ac5015e8cab49aca452a25183694184" name="GPS">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ab5a9dfe4f39480cb265b4e6ff6da377" body="Het meetinstrument dat is gebruikt om de meting te verrichten, is een &apos;Global Positioning System&apos;: een apparaat dat met behulp van satellietcommunicatie diens exacte plaats kan bepalen. Hierdoor kan elk object dat is uitgerust met een GPS diens exacte pla"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f0b68a3e3b37487ab007b47ae1df79af" name="Lux">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_45b8af8824954813a8c6306dcd1ddf43" body="Een lichtsensor die de hoeveelheid licht meet en op basis hiervan een systeem tot actie aan kan zetten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bf1f9fab039547f5b35a1b78f3b5f6a9" name="Pir">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_be59d3583f8b41e685fafb500d83a8d7" body="De sensor intern aan het object is een passieve infraroodsensor."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0e973041c9a44f4fa4ef7140be964bf3" name="Scheefstand">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1d3ee5defbdf45a59f99b563bb2ad505" body="De interne sensor die het object bevat registreert de wijziging in hellingshoek van het object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e9c5a4d02fe842968c1c5e3be1c052c8" name="Temperatuur">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_056c475c308342d3863a979c558b42fd" body="Wat de sensor meet is de warmtegraad van het object zelf of van de omgeving rondom het object."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_1eca04e48cf04137afaf7df8d44ffe43" name="enum_LichtsturingProtocolNaarCommunicatiemodule">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_70202f0909f541a9ba23f4ccb9c06f09" name="i/o">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fcc93098d2224fc18a052844139de584" body="Type van een communicatieprotocol."/>
        </ownedLiteral>

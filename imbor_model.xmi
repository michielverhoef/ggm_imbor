        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e813c836b6f046e0807c5be1f3e5e954" name="Boomjuk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_face7fb004cf436490c918721938016a" body="Constructie van drie of meer staanders van hout of ander materiaal rondom de stam, die onderling verbonden zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_76ae3d20488c4257a80c27587c4f1465" name="Boomkorf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d34d57a5fba9490292a827d7996a3d8c" body="Hoge boombeschermer, vaak van gaas of smalle metalen strips, volledig rondom de stam."/>
        </ownedLiteral>
      </packagedElement>

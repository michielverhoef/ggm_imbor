        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4190bd864ec24cd09ade526543eef269" name="T24-3r-01_C18-2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c2a69a85ec264d76a5814452ef616a3e" body="2 rijstroken met 1 rijstrook met breedtebeperking rechtdoor en einde rijstrook voor de naastliggende rijstrook met asverlegging."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d8309ef2797e4f9a971f57dd3dba0a98" name="T26-2l_C18-2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3a05611a0b21482488b0be29fbd961a8" body="Einde afsluiting rechter rijstrook, 2 rijstroken, breedtebeperking voor linker rijstrook."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_018c82839a7e4b2c9bcf3ef56daccbab" name="T26-3l-01_C18-2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_15b0747889c24088bb52677090a266ee" body="Einde afsluiting rechter rijstrook, 3 rijstroken, breedtebeperking voor linker rijstrook."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f214be8c22df4572a19260a97766d03f" name="T27-3l-01_C18-2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_df5175999aa74f3fac3de3b90670ce77" body="Einde obstakel rechter rijstrook, 3 rijstroken, breedtebeperking voor linker rijstrook."/>

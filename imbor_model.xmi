          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_42f23546ec4a4d9b86f0ee8784473fab" body="De geometrie is ingewonnen vanaf daartoe geschikte (digitale) foto&apos;s, meestal luchtfoto&apos;s. (bron: BGT)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_398776e999f04d459a139d140e7d0b72" name="GBKN">

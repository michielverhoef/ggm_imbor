      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_a4a359bb57894607aa4356e9d34d384c" name="enum_BijzondereTegelVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2d1d652c0c4d4689b6808c43659fcec5" name="Aardingstegel">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b23b52b9bd244b33bd22a75a42aafa25" name="Afkoppeltegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5f1fa63f7a754cefb34196cc2191dcae" body="Tegel die er voor zorgt dat het regenwater in een duidelijke richting afgevoerd wordt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_aa56f1a1b2e74206bcb02ca32087211d" name="Asbaktegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2d9c8d94c4c64429b6fe0e47b824a6ca" body="Tegel bestaande uit een rooster met daaronder een opvangbak voor sigarettenafval."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_aba2589711c54501b0504c42c76071c8" name="Haltetegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d86d197744444d2b910d667564a2cefe" body="Om en om geplaatste tegels die de opstapplaats voor een bushalte markeren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b5ec61a01592468abafb92e5d5d9dc89" name="Huisvuilcontainerplaats">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6b5afcf57bd44ed0a909b041fd6558c3" body="Tegel met daarop een symbolische representatie van een huisvuilcontainer om aan te duiden dat de plek een locatie is voor het verzamelen van huisvuilcontainers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c4a03a90042a4436b2dda7e560f3842d" name="Knikkertegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8cec9e45a5604b3498818da57399d58e" body="Een tegel met een kom of kuil in het midden dat dient om het spel knikkeren te kunnen spelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e0e5bb6536b3414ebf51f6cd5612f579" name="Markeringstegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7f8eed6d4cbb4451a748d5fb8f5bd189" body="Tegels die onderdeel vormen van een wegmarkering of een bepaald herkenbaar oppervlak hebben, die derhalve een geleidend, waarschuwend of informerend effect hebben op passanten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3a24754a5ff2455d87a0d091f3c2d071" name="Nummertegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8de1dff53a0e42c3b42cbe3d048006fb" body="Tegel met nummer om objecten in een gebied aan te kunnen geven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_81fd89e4bdb44d7bb68717db50e2121c" name="Oplaadtegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_30a8c44d9f3a4c46847957b45786f464" body="Een tegel met een symbool van het opladen van een elektrische auto dat een laadvak aanduidt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bcd8883b59cf452e9d052f75b6c1eb5f" name="Opruimplicht hondenpoep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b7b5ae86a53d4b61b9e848d13f87f416" body="Tegel die hondeneigenaren erop attendeert dat hondenpoep in deze omgeving niet onopgeruimd achtergelaten mag worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1d624c58cd7a486abc749cbaa30634d7" name="Parkeertegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4fefab5fd052480187fcd9f3dca538cf" body="Tegel, gemarkeerd met een &apos;P&apos; die een parkeervak aanduidt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5460ec18efe64eb893f4cee410d27424" name="QR-codetegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6e9736e9206f420ca1800121f778d4c9" body="Een tegel met QR-code heeft dezelfde werking als een link naar uw website. Bezoekers en voorbijgangers kunnen doormiddel van een app op hun smartphone de QR-code scannen en worden direct doorverwezen naar uw website."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4a5cbc0d45dc4188b10731f207bde912" name="Teksttegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9747206196cd44739a3fd1a24da9bea9" body="Een tegel met een opschrift, vaak om passenten iets duidelijk te maken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_45c69b1b63164e74b99da7ff6b83aa7a" name="Verkeerstegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ce5aaf24cfd34949885913571bc4bff3" body="Tegel waarvan het uiterlijk een verkeersgeleidende of -regelende functie heeft, zoals bijvoorbeeld een tegel met daarop of in de vorm van een witte driehoek."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_503b0d4b48584c81931b561545a464da" name="Voetstap">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_01ddb1f7422a430c937512e8d65837f2" body="Tegel waarop een afdruk van een voet staat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d4aa4cad36f04dbdbd9a71392e606054" name="Zinloos geweld tegel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d64e51724b444cd39c5e3b9bc119169e" body="Een tegel met daarop een lieveheersbeestje dat symbool staat voor respect en de kwalijkheid van zinloos geweld."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_3a31fadec01245fb81e9edaefdcce258" name="enum_BlokVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b4232e393388441791cde8fa6dd144a4" name="Hoekblok">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_af067bdf82714ae2a8328d5b6f362762" body="Blokvormig, soms afgerond, element, meestal van beton of steen, dat wordt gebruikt voor het maken van hoeken in bandconstructies."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_68536efb466d443aaa038a5675350525" name="Piramideblok">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_54c71e6d664b4d6097c3fd852bcb241e" body="Piramidevormig element, meestal van beton of steen, dat gebruikt wordt als linie beschermende elementen voor het voetverkeer langs de weg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9fec014d24fb414091af43a7090c80ae" name="Schampblok">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_74af0f9de8754841b1e66aa99bb2622f" body="Element met de vorm van een lichtelijk hellende schans, meestal van beton of steen, bedoeld om aanrijdend wegverkeer te weren."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_dcbd0f528f66441eb98c0f557403d5d7" name="enum_BodembedekkersVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2d9be370b1804887ba3a2528ee27d1ce" name="Bodembedekkende heesterrozen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9893ec0d98c542b798771aa47f91b1ac" body="Bodembedekkende rozen (met een maximale hoogte van 0,60 m), die laag over de grond takken vormen waardoor ze de bodem bedekken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_10c9ddbb996642c888abe524a61d478c" name="Bodembedekkende heesters">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_739af46acd604dc289b898a524ad61a5" body="Heesters met een maximale hoogte van 0,60 meter die door hun natuurlijke groeiwijze en hun plantafstand de bodem volledig bedekken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_92fc212476214d5cb829a21b9b2d4a00" name="Bodembedekkende rozen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7c8b375cba8a4a1fa787afb234a2fdeb" body="Rozen met een maximale hoogte van 0,60 meter die door hun natuurlijke groeiwijze en hun plantafstand de bodem volledig bedekken."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_8e33231965614197b8e889395b033876" name="enum_BodemVoedselrijkdom">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_243c54af380245f2b41db15ef7d8d329" name="Matig voedselrijk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c6a66c0705154de9907ada122b914472" body="Een bodem met met een middelmatige beschikbaarheid van minerale nutriënten (trofiegraad)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a40b2294abed4fcc861b3f1105ebdfb6" name="Overmatig voedselrijk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_18ccdbb815e447d5b8bb8b80c18484f2" body="Hypetroof is de overtreffende trap van eutroof. In een hypertrofe bodem is er een overaanbod aan voedingsstoffen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fc20ea13ea5d4e57bb23ef4b3ebfb6c5" name="Voedselarm">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c07434e29b964567b9024a84ceda3bc4" body="Er zijn binnen een bodem maar (zeer) weinig beschikbare minerale voedingsstoffen aanwezig."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b9cfdbe9f5884ceb9c9c31b4751bf5ec" name="Voedselrijk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_97d5ae8e4d40419c95cfc8f8f5757a2d" body="Een toestand waarbij er veel minerale nutriënten beschikbaar zijn in een bepaald milieu of ecosysteem; de trofiegraad is dan hoog."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_895f620ed7bf4fa1b53bdd5cc25f3853" name="enum_BolderVorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0892f09fcfa84a03afdad7394ebaa722" name="Cilindrisch">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4257e15087854b98a4d7247aa000e92a" body="De vorm van het object is die van een cilinder: een cirkelvormige basis die voor een bepaalde lengte recht de hoogte in reikt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5d69fc1c081a4a84be7732d0c0d57aaa" name="Conisch">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9b99d9b4dea1424a898ddd83d214c86c" body="De vorm van het object neemt, vanaf het maaiveld bezien, geleidelijk af of toe in diameter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2dcab1b28f53421dacf3afd741452f6c" name="Rechthoekig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3296e2c4ee52475ba98953bc65a0da54" body="Een vierhoek met louter rechte hoeken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6b5fb1f984e547dc82512a7c10c4b840" name="Rond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_912f49c7ae6c4d5a89c60c9540add1b7" body="Cirkelvormig en zonder hoeken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6608046db85b4c0991cfd65ff71818d4" name="Vierkant">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_71e538d53e3f4aa08f05b02a71ad370a" body="Een vierhoek met louter rechte hoeken, waarbij alle zijden dezelfde lengte hebben."/>
        </ownedLiteral>
      </packagedElement>

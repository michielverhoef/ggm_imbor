      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_a472fbbfcb6c4e5aa9bc966634508872" name="enum_WegasMaximumsnelheidsklasse">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_dce3144689ce4ad9b79a34b985489e86" name="100 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1a2a5c64af9c4c838d0109b76fe606e0" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van honderd kilometer is en de tijdseenheid één uur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e5b17009bfd14d469cd5eff630fed6ca" name="110 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7b1a8a9b916a4ded91c24b92c818c31b" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van honderdtien kilometer is en de tijdseenheid één uur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3f04c0d06212409598d1b0e59e8bc80f" name="120 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_162c5548b3654df7aa20cb77c073c499" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van honderdtwintig kilometer is en de tijdseenheid één uur."/>

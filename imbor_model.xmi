        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b414f5fd0e1242318e01281ec3bb9851" name="RB-k">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d6c8ad6ae58c4f8991adcdc7c3a92fa8" body="Ruigte van Gewone berenklauw (Gewone berenklauw bedekt &gt;50%)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_eed40f2575ef486186b4946c8b63d027" name="RB-n">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4e6c2f9853034731b31fd6123bd17c3d" body="Ruigte van Grote brandnetel (Grote brandnetel bedekt &gt;50%)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_84554a1e8eab43329862ceebc79d27a6" name="RB-r">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b8ed630a903043c8bfb81696f36eb8f1" body="Ruigte van Braam (bramen bedekken &gt;50%)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7041766d7aef42ecae56a06128bf1c63" name="RF">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d9c4c1085cc44615804f6469d1e9e89f" body="Ruigte van Fluitenkruid en/of Look zonder Look (bedekt &gt; 50%)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ad2413f4ea744d69b40b0aa5b38b183f" name="RH">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2b827484d60649afb924e6fb60a86c37" body="Ruigte van Haagwinde (Haagwinde bedekt &gt;50%)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b42db822ae494457999d4ea35cae6869" name="RH-g">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a7b5fdd93822499180ad80c36ada37d0" body="Ruigte van hoge grassen (Glanshaver, Kropaar, Kweek, Rietzwenkgras, Rietgras bedekken &gt;50%)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_591865ca6afb402796b954f1ba52647b" name="RH-w">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c5224721b24e44e9b131da487bea54a5" body="Ruigte van Harig wilgenroosje (Harig wilgenroosje bedekt &gt;50%)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a5256402fd2d4f30a01234df656a532c" name="RO">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_760893027c89441993ae53c80197f1b7" body="Overige ruigte (niet behorend tot een van de andere subtypen; kort beschrijven)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7d5183a1944e450a91bf6c394ef890ae" name="RR-z">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5660bcb1fda647d4a5923acf8539055f" body="Ruigte van Ridderzuring (Ridderzuring bedekt &gt;50%)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f13634b852c941d29e78956f4e6a5b45" name="RV">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_03e30f14314a4f978c21928eff3d4adb" body="Veenmosrietland (veenmossen bedekken &gt;50%)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f54fa96f010645589af6d20484332da6" name="SG">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dfa8e4fb9517407e97c9dc9757b7b9b5" body="Gemengd struweel van vnl. inheemse soorten (geen soorten met bedekking &gt;50%)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_14825033a4c345e28e5d5729ba15e8fc" name="SO">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_87509530ff3b4bce9a4eb96ba567d4f2" body="Overig struweel (niet behorend tot een van de andere subtypen; kort beschrijven)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1975bbe3d240466bb9c5512cbf067ff3" name="SS">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7fd94d62a926446689ea002f076a0d15" body="Sleedoornstruweel (Sleedoorn bedekken &gt;50%)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8259634fcdea4e2eae78ead7f46d3cf9" name="SW">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4c465c2afcc446f587f38b6b3bdaec95" body="Wilgenstruweel (wilgen bedekken &gt;50%)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_81f2a4bfc9cd4261ace86301162569af" name="V1">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0149451b73bc40c59f258b0e5098b6af" body="Arm aan plantensoorten en kruiden (niet passend in V2 of V3)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c1a923258b924498ac8dc6763e422de2" name="V2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_286941713c7540c28bc0ee124aad584f" body="Arm aan plantensoorten, kruidenrijk (een of twee soorten kruiden minimaal abundant)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bdd9dfbba7f449178c03a418fb9781fc" name="V3">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1e950d194615461eb0b646945128ae84" body="Soortenrijk en kruidenrijk (meer dan twee soorten kruiden abundant)."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_b1491c0ca4bd44dbb1cef2befa40847c" name="enum_FysiekObjectBiotooptype">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d8ecc858f390429996895442aa4f984e" name="Bloemrijk grasland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aa8352ffcff1458dafdee7655bd73a47" body="Een groen oppervlak waarvan het fysieke voorkomen wordt bepaald door grassoorten en meerjarige bloemen, waar de bodem niet of nauwelijks verstoord wordt en jaarlijks één tot twee keer wordt gemaaid. (Bron: Cruydthoek)"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a203698320334213af2daaa4584ae48c" name="Bos en plantsoen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_982b57b2687342729ced782afa749196" body="Een groen oppervlak waarvan het fysieke voorkomen wordt bepaald door in bosachtige structuur groeiende bomen en jonge aanplant van boom- en/of struiksoorten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_644657bc67c6411399285f9372f5a514" name="Gazonnen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d97c178d69084bf2913fe6e197c998ac" body="Een biotooptype met als functie verfraaiing en als fysiek voorkomen een grasterrein met een relatief uniform grasmengsel zonder onkruid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2f28c0d40c99493285f1d92453b97827" name="Natuurvriendelijke oevers">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_25e6ca438bce4ced9e87c368f4a2b19e" body="Een biotooptype bestaande uit weelderig ingerichte, vaak bloeiende planten dat een beschutte omgeving vormt voor flora en fauna die gedijt in waterachtige gebieden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c773c30e15334d978bf4901e6b612c4a" name="Rietlanden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_03dd0f7cfd434d479101060e4e11a1aa" body="Een biotooptype dat wordt gekenmerkt door een overheersing van rietvegetatie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_900bc1c702374474b638fba908170f02" name="Struweel en ruigte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_416edbd2f03a4afe9bef3f10148fd30a" body="Een biotooptype dat wordt gekenmerkt door een overheersing van laagblijvende struiken en hoog overschietende, overjarige bloeiende kruiden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a4941b82eb584aafb3b6945718580107" name="Vogelrijk grasland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_86681e63da8e41df8f80cc66d9c94c62" body="Een biotooptype dat wordt gekenmerkt door grasvegetatie en omstandigheden die kortstondig en langdurig verblijf voor vogels aantrekkelijk maken."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_7ef0029e17df452f899607ae8d57d394" name="enum_FysiekObjectConstructietype">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1fb8d2798ea14a0d9fb5208ffe1f4011" name="Doosconstructie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_87e587dd7a36418ea3c75f8830f930b4" body="Deel van een rechthoekige constructie die hol is uitgevoerd, zijnde een bepaalde lengte, breedte en hoogte met daarin een ongevuld volume."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_acec2ed432324d2794b318eef330e3c2" name="Tandoplegging">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_671b7f6e7fb44c608dbb3b4deb99d6e8" body="Betonverbinding waarbij het ene deel van de verbinding een uitstekend balkdeel bevat dat komt te rusten om een uitstekend deel van het andere deel van de verbinding."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_1dea436d59884e37bbb74511a62d39aa" name="enum_FysiekObjectLeeftijdDoelgroep">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_96f0f2a6c5094a478fd05332a22d6d42" name="13 tot 15 jaar">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_772b969ae5f843ce991cacf34f94add1" body="Leeftijdsbegrenzingsklasse voor een doelgroep in ondergrens voorzien door de leeftijd van dertien jaar en in bovengrens voorzien door de leeftijd van vijftien jaar."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2296730f0b8e4e3caedaa3fb46750006" name="16 tot 19 jaar">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_89919b2b2a5d46c699840de90ed934f3" body="Leeftijdsbegrenzingsklasse voor een doelgroep in ondergrens voorzien door de leeftijd van zestien jaar en in bovengrens voorzien door de leeftijd van negentien jaar."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_09a51a15bd794954a9142c1d418dabff" name="6 tot 12 jaar">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d764b9565f6642f1bc97f7d38c2aa235" body="Leeftijdsbegrenzingsklasse voor een doelgroep in ondergrens voorzien door de leeftijd van zes jaar en in bovengrens voorzien door de leeftijd van twaalf jaar."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_eaf11f6444764a1b9c82a2c36ca152f0" name="Alle leeftijden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f8a881d7782e43948bb903d007d63440" body="Het object is bedoeld om te gebruiken door voor gebruik door mensen ongeacht hun aantal levensjaren"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ede698d611a147bca99892507c59d95c" name="Onbekend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5d6db5f634a041c1a31c2f558e7f6e03" body="Bij deze waarde moet nader onderzoek uitwijzen of welke attribuutwaarde van toepassing is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0e747fd1706a4eb9982b327cbe6484cd" name="Tot 5 jaar">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a57792c5a21649059953691a5198dbd7" body="Leeftijdsbegrenzingsklasse voor een doelgroep in bovengrens voorzien door de leeftijd van vijf jaar."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_ed663e78ef1a41289fb9bdeb729f48a4" name="enum_FysiekObjectPompschakeling">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_19575aa911bb4b8894a4301d295b8808" name="Enkelloop">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_389d7b457a474747b091da3ea9cab012" body="Een pomp die zelfstandig en niet tegelijk met andere pompen werkt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a8ef14fb511f443c82f2a893211afe10" name="Samenloop">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e2f76a89305e4baa879de57677fb0865" body="Een pomp die niet zelfstandig en juist tegelijk met andere pompen werkt."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_3339f096340047d48987b4116b533799" name="enum_FysiekObjectRijrichting">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4be1a5c426b34c788d283d2e3e6a3be9" name="Beide richtingen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f3a75d53c3114d46820ee5068b42bef1" body="De weg is bestemd voor weggebruik vanuit beide uiteinden van de weg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a181cbdad9614d16a77a073cdbfb11b9" name="Gelijk aan de fysieke richting">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9a53b50fa431420982df466eb29ab8e1" body="De rijrichting van het wegvak is de richting van de verbinding tussen de begin- en eindjuncties van het wegvak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1df593aff05a4fc1b336ae631e56a61e" name="Tegengesteld aan de fysieke richting">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_91cfe4d9bfe74bb2aec0cb192d837485" body="De rijrichting van het wegvak is tegengesteld aan de richting van de verbinding tussen de begin- en eindjuncties van het wegvak."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_caa06e33abf0491d9e0975dd5b1d817e" name="enum_FysiekObjectStijlOpschrift">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_528ae4ca7982458e839f6bfd53a9ab16" name="Afwijkende uitvoering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e70c69ae757a4f068e6873920b0703ed" body="De opschrift op het bord is in stijl conform geen van de in de keuzelijst gespecificeerde uitvoeringen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_90b42d9ddb1144e893590f65614eaef0" name="NEN 1772">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4f436decf5a442f9927cbf7268d3c8f0" body="De opschrift op het bord is in stijl confom de publicatie &quot;Straatnaam- en huisnummerborden&quot; van de Stichting Koninklijk Nederlands Normalisatie Instituut, uit 2014."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d6b97d6e755f483184baf3d5b970e40e" name="NEN 3225 uitvoering oud">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_31ce328fbed44712903990d99bdc8b8d" body="De opschrift op het bord is in stijl confom de, inmiddels verouderde, publicatie &quot;Nederlandse letter- en cijfervoorbeelden&quot; van de Stichting Koninklijk Nederlands Normalisatie Instituut, uit 1962."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_1c31a23da3d74b45b448e6555c2793d8" name="enum_FysiekObjectTypeBediening">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_649bed98808b4a08b8b5f7ac09c3e673" name="Elektrisch">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_68a4b444060b46c2a5d6f417942ca44d" body="Aanduiding dat het object wordt aangedreven gebruikmakend van stroom die werkt middels ladingoverdracht van elektronen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b6ed8d56efcb4408b23c4f3d43752da9" name="Elektro-mechanisch">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5101a37054e84cea9c57ba6231aee497" body="Aanduiding dat het object wordt aangedreven gebruikmakend van een mechaniek die door elektrische stroom kan worden beïnvloed."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a4a57c5fd8d946f4a2de128677f21380" name="Handmatig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_215bc1195015484bbedb198b9c290fd9" body="Door middel van menselijke arbeid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_25333cdb3b654c5eae910ce851c4c414" name="Hydraulisch">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_658a53b23d064273b923035b82629648" body="Aanduiding dat het object wordt aangedreven gebruikmakend van vloeistof onder druk."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_eec64144f47646ab93ccdabbede684e9" name="Magnetisch">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4b386b0f70614d84b4d3aed055efc22f" body="Aanduiding dat het object wordt aangedreven gebruikmakend van de aantrekkingskracht tussen metalen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4df24018d74d405586d50ac4e83d2d65" name="Onbekend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_798d4f202ece4ec6976d9f5d06fcd4b4" body="Bij deze waarde moet nader onderzoek uitwijzen of welke attribuutwaarde van toepassing is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ebd513077c0d440a914bd31c5e9773bb" name="Pneumatisch">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a8b7766f99c04ae9bed800436ac54d01" body="Aangedreven door luchtdruk."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_5514ee36a11d4421a484981623fbf38d" name="enum_FysiekObjectTypeBevestiging">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8d779bf1ab08468aa1bf0487cd04ae88" name="Beugelbevestiging">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a2613a1b85e7489f994e10c0e6d8627c" body="Bevestiging op basis van twee met schroeven verstelbare platen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_703792ef705347b59a011c7a5c67a127" name="Boutbevestiging">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ee705248e56049fc97c4a5dba9f43c13" body="Het object is aan een drager bevestigd door middel van het schroeven van bouten door het object in het oppervlak van de drager."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9dfa5bbfe02c439fb848e516bfd74664" name="Buisbeugel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_04f35dbb665d43ff9cdb402f9681570e" body="Bevestiging op basis van een ronde ring die om een buis geklemd kan worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fa9cf87589624dce925e87fac8c140b9" name="Handwijzerpaneel (driearmig)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2c5b73e939e7415aa097af72289f52d8" body="Bevestiging op basis van een paalklem in het verlengde van een handwijzerpaneel met drie armen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b341f5ae58a844e2874e7658724b4ecc" name="Handwijzerpaneel (éénarmig)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ddaf1416a642469aa95f1da7f02c68dd" body="Bevestiging op basis van een paalklem in het verlengde van een handwijzerpaneel met één arm."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a7a4be2834c04e12bd938c68d22a340c" name="Handwijzerpaneel (tweearmig)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_62667f53fc7c44988a7abae4414d8e8a" body="Bevestiging op basis van een paalklem in het verlengde van een handwijzerpaneel met twee armen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1d020a78564e4f6897de074608e439a3" name="Hangbevestiging">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_54c9630b38564f8b87e4543cd7589b18" body="Een apparaat dat (hangend) bevestigd is aan een uithouder."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6c5e57e4d4614cb2b4b127fe0592a6d1" name="Hekbeugel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5900eb2823894b33b8a840b5775a8239" body="Bevestiging op basis van twee met schroeven verstelbare klemplaten, waartussen het raster- of spijlenwerk van een hek geklemd kan worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f4a5a2bd7eab42c8907b4b32feacb697" name="In object">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7becbd7cf05d494987e0f7bc0df0aa6d" body="Het object is in een object gemonteerd of bevestigd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_31d95cbccad143288845d795c66e03e7" name="Klemband">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c3f554175a334ce9a0c2ebe8e6fc606e" body="Bevestiging op basis van een metalen aandraaibare ring."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_be3e6a46a25442149059c363f3b44e18" name="Los ingegraven">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7d55bfc073304d94ac72c6b10da44174" body="Het object is niet vast in de ondergrond geplaatst, bijvoorbeeld in het geval van grondspots."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9dde46382d574d5ab2056003a1983ad4" name="Middenachterbevestiging">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_58304a2c539e4355b49dac21be34696f" body="Een bevestingsmethode waarbij het object vanaf een punt midden op de achterkant van het object aan de drager wordt vastgemaakt. Hierdoor is deze bevestiging alleen geschikt voor enkelzijdige montage."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_936644106c574ab5afb9ef2ddad8cf54" name="Muurbeugel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_16c8486134a14f0b8bf31d25bceeeb85" body="Bevestiging op basis van een kromming die aan een muur is bevestigd of een plaat die aan een muur is geschroefd met daaraan een haak of een andersoortig uitsteeksel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b49127bd73364b4dbb1164879ab44852" name="Onbekend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_274379f25d5040b780d804b0c32b0940" body="Bij deze waarde moet nader onderzoek uitwijzen of welke attribuutwaarde van toepassing is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c192414e369847d6abad19c1b3c99943" name="Opschuif">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5be0026e5be94a94adad74df63757032" body="Bevestiging op basis van een ronde opening in/aan het armatuur zodat deze horizontaal op/aan een uithouder gemonteerd kan worden met schroeven/imbus. Hierbij is de diameter van de opening belangrijk om te weten, belangrijkste maten zijn ᴓ48, ᴓ60 en ᴓ76."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_aa8b6a4c377e41bb902086ff8e10ca42" name="Opzet">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e7de8fd9483b4399a5d1b571b6d5705d" body="Bevestiging op basis van een ronde opening in/aan het armatuur zodat deze bovenop een paal gemonteerd kan worden met schroeven/imbus. Hierbij is de diameter van de opening belangrijk om te weten, belangrijkste maten zijn ᴓ48, ᴓ60 en ᴓ76."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9eb8cd7fd0e8444ba6a0c38c8659a940" name="Opzetbeugel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_65381252884e4255964ea249c6452c95" body="Paaltop."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_117aa30eea194dfda6b61da844236583" name="Overspanningsbevestiging">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b0881950c03c4df581d7e4d2493698a6" body="Een apparaat dat bevestigd is aan een (span)draad."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_019af5412ad14225887dbf0848067a39" name="Plakken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_27f63d5d201b4515b67779d3a3d1078e" body="Het object is bevestigd aan de drager door op de drager geplakt te zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d6a45281cb3f48559244abdc3e27c0dd" name="Scharnierbeugel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_eb0efb67d92f436098e42d5786402ad3" body="Bevestiging op basis van een beugel met aan de ene zijde een schroef en aan de andere zijde een beweegbare verbinding."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_853b5d546ba14137b8dcd91d2b504232" name="Scharnierbeugel ruggelings">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4bbb8aaa7e42412288015a1b95cd4fd1" body="Bevestiging op basis van een beugel met aan de ene zijde een schroef en aan de andere zijde een beweegbare verbinding, met zowel aan voor als achterzijde een klemplaat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e130f59cce7a457899396b2ec872f36d" name="Uithangbevestiging">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_17ed088dc7774b128cbfacc5e2874ec4" body="Een type bevestiging waarbij het bevestigingsmiddel van de drager af hangt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2fc1d3bfad694246b345743bc03aad42" name="Vast in omgeving gemonteerd">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5022bd168d5b48268672985be0d183ea" body="Het object is vast in de omgeving gemonteerd, bijvoorbeeld in beton."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_87b17938ed374b4ba7857dc24489b0fc" name="enum_FysiekObjectTypeSport">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_036cd0e00ce6402fa66105cfbe1173c3" name="Atletiek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_33c9136889414b90b7cb6b3f0eb13ed8" body="Een sport waar de sporters (atleten) individueel of in groepen moeten presteren, die zowel op de weg, in het veld als op een verharde baan wordt beoefend. Voorbeelden zijn looponderdelen, estafettes, springonderdelen en meerkampen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_89f78b70e8d54e2587828ae11ced653e" name="Beachvolleybal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bbd4f8be7242488ab64b44a4e53eaf90" body="Een olympische balsport die wordt gespeeld op een strandachtige zandondergrond waarbij twee teams gescheiden door een net tegen elkaar spelen en trachten om de bal in het vak van de tegenstander op de grond te krijgen of om een fout bij de tegenstander af"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c430d981dd3847798c7b86d6b7922314" name="Bowls">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6922c697881049c8a038e18612c29366" body="Een precisiesport waarbij het de bedoeling is dat de spelers afgeplatte ballen, bowls, zo dicht mogelijk naar een kleinere doelbal laten rollen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_afe34653460c4ffd90f2641287213abd" name="Cricket">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_45f898342e3b418bbb4321bfabc560d7" body="Een balsport waarbij punten worden gescoord door heen en weer te lopen over de pitch (een run). Het is een teamsport waarin om beurt het ene team gooit (bowling) en het andere team slaat (batting)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_33447a8a8d214940bdb77c9977cd7523" name="Golf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bb1cbb643c9c436cb5b4554ddc7a6ae2" body="Een balspel waarbij een kleine, harde bal met een club van de tee (afslagplaats) weggeslagen wordt in de richting van een met een vlag gemarkeerd punt (de hole). Het doel is om de bal in zo min mogelijk slagen in de hole te doen belanden. De sport wordt g"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e157683d1cc745fdbbfb4514a1df2ea3" name="Gymnastiek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3dadf3de418d4948a43359c9fe65b312" body="De naam voor sporten die als onderdeel een bepaalde vorm van acrobatiek omvatten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6207a305c43f4a6b9b968f97669ef256" name="Handbal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5904a925e5864b1282f7648db6c57555" body="Een sport tussen twee ploegen van elk zeven spelers. De winnaar is het team dat de meeste doelpunten maakt door de bal in het doel van de tegenstander te werpen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_25cf28ad23aa44b299bf2bf182f5c4eb" name="Handboogschieten">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_74948bb0260a4d55a69a3d4bb82393fd" body="Is een sport waarbij pijlen worden weggeschoten naar een doel met behulp van een boog."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ab9a1d40fbb241b383767d6b3549c456" name="Hockey">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_456677075e9745a9a762fb0866525b06" body="Een balsport voor teams waarbij het belangrijkste attribuut van de speler van de sport de stick is, die wordt gebruikt om de bal te hanteren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a7c866d2eb95482598b1110de73bacbd" name="Honkbal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9ed9be53d1774696bbccbf1dabc1c864" body="Een sport waarbij gebruikgemaakt wordt van een knuppel en een bal tussen twee tegengestelde teams die om de beurt aan slag zijn en in het veld staan om de geslagen bal te vangen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_be2054f241aa4e0dbd2d1dd8ed9a83c0" name="Jeu de Boules">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_29446999ebcc47d3940734a65abde37f" body="Jeu de Boules of petanque (Frans: pétanque) is een balsport die in Nederland ook vaak wordt genoemd. Petanque is echter een vorm van jeu de boules, waar de laatste term alle spellen omvat die met metalen ballen worden gespeeld."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_42fcb8d1d33847c7a89eb738a1eff122" name="Kaatsen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_49cafa88611249738452b9df290819c1" body="Een verzamelnaam van balsporten, waarbij de spelers de bal met de handpalm zodanig proberen te slaan, dat deze door de tegenpartij niet geldig kan worden geretourneerd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7b45272c62a4486480043f6f41ff2e63" name="Kogelslingeren">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_432bb35754054fcc85a54e7532b5d531" body="Een onderdeel binnen de atletiek waarbij een kogel, die bevestigd is aan een staalkabel met een handvat, zo ver mogelijk moet worden weggeslingerd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_27fd913610574ad882193ef2b47795d1" name="Korfbal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_07e9720b3ee84181b259104d588a1e17" body="Een balsport waarbij getracht wordt een bal zo vaak mogelijk door de korf van de tegenstander te werpen. Elk team heeft een korf die op een hoogte van 3,5 meter is opgehangen aan een paal."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_569760f020e74661923e0e472c546006" name="Paardrijden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f4fbfa2b75634e8f85ce55d6535e90b3" body="Is een verzamelnaam voor sportvormen waarbij een of meer paarden gebruikt worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f425366739c84e42866a311109f6e5ca" name="Padel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_60e1ae13adb948b19cb28142b041c20a" body="Een racket- en balsport. Het wordt voornamelijk met vier spelers gespeeld, waarbij een bal, gelijkend op een tennisbal, met een racket over een net gespeeld dient te worden. Het lijkt een mix van tennis en squash."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f99b3f8a8c884055b0492c1281002c1c" name="Rugby">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5f55d13247474ea48f8780c27f9074a8" body="Een balsport waarbij men de bal al rennend aan de achterkant van de veldzijde van de tegenstander dient te brengen, waarbij er getackeld en geworpen mag worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_05aa391cbd60480582c3dc721abdcad4" name="Schieten">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5b84c32ee6fb4c5099cab4a707080e7b" body="Het afvuren van een projectiel met behulp van een vuurwapen of een ander hiervoor gemaakt hulpmiddel voor competitieve en sportieve doeleinden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_11d807f018564b759f59929532a81183" name="Skaten">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_76694127e7e94aa28632b1954882cc05" body="Een term voor een groot scala aan sportdisciplines waarbij men zich op inlineskates voortbeweegt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cf732ca5abc24bb08138dc75b9661c7b" name="Softbal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_54a3de1a0e914476b9ab12461aa6cf58" body="Een sport waarbij gebruikgemaakt wordt van een knuppel en een bal die gelijkenissen vertoont met honkbal, maar gebeurt het aangooien onderhands, is het speelveld kleiner en is de bal iets groter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0f81b8d9406c4648889cbd8d5a189b44" name="Squash">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_926de191f627429fa7ea6ee9ecc54bf4" body="Een racketspel dat door twee personen in een gesloten ruimte wordt gespeeld en een klein beetje vergelijkbaar is met het tennisspel, althans in zoverre dat de spelers hier niet tegenover elkaar staan maar naast elkaar en gebruik kunnen maken van muren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8b9876c698644b5cb986bdd5e460c853" name="Tafeltennis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6b12c4b95541467392c3766a8e51ed72" body="Een sport (ook wel pingpong genoemd) waarbij twee of vier spelers een licht en hol balletje met een batje heen en weer slaan over een tafel met een net in het midden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0cc706592a2c4773adfb853cd5f0ee81" name="Tennis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0dbddb7a9a06413a96e8ebd9f8638a8a" body="Een balsport voor twee spelers (enkelspel) of paren (dubbelspel), waarbij een bal van gemiddeld 67 mm diameter (meestal geel met witte lijn) met een racket over een net gespeeld moet worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4094d427a1d34ba4a08a9a028256a02f" name="Universele buitensport">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_42fe7e1780fc4ae0acfbcac32d4d6293" body="Het sport gerelateerde object is bedoeld voor gebruik ten behoeve van alle soorten sporten die in de buitenlucht beoefend kunnen worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b0f0834ab666459594dbcb2fbe7a5f8d" name="Voetbal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_19c0f01a308145bc9b4a82fa560acbad" body="Een wereldwijd populaire balsport waarbij twee ploegen van elf spelers moeten proberen de bal in het doel van de tegenstander te krijgen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d1959ab8d6a24316a636212ca05f21b1" name="Volleybal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0d4caca7684943fd9338afc738e0b5c3" body="Een olympische balsport waarbij twee teams gescheiden door een net tegen elkaar spelen en trachten om de bal in het vak van de tegenstander op de grond te krijgen of om een fout bij de tegenstander af te dwingen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f074c6bcd50d4101a8948858e5bb112d" name="Wielrennen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cc9abbea22004198a678f358e139f3e8" body="Een verzamelnaam voor alle sporten waarbij gebruik wordt gemaakt van een fiets en het op het bereiken van snelheid aankomt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_292af366d8034ba8b6dfce2f374f2377" name="Zweefvliegen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fe6e99589a2149c5817a65b8652945a6" body="Is het vliegen door het luchtruim gezeteld in een vliegtuig dat zich zwevend door de lucht verplaatst zonder gebruik van een motor."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_03e90f155bdc433296d1cf9c913dfbf6" name="enum_FysiekObjectVerbindingstype">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6b95af6ec47f4c13bda3e19a1b0423a9" name="Dichtingsmassa">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8b9d71c81c7e48b7aba5d57f07b999c6" body="Speciale kunststof voor het afdichten van voegen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6d72fccd66c045929fffc67be09c807f" name="Dubbele steekmof">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7a9c77702eda46d1bb2ebfbc7f9b2fb1" body="Verbindingsstuk waar de te verbinden leidingdelen van tegengestelde kanten in gestoken worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_88af76d014824ee2a6bfdc8458c675f2" name="Flensverbinding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e5ff35dbf5054db39a99dc54cd2543e5" body="Vlakke, platte uiteinden van de te verbinden delen zijn aaneengeschroefd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b529b6056b6d40d6821ba4d0647ee2e5" name="Glijverbinding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f20fd21e0a8e4bfc837ef56ef772cbff" body="Twee delen zijn verbonden doordat het een deel met een vervormbare rand in het andere glijdt en daarna uitzet en achter de opening haakt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d499837c10084f43bdac9c9463c09de2" name="Lasverbinding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2bbd1e2fd97d40bc99faa52ac2fdbff7" body="Een middels lassen tot stand gebrachte koppeling van twee delen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d158fdf9adca47548451e1dc92cc7465" name="Lijmverbinding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cf050bba732c4a08a28319b5c1b7e74d" body="Een middels lijmen tot stand gebrachte koppeling van twee delen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c748fe256a594fc4b0cb7624da6968ac" name="Mof/spie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_01a0cd6c504c49d19ac60c355b52718e" body="Een buisdeel dat twee buizen verbindt onder een bepaalde hoek, meestal negentig graden of meer, met een verwijd uiteinde. Een geheel dat waterdicht is, wordt gerealiseerd door een ring gemaakt van rubber om het spie-eind van de buis. Dit uiteinde wordt in"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d906154224cf4d21af1aa47227bd94da" name="Onbekend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b8415b9177354cd0ba5c3f8632717f78" body="Bij deze waarde moet nader onderzoek uitwijzen of welke attribuutwaarde van toepassing is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f9fc4af63a53496b9783a8c3a393df98" name="Rolverbinding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_62ba90a9a3e84efbbc08b836447ab20d" body="Verbinding op basis van een ring die om een spie wordt aangebracht voor spie-spie of mof-spie verbindingen, waarbij de rolring door de wanden van de ontvangende buis wordt uitgerold en afgevlakt en als zodanig een watervaste verbinding vormt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c8b3bfbdf0b94c6e8ef5969d208e3bbd" name="Trekvaste koppeling">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ba4be5105b6848a8ae2606cc29d281c0" body="Verbinding waarbij de verbonden delen dankzij een klemming inherent aan koppeling niet uit elkaar kunnen worden getrokken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a577790aff564f4da7fafbefb25f4207" name="Vaar/moer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b3785c82f1ff4e95a676555afc7608d3" body="Verbinding die tot stand komt door een schroefdraad aan het oppervlak van de vaar en de draad in de moer, die om de vaar heen gedraaid wordt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d825ec4d56164ef6a5b7db84c981f55c" name="Voegenkit">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c2399458128c4cae98d91dd8d77b0634" body="Mogelijk asbesthoudend opvulmateriaal."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_d9b90483860e4b8281073eb54a56e58e" name="enum_FysiekObjectVerkeersrichting">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bf96d2fddc6e4cb0a2b220d00336d812" name="Eénrichtingsverkeer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a309fc2eb01b4b0086adb79b3d9d1933" body="De weg is bestemd voor weggebruik vanuit één enkel uiteinde van de weg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9410f2edaa824fb7872a2664e904e589" name="Tweerichtingsverkeer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b7d3ca063a794c2c9ea3ae9de4bc0e41" body="De weg is bestemd voor weggebruik vanuit beide uiteinden van de weg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6533849cf8af459d8f6f7c71b98d2082" name="Tweerichtingsverkeer voor fietsers éénrichtingsverkeer voor het overig verkeer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_611dcd21d647437b8eb65263e9224840" body="De weg is bestemd voor weggebruik vanuit één enkel uiteinde van de weg, uitgezonderd fietsers, die zich vanuit beide uiteinden over de weg mogen verplaatsen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_f6595151c6a14ed493add9f754ecd514" name="enum_GasstationVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ad13b6c78b604dda860d799aa130b3f4" name="Afleverstation">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4155b63ba1834ea0bcdbfc094a7f5dff" name="Districtstation">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_81b65cea87de4d89991cbda02a044d84" name="Hoofdverdeelstation">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_78c9f866d4fb4eba8c4fdab6433ae2d9" name="Ontvangststation">
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_4c61ef5c72854429b29e4a72e976cdcf" name="enum_GebouwAard">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1973ded3372e455e90249d47585173f4" name="Heterogeen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_73fba2f6a0244feaa465d3c61d3adb9f" body="Gebouw dat onderdeel uitmaakt van een reeks aan elkaar verbonden gebouwen die onafhankelijk van elkaar zijn gerealiseerd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_347576ca42d743d5927a565372d711da" name="Repeterend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5cbece64aca44fc38038049bfca9d8fd" body="Gebouw dat onderdeel uitmaakt van een reeks aan elkaar verbonden gebouwen die als zodanig in één project zijn gerealiseerd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2a4dc73c647a49fa8dcfafeaffeeb954" name="Vrijstaand">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8aa3feffe9db47c89729a5dde32d6c03" body="Gebouw dat niet is verbonden met een ander gebouw."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_631c4d614dbf407eaa918991cb71facd" name="enum_GebouwGebruikstatus">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fe5e80b7ce4f49baa9ce4f2dfc90486c" name="Eigen gebruik">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c481962b6aa240c481460248131237b7" body="Het gebouw is ingericht voor benutting door de eigenaar zelf, zij het voor een particulier, zij het van overheidswege."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_213151eb4ab34ffdb016a74bfdad897a" name="Gedeeltelijk verhuurd">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_50e20365b5b049e98d9c6a95bc652a75" body="Een onderdeel van het gebouw, bijvoorbeeld een ruimte, wordt verhuurd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7eb758dd6d254b2d8c5e2f5cdd830917" name="In gebruik gegeven">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d8808f246c664ac6ac80ad4f9e620a88" body="Het gebouw is door de eigenaar ter benutting overgedragen aan een andere partij."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ed37683bb85041e7b0121a84a46f5ff4" name="Recht van opstal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9ee2660d7b7044728f7ce64a994ab14a" body="Er mag op, in, onder of rondom het gebouw door een derde partij gebouwd worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3ff4a615e509481289a13d0ea897ff12" name="Volledig verhuurd">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1ebc79a82e224a749570ce5d557edc1b" body="Het gebouw is in zijn totaliteit verhuurd aan een derde partij."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_1e103e7fc2444941886bfe18b793ad6f" name="enum_GebouwzoneAard">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4508448d78f94fb8ad16b2fdcad53a47" name="Basisconstructie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7862f079b6224c428855b7c310dd6554" body="Gebouwzone is een nader type van de oorspronkelijke constructie van het gebouw waarin de gebouwzone is gelegen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_dd23830d99084cd0836da8827af34d7d" name="Serre">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1d87746e5724416f945e113049ad6c1b" body="Gebouwzone betreft een serre die al dan geen onderdeel uitmaakt van de oorspronkelijke constructie van het gebouw waarin de gebouwzone is gelegen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e07874c00c3b40d291d421149a31e3c4" name="Uitbouw">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fac1c1d316774f3d8c4b78aed3b6cd45" body="Gebouwzone betreft een later aanbouw (niet zijnde een serre) of opbouw ten opzichte van de oorspronkelijke constructie van het gebouw waarin de gebouwzone is gelegen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_6df58ea0bc9844b4a585d1e9daf73a35" name="enum_GebouwzoneVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_574f26fda98a417a9053c6bee6b475d7" name="Agrarisch bedrijf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e62d360dc64345df94785525d059f7d9" body="Bedrijfsmatige activiteiten gericht op het voortbrengen van producten door middel van het telen van gewassen of het houden van vee."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_901f0667ea44444eb8fa83eb9e9a7b0d" name="Bijeenkomsten">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_414bd0af89e34a55a492be35fa696695" body="Activiteiten waarin grotere groepen bijeen worden gebracht voor communicatieve doeleinden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_aee79bd8926c4ceeaef7b50e77c9f57f" name="Cellen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5fbf4c75baa443818618adb39476a1ef" body="Dwangverblijf van personen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_567c5f46776d4bc1a2639e4e4c813441" name="Detailhandel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_66df7dcc951f488e81272c51f73160b0" body="Bedrijfsmatige levering van fysieke goederen voor persoonlijk gebruik aan consumenten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d890b400a1a246b09660eee4588b6fdc" name="Dienstverlening">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_41da67dfd0784ab49fed0ec016399d17" body="Levering van niet-fysieke goederen door een persoon, instantie of onderneming aan een andere partij."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0453b826f6d644f28027bb8baffc9b9c" name="Energievoorziening">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3a77f5b6fe5248dd82e23c7997dbd203" body="Levering van elektriciteit en warmte aan consumenten en bedrijven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_befe49d0dc65440e91cbd59fb6823154" name="Groothandel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b46cb14c12c84a8f95eb8ebcb0af3884" body="Bedrijfsmatige levering van fysieke goederen aan bedrijfsmatige afnemers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_838f918b805f42b38a4c83cf0dae989a" name="Horeca">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_74bb533658734afd9facad6acb11b8a8" body="Verstrekken van logies en/of bereide maaltijden, snacks en dranken aan gasten voor onmiddellijke consumptie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8b787d1ba5dc4e9f9c05e93fcd86d79a" name="Industrie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e40f3a4dde5e4bf084285b5582e8fbe6" body="Met een hoge graad van mechanisering en automatisering produceren van materiële goederen of artikelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2f0a5fe20b8c46c080df856def80dff4" name="Kantoor">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1500c259eb2c4922a7118647d8a10da2" body="Uitoefening van een bedrijf, beroep of dienst waarin geen product wordt vervaardigd maar uitsluitend dienstverlening wordt bedreven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bfd5c5f7ffbd46c6b34f3d399d5f0a4b" name="Kunst">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1b3b46f56a094c4887eb4b0975ad8eeb" body="Activiteiten waarin met behulp van vaardigheden en verbeelding unieke creatieve producten worden gecreëerd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d8191827ef96404a8e5fce8ec724abc7" name="Onderwijs">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9f28c88f66aa4f788cc8685f2a53764f" body="Activiteiten gericht op het overbrengen van kennis, vaardigheden en attitudes met vooraf vastgelegde doelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c40c23b4bf6d426598c77018d315fcc9" name="Opslag">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_82e019ae4b5249c18914f8a6a71e5806" body="Activiteiten gericht op het voor kortere of langere tijd bewaren van goederen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d994fee178404f3d81751537a553a251" name="Productverwerking">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a2a2e5aa1e534b4c9f66eff064b24fce" body="Activiteiten gericht op het verwerken van een product tot een ander product."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b3405fb2e52047cba0093fe7186a879b" name="Recreatie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ad4aa983954e4d529dc65146ebb45b10" body="Uitoefening van vormen van vrijetijdsbesteding die in hoofdzaak geen lichamelijke beweging omvatten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1454471ea9ee44f0a8d769b231638e7c" name="Religie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_70ed904f89ad4d4fa9509b17bce60683" body="Activiteiten verbonden aan zingeving of het zoeken naar betekenisvolle verbindingen, waarbij meestal een hogere macht, opperwezen of god centraal staat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e945b35c62434c3d9e9f932859ae9ad7" name="Sport">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7d06557ff188410fad4ff9416bf5eff7" body="Activiteiten gericht op lichamelijke oefeningen en ontspanning waarbij vaardigheid, kracht en inzicht vereist worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f39184389cf544a4b24cc0ee7eaac2de" name="Techniek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_910856cd02924cc59855c392e9ef8acc" body="Activiteiten waarin de ontwikkeling of het gebruik van apparaten, machines en andere complexe voorwerpen centraal staat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7d5bd1e33ca64970914bfbc7a2a6321d" name="Voertuigen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_041e361d7b034c7789d72f117f7758d5" body="Bedrijfsmatige stalling of opstelpunt van verkeersvehikels."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c1d27f0bb084491c8456fadd453429ac" name="Wonen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2b9825c5edee434a9c995ace38f571a0" body="Permanent verblijf van personen voor niet bedrijfsmatige activiteiten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c6534b44bf5747348e9980b68f051281" name="Zorg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_80149a4c80024545a3e9d334afc7814e" body="Bieden van lichamelijke of geestelijke hulp of aandacht."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_bd843518962a42489c68e315e01c8613" name="enum_Geo-ObjectStatus">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a90089398c674078851c647e87105147" name="Afgevoerd">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_465b6e65250d43b2bd0c1e0ace484ebb" body="Object dat ten onrechte is opgevoerd in de registratie of waarvan is vastgesteld dat het ontwerp of een geplande bouw of aanleg niet heeft geleid tot een feitelijke realisatie van het object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7297ebc7858e46e5b002ddbc65a8405f" name="Bouw gepland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9eed479177914a62822b25a9812706de" body="Object dat nog niet is gebouwd of aangelegd maar waarvoor de voor de bouw of aanleg noodzakelijke ruimtelijke procedures zijn afgerond."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7e07e8f44f734007859904c263710776" name="Buiten gebruik">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0f4f74e08f934753ad3420b542fcb19e" body="Statusbeschrijving die aangeeft dat een object niet bruikbaar is voor zijn gebruikelijke functie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_741eb6b3edd44ad4bdb6aa205c888e77" name="Dichtgestort">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6ec3dab91d764036914ea79df84fe889" name="Gesloopt">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7d4ab01788dc49f8aa25e51efa3cde94" body="Object waarvan de feitelijke sloop of verwijdering is afgerond."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_567a6e8daf784c57b59b475bfd88e182" name="Gewijzigd">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3fbdd0772c0741439ff30d67d30bdb30" body="Status die aangeeft dat het object in de werkelijkheid een verandering heeft ondergaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cc5c01111a06424ea9ca8677f5a322e3" name="In aanleg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d1c2fe16f5904de989262323ca07c45f" body="Statusbeschrijving die aangeeft dat een object zich bevindt in het proces van realisatie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ce93c91c29e0412db91f888afa1c892a" name="In gebruik">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0b3979efc75946aea9e23176334cbe58" body="Het object is een actualiteit in de werkelijkheid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ba986832155f4bf1bf2fc83c93e88390" name="In ontwerp">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4cc3e34664984049be1ac20a20af6330" body="Het object is planmatig geschapen, maar nog niet gerealiseerd in de werkelijkheid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_08844ffadc6940bbbf220696199d7009" name="In opslag">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_87471b2ed0534fdf89cf339675ed4c42" body="Het object is (tijdelijk) buiten gebruik en voor toekomstig gebruik opgeslagen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_247b9d45448a43e3ab332d1e37abfb94" name="In sloop">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2d13fc04dc9e4006b3e72d5bb1e83125" body="Object waarvan een langdurig slooptraject is aangevangen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_60c0a16f9b78402eaad0dc61c12fc618" name="In voorbereiding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5d3096da4dbf4ba7b30b11f6622e7036" body="Gevormd object waarvan de voor vervulling van de functie noodzakelijke reële objecten nog niet gereed zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3c84e573494149a7a78df1a6cd31f04b" name="Ingetrokken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3f4a7939cb9e4b898d563cec92df5689" body="Object dat door het bevoegd gezag is herroepen op grond van wet- of regelgeving."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b3ffcf565c7f423f903d25f0d8f9136a" name="Kelderresten">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5ec15071d57d418185e3717992b2aabc" name="Niet te beoordelen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bbb8544989c74b678dba1b04e49f864c" body="Status die aangeeft dat de toestand waarin het object in werkelijkheid verkeert door middel van observatie niet kan worden vastgesteld."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_af430d33ac9445a487389e8b2a75cc43" name="Nieuw">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_97615448a01c438c8326bda797e5c623" body="Het object is recent komen te bestaan in de werkelijkheid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9ee2a04dd025459b918f8255a3be6ea3" name="Onbruikbaar">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_11835f4d8d9b4732808ff6abc9830c81" body="Object dat niet geschikt is om zijn functie te vervullen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9bdae89dee694c80b9d54fbd095b2445" name="Ongewenst">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_29490829e2e1402192d5420fc5bdb2aa" body="Status die aangeeft dat het object zelf, of diens toestand, als verwerpelijk wordt beschouwd vanuit het perspectief van de beheerder."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ccc644ddd06e4756a430cadf32cd6c4d" name="Sloop gepland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ce89779e934d43b4b230c22dca96c79c" body="Object waarvoor de voor de sloop of verwijdering noodzakelijke ruimtelijke procedures zijn afgerond."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6067e0eddbc04614b6b7c611529e154c" name="Toekomstig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c6b5a234de404373a342165e1d776b9b" body="De status &quot;toekomstig&quot; duidt op een toestand die nog niet is ingetreden, maar die in de toekomst zal plaatsvinden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e3cc8dbfb99e44e48b3d233531f021a0" name="Vastgesteld">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8a20ff72015448db97c28ba325eb61fc" body="Object dat door het bevoegd gezag is benoemd of afgebakend op grond van wet- of regelgeving."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cc86fffa412d4602b9e054a3c65c1478" name="Verbouw gepland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f93a3453c23f4425ac5645e60c56457d" body="Object dat nog geschikt is voor oorspronkelijk gebruik, maar waarvan de voor de verbouw of wijziging noodzakelijke ruimtelijke procedures zijn afgerond, en de verbouwing of wijziging nog niet is voltooid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0af388135e8744bbaa12f91fa013a06c" name="Vervallen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_82cbee5e76144dd695bb976565346867" body="Het object is in werkelijkheid niet langer aanwezig."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c3f239c501264682b4e4b26d8b92ae72" name="enum_Geo-objectWegcategorieDuurzaamVeilig">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0befe1882c4841bfb445ab8977251377" name="Erftoegangsweg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_06486cf802964247b1af43675e01e823" body="Weg bedoeld voor het toegankelijk maken van erven (in de verkeerskundige betekenis)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_888c0121454c44dc9c25b235237b3feb" name="Gebiedsontsluitingsweg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7656b81e10ab4ffb873a26e09fda3941" body="Weg waarop het verkeer op de wegvakken kan stromen en op de kruispunten kan uitwisselen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0521e93e6a9342eca916a919a3c09a82" name="Nationale stroomweg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b8b3508810c94db8a540a54b648d961b" body="De wegen van de hoogste orde. Deze wegen voorzien primair in verplaatsingen tussen landsdelen en bijbehorende economische en culturele centra. Ze sluiten bovendien aan op de hoofdwegennetten van de buurlanden, zodat ze ook voor internationale verplaatsing"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0fe5845e9e71415ab54f3d1f0ebadf15" name="Regionale stroomweg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b68481e0b99649ab83f34d9e3c5574b6" body="De verbindingen tussen regio’s en bijbehorende centra."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fe80c3764c1544828c5994cdaba57da5" name="Solitair fietspad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fef0caecea8d4b34b638e91985ac2084" body="Aanduiding voor fietspaden welke niet langs een weg liggen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_62f964f36a2a46a983d8af46b803f3be" name="enum_Geo-objectWegcategorieDuurzaamVeiligGedetailleerd">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6c3d6ac21d664b8d9f9f5c4cbe07e9c2" name="Erftoegangsweg: 30 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2e9dece079804c7da9768c75fc17f3c0" body="Altijd bibeko (binnen de bebouwde kom)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_65010b7a32a34ee3b41a7c86eb7a642a" name="Erftoegangsweg: erf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aca554c9735f46a68b620af3b072a7e5" body="Altijd bibeko (binnen de bebouwde kom)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cdc9a294eed34123a22f5538d5883b6e" name="Erftoegangsweg: fietsstraat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a6edbb62fbe6466c8049a85085b38ab8" body="Altijd bibeko (binnen de bebouwde kom)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9d0870c2bad440fe9087fe44dbf60d0a" name="Erftoegangsweg: type 1">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c3596b4815c04b9e8e5aa3493b3f2e4f" body="Altijd bibeko (binnen de bebouwde kom)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2d76919b0f4e4998bd1a328881121a17" name="Erftoegangsweg: type 2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_953a532ad49a4c5fbe1c93b7dc5e2775" body="Altijd bibeko (binnen de bebouwde kom)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bb9c8ef03f884e45b8a87de02ecf81fe" name="Gebiedsontsluitingsweg: 50 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8f9baa7f374748d8bafa79995f2ad298" body="Altijd bibeko (binnen de bebouwde kom)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d0d300c449eb45afb7142f5643eb3157" name="Gebiedsontsluitingsweg: 70 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0958a07d6a4d4c9795347565beff669a" body="Altijd bibeko (binnen de bebouwde kom)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_427bb394698d4d63ac41f86feaa2d870" name="Gebiedsontsluitingsweg: type I">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f59893edeb2d4e4e994fa5afe2be5493" body="Altijd bubeko (buiten de bebouwde kom)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6900bf50ece34089963f0cc4b6aea306" name="Gebiedsontsluitingsweg: type II">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fe57e3e2b54a4fa5929215c3c9c4dd19" body="Altijd bubeko (buiten de bebouwde kom)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d92083c5376546ab99c7ff2c51243ec0" name="Regionale stroomweg: type I - 1x2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8b4451c421db4216b9c79c83b6aefe83" body="Altijd bubeko (buiten de bebouwde kom)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_714c73a1a63c44ff8fd60bc66ad3ff1f" name="Regionale stroomweg: type I - 2x1">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_97a982f2c9ea4144a07e7305cdb16816" body="Altijd bubeko (buiten de bebouwde kom)."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_9d23d39539004368a02bdf20156e2c6f" name="enum_GlijbaanVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b16aad1419734f8680735d8b343a9cff" name="Glijbaan type 1">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_72c6b64fe2c54aaaa3f20fc4e233ce7d" body="Een glijbaan waarbij de glijbak de vorm heeft van een niet krommende, dalende helling, al dan niet met een uitloopsegment als verlenging."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_eeb594a4d4344aceb794e7d8b0c1bc46" name="Glijbaan type 1 met meer glijgoten">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_12e1460e192f4343a1a355bc58dff98c" body="Een glijbaan met meerdere glijbakken waarbij ieder van die bakken de vorm heeft van een niet krommende, dalende helling, al dan niet met een uitloopsegment als verlenging."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_937508b3456b4b1eb5688223ec8b10d6" name="Glijbaan type 2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_98daa2fa2b0c44048f413326f099a557" body="Een glijbaan waarbij de glijbak de vorm heeft van een kromming of een golf, al dan niet met een uitloopsegment als verlenging."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bd9a8e44860d4cc8918f9de7a3eb56ed" name="Glijbaan type 2 met meer glijgoten">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2dc63a3af79c4354842f2e8d04755a25" body="Een glijbaan met meerdere glijbakken waarbij ieder van die bakken de vorm heeft van een kromming of een golf, al dan niet met een uitloopsegment als verlenging."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_9530b0a4b8c540818e60d282e6f5deab" name="enum_GlooiingVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9e70f4056207470b94d815ab0a8aeb6b" name="Bestorting">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_366719106bcd4658a56a927455e36f90" name="Steenmatrassen">
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_4580505960304a509c021097420edfef" name="enum_GolfbaanonderdeelVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1c860b2f3e98419e8dcb8045dbdbc71e" name="Baan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7446d9ea1322449ca64e645aa2ae696a" body="De verbinding in het golfspel tussen de start en het eind van een hole waarop gespeeld dient te worden (excl. green, bunkers etc.)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_aca81c0db7064eca80a67d3b46cf81be" name="Bunker-golfbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_700f9e8d2e514b7f8beba1440d8c651f" body="Een bunker is een met zand gevulde hindernis op een golfbaan. Een bunker maakt deel uit van de baan en bunker bestaat uit een ondiepe uitholling waaruit gras of aarde is verwijderd en vervangen door zand. Bunkers bevinden zich op strategische posities in "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6f0526c0b5ca4308acb8b2d872b6fb56" name="Carry">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b6fcda67d2464f1783d40e4690202cc8" body="Het gedeelte tussen de tee en het begin van de fairway. De begroeiing ervan kan per hole of per golfterrein sterk verschillen. Solitaire bomen die dienen om het landschap visueel te breken mogen het spel niet storen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d98034847b4f4f0485fa35ad97d5eab3" name="Chippinggreen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bbb54e76a8864c7eb1c26c9593f7c89c" body="Plaats om het chippen te oefenen. Dit kan over een obstakel gaan als een bunker, heuveltje of eventueel een watertje, richting de green. De afstand is ca. 25m of korter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_42c0122a02f541b1b488b72ae5701be5" name="Circuit Training">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_854d01e7f8a74240b8f0976187e934f5" body="Een buitenfitnessveld ingericht met toestellen die gebruikt kunnen worden in een roulatie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_03d706a7ce8c49119514cd3163bfefe1" name="Driving range">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a4805aa7b36e4b87bd7544edc407749a" body="Het oefenterrein waar golfspelers ballen kunnen slaan over grotere afstand, vaak voorzien van meerdere afslagplaatsen naast elkaar."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c4e4c2f2369540d08ae26ec241a68412" name="Fairway">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4bcd3aa25f9945228f660a5f8b1f0efd" body="Het deel van een golfbaan dat zo’n honderd meter na de herentee begint en loopt tot aan de foregreen. De lengte van dit onderdeel is afhankelijk van de hole. Het is meestal tussen de 15 en 45 meter breed, egint vaak 50 tot 200 meter na de tee-box en eindi"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a976b40b23ca4846802472ca6dfbd893" name="Foregreen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e3ee4b15acb047a7a9a0788e9d388363" body="Het stuk baan om de green gelegen waar het gras net iets langer is dan op de green. Dit stuk tussen de fairway en de green wordt ook wel de &apos;fringe&apos; of &apos;apron&apos; genoemd en vormt de overgang van de fairway naar de green. De apron ligt rondom de green."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e2403cfe316b48698ed09481d5c1d5e3" name="Fronttee">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c33038b6cd504098abd41e65fd96d4b4" body="Op de 18 holes baan is voor de teeboxen veelal een front tee uitgemaaid in de semi rough. De onderhoudsmaatregelen betreffen de gras tee’s op de 18 holes baan, tenzij anders is aangegeven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6a0305c712c54345a419668bd264ec3f" name="Green">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5731211feca4487883b7e51ecc405736" body="Het kortgemaaide gedeelte gras rondom de hole en het meest intensief bespeelde deel van een golfbaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f2fd742c43f347e59f29f37e3da1208d" name="Hindernis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d88b25715ced457286ac970943dc474a" body="Alle onderdelen op een golfbaan die geen onderdeel van het spel zijn kunnen als een dergelijk obstakel dienen. Denk aan vijvers, bosplantsoen, etc."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1536099a2cbd412ea5079fe05eecc45f" name="Hole">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c32044c02fab45e48968545b1115d466" body="Stuk golfbaan tussen tee en de green rondom de cup."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b11bc671acbc45abae5382cc7e08c172" name="Lus">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4f069fb0767d42398d4122d959ceaaa8" body="Groep van 9 holes."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5c0b3fe8ac024c8d99d7c7ed54fe6bb4" name="Oefengreen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a5dca6f2b6ea4322b7f89d3de0a6081d" body="Green voor het oefenen van het putten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b1174485575840c4881044ef23ee7292" name="Out of bounds">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_893c1ec0a67248678cc34f04815e0f75" body="Alle onderdelen die buiten de baan (spel) liggen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_66534c27b87a489db5a5dcb2d78c9093" name="Rough">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b5abcc7deab244d6a32b91776ea8dc2b" body="Het gebied buiten de green, tee, fairway, semi-rough en apron, de carry en waterpartijen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0e7a0978bb764f9e9179769732d6953e" name="Semi-rough">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dfd97e67e0d944329f1ef98726042cb8" body="Langs de fairway bevindt zich een strook gras van ongeveer 2,5 tot 5 meter breed en een hoogte van 30 tot 40 mm, ook de omgeving van de green grenzend aan de apron bestaat vaak hieruit."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_57f998cbda5f46b584f64da78ba5b110" name="Slaglijn">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4244fad5aebd407287a111a40b70c877" body="Ideale lijn voor het spelen van de golfbal tussen tee en green."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_828b43656aa444e7b7e87a22cd997fc9" name="Surrounds">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c6588c09a17f4f7bb8a062c11282ba66" body="HJellingen in de omgeving van de green (mounds en graskuilen). De hellingen in de vorm van heuveltjes worden mounds genoemd. De gemiddelde oppervlakte aan surrounds op een achttienholesbaan bedraagt één ha."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_73373275226a4e42b41025a9afcb2334" name="Tee">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fa9e372fd1cd4713b4026f61c76890a2" body="De afslagplaats aan het begin van een hole. Het iseen begrensd, kort gemaaid en meestal licht verhoogd gebied aan het begin van de hole. Vanaf hier wordt de bal met een verre slag over de carry naar de fairway geslagen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_abef4c87db5144a78d8d8d73c3d7bb8e" name="Waste-area">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3eaadd9b7b4e4ab09f8a70592376a6c9" body="Grond op de golfbaan die niet functioneert als hindernis en niet bedekt is met gras."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f3bb32015f9a4cb5b0cc9d6aca4132ad" name="Wintergreen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_19a2be6083ca400cbe70af5fcd8f7c12" body="Gemerkt deel van de fairway tijdens de winterperiode bij gesloten (zomer) greens. Het wordt gedurende het gebruik korter gemaaid dan de resterende fairway."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_2bbe08ea0901487db501fdce64987b02" name="enum_GolfbaanVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_36d272239cf34c0bb47a83f0bc902e65" name="A-baan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_07fe24e103194d9390b36ee968663d68" body="Golfbaan: minimaal 5.200 meter (heren) en 4.550 meter (dames)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_48d03e19032c4427ad1cbdf98583fc05" name="B-baan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f0d7f0f8aa894251870c66d988d62edd" body="Golfbaan: tussen 3.650 en 5.200 meter (dames en heren)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cebf000e62b646699b96fd4751c91473" name="C-baan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_60827c3272714b3a9b73c740caccdfbb" body="Golfbaan: tussen 2.750 en 3.650 meter (dames en heren)."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_2032f5c0a2af47caaaf0b341cf70025e" name="enum_GolfterreinVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e60a96c213cc4ac0b07caccd28524f40" name="Bosbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_43cba9cfbd574737bfaba30b0eb73303" body="Een golfterrein in een beboste omgeving, waar men met andere zaken rekening moet houden dan op een kustbaan of een polderbaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1c4a0f8ef1254d5388eea54a79c514fb" name="Duinbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e39d777afb6e459090442caa7fb59fc1" body="Een golfterrein dat is ingericht op een terrein met een duinachtig fysiek voorkomen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e19dc0ce9c524a09864079990662ff02" name="Par-3-baan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ba0cb56f4f724add8fc363588204d838" body="Een golfbaan waar geen baanpermissie voor nodig is bestaande uit kortere holes dan een reguliere golfbaan, maar langere holes dan een pitch en put baan en waar een professionele golfer drie slagen nodig zou hebben om een par te maken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c5eabcf9941b4ac2a04c298828e8a88c" name="Parkbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_13e6f7a7981149c3962c9a6c0cb69c79" body="Een golfbaan die is aangelegd in een park."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a5f340248ad341df8543f32bdd304e58" name="Pitch en putt baan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4280aaa537144b11ab8a9d74d883577d" body="Een golfbaan die bestaat uit negen tot achttien holes die korter zijn dan reguliere holes en met maar twee clubs gespeeld worden: één om mee te pitchen en één om mee te putten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_06951c0fd7d344a993502c79d81435ad" name="Polder- en weilandbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0984238296a848a99203bd9517db0e48" body="Een golfbaan die is aangelegd in een weiland of op een open polder."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c60f6a61ca9349ea8fa8bbe921589da5" name="enum_GrafJuridischeStatus">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a940df27e2ec4779bb675acb7e4cd95f" name="Algemeen graf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9e5e5e16c1624f1ea59885f138c77cb1" body="Een bestemming waarbij de houder van de begraafplaats bepaalt wie daarin wordt begraven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9ce662f46e18419e9b6369dbdbf92c6c" name="Particulier graf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7ceadadc744b46e99c2a46d9ac7b74eb" body="Een bestemming waarop een uitsluitend recht is gevestigd, waarbij de rechthebbende bepaalt wie daarin wordt begraven."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_19bd5dec9fd44c65bf79263e94bceb5a" name="enum_GrafVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_aff1a1b7a7874b65956a0865be184ccb" name="Familiegraf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_86add94ffa1d4d78a43f9b838eab1824" body="Enkel graf waarin meer dan twee leden van één familie zijn begraven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fb081d9f71e444a2bdc8e875890b99d6" name="Geallieerdengraf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e6d8efdedf5f4cde8332757ffc109ebf" body="Een laatste rustplaats voor de feitelijke of symbolische menselijke resten van overleden soldaten die behoorden tot een van de landen die zich tijdens de Tweede Wereldoorlog verbonden als de &apos;geallieerde mogendheden&apos;."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a046c616dda8433984fc69cbb592424c" name="Oorlogsgraf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a9a72ad6511d4c0f86698513436bd47f" body="Een laatste rustplaats voor de feitelijke of symbolische menselijke resten van oorlogsslachtoffers."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_1bf7446d4db944c49bbaed3b3cfb0153" name="enum_Gras-EnKruidachtigenVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9f8bbb5aaa3e48d8aad67981d2f957fe" name="Droge ruigte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1d6c7734ba6e4c268e1e9b3735d7cc77" body="Hoge ruige vegetatie met veel Akkerdistel en Brandnetel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b27763b78fc148edb2f0475b6bb41f7e" name="Gazon">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7d28dfe04e7346d1be1016d2636a15a8" body="Verschijningsvorm: grasterrein met relatief uniform grasmengsel zonder onkruid, met een maximale hoogte van 70 mm, Functie: verfraaiing, onderdeel van de groenstructuur zoals vastgelegd in beleid, Beheer: Wordt veelal intensief gemaaid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9150db44d0424ebf982223856ed1e106" name="Gazon extensief">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_52be48e091b74ec39000cb90f456e4fb" body="Grasterrein met relatief uniform grasmengsel zonder onkruid dat extensief bewerkt wordt, dat wil zeggen gazon dat kleinschalig en niet gemechaniseerd, minder vaak en minder kort gemaaid wordt dan intensief gazon."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_14502238661d4cb8b7d98a88078169bc" name="Gazon intensief">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_481f4f882f19435681070a90cc964a33" body="Grasterrein met relatief uniform grasmengsel zonder onkruid dat intensief bewerkt wordt, dat wil zeggen regelmatig kort gemaaid wordt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_870637ce2310408eb614335c3379f8ee" name="Grasveld">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f48328f132d34eba9c5165c430548a23" body="Verschijningsvorm: grasterrein met relatief uniform grasmengsel met beperkt bedekkingspercentage onkruid), met een maximale hoogte van 100 mm, Functie: onder meer verfraaiing recreatief (mede)gebruik, zoals spelen, recreëren, lopen, picknicken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4731e081b67f49b5885af0a686a8c055" name="Mosvegetatie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cc5611dd60a34fd2ae7b8b105c504444" body="Matten- of kussenvormige begroeiing van dicht opeen groeiende, kleine kruidachtige planten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7a82b439d51b45c2a9c24d6b988c0db8" name="Plasdras">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d12e842f50094ca19099447892a52f56" body="Voorkomen dat ontstaat door lage delen van april tot augustus of zelfs het hele jaar rond onder water te laten staan of onder water te zetten (0-20 cm)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a7926610d52147fc8c4e4a6a82a5cd50" name="Ruig gras">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_31fb9a9231f54abfa5a50cbc18e200ff" body="Terreindeel met gemaaid(e) gras (vegetatie). Ruiggras wordt onderhouden door het zes tot tien keer per jaar te maaien, afhankelijk van de grondsoort."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bff228bcda2a435a8a1f1a04550a32d9" name="Ruigte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_972a959a6351453d95be3c2a3592192c" body="Verschijningsvorm: gevarieerd grasmengsel met beperkt aantal soorten van hoog opgaande, meerjarige (overblijvende) algemeen voorkomende kruidachtige planten zoals distels, gewone berenklauw, brandnetels, bramen en diverse grassoorten; Functie: verschillen"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_efd173929f0340088f057eb190893b8e" name="Ruigte zonder boomvormers">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2592ad3a4f7c40658c18450893489ca4" body="Hoge ruige vegetatie met veel Akkerdistel en Brandnetel, zonder boomvormers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4085835c05fd44f787fae313ba534f10" name="Ruw gras">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7b4fbd05ff9a4ddcbf0cf8f37d4fa8f5" body="Verschijningsvorm: grasterrein met gevarieerd grasmengsel met kruidachtigen, met een min of meer ruig karakter, met een maximale hoogte van 1000 mm Functie/doel: verschillende functies, Beheer: extensief, de maaifrequentie ligt veelal tussen de 1-2 en 6x "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_33189accfbfc4bf19a7d7058d8ae963a" name="Stinsenbeplanting">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_017fcddb095849a3bef6b7a9103d8b7d" body="Stinsenplant (of stinzenplant) is een in Nederland en Duitsland gangbare benaming voor een groep planten die van oorsprong in een regio alleen als ingevoerde sierplantensoort voorkwam in landgoederen, boerenhoven, pastorietuinen en dergelijke, en zich daa"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_27299101271f4bffbb4fad4efce77966" name="Valdempend gras">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c0792aed7aa44100954a56ed58d8919d" body="Natuurgras geschikt voor een valhoogte tot 3 meter. Het betrokken product heet BUMPgrass®. BUMPgrass® bestaat uit een onderlaag van speciaal ontwikkeld steenwolsubstraat en een grasmengsel dat geschikt is voor zeer intensieve bespeling."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c31a4fadfc1a471492bedb0f97e9fcf4" name="Zoomvegetatie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5af590676a0241f88d10be0b904bbe39" body="Ruige begroeiing met vrij hoog opschietende kruiden op vruchtbare bodem."/>
        </ownedLiteral>
      </packagedElement>

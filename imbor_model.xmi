        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8cda567bb8654375840df48058a4a268" name="130 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8ae194bf9f784edcbb2066625f2d4932" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van honderddertig kilometer is en de tijdseenheid één uur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e7203d24128e402088d6b8f2c2fec00a" name="15 km/h (= stapvoets)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_099fa19fe47a4d6287d69dd29a2d1ecd" body="In een arrest van de Hoge Raad van 5 oktober 1999 is bepaald dat stapvoets gelijkgesteld kan worden aan 15 km/h en dat overtreding ervan visueel kan worden vastgesteld."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6a4b47c9adac435caafdd0cb6d5b67aa" name="30 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1d60f08c9deb42d99be5f87373beb6ab" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van dertig kilometer is en de tijdseenheid één uur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_04283b3e41fb4c0f990b671342c6e09d" name="50 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0aaff4a6906d4d5f897adec2c8bf05cf" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van vijftig kilometer is en de tijdseenheid één uur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d23b0b6400e5475681dc868f822de5e0" name="60 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4a636ea49066446c99b618ccff93ba92" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van zestig kilometer is en de tijdseenheid één uur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f61cd40780794c8a910a76e0eb11eadd" name="70 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4e581e3ba99441b7a4a343fd7264f664" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van zeventigkilometer is en de tijdseenheid één uur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4fb777c5e2c14a83860437c56c527109" name="80 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cb98357b764b4289aff66b7324964b07" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van tachtig kilometer is en de tijdseenheid één uur."/>

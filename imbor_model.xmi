          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_097b07dbb72b4aa2898b84cc3332b484" body="Indicatie van de nauwkeurigheid in horizontaal vlak (x,y) waarmee de geometrie van de ligging van de leiding is aangegeven. De nauwkeurigheid is minimaal +/– 1 meter. Default wordt er niets vermeld. Indien nauwkeuriger dan +/– 1 meter kan men dat aangeven Millimeter"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="attr_c2b90b22da2e458b9c26bf219140cac9" name="verhoogd risico">

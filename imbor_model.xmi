        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_04e8ce85c96c468c82140714dc4ff527" name="Informatiebord parcours">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b2507d01dca440e980e210083284f276" body="Een bord dat informatie verschaft over de aard van een recreatief of sportief parcours."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cad8ab8160dc4976911579fd392067fb" name="Instructiebord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_76e227cdbd2d4770bb250ea29d3b9c9b" body="Een bord met daarop de instructies voor een speeltoestel of -terrein of voor een sporttoestel of -veld."/>

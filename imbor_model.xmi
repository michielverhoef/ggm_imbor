        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6a670d9fb62f469dacccc417fca1f9b3" name="Klimduikelrek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dc1248f253f3407497c51d5611f20748" body="Een klimrek dat is verbonden met een duikelrek."/>
        </ownedLiteral>

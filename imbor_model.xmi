        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_899f82cf26b04dcb9a31af957e1ede2f" name="Inspectie boomonderhoud">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c2e0a7a329a644399ffbad2bfd241ca5" name="Inventarisatie boomgegevens">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d742c05ab9ac430493ba22ce045cf122" name="Orgelboring">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2af57e65aa1c46feb59502c683ba6a37" body="Het verzamelen van kernen uit de asfaltconstructie door dwars op de rijrichting te boren."/>
        </ownedLiteral>

      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_a154e64b07834322b8836a5170d6d49f" name="enum_VerhardingTypeConstructie">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bfb821f450c9469fbcec8892cd0dae6e" name="Gemiddelde constructie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e154cbf7072e4737b2df7eaff68e4a1c" body="Een constructie van middelmatig gewicht."/>
        </ownedLiteral>

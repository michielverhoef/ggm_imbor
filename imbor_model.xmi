        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f534e4c8d86342faa2664cc6ebf102db" name="Grondwatermeter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b56806361916484e8876e181ddff52d6" body="Een buis met een schaalverdeling, een meetinstrument, waarop af te lezen valt hoe diep het grondwater onder het maaiveld staat."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_dbbd464eb156468480821466e0f28dd1" name="enum_DekselVorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e9065546359f40c0ab3a04f5f30f387a" name="Rechthoekig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b8399260e62748c490202451282cab8c" body="Een vierhoek met louter rechte hoeken."/>

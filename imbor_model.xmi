      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_2589f69fd1a848ec842450fc4bd82dfb" name="enum_FloraEnFauna-InformatieFloraEnFaunawetAfwijking">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2f8b642cb8f6434f9c827bbcd308e3d4" name="Arboverplichting">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f71cb8e2101c49578544c191b5568433" body="Een uitzondering in het kader van verplichtingen die werkgevers hebben richting werknemers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_14930bdc2c3d46dda87acfa42d30b0c1" name="Extensivering / mitigerende maatregelen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c0394794537c480a9b8cdd83c24168a9" body="Maatregelen die negatieve effecten wegnemen of het minder intensief bewerken van objecten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6bed411e229b4042828bbcbf2747895c" name="Laag gelegen landbouwgebied">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2e88dac9a30e4005904c381a3794ec2b" body="Een gebied voor agrarisch gebruik dat relatief aan de omgeving een lage peilhoogte heeft en welke vanwege de risico&apos;s omtrent die lage ligging en de invloed op flora en fauna als uitzondering op enkele bepalingen uit de flora en fauna wet is aangemerkt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fd7be7494eeb4c9da352e30ae21fe0c8" name="Piekafvoer en bescherming bebouwing">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_41627d619a7a49c2a05abf47448b79b1" body="Een afstroming van een waterobject die in de bedding terechtkomt en er bevindt zich bebouwing die onder bescherming staat van een bepaalde organisatie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_147c08d51ced4ed795d7d31a8dce1c7a" name="Piekafvoer hoogwaardige teelt">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8f158de2975c43d385efc6cad65eba64" body="Een afstroming van een waterobject die in de bedding terechtkomt en agricultuur van goede kwaliteit."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6f141f91873b47468e27b3b0ea7ddb51" name="Piekafvoer regelmatig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4b08ea77391743ff91b835d9b90e0258" body="Een afstroming van een waterobject die in de bedding terechtkomt en regelmatig plaatsvindt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c9732653ac2c4f29a091973313715b1f" name="Wateraanvoer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_294d900648d240ed9e741008c0a8aa11" body="Het verplaatsen van water naar een bepaalde plek."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_b20f92706cae4bffb1c21ac4d30a56e9" name="enum_FruitkwekerijVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e39405b3140b43fc962eddb5b065b214" name="Hoogstam boomgaarden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d0db14e3fc1d4e03b669e357abfe2d3f" body="Laagstam fruitbomen hebben een stam van ongeveer 40 tot 50 cm, gemeten vanaf het maaiveld. Vanaf dit punt wordt de boom doorgaans geleid of gesnoeid op een specifieke wijze waardoor de boom veel fruit produceert."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6e105cbc43a84c3b88488742681b083e" name="Klein fruit">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_92180834b04e453fa06f147edf80cf93" body="Een met hoogstam fruitbomen beplant stuk grond waar vruchten en noten geteeld worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2f5f91f35081426eb07ffa8248e2d058" name="Laagstam boomgaarden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f34f28d7bdc244a1bb8a2e36fd8db16a" body="	Terreindeel begroeid met laagstamfruitbomen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_60e94ab7cf024db58b8d664f7389782b" name="Wijngaarden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_91871090224c47dd86184c50a5fd702f" body="Een wijngaard is een met druivenplanten, ook wel druivenstokken of wingerds genoemd, door wijnboeren in cultuur gebracht stuk landbouwgrond."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_dd85977c3e4648a6b3e0ba6ef9cede70" name="enum_FunderingTypeFunderingsconstructie">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ec4849dcdc024828aca5bf101cf59e4e" name="Betonvloer op palen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9dc33b1dd58147d68605ae64cd2ac2cc" body="Een fundering die bestaat uit een betonnen grondvlak dat wordt ondersteund door een verzameling van in de grond geslagen palen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0066849007524109b48d513d6d00d65e" name="Boorpaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7da9fedb9d114ca7826be16d3db5b082" body="In de grond gevormde betonnen funderingselement van grote diameter (1 tot 2 m) die tot grote diepten in de bodem kunnen worden aangebracht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c2290522c937491f99dea607072479fd" name="Gebonden fundering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b8b9d5212bee4ab9ab6ea5b943262d23" body="Funderingsmateriaal waarvan de elementen onderling verbonden zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_62145df7cd0b4301994be035e976415c" name="Gedeeltelijk onderheid">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_045e328f39754c9c9507cdc92706aaaa" body="Het object is voor een gedeelte van het grondoppervlak van het object voorzien van een fundament van heipalen en voor het ander gedeelte is er geen of andere fundering."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c5acbdbafd1a4116a903d4cf80567b3a" name="Geovlies">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5f7cae2034bc48578ae047297d7fb859" body="Een stabiliserende doek die als onderste verhardingslaag kan worden aangebracht om druk te verdelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7abb4bf39ef34f8c99f9bf88790567fb" name="Houten roosterwerk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_165a5703f6a64d118af340a728e798cb" body="Een fundering die bestaat uit langs- en dwarsverbindingen van houten balken of planken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_57c8316f13234076b8767264e2011df1" name="Ketelzand">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_544985550aec4664819acc30fe05d243" body="Een verbrandingsproduct uit energiecentrales dat gebruikt wordt als ophoogmateriaal voor zettingsgevoelige gebieden en die dankzij de haakvormige korrels goed bestand is tegenwater."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_14c0c9776c194b56bfdbf2888fd9e0a5" name="Kunststof stabiliteitsconstructie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d37fc49326d94eb29dc016d10d2604ea" body="Voor betere stabiliteit, waterafvoer en robuustheid. Geen onkruid, bodemerosie of spoorvorming."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_74fe2bd7414046178bee61b5a7346a5f" name="Ongebonden fundering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b64a4954176d4dd8a27e12eb2613e780" body="Funderingsmateriaal waarvan de elementen niet onderling verbonden zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a52a5d97a11c4922a304f60094b9c4e8" name="Prefab fundering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8f5bbc197c844fb899960a9674b99db8" body="Fundering die in zijn geheel in een fabriek of werkplaats is gemaakt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a53c13ce18c94106a3d9d4211b577d39" name="Wapeningsnet">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6628675697c34d159fdf469c1773d7a6" body="Een kunststof weefsel (meerdere uitvoeringen mogelijk) dat onder het gras wordt aangebracht, voor een meer gelijkmatige verdeling van de belasting zorgt en de mogelijke schades tot een minimum beperkt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a7843fdd71be4272bd07ca144013b03a" name="Zelfbindende fundering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_57f602db85194a82b10b6cea3b185487" body="Funderingsmateriaal met een kleine hydraulische werking zodat op basis van de eigenschappen van het materiaal een lichte samenhang ontstaat."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_92b460562f2f446cb42beb273a33fb78" name="enum_FysiekObjectBelasting">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2b5a907a4e0d4c299604baa6b59b2c0a" name="Licht">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_618d7fffbe1f4e48a2173d888c2bcb55" body="Kwalitatieve maat voor de geringe lasten die een object ervaart van passerende (weg)gebruikers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a200b99605a64799ad674dcb3a740d96" name="Niet (volledig) te beoordelen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6a47cd0cf5324b6ca1466e1174e56d5f" body="Het kan niet of in onvoldoende mate vastgesteld worden wat de domeinwaarde van een attribuut moet zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ba122f4087254fcda0d6331061446351" name="Niet bepaald">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0d872eb0406043699a021808289398d4" body="De domeinwaarde van een attribuut is niet vastgesteld."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7e09460c953d43009cca8c0845a6399c" name="Niet van toepassing">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_42d222413ce141f8a8bfe5fa9c852e16" body="Waarde waarmee aangegeven kan worden dat een attribuut niet geldt voor een bepaald object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ffc747228bfb4780ac68462970ac1402" name="Normaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4c66e0c643994c6e8f23b209d0a6e412" body="Kwalitatieve maat voor de gebruikelijke lasten die een object ervaart van passerende (weg)gebruikers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5698df90a72b4a138aea4590d3279c7b" name="Onbekend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a0d938727cd94851bbc9da604ab5c86a" body="Bij deze waarde moet nader onderzoek uitwijzen of welke attribuutwaarde van toepassing is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c0eca04bbe73424f83b160310e1a8187" name="Zwaar">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f2e182344de74272a8d3eed4cc037d61" body="Kwalitatieve maat voor de forse lasten die een object ervaart van passerende (weg)gebruikers."/>
        </ownedLiteral>
      </packagedElement>

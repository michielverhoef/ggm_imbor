        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_30d235e54af54e9e966cedbf049ab0fd" name="Getalmarkering: 70">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2f91a6f7e8f64d51bf2d99e82788309d" body="Wegmarkering van het getal zeventig, niet zijnde het symbool van een verkeersbord, die aangeeft dat de maximumsnelheid zestig kilometer per uur is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e87ca6cd668a44f996ab72512c9d6f70" name="Getalmarkering: 80">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6ca92b203cc4413fa0c0285267b80dfa" body="Wegmarkering van het getal tachtig, niet zijnde het symbool van een verkeersbord, die aangeeft dat de maximumsnelheid tachtig kilometer per uur is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_62bbd4ee705f43419e75d5ca25e5285f" name="Vrije tekstmarkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9eae1b1f32b44c938a76fcfb953377d3" body="Wegmarkering die gebruikt voor teksten die aangebracht worden die specifiek zijn en niet tot de standaard teksten behoren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_abc2b248e44e4d3e85a5299e8d39bb98" name="Woordmarkering: bus">

          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4a8117032ab14bd38618fb5552a5de2f" body="Voorwaarschuwingsborden bij werk in uitvoering, 2 rijstroken met asverlegging naar links en geen tegemoetkomend verkeer."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2c860dd2041a4e98be09550490de99f7" name="T04-2r_C18-2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a878b2f995fa4d278f22bbfc447c68af" body="Voorwaarschuwingsborden bij werk in uitvoering, 2 rijstroken met asverlegging naar rechts en geen tegemoetkomend verkeer."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d73c352bd9db4c3d9eb14f87e132319e" name="T11-2l_C18-2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5551413249b14e4db651fe8f09c301ac" body="Voorwaarschuwingsborden bij werk in uitvoering, asverlegging van 2 rijstroken naar links naar de naastliggende rijstrook."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2e6f6ca3599e42d19a87309af86fb79c" name="T11-2r_C18-2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_57db091137de4b33ae17fd650bb52767" body="Voorwaarschuwingsborden bij werk in uitvoering, asverlegging van 2 rijstroken naar rechts naar de naastliggende rijstrook."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_24e3a1c479a74bbc845424bc6f6045ee" name="T12-2l_C18-2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d5bf59defa9c46bc9471710251385771" body="Voorwaarschuwingsborden bij werk in uitvoering, asverlegging van 2 rijstroken met 1 rijstrook naar links naar de naastliggende rijstrook."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0f7a98affea74b9099f5efbc8b39685b" name="T21-2r_C18-2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ace259a5b8754ac7828aad96ff5607fc" body="Einde rijstrook met asverlegging van 2 rijstroken naar rechts met voor 1 rijstrook breedtebeperking."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e5670365021744a09d28fe1209f36b99" name="T22-2r_C18-2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f1d5e84466e0487b972ac7847cd9a792" body="1 rijstrook rechtdoor met breedte beperking en einde rijstrook voor de naastliggende rechter rijstrook met asverlegging."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_dd23d499985841a3b5c991f8e1c54911" name="T23-3r_C18-2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f700814051de4798b28c7e75140845ef" body="1 rijstrook rechtdoor met breedtebeperking en einde rijstrook voor de 2 naastliggende rijstroken met asverlegging."/>

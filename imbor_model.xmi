          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ecff5f48b31a47b59e186d618ee6faa3" body="Een schraalgrasland van opvallend kleurige bermbegroeiing met hoog opschietende bloeiende planten, dat gedomineerd wordt door de klaproos (Papaver), een geslacht van bloemplanten die worden gekenmerkt door bolstaande, vaak roodkleurige, bloembladeren, en "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7acdcdd0480449158d3ea643b968d1db" name="Natuurlijke grasvegetatie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1433a3b512834aada9dfcef86ebd0e72" body="Vegetatie van verschillende kruiden en grassoorten die een (spontaan) aangenomen rangschikking hebben aangenomen en bestaat uit verschillende grassoorten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_856ecaec86484045a02d30fc43427076" name="Pimpernelhooiland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5493459499a849868c9d5f5833a975c9" body="Specifieke flora en insecten (grote pimpernel, donker pimpernelblauwtje en steekmieren)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f70b82d8bd514c9fbc496152c649abac" name="Ruige glanshaverhooilanden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fd819cc69a534412a22edb75db6e7584" body="Hooilanden die worden gedomineerd door soorten glanshaver (Arrhenatherum), een wilde grassoort van maximaal anderhalve meter hoog met gladde, glanzende stengels, en waarvan het beheer zeer extensief en veelal ecologisch is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_925d28454413497481692d9165c50f14" name="Schraalgrasland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_417b837a957042248535f3e1e5fbff1d" body="Grond met laagblijvend en kruidenrijk grasland, gedomineerd door grassen met een open structuur op een voedselarme bodem. Dit is een specifieke vorm van natuurlijke grasvegetatie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3daa1116627f45a580073dcaf7e328dd" name="Soortenarm grasland op zand">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_06ad64f21da24d1a928ac07c1cdb4760" body="Grasachtige begroeiing op een zandbodem die dankzij de droge en voedselarme bodem weinig verschillende soorten herbergt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c535fe25c7a14589b58e8d0666aa07f5" name="Soortenarme oevervegetatie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a7f6828425434c18bc1cae25ef661894" body="Begroeiing die dichtbij een watergang gelegen is, waar dankzij de voedselarme natte bodem weinig verschillende plantensoorten voorkomen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_99925e75f1564738b0fdec704edda89c" name="Soortenrijke oevervegetatie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9043fcb8135e4df1aa36ccbaa8f040c1" body="Begroeiing die dichtbij een watergang gelegen is, waar dankzij de voedselrijke natte bodem veel verschillende plantensoorten voorkomen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4af75c1b029146afb3a947803f097f9b" name="Vlasbekje-Sint-janskruid">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0ab785f017b94ebfa37f3f87776d00fb" body="Een schraalgrasland in de vorm van een in de zomer en nazomer bloemrijke gemeenschap met hoog opschietende kruiden, dat gedomineerd wordt door het vlasbekje (Linaria vulgaris), een plant uit de weegbreefamilie die lijkt op veel vlasplanten en die bloeit v"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5d020e4ab4de40b6971dcc9d25252cf0" name="Vogelmuur-Herderstasje">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cdffbf1c5d084ba8bb25c4fba6fa7ec1" body="Een schraalgrasland dat wordt gedomineerd door vogelmuur (Stellaria media), een eenjarige plant uit de anjerfamilie, en herderstasje (Capsella bursa-pastoris), een plant uit de kruisbloemenfamilie, die beiden worden beschouwd als onkruid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6dca8143f4d44ccf8eee7b5ef7ba3c7f" name="Zandblauwtje - Biggekruidberm">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d17f7bfd53dd42558b017bb05c6d4f66" body="Een op zandgrond terend fysiek voorkomen dat bestaat uit grazige, open vegetatie met kleine planten die vroeg in het seizoen bloeien."/>
        </ownedLiteral>
      </packagedElement>

      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_620e12cff9584f7681efa397b8f74603" name="enum_NatuurlijkGraslandVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_77539d9233284ac9af18a14b161cdd5b" name="Bermen met Gladde witbol en Havikskruid">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_65d65b9acd144449a9b88c183125bdb6" body="Een vorm van schraalgrasland waarin de Gladde witbol (Holcus mollis) en het Havikskruid (Hieracium) voorkomen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fe01b26c43ad43cfb47ffb725b2d411a" name="Bloemrijk droog gras">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6e974641d3424e30bc03aa4f9e39a2f1" body="Verschijningsvorm: grasterrein met gevarieerd grasmengsel met kruidachtige en bloemrijke vegetatie, met een maximale hoogte van 1000 mm, Functie: verschillende functies, bijvoorbeeld verfraaiing, Beheer: Het beheer kan bestaan uit 2 keer per jaar maaien, "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_788c6b1e3d0f45b0a6a0e27145c141b3" name="Bloemrijk nat grasland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f3d41bc157054b658abd990227a7e6a5" body="Nat perceel van grasbegroeiing, in de buurt van watergangen zoals poldersloten, dat rijk is aan bloemensoorten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_021aa79e7a1b4e37b20277fb59311fc0" name="Bloemrijke glanshaverhooilanden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_240a7dcbbed04dac8867f326cbffaf07" body="Hooilanden die worden gedomineerd door soorten glanshaver (Arrhenatherum), een wilde grassoort van maximaal anderhalve meter hoog met gladde, glanzende stengels."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b56e6b3d597c45d3ac1163d9c19113a5" name="Bloemrijke glanshaverhooilanden, variant met stroomdalplanten">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7f62a9141cdd4515a08d77e14a2a9904" body="Hooilanden die worden gedomineerd door soorten glanshaver (Arrhenatherum), een wilde grassoort van maximaal anderhalve meter hoog met gladde, glanzende stengels, en door stroomdalplanten, een verzameling van circa tweehonderdvijftig soorten die karakteris"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9d7b70a6268d499680d12bc106e7d1f4" name="Bloemrijke natte ruigte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_364fd71c2e35400fafff41f1c802141c" body="Een perceel in een natte omgeving bestaande uit kruidachtige planten die groter worden dan een meter en rijk zijn aan bloemen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b08e228850ae4dc49ead44df4e28913f" name="Dotterbloemhooiland (droge vorm)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_862a0e8a6f384ed593cc7b2de4da0b12" body="Een niet drassig grasland met een weelderige hoeveelheid bloemen met soorten uit graslanden, broekbossen en moerassen, waar sprake is van invloed van grondwater op de vegetatie, één tot twee keer gemaaid kunnen worden en &apos;s winters kunnen overstromen, maa"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_59ed3dcf055f48e9830c3043a1d28530" name="Dotterbloemhooiland (natte vorm)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b312f3e47e6642f4a48d1f52a00ee5bc" body="Een drassig grasland met een weelderige hoeveelheid bloemen met soorten uit graslanden, broekbossen en moerassen, waar sprake is van invloed van grondwater op de vegetatie, één tot twee keer gemaaid kunnen worden en &apos;s winters kunnen overstromen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_135902f3ee2b4fb9954ab5e66ec624e2" name="Gemeenschap van Biggekruid en Moerasrolklaver">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2bd75e4adb4142f695f256fea7bb217c" body="Een schraalgrasland dat gedomineerd wordt door biggekruid (Hypochaeris) – een geslacht van kruidachtige planten met opgaande, gele lintbloemen en ingesneden bladeren die dicht bij de grond blijven – en moerasrolklaver (Lotus pedunculatus) – gestreepte, be"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_46759f61e6f441fe988a364e69fb4c6a" name="Gemeenschap van Engels raaigras en Grote weegbree">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cc39f94556e7463c87bb4c672beb2152" body="Een schraalgrasland dat redelijk voedselrijk en basisch is, maar weinig nat, en dat gedomineerd wordt door Engels raaigras (Lolium perenne) – een groene, vettig glanzende, ongeveer een halve meter hoge, stevige grassoort – en Grote weegbree (Plantago majo"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_361c5ceb45d44a13a47a65778ec6da77" name="Glanshaverhooilanden met kenmerkende, aan rivieren gebonden soorten">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ad7a73f37efb4f9bb04f3ebb42629ecf" body="Hooilanden die worden gedomineerd door soorten glanshaver (Arrhenatherum), een wilde grassoort van maximaal anderhalve meter hoog met gladde, glanzende stengels. De overige soorten in het hooiland zijn soorten die kenmerkend zijn voor het rivierenland waa"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_75e62b2bbb214a149f36f25a4c84ca23" name="Glanshaverhooilanden op schrale bodem">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d4982496ba724753812a2686bbe618b3" body="Hooilanden die worden gedomineerd door soorten glanshaver (Arrhenatherum), een wilde grassoort van maximaal anderhalve meter hoog met gladde, glanzende stengels, en gelegen zijn op voedselarme, zanderige grond."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5407e836c56040fb95d3ebaad5ace2d5" name="Heischraal grasland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a792fe3401e34baea3f7bf16a78ccbfe" body="Specifieke flora, reptielen en insecten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8632b7a875eb471aa8205e349add21fc" name="Helmgras">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_705c343531804e1b8de4d8c55cf76d5e" body="Rietachtig gras dat in het zand van de duinen groeit en heeft de eigenschap zand vast te houden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ec333abcd23a425d9759515845feb4d2" name="Kalkgrasland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6371917da500483ebc25fdcd99e0c0cb" body="Kalkflora (m.n. orchideeën) en bijbehorende insecten."/>
        </ownedLiteral>

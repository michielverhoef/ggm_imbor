        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d171bc7e13524b159f50f9bc2e1bef79" name="Bruto vloeroppervlakberekening">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_afcbdc4c5cf64e7ba19377c5ad15d7a0" body="Bij het bruto vloeroppervlak gaat het om 100% van de vloeroppervlakte. Het BVO wordt dus gemeten inclusief de omringende muren van een ruimte"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5e653296ca624bd89545739c9d06d264" name="CBS">

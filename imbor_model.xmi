        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_abe15da58f8542b3a3120922b053ca33" name="Constructieboring">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0c213ac5bed94463bba469a862ebc917" body="Een asfaltboring waarmee wordt vastgesteld hoe schade aan het asfalt ontstaan is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b47fc8e23ad0412eacecffebfe10a83f" name="Groeiplaatsinspectie">

          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0a4e96bd89c7413381165e35fe953f1b" body="Een afgedankt personenvoertuig als speeltoestel in gebruik."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0381ed68e5ca4993b68f78746ce39e52" name="Boot">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b403766150354dc4bcb2ce290b41c107" body="En voertuig waarmee men zich op het water kan voortbewegen."/>

        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9024308436a748b3b60b7828e247b284" name="100NE3">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_558166e929a346df8e27105dc189ea04" body="Een botsklassecode volgens NEN-EN 12767: 2007 bestaande uit een combinatie van impactsnelheid (100 km/h), energieabsorptiecategorie (NE) en het veiligheidsniveau voor de inzittende(n) (3)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4df92232707b48bcb1d11b65f0b6e6d3" name="100-NE-B-S-NR-MD-0">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2d277b90975841ae8a6de0cd72ddb9a7" body="Equivalent van 100NE3 in NEN-EN 12767: 2019. De botsklassecode is opgebouwd uit een combinatie van impactsnelheid (100 km/h), energieabsorptiecategorie (NE), het veiligheidsniveau voor de inzittende(n) (C), de specificatie dat collapsmodus niet is opgenom"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_da89ca8881a741ee83cc210de83bf360" name="70NE3">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9a903f238c6f4ec0ac17948c1fae9900" body="Een botsklassecode volgens NEN-EN 12767: 2007 bestaande uit een combinatie van impactsnelheid ( 70 km/), energieabsorptiecategorie (NE) en het veiligheidsniveau voor de inzittende(n) (3)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a83ef96f83184d8bb927a55af80a81fe" name="70-NE-B-S-NR-MD-0">

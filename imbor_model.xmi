      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_d754d2bcbb2d4e4da3ef3f998db93916" name="enum_RuimteVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e85002fdf76646e2bc8a78a54d6f47e5" name="Commerciële ruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_81d823352d4a415c949d2db4b811defb" body="Ruimte die ruimtelijk zodanig is vormgegeven dat deze geschikt is voor het daarin uitvoeren van op verkoop gerichte activiteiten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_035fbc3e0cd748e787dda18e8a02a141" name="Gebedsruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8cca57e0d79d4f75b5ecf21daf222ede" body="Ruimte die ruimtelijk zodanig is vormgegeven dat deze geschikt is voor gebed en individuele bezinning."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d41788add94e437fbab4be420cace6df" name="Horecaruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5a2dc166e80845afa56bcecac97723ad" body="Ruimte met een zodanige inrichting dat deze geschikt is voor het verstrekken van bereide maaltijden, snacks en dranken aan gasten voor onmiddellijke consumptie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8b0a3d7764eb47629b226098499b2edf" name="Installatieruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a611f68aa0364092acbc7345d24c57e9" body="Ruimte die speciaal is ingericht voor het daarin kunnen plaatsen van specifieke technische installaties."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cce4616d03a7488f889c314cc39195f7" name="Kantoorruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1e3b8985fd514c078d5cee0c6a5209f0" body="Ruimte die geschikt is gemaakt voor de uitoefening van een bedrijf, beroep of dienst waarin geen product wordt vervaardigd maar uitsluitend dienstverlening wordt bedreven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e6c570d64548452c8fc519eb3d5fb3b5" name="Keukenruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_73a23c175551444aa3ec65ff929a1329" body="Ruimte die voorzieningen bevat voor het bereiden van voedsel en/of het reinigen van bij de bereiding en nuttiging van het voedsel benodigde hulpmiddelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_126a5285bfcb4675a5c350fc47ad08bb" name="Kleedruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_db82fb9bc79b410abf6ebd0489db29cb" body="Gebouw met als functie omkleden te faciliteren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d2646c72edc241bc8b9b793075140664" name="Leslokaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c89c91ff0cdd4cbdbd35b986bb8b265b" body="Ruimte die is ingericht voor het daarin kunnen verzorgen van instructies gericht op het bijbrengen van kennis en/of vaardigheden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f0c2200bfaef4e04be580e5a42b0bb32" name="Lockerruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f6c6cb0c67b84a54a3317064fbc840cf" body="Een klein gebouw gevuld met kluisjes ten behoeve van het opslaan van de eigendommen van personen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6c11cff511cd40bbab2a7455b71b630d" name="Ontvangstruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4c488bc910fb471fab191624626b0a0e" body="Ruimte die is ingericht voor het kunnen opvangen en verwelkomen van bezoekers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_22a07d56f71b4e849205e3d2080ffe9c" name="Opslagruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7023998cfb3e4637be2a06b471b7daed" body="Ruimte die geschikt is voor het voor kortere of langere tijd opslaan van goederen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_90fb45d222d1453e81283bc78c8bd026" name="Recreatieruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_efd6c7ff024548e692ae1b9c3ad9e8e3" body="Ruimte die geschikt is gemaakt voor het daarbinnen kunnen uitoefenen van vormen van vrijetijdsbesteding die in hoofdzaak geen lichamelijke beweging omvatten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1225358a418f4667ae737fca203d069d" name="Sanitaire ruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0e3e23b20e544e0590652187c5c01867" body="Ruimte waarin zich voornamelijk op waterleiding en riolering aangesloten voorzieningen bevinden die zijn gericht op persoonlijke verzorging en hygiëne."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f06bdc0ed20e4eca9ed65e77699bd584" name="Sportruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a05d682d1d3742a591c94383094fdbbd" body="Ruimte die geschikt is voor activiteiten gericht op lichamelijke oefeningen en ontspanning waarbij vaardigheid, kracht en inzicht vereist worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_81a0c151d80c4901b1fab212df6ea213" name="Vergaderruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3cec930048f94134ac13c7d39d0de7c8" body="Ruimte die is ingericht om daarbinnen bijeenkomsten te houden waarin meerder personen met elkaar overleg voeren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bde8878455184deea3df2b54b21365c7" name="Werkruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_42210b332dd343eba0cea0302e51e75d" body="Ruimte die primair geschikt is gemaakt voor de uitoefening van een bedrijf, beroep of dienst waarin een product wordt vervaardigd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_909633cc7c90455297e91e7610e9c22d" name="Woonruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dba5a75716cd4dcf8f36dd261739773b" body="Ruimte die is ingericht voor het daarin permanent kunnen verblijven van personen voor niet bedrijfsmatige activiteiten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d222fda9a8914072a2423de34ffc5c14" name="Zaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_53284b1fcd1d4d73b66f8ed9010a0498" body="Grote ruimte die als locatie wordt gebruikt voor bijeenkomsten, evenementen of andere doeleinden waar meerdere mensen bij betrokken zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_945cc8ea9b534d5f819350cef753aefc" name="Zorgruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9db79b1db2554ea3bdf3f262ed73cfc9" body="Ruimte die is ingericht voor het daarin kunnen bieden van lichamelijke of geestelijke hulp of aandacht."/>
        </ownedLiteral>
      </packagedElement>

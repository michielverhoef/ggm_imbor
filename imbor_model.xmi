        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_561d558dd24144e49630c92a87526c4b" name="Wachttijdteller">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0523ed03ee0143e4b3048b3701954551" body="Een parkeerbord met een ingebouwde timer die bijhoudt hoe lang een weggebruiker op een cruciale parkeerplek geparkeerd staat en tevens aangeeft wanneer de maximale parkeertijd is overschreden."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_0609f926a9e44b3f888f38c9553b56b3" name="enum_VerkeersbordVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5553ab27907145b39cdf2269743bd5e1" name="Bebakening">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d2658152df04438cbe408b0e324eb1e1" body="Officiëleategorie BB conform RVV1990."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_41ce04c93d234088810569f721a4236a" name="Geslotenverklaringbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6a3bed0001bd4d18b308aff3800535bc" body="Categorie C officiële verkeersborden conform RVV1990. De C-serie verkeersborden maken de weggebruiker duidelijk of ze toestemming heeft door te rijden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0cf5c707de924b4b81d93ab7a1b97ff6" name="Informatiebord verkeerslicht">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c5997002fa774670adf1712eefb00888" body="Categorie VR."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ac2e32757c654f60b77101d518a0d599" name="Informatieverkeersbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_517237ee7be9486d8fcde16b04d1af24" body="Categorie L: officiële verkeersborden conform de richtlijnen. De L-serie bevat informatieborden voor uiteenlopende doelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_064d7f03678c4db3b1e8e9ba187fc2ac" name="Onderbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0ebfb22706de40abacce6589ad58b824" body="Categorie OB."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b3d51b535d6344f78816fdc1d80d5292" name="Parkeerbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_07cc582b5354459e8ec5daa09d926a3f" body="Categorie E: officiële verkeersborden conform RVV1990. De E-serie verkeersborden maken de weggebruiker duidelijk waar u wel/niet mag parkeren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_de7c27f48a33472abacb35ca06bbf9d8" name="Rijrichtingbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d0a3e9c890184c5b9822c55a3c4b4669" body="Categorie D: officiële verkeersborden conform RVV1990. De D-serie verkeersborden verschaffen duidelijkheid over de te volgen rijrichting."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e15cb8cdaca64988b28b0656f3b2c101" name="Snelheidsbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_40026b913219405097589cd2226893c7" body="Categorie A: bevat alle officiële verkeersborden RVV1990. De A-serie verkeersborden zijn snelheid gerelateerd, het verkeersbord geeft de maximum (rode borden) of adviessnelheid (blauwe borden) weer."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_66cf934abf1a48d7a7cb6bd70ac89239" name="Tijdelijk informatiebord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2f4c19cb7ee24e949951e183465de84f" body="Categorie T: verkeersborden die in tijdelijke situaties worden geplaatst."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5ce7df010b734bdc8af9cb9c17c551fe" name="Verbodsbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_676f372660054129bf351a06da04b478" body="Categorie F: officiële verkeersborden conform RVV1990. De F-serie verkeersborden verschaffen duidelijkheid over naderende geboden en verboden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c772eec69fab4313b8f02fcca3d9af1c" name="Verkeersregelingbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7e1130b49e4546a2990726c538d3a80b" body="Categorie G: officiële verkeersborden conform RVV1990. De G-serie verkeersborden duiden het naderende gebied aan zoals erf of fietspad."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_aa6c3db9a6b045438ed035be299d8391" name="Voorrangsbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f38c01b6e38943aa96d2ecee035b4f72" body="Categorie B: officiële verkeersbordenconform RVV1990. De B-serie verkeersborden verschaffen duidelijkheid over een naderende voorrangsregeling."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_52aa73e018c3483486e905ffe2406076" name="Waarschuwingsbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8f1d3301a8b943079e6d8b2459102205" body="Categorie J: officiële verkeersbordenconform de richtlijnen. De J-serie verkeersborden waarschuwen u als weggebruiker voor gevaarlijke situaties of locaties waar extra attentie gewenst is."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_665cfa3f44c24eef99e052b483d1871e" name="enum_VerkeersdrempelOntwerpsnelheidsklasse">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ec40e6fe6a244f8ebb84534eaf206afa" name="20 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_01c86d98f8e3419c94a07496b3b2fdd2" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van twintig kilometer is en de tijdseenheid één uur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9135dfd4f13f4c3a92f37106292f15df" name="30 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1e948d7aaffb44fc9416f8ff41512fbf" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van dertig kilometer is en de tijdseenheid één uur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_636652f022e34b9e993a3076ec093a50" name="50 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aaf6c57beaf7435e95895f095e6aa8fc" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van vijftig kilometer is en de tijdseenheid één uur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_acd0e18bcc5545e4838493548bdee643" name="60 km/h">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2e14dd40e8bd4a108863f9195c4ce259" body="Een mate van verandering per tijdseenheid, waarbij de mate van verandering een afgelegde weg van zestig kilometer is en de tijdseenheid één uur."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_00fb9ec0ecdf49cb929f2dfa2ad6188c" name="enum_VerkeersdrempelVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_60081dcfa0fb4f30a3b0186fb36e393b" name="Bromfietsdrempel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_93acc64339e343b691d1ae37c744f335" body="Golvende drempel bestaande uit vier opeenvolgende rijen aan drempelsegmenten die specifiek bedoeld zijn om bromfietsen met een lage(re) snelheid te laten rijden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b41e732dde644b82b6755bb163a7b8f1" name="Busdrempel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9c47532401f648de9b71e1f70a915d27" body="Busvriendelijke verkeersdrempel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_844b1dd4412d4e719358241bc0ca0e3d" name="Motorfietsdrempel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_21d757e52aa64194868978d18f53dc1b" body="Golvende drempel bestaande uit vier opeenvolgende rijen aan drempelsegmenten die specifiek bedoeld zijn om motorfietsen met een lage(re) snelheid te laten rijden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_39a34e708b8447b788f1cd598bb3749c" name="Sinusvormige verkeersdrempel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fad0b8ffdc5c4dd7a1a21ad098dcf5f6" body="Een verkeersdrempel waarbij de hellende drempelblokken niet de vorm hebben van een rechte helling, maar van een afgevlakte sinusoïde."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b463f19ef7a044568c4112b19d92bd5a" name="Trapeziumvormige verkeersdrempel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b46000e185a64350825ca877fdb77dda" body="Een verkeerdrempel in de vorm van een trapezium die alleen bij bij maximumsnelheden van 50 km/h wordt toegepast."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c33eedbf4f3542f3bf537e3dce90ede5" name="enum_VerkeerseilandVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3dbfb0b2a3a846909ba4a6203546add3" name="Middeneiland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a6a13a34716940518770fb3ab7efdb22" body="Een verkeerseiland dat tegengestelde stromen scheidt. Veelal gebruikt voor het middeneiland van een rotonde."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_12a365c7aec94a3497942c73181402bc" name="Middengeleider">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_416a0b3ba7df4ce0bc1f9d8bfd89416e" body="Een (verkeers)geleider: een langwerpig verkeerseiland dat tegengestelde verkeersstromen scheidt."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_fc97ea8dcfb74a04b77c5919e26fe8d3" name="enum_VerkeersknooppuntVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9db99fcedda3425c87d8dbfec96aff0e" name="Driearmige configuratie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e095cd8d61e14035b4e3c72035adfa33" body="Ongelijkvloers kruispunt van (regionale) stroomwegen dat drie uitgaande wegcomponenten bevat, gelijk een T-vorm."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fbad2ab7fb7142888c0b4c1f0e28cbfc" name="Vierarmige configuratie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5a23cef6d6b94d8dac1dc31a449b8648" body="Ongelijkvloers kruispunt van (regionale) stroomwegen dat vier uitgaande wegcomponenten bevat, gelijk een kruis."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_226d09527c9c4a4fadcbe9419ad56114" name="enum_VerkeerslantaarnVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_360da97f455d4af68e0602e96b8dd83e" name="Driekleurige verkeerslantaarn">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6aefc134980e4156bbedbdadaa487b19" name="Eenkleurige verkeerslantaarn">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_710b47ef6f174f54ab5597ab5b05adb9" name="Enkel rechtsafarmatuur">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2090b82c5921429f9d6498d4130f30c3" body="Een verkeerslantaarn in de vorm van een elektronisch bord dat direct boven een rijstrook hangt en met een groene pijl aangeeft dat de rechter rijstrook toegankelijk is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_084893eacb034a9396b511dabe04494c" name="Tweekleurige verkeerslantaarn">
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_7ee0cf468f914e6bba72a018d5193f83" name="enum_VerkeerszoneVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9a22b809d0ab4cafb21c63eef2a56ae0" name="15 km/h-zone">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9c7cf3f224de45fe9a0148da2f5e7a7a" body="Gebied waarin een maximumsnelheid van 15 km/h geldt en waarin de inrichting van de wegen en eventueel snelheidverlagende voorzieningen het rijden met een hogere snelheid tegengaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0a6f973dde4947b58de3c22583a51d10" name="30 km/h-zone">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e994400411dd4a709f384abad9d7fe69" body="Gebied waarin een maximumsnelheid van 30 km/h geldt en waarin de inrichting van de wegen en eventueel snelheidverlagende voorzieningen het rijden met een hogere snelheid tegengaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b2d10821d75c457c9f28980c8f94cd29" name="60 km/h-zone">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_54570cbe5af1409bb1531a083318b06e" body="Gebied waarin een maximumsnelheid van 60 km/h geldt en waarin de inrichting van de wegen en eventueel snelheidverlagende voorzieningen het rijden met een hogere snelheid tegengaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3b71560d1c7b4925bf0c648a00fd6de7" name="Geslotenverklaring (C-borden)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_458c0f15ce3649e0a48cde72e47f7cde" body="Een verkeerszone ingesteld op basis van een officieel verkeersborden van Categorie C conform RVV1990. De C-serie verkeersborden maken de weggebruiker duidelijk of ze toestemming heeft door te rijden. De zone heeft daarmee betrekking op een doorrijbeperkin"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_96760793d86142898ee854cdcff5d24a" name="Milieuzone">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_39babf21c65d488cb66d73c416fe3d88" body="Een gebied in de stedelijke omgeving waar motorvoertuigen van een bepaalde graad aan vervuiling verboden zijn of geweerd worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_98f1ba486676459a9ee6b87bffbb5f18" name="Parkeerverbodszone">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0eb45007d88148bcb43f7d878e048568" body="Gebied waarbinnen het verboden is te parkeren, behalve op plaatsen die daartoe zijn bestemd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_30227149d02c48398a6c600893907d04" name="Parkeerzone: betaald parkeren">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_db56c72bf9714daf9f28f63c9ac03957" body="Gebied waarbinnen het verboden is te parkeren behalve op plaatsen die als zodanig zijn aangeduid of aangegeven of op plaatsen die zijn voorzien van een blauwe streep. Op plaatsen die zijn voorzien van een blauwe streep is het parkeren slechts toegestaan a"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d3ca614133464be2871a26f8ffb0fcd5" name="Parkeerzone: parkeerschijfzone">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c9bd6f0aa5904bc2a844535f3cadae92" body="Gebied waarbinnen het verboden is te parkeren behalve op plaatsen die als zodanig zijn aangeduid of aangegeven of op plaatsen die zijn voorzien van een blauwe streep. Op plaatsen die zijn voorzien van een blauwe streep is het parkeren slechts toegestaan a"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7153a4a1a4b54ced89ba027794f9f3a6" name="Parkeerzone: vergunningshouders">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fedbe6c7562641209c7115fc33d03124" body="Gebied waarbinnen is toegestaan om te parkeren, al dan niet in een door voor aangewezen plek of langs de weg, voor weggebruikers met een parkeervergunning voor de desbetreffende locatie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b550010ce2a8489d8a3d22798eb9167e" name="Voetgangersgebied">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f68267963bfc42e8b3db75f2a59a54c0" body="Wegdeel alleen voor het gebruik door voetgangers, waarbij het door voetgangers te gebruiken gebied de volle breedte van de weg beslaat en het gebied een nadrukkelijk openbaar karakter heeft."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_47f4e1a8b5f54a4292b7ee70a7b65912" name="Winkelerf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3c17469d15684824899dc25ab0abbd29" body="Het object wordt gebruikt als voetgangersgebied rondom winkels."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_931930b700914b558540e80d5232c032" name="Woonerf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_59dd240453594c07a5a70b7e28289790" body="Wegdeel waar de verblijfsfunctie (lopen, spelen, ontmoeten etc.) prioriteit heeft boven de verkeersfunctie, daartoe aangeduid met de “verplichte” verkeersborden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_86c37a9ad9ea4b5484bc478dbf6acf28" name="Zero-emissiezone">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4f66085c6d784e96be6da31276dd3818" body="Een stadsgebied waarin geen voertuigen met CO2-uitstoot mogen rijden en waar alleen batterij-elektrische en waterstofaangedreven voertuigen (en andere vormen van zero-emissie-aandrijving) zijn toegestaan."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_17a1e26ed333416a8713019a2853784b" name="enum_VerkeerszuilBordcode">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_27c663e9a091408f8570127c3c40374c" name="BB21">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_01d6ef32df5f4a44b616f4c3b0fccdd0" body="Zwart-witte zuil."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_685dab2303c44860bdfeabd95402a086" name="BB22">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6e10f8292b18489bbe4eaa7bdbfbf11b" body="Zeskantig gele zuil."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a7035b4bda7849e5bad98c933ff71ee2" name="BB22_lichtmastschild">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d0388d9f548747968eab63d8890f32e6" body="Verkeerszuil met een geel reflecterende en afschermende plaat aan de voorzijde van de zuil."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_1cceb6289fc54e47b28a6ee002af6052" name="enum_VerzamelplaatsVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_eb9774a405b44a75a8dd49ef3b4d2e30" name="Depot">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4b23ea792dbd4b3d9e3e281f6e1a5baf" body="Terrein of plaats waar voorraden opgeslagen kunnen worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8501c4b66eba4814b781581ac071c1e1" name="Inzamelpunt">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d72ec9233d674659b6d9a21ad2310d3b" body="Locatie waar specifiek afval ingezameld wordt, bijvoorbeeld door inlevering."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bbe2d0939f954d6aa6d5fd29a49ba97e" name="Opslagplaats">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d96013203652463088c889a4af80c985" body="Terrein met eventueel verschillende soorten verharding, bedoeld voor de opslag van materialen of producten in de open lucht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c65da2702a624c23b93f6c627888f2fa" name="Stortlocatie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0490e48690994cfbb019bf60b96f5cd3" body="Een landelijk door de Werkgroep Afvalregistratie (WAR) geregistreerde verzamelplaats waar afval of bouwmaterialen kunnen worden afgeleverd."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_370961aa4cb84c439fc19a0ae12ea338" name="enum_ViaductVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b2aca8e12cc942109c47aa40f65f186b" name="Dalviaduct">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_002a1f80e3c648c18c9a0c21f56710b8" body="Een groot viaduct dat een dal overspant."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_21f94aa6e68c43029a09f246dcf681ca" name="Maaiveldviaduct">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bc37b3f938534ada90f1fbdf475c77d4" body="Een viaduct waarbij ondergrondse leidingen een (autosnel)weg kruisen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_60e2b30f1f914d8aacca62b2cfd0273d" name="enum_VijverVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_580623af59524a719982630339ced98e" name="Bergingsvijver">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_03691a9e5af24af1bf6c09be087c29f0" body="Een open reservoir (vijver, sloot, gracht, etc.), bestemd voor de berging van afvalwater ter regeling van de afvoer van het afvalwater."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_54c55fb152464d42aec48ec6bfa467a0" name="Kweekvijver">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e9cef6e2143e4297868abc65dbc01964" body="Een vijver die wordt gebruikt voor het fokken en kweken van vissen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d79af77276314cc0a3784e0f63ef6eda" name="Stadsvijver">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d93bc66f74d24f41beb92d62a5a786a9" body="Een door de mens aangelegd waterlichaam in een stedelijke omgeving."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4eb0bfcbb45f4c11b69b9858003dac99" name="Visvijver">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a07b819146544b22bde3ebeb64ae9a59" body="Een aangewezen stuk oppervlaktewater waar het is toegestaan te vissen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_acb360faa9b747c89c1a430c7de608e3" name="enum_VlakmarkeringMarkeringToepassing">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_015cbef6ef7f43f6bb20ecae77858b23" name="Afgestreepte wegvakken/vlakken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_159040640e8841e1873facb8f4b1bb9e" body="De wegmarkering wordt toegepast om delen van de weg af te strepen, wat betekent dat ze niet bereden mogen worden of er niet geparkeerd mag worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2424f0849ec24f05b20d50b12567e964" name="Convergentiepunt invoegstroken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_34a8f64776f340fa8be7d3ab7e11ea90" body="Wegmarkering ter aanduiding van een convergentiepunt. Het convergentiepunt is de plaats waar een rijbaan wordt samengevoegd; twee rijbanen convergeren in één rijbaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_749cfddda01a45c2bdd98c31c8137ea6" name="Divergentiepunt uitvoegstroken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_125b264db06744c8818e21d5f520bb18" body="Wegmarkering ter aanduiding van een divergentiepunt. Punt of gebied waar verkeersstromen met dezelfde rijrichting op een rijbaan onder een kleine hoek uit elkaar gaan en zich verspreiden over meer verkeersbanen danwel rijbanen op dezelfde verkeersbaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_45f1f68d57a24726ab8bb0a9d5480a57" name="Parkeerverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_51fca2895a0948f3a286f65b1d6616ce" body="Wegmarkering die aanduidt dat er langs een lijn of in een vlak niet geparkeerd mag worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_29585621ec3c47118145af27ede23501" name="Scheidingsvlak">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aca1ebd6d2354ab89d253bed804b98c7" body="Wegmarkering die dient om verkeersstromen te scheiden, uitgevoerd als vlak. Soms wordt alleen de omtrek van het vlak aangegeven. Wegmarkering die dient om verkeersstromen te scheiden, uitgevoerd als vlak. Soms wordt alleen de omtrek van het vlak aangegeve"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e92898ccc7704be9910484e6cc14db89" name="Verkeersdrempelmarkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ba77659bb74c47938affd98c1de19033" body="Markering van een verhard object, verhoging in de rijbaan, bedoeld om het gemotoriseerde verkeer met een lage(re) snelheid te laten rijden. Toelichting: Sinds ongeveer 2000 beschikt de Nederlandse wegenbouw over technische mogelijkheden om drempels uit te"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9d2ccc367f2c4198b9340e3936a5e1e2" name="Verkeersplateaumarkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a45c73fc665944a390a542b694fc5271" body="Markering om een grotere verhoging van de weg, bedoeld om gemotoriseerd verkeer met lage(re) snelheid te laten rijden, veelal samenvallend met een kruispunt, waar bij de plaatsen van oprijden drempelblokken zijn aangebracht, aan te geven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_47b1f29589dd4810b854b15e803ccf26" name="Voetgangersoversteekplaats">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8b6e88154b4846b8a8d17750db9b6dc4" body="Door wegmarkering in dwarsrichting aangegeven deel van de rijbaan ten behoeve van het oversteken."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c7107c7aef544f8d8ed45ecf93a959b0" name="enum_VlakmarkeringVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4e76ad3c0cc9449a811ec36065bf09c2" name="Drempelmarkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2f25e31f5e0b4974b9eaec91d0b7b580" body="Wegmarkering die het begin van een verkeersdrempel aangeeft."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_80d2a981062642bdbcc7f507121079b7" name="Kruismarkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0b1241e389cd405a8aad99b14e9423d4" body="Wegmarkering ter aanduiding van een vrij te houden vlak in de vorm van een kruis binnen de hoekpunten van een rechthoek."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3ebb608d00d0436db58819ea066f2c3c" name="Parkeervakmarkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c641073cbb5a49999161a5d8fc744c0b" body="Wegmarkering om parkeervakken te definiëren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6210edcee9af4f5b9b1a904df18982e3" name="Regenboogmarkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_73fd270641f740d7ae6b39ca54444c81" body="Een zebrapad dat bestaat uit de strepen van de regenboogvlag om aandacht te vragen om daarmee aandacht te vragen voor diversiteit en acceptatie van lesbiënnes, homoseksuelen, biseksuelen en transgenders (lhbt+-gemeenschap)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_943ca085f25340a386550e23a306bb85" name="Verdrijvingsvlak">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_485554a4d8d64deea74a7306ece496ab" body="Een verdrijvingsvlak is een weggedeelte dat gemarkeerd is met schuine strepen en bevindt zich doorgaans aan het begin of het einde van een invoeg- of een uitvoegstrook. Op verdrijvingsvlakken is rijden niet toegestaan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e2cb59739d7e4728904666511063e821" name="Verkeersdruppel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fe93504b19134fa086994810b44bbaec" body="Een weglichaam dat de rijbaan voor een korte afstand opsplitst."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_55e6547c086b4d32adf19a1230e1ddbe" name="Zebramarkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dfaf586f81074ce9a9c19f15e68ba5a6" body="Een met dikke dwarsstrepen gemarkeerd gedeelte van de straat waar voetgangers ongehinderde doorgang dienen te krijgen bij het oversteken van de weg."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_71d68cb91eba4c38b663c4df433d99a1" name="enum_VoegovergangVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_16a759383b10470d936244db27f95071" name="Dilatatievoegovergang ">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8b6c5adb9c12466dabc538b537f7f9b3" body="Kleine ruimte tussen constructies en bouwdelen voor het opvangen van krimp en uitzet."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a323f742f94c40ca9658ffb94bbbdc50" name="Flexibele voegovergang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_00b51db48e9e437fb3f84a7f36569eff" body="Voegovergang van speciaal ontwikkeld flexibel materiaal, in situ vervaardigd, dat tevens het wegoppervlak vormt. Het oppervlak van de voegovergang is in lijn met het wegoppervlak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1479bcb501664e4da95ef06c3414aad6" name="Lamellenvoegovergang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_35d9f9b6bc6a4883a29670eb54b818eb" body="Voegovergang waarbij de continuïteit van het wegdek is verzekerd door in serie toegepaste stalen balken, ondersteund door dwarsdragers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_40c62d8e3c7e4df3a2649b74eff85324" name="Mattenvoegovergang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_eb6523ba50234da1a8169b8c32a3f37e" body="Voegovergang die de verplaatsing van de brug opneemt als verlenging en verkorting van een rubberen element. De rubbermat is vast verbonden met de hoofddraagconstructie. De bovenzijde is in het vlak van de rijweg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_db1e2c2e3f854b4c9e6476900d984a0b" name="Meervoudige voegovergang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a89abd5a2b354badb64b143db83bcb71" body="Voegovergang waarbij de continuïteit van het wegdek is verzekerd door in serie toegepaste stalen balken, ondersteund door dwarsdragers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a8decf3bd4d44bd6a3fbd9c766073464" name="Overgangsconstructie voor integraal kunstwerk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_831a266801fa48a396c69706b2387cdf" body="Voegovergang die integraal onderdeel vormt van een wegconstructie en een integraal kunstwerk. Het kunstwerk (zonder opleggingen) en de weg werken dus mee bij het opnemen van de bewegingen en belastingen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d8a60764d1834df6991fc1794a5ced59" name="Rij-ijzer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_45434768971d44eca27d67ff7a8435d7" body="Stalen voegovergang geïntegreerd in de vloer of het dek van een betonnen constructie van een kunstwerk."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c83729a7d40a4e04881f342e44c6d11e" name="Schijnvoeg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e92d1b6dd5e444afb03e55388a49e510" body="Een overgang waarbij de verharding gedeeltelijk wordt ingezaagd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_73af9416532a4e698613b08da577fca6" name="Verborgen voegovergang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_123661749af74d4e8091efd5388f483c" body="Voegovergang gemaakt in situ als onderdeel van het asfaltbeton van het wegdek en bestaat uit diverse componenten die bewegingen en belastingen uit de constructie en het verkeer over een groter oppervlak verspreiden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b7a97a0265cb4e9086a05d86da111905" name="Vingervoegovergang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bc75268878ae47fc8a6e66fae7c3e959" body="Voegovergang bestaand uit uitkragende symmetrische of niet-symmetrische elementen (zoals kam- of zaagtandplaten) die de voegspleet overbruggen en aan beide zijden van de voegspleet zijn verankerd. De uitkragende tanden of vingers dragen de verkeersbelasti"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fd901bcd45264455bd856872e104d266" name="Voegovergang met of zonder balken en randprofielen met afdichtingrubbers">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8a4a141e79cd428aae0c35a66a199983" body="Voegovergang met stalen randprofielen met of zonder overgangsbalken van beton, kunsthars of elastomeer. De voegspleet tussen de randprofielen wordt gevuld met een flexibele niet verkeerdragende voegafdichting."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_08aff9994b1e4b398cdc40206387da32" name="Zinkvoeg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_97c162700d8f4da5898f55922294abba" body="Een voeg om ongelijke zetting van twee naastliggende tunnelelementen te voorkomen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_d6a16fde28de4641a7c2ec79767fbb0a" name="enum_VoetgangerslichtVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6bd08a35c0354775aaa3e498d42c0b9e" name="Standaard voetgangerslicht">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d9c31e27c1a84a0396b77afc79815c30" name="Voetgangerslicht met rateltikker">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a9c6228d3ca040ec84cbabff4cec783f" name="Voetgangerslicht met rateltikker en wachttijdvoorspeller">
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_e935b42b2809432c9237945fdc0ab43b" name="enum_VoetpadAan-OfVrijliggend">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3edbfa7a4df541be80d37139ad98a193" name="Aanliggend voetpad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_629f6542a4634cc991c9334d75c95bf3" body="Een pad voor personen die te voet aan het verkeer deelnemen dat zonder fysieke begrenzing parallel aan en naast de rijbaan ligt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ba663b4d72964515b80c41bf5c021ccd" name="Vrijliggend voetpad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_50a0db4b6b2b4d95bcb4b7cf8f4b866f" body="Een pad voor personen die te voet aan het verkeer deelnemen dat niet zonder fysieke begrenzing parallel aan de rijbaan ligt."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_a379e76853914e658a895fac8c3477ed" name="enum_VoetpadVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d8b2f40300ca4a38a8187cc7ce47b856" name="Achterpad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f1ce943672d6489a9eae83e81bd1b1d3" body="Voetpad dat achter of tussen rijen van huizen loopt en een vluchtweg in geval van calamiteiten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f528fdc1768e4f058751721ce1be2d99" name="Recreatief voetpad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_64583df372d94942a712550e02afe16a" body="Een pad voor personen die te voet aan het verkeer deelnemen dat gebruikt wordt voor recreatieve doeleinden, zoals een parkpad dat gebruikt wordt voor een wandeling."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0d343bf9650a4a408aa36953d69b5cf0" name="Trottoir">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d20983c397b242ec87da76d677caaca4" body="Verhoogd voetpad (ASVV)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_99ae005a03f047019d9f2b2b6de09abd" name="Utilitair voetpad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2a5e4dd016e54fd4aa3184120ebfd4d8" body="Een voetpad dat dagelijks gebruikt wordt voor de verplaatsing van voetgangers."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_75d1513fc65c404f8859b4fd16c22ba6" name="Voetpad op trap">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7b826bf6f3a34218a376801c6aaabbb4" body="Voetpad op verkeersinfrastructurele voorziening bestaande uit een constructie van treden, waarop men een hoger of lager gelegen plaats kan bereiken."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_d02ac033d3f442ab96e64c7f426b6a14" name="enum_VogeltilVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f533dbe1d39545e582b5b6a72e6e04d7" name="Duiventil">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dd638d167fa84d128e8a724fe70eb675" body="Een door de mens gemaakte nest- en verblijfplaats speciaal gemaakt voor duiven. Dit duivenhok is op een paal gezet of boven een gebouw uitstekend."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1e38c1f024684da99489f78fbe50a466" name="Gierzwaluwentil">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_56dbe422a2614d1b865ed38710e88922" body="Een hok met nestplaatsen speciaal afgestemd op de gierzwaluw. Deze kast staat op hoogte op een paal gemonteerd."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_ea035370a7544fc28bb13d960444e9e9" name="enum_VoorschakelapparaatDimaansturing">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_291ce06e6dce43799bb3bc864d30be05" name="0-10V">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d215d874360144808dfd9253cb3aaaf5" body="De klasse met als ondergrens een spanning van nul Volt en als bovengrens een spanning van tien Volt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9fb0105bfde54be3b0138723e41a5318" name="0-20mA">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_125f9b917f8645a5927c63ff32f249e2" body="Protocol"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0ec0a940b7114cbda5daf0da7d49c6d6" name="1-10V">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_17f48d8978c340bebd993660e71a464e" body="De klasse met als ondergrens een spanning van één Volt en als bovengrens een spanning van tien Volt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_93cf8fa44039445391f3103b779e4327" name="4-20mA">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bd001b6752ac476baf1036f542330aac" body="Een 4-20 mA stroomlus is een tweedraads elektrische verbinding, gevoed door een constante spanning van (maximaal 24 V) en aangesloten op een omvormer die een te meten grootheid omzet in een gelijkstroom tussen 4 en 20 mA."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ba69c3f02de74ba592246e5f11e6e019" name="Art-Net">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f0c67bf487684da4ac3c8f7246875394" body="Een royaltyvrij communicatieprotocol voor het verzenden van het DMX512-A-protocol voor lichtregeling en het Remote Device Management-protocol (RDM) via het User Datagram Protocol (UDP) van de internetprotocolsuite. Het wordt gebruikt om te communiceren tu"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_78d68d9e4e124925802a3fe6d0987cfb" name="Dali DT6">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e465ce539d934172889d3df0bba3a57c" body="For DT6 driver, single address single channel. This type driver use one address to dim the color temperature and another address to dim the intensity, supporting DALI 102, DALI 207 protocol."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1ed958dab35a43c88c84d90670358c08" name="Dali DT8">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_37815efd1f474c11a1f6b288fb2b0ff4" body="For DT8 drivers, single address multipath channels. Those drivers use one address to achieve tunable white application. It’s compatible with DT6 and support DALI 209 protocol."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ed20c73fe5e54cddb0e7c26ac1e5ecb7" name="DMX">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_af8dc33afb5943e4964dc775db547d0f" body="De taal waarmee verlichting en effecten kunnen communiceren met elkaar en/of een lichtsturing."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a34084c3356b401d9656274b2b1e6da4" name="DMX/RDM">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5259daa86d304c7fbab43fc7f6de62d3" body="Remote Device Management (RDM) is een protocolverbetering/toevoeging van DMX512-A die zorgt voor terugkoppeling van de dimmers en andere apparatuur aan de lichttafel of een ander apparaat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_993b1f7144a04d0a840bbe3d2fb74f84" name="Geen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9442020ad5c14a2abd169ec6d031ca0b" body="De waarden uit de suggestielijst of vaste lijst van het attribuut zijn niet van toepassing bij dit specifieke object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_66ba8153b0514c5e99c82587ef643cc7" name="KiNet">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8ffceeb9c70f4832810df8fbd9a7da8e" body="Het protocol gebruikt door Color Kinetics om LED-lampen te besturen. Het gebruikt UDP op port 6038."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0afefe43b08f427fae9100b95056604e" name="Kling-Net">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_28bc1abbb25f45e3a4331808928a0b09" body="Een revolutonair plug-and-play protocol voor het gemakkelijk besturen van LED-apparaten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_61099bf2c2384e468b0375b212cafb9a" name="LineSwitch">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e1acf8d901a24620b9ef61e810fa79a6" body="Het voorschakelapparaat bestuur de lichtbron door middel van een technologische component die de gebruiker in staat stelt meerdere lichtbronnen tegelijkertijd te dimmen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ddb8ea84a05a4ee2955fdbafd5378097" name="SPI">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ef15c614fa0c4fe6a08af7f9c9061a92" body="Type van een communicatieprotocol."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_3bc5a7b78508474a851ef5846837f1fe" name="enum_VoorschakelapparaatVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_654ae976a3214a6a9fa4d36a23c015a4" name="Conventioneel voorschakelapparaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4494cc51570340ed85d89e0cfb1b2688" body="Het conventionele voorschakelapparaat bestaat uit een spoel. Deze spoel zorgt ervoor dat de TL buis een voeding krijgt van 50 tot 100V. Conventionele voorschakelapparaten voor TL buizen hebben bovendien een starter nodig, deze zorgt ervoor dat de buis voo"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3de8d80577b049b995aa32f7dd8c8c88" name="Elektronisch voorschakelapparaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3027356dd1ae4a5a8af3acbc0089d2d5" body="Apparaat voor het starten en bedienen van TL lampen en gasontladingslampen op een aanzienlijk andere manier dan conventionele voorschakelapparaten. Ze werken zonder starter en regelen de ontstekingspuls via de geïntegreerde elektronica."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3c266730d34a482cba64f272a4ca61b9" name="LED Driver">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c83b9cc729f547f4b70e2394f64d894d" body="Apparaat dat zorgt voor de juiste toevoer van stroom bij verlichting voor LED-lampen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_158b998ce89c4d55a34e41f1e0394918" name="enum_VuilvangReinigingsfrequentie">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_66bd6772232440ae9575cdf0066d5950" name="1 x per 2 weken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c382c8698b554518ba6d07520c81fb98" body="De gebeurtenis vindt elke periode van veertien dagen eenmaal plaats."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cf24e57d0fdf44c593a6ac0aae81153d" name="1 x per halfjaar">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0967bd247f7d495ca631290d301f3c5f" body="Eenmaal om een periode van zes kalendermaanden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7ce1373821ef4df4bb5235f19080df9a" name="1 x per jaar">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c44d67fcd74246cda996a1a47ff2bb9a" body="Eenmaal om een periode van twaalf kalendermaanden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_069aa9efaa1c42f8909ace98f2960b1d" name="1 x per kwartaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1b81c811a08c405992cd06cc84c997d1" body="Eenmaal om een periode van drie kalendermaanden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5d3058dcbafc4258a7c17e2ddac953a0" name="1 x per maand">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_91e1aaa3751f4b62ad50e6878ea952e1" body="Eenmaal om een periode van een kalendermaand."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e1d669b5335c4f90bb89041ce1583aca" name="1 x per week">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3f4e35d4eb914e1ba3b2901699b6286d" body="Eenmaal om een periode van een week."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_877a002b483b48c6a002d7bf9f94928d" name="Niet van toepassing">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_eb23dc88dfad4d2bb611dcef134e3a8a" body="Waarde waarmee aangegeven kan worden dat een attribuut niet geldt voor een bepaald object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1aa89771ab1c46edb4eadc27882c82b0" name="Onbekend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ad85de55d06745168d555a116b20147d" body="Bij deze waarde moet nader onderzoek uitwijzen of welke attribuutwaarde van toepassing is."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_3340807057594d5685984db6576d5d68" name="enum_VuilvangroosterTypeVervuiling">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6428866d44cb4922a8e19f3d4b0b27dc" name="Grond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0d8a4ba8e78b412584cf4079b5824292" body="Vervuiling in de vorm van een mengsel van mineralen, organisch materiaal en bodemleven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_caef14818a284889914978b60d102875" name="Grond en wortels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1dca57e30fc2467cb7f2e8db3a7a05a7" body="De vervuilingsvorm bestaat uit hoeveelheden zand en zwarte grond en stukken of delen van plantenmateriaal."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_eb68a85bfcf3400daf3a910fa46293f9" name="Huishoudelijk vuil">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_23da548678e44be589beeacf5a2b0092" body="De vervuilingsvorm bestaat uit stoffen die in en rondom particuliere woningen gebruikt en geloosd worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_36a4b14b2fef41b1bf1adc5b33f61228" name="Olie/benzine">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fb0c945081b6430683a2e06e5f74d5ea" body="De vervuilingsvorm is olie of benzine; aardoliën die als fossiele brandstof gebruikt kunnen worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_70c971d306f245fc8d6921f6a61872b9" name="Slib">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2c23ac014b04495596f27180387f634f" body="De vervuilingsvorm is neerslag van in water stromende vaste deeltjes die zich in het object hebben opgehoopt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e21588e44e304f60a4b2c80541a99eef" name="Spoelcement">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_694876d283ca40cba1e8cc0dcabbda1e" body="De vervuilingsvorm is gestold cement dat zich heeft opgehoopt in het desbetreffende object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bf2d4fa2a54a43de82862fe361071e09" name="Straatvuil">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7eec60bafa834941bf9dd8a729bec038" body="De vervuilingsvorm is vuil dat op straat is gedeponeerd en zich in het desbetreffende object heeft opgehoopt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a9003bd506304313ba2caaa5a7cd0d00" name="Vaste deeltjes (vuil en slib)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8350bf32a4854390877cc4cf579a3fe7" body="De vervuilingsvorm is vuil, dat wil zeggen, vaste deeltjes van diverse aard, inclusief slib, neerslag van in water stromende vaste deeltjes, die zich in het object hebben opgehoopt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bd8a2ece4101479f9b9acd8518c54825" name="Vet">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_816f887d583c4b458c28dfc25369b3a7" body="De vervuilingsvorm is een gestolde, olieachtige laag van organische stoffen van plantaardige of dierlijke oorsprong."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0776fda1383e4035932f2c9883866ea1" name="Vet en grond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e547c323e065488a87969a686a9f0419" body="De vervuilingsvorm bestaat uit een gestolde, olieachtige laag van organische stoffen van plantaardige of dierlijke oorsprong en een mengsel van verweerd materiaal."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_700c713bc59a4d28ac94bced83217260" name="Vet en wortels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_029eca89fc0e4547a71fb8b47bf75cf7" body="De vervuilingsvorm bestaat uit een gestolde, olieachtige laag van organische stoffen van plantaardige of dierlijke oorsprong en (afval)delen van de wortels van planten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_12bf30e006154b7fbd4cfc786af9f3e0" name="Vuil">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f9e2731266be4abd84e83a3e1f3fb903" body="De vervuilingsvorm bestata uit vaste deeltjes van diverse aard die zich in het object hebben opgehoopt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b2e636d4acbb4718b011d6c672de51bb" name="Wortels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5efd278e06cb43bc8a6f4af66aa22ab0" body="De vervuilingsvorm is (afval)delen van de ondergrondse delen van planten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_97603c7ba65c492f9a75d0a40d61b1a3" name="Zand">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7b82f324ec6b47f0b2e3f57f6f995798" body="Onverhard object bestaande uit zeer kleine stukjes steenl korrels die in grootte variëren tussen 63 micrometer en 2 millimeter. Het is een zacht, hard, los of korrelig materiaal en een van de meest voorkomende natuurlijke stoffen op aarde."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_ea6ac7e4c9384c6c9c7b79df9c41b712" name="enum_VuilvangVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a90fb0ca1ecc4d91874bec13de3b0b47" name="Drijfvuilnet">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8b6a99a293aa4ad1aadfd123301c4462" body="Net voor het opvangen van drijfvuil."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2289134f2e854f9a95ee93c5a81b6930" name="Krooshek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_24d25b28a13644c09dc8d356ad65c4be" body="Een object dat wordt gebruikt bij poldermolens om drijvend materiaal, zoals planten, waaronder eendenkroos en hout, tegen te houden. Hierdoor wordt het scheprad of de vijzel tijdens het malen niet beschadigd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e07fa7f85f5f401590db93070df5de99" name="Vangbalk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4fde7056f5ef4addb9ad52f91672ce80" body="Zware balk, scharnierend in de ezel bevestigd en wordt opgehangen aan een haak, of op een duim, of op een klos."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_36286bee9f674ca0a194be3f9dc9a65a" name="enum_WaarschuwingshekBordcode">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9107cc278d8049619b3645baf92e65a9" name="BB15-1A">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_99c71af8f6014bf4bfa24603ef115c69" body="Schrikhek 2 smalle planken 2 palen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6c59ce5a4fdd4dd2a95ee0f51031a136" name="BB15-2A">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3c1d4bd72711415e999baf99e2aee630" body="Schrikhek 1 brede plank 2 palen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_11caee97704c44ea93c86ef2190a259b" name="BB16-1">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b8d8ac27bc3e4b269f01378742114837" body="Schrikhek 1 smalle plank 3 palen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d991279b94a54d3989aed68b61211252" name="BB16-2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4375d504107c43f1a4affc2a5faebcda" body="Schrikhek 2 smalle planken 3 palen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f7361703b32a4015aedb51dfef77cab6" name="BB17-1lr">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_db35b487493245baa23fca6ab25f8080" body="Schrikhek 1 plank 2 palen pijlen naar links en naar rechts."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b11ddab524c4489582d03c894e3603a5" name="BB17-2lr">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d0409c5501fd4a45a885c9fc1d1b0f7f" body="Schrikhek 2 planken 2 palen pijlen naar links en naar rechts."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5e4506607da846759062a32fe4140345" name="BB18-1l">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e0cae468fa0a4806b0f306be8e50322a" body="Schrikhek 1 plank 2 palen pijlen naar links."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_45c3dbf78d2d4875802e6411bdb71b77" name="BB18-1r">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8782e0a67eb54939b1b77a4ea31aa156" body="Schrikhek 2 planken 2 palen pijlen naar links."/>

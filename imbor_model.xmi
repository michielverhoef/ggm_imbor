      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_10644405ea0c44e69003c339c0662abc" name="enum_PaalBotsklasse">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6a5c83d8df7d4e13aa3cf2785b01ae59" name="100HE3">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d8173acad7194703b13ef4b6040cfb07" body="Een botsklassecode volgens NEN-EN 12767: 2007 bestaande uit een combinatie van impactsnelheid (100 km/h), energieabsorptiecategorie (HE) en het veiligheidsniveau voor de inzittende(n) (3)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ca10e8e46656423c94cfb505bea39657" name="100-HE-C-NR">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0f5f6019da4b487bb17ce5d53da89220" body="Equivalent van 100HE3 in NEN-EN 12767: 2019. De botsklassecode is opgebouwd uit een combinatie van impactsnelheid (100 km/h), energieabsorptiecategorie (HE), het veiligheidsniveau voor de inzittende(n) (C) en de specificatie dat alle hierop volgende eigen"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6428e14a177f4ac5bfa1665f7a5c3ef6" name="100LE3">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f6cbd55decd34fa3bd82bcd298318975" body="Een botsklassecode volgens NEN-EN 12767: 2007 bestaande uit een combinatie van impactsnelheid (100 km/h), energieabsorptiecategorie (LE) en het veiligheidsniveau voor de inzittende(n) (3)."/>

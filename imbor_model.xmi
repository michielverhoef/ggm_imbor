      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_1024453ae8d5454198521aa4967acc89" name="enum_BosplantsoenVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4ab96903c65e467083c1771267404cce" name="Bomen en struikvormers">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_75cdcc5b756f4d0eb0c51a5d4372e167" body="Opgaande beplanting van houtige gewassen met struikvormers en boomvormers, die extensief wordt beheerd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_337173c445754da3987befdc7ad42563" name="Boomvormers">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_83688e6d36114fb6bdae2a97a9d24128" body="Opgaande beplanting van houtige gewassen met stammen gelijk die van bomen, die extensief wordt beheerd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c34c1aef6ebc487cb65597071cf30327" name="Struikvormers">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_13729310dea246b091a4df2bebac8d5a" body="Bosplantsoen welke geheel uit struikachtige planten bestaat."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_e496ffc793b14e0cac2e189702c34daf" name="enum_BouwlandVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fcf4d56b05ef4c878096d7fa9af51e26" name="Akkerbouw">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1c6a0b00926e4b4e8bbfb9369af20d2f" body="Terreindeel in gebruik als akker, voor de teelt van akkerbouwgewassen. (Bron: definities.geostandaarden.nl). Een tak van landbouw waarbij veldgewassen worden geproduceerd, beheerd en verbeterd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_db373b2650ed4bb68fc03483d4b3e02f" name="Bollenteelt">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a1333c8e27b8448495b0d4c54a46cdb3" body="Terreindeel in gebruik als akker, voor de teelt van bloembollen. (Bron: definities.geostandaarden.nl). Een tak van tuinbouw die zich bezig houdt met het telen van bol-, knol- en wortelstokgewassen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1534d2c1c9944467b955f796572dad66" name="Tuinachtige grond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_164f531043e642ba826315c026e5da4d" body="Grond in gebruik als tuin en erf. Het gebruik wordt gekenmerkt door een afwisseling van bomen, struiken, sierplanten en recreatief gras en het kleinschalige verbouw van gewassen (volkstuin, moestuin) valt hieronder."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_03cc4bb5faa342298e8bce1ced54887b" name="Tuinbouwgrond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_208fd8212e3246f383266fbec1df5210" body="Terrein waarop horticultuur wordt bedreven, dat wil zeggen, het commercieel telen van eetbare gewassen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2a824fde5eca440fa4a68edd02d2dba7" name="Vollegrondsteelt">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b39ea2293ab14751986c224dcc0d7c51" body="Terreindeel in gebruik als akker, voor de teelt van tuinbouwgewassen. (bron: definities.geostandaarden.nl)"/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_41d57f1ffcce4eaeb48cc2f029a7c310" name="enum_BouwwerkVorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1a38f50f0c534f0bad898c6e00654a9e" name="Anders (vorm)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3de3279ad8694c12b790fa6e3c18b96b" body="Als de vorm van het object niet rechthoekig of rond is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1ddfee48f9554c4891ef3a100811324a" name="Rechthoekig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e2dd69195d4b4e5bb49c6f410f787ee8" body="Een vierhoek met louter rechte hoeken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bc32b9af5ee240c889979035278c6031" name="Rond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_397641e8d5784b2db20530260e7e2088" body="Cirkelvormig en zonder hoeken."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c710a0324b2e45138f2ae4e1f96a419a" name="enum_BuishekVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b122bf89ad5040ebb1b38cb9d4166088" name="Leunhek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a5a459e7a50b46f996a7581869a8feb9" body="Een hekwerk van verticale, in de grond bevestigde buizen en daartussen een raster of gaaswerk waarop horizontale buizen rusten om met de armen op te kunnen leunen; vaak gebruikt als omheining van een sportveld."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_11e19d1a278b4be89be5ef680cf77a9e" name="Voethek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_261811f442ce4c6dad6c4516f39c5c5b" body="Een leunhek is een type hek, waarbij op de (meestal ronde) staanders een doorvoerkop is geplaatst, waardoor een stalen bovenbuis is geschoven, zodat het geheel een stevige constructie vormt."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_f88f7f5190b84adf836c3d681044c269" name="enum_BuitenfitnessterreinVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6c34eedd563d4598862d51ebf7d52dfe" name="Bootcamp Base">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_53a01b1627304cf787e2682e297001cb" body="Een buitenfitnessveld dat is ingericht met toestellen die geschikt zijn voor een afwisselende vorm van training onder begeleiding van een professional (bootcamp)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3c1aa4c3d1524f599107fbb1c61471de" name="Bootcamp en Circuit Training">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bf9ec765e5da4e9080e434491915a67c" body="Een buitenfitnessveld ingericht met toestellen die gebruikt kunnen worden in een roulatie. Het veld is ook geschikt voor een afwisselende vorm van training onder begeleiding van een professional (bootcamp)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bafc9af6d6464077993a78710e7a471a" name="Cross &amp; Circuit Training">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e2e271871df74d75b09ef96c480bacbb" body="Een buitenfitnessveld ingericht met toestellen die een street workout en andere oefeningen met lichaamsgewicht faciliteren en waarvan de toestellen gebruikt kunnen worden in een roulatie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d4b6c5e3bfc24b7f905445a5b7c7c209" name="Cross Training &amp; Circuit Training &amp; Bootcamp &amp; Street Workout">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8baab2ad4db94a20823bb0542bb86526" body="Een buitenfitnessveld ingericht met toestellen die een street workout en andere oefeningen met lichaamsgewicht faciliteren en waarvan de toestellen gebruikt kunnen worden in een roulatie en verschillende lichamelijke onderdelen trainen, zodat atleten door"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_27c8e0e47d8540628d184e2a5cc3e890" name="Cross Training &amp; Street Workout">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7a8f1759338f41ba9a0a85706d696797" body="Een buitenfitnessveld ingericht met toestellen die een street workout en andere oefeningen met lichaamsgewicht faciliteren, maar ook verschillende lichamelijke onderdelen trainen, zodat atleten door allerlei soorten oefeningen te doen hun algemene prestat"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_741bc8b8f92f49afbb071e084aead0e2" name="Hexagon Pull Up Station">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9b809f71b4584435884ffcc179ff6646" body="Een zeshoekig frame met aan iedere zijde een dwarsstaaf om optrekoefeningen mee te doen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_db6e3ff4b1fa4fcfa578c43812bc20bc" name="Obstacle Course">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c44b64ef01644e0cb4d9df2b31e2c006" body="Een buitenfitnessveld dat bestaat uit toestellen die een hindernisuitdaging vormen en waarbij de fitnessoefeningen bestaan uit klimmen, rennen, springen etc."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bf8e0bdd5bd043ee869dbee57bf31238" name="Pull up Station">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9d3b88f1a2824caca586dbbe86ae20fd" body="Een frame met een staaf en handvatten op of boven hoofdhoogte om optrekoefeningen mee te doen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9ddcc2d338b14fe28778f859c5bcf635" name="Square Pull Up Station">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2add61be17174da6a7efca8b91b6c4eb" body="Een buitenfitnessveld in de vorm van een vierkant met verschillende toestellen om optrekoefeningen te doen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4c489bf58f244562819f45e424eb378b" name="Street Workout">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b7386562ff50494297c2d5113effef81" body="Een buitenfitnessveld ingericht met toestellen die oefeningen met lichaamsgewicht faciliteren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_84a422718c4a421fb8c4665f5de66381" name="Street Workout en Parcours">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0ed591f3ac9f47469e29810d3b2f0aec" body="Een buitenfitnessveld ingericht met toestellen voor parcoursoefeningen en gerelateerde oefeningen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_acb7c288b5504c108ece89052d876f91" name="enum_BuurtbordVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_429240bae0204acda63ec4bf4ceca6d8" name="Afvalbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_da8dc5e0a4804a1698335a94cf5c8336" body="Een bord dat een algemene plaatselijke verordening aangeeft met betrekking tot afval in de openbare ruimte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0ee79c7aab474055843cc12488531d31" name="Buurtregelbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a9edd2ec1d2b40f6b620619ab69d080a" body="Informatiebord dat aangeeft welke lokale (gedrags)regels gelden binnen een buurt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1727e310d75a420a9b3e9a2942d5fc24" name="Hondenbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a79e058ae692435aa49b6f112c1e5211" body="Een buurtbord dat betrekking heeft op het lokale hondenbeleid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6a3542f62f47407d8ed1b4ff82ec9bbf" name="Kinderbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2bb35e10c7024f55aaacd4bdc85ccff1" body="Een buurtbord dat informatie verschaft over het gedrag van kinderen in de buurt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_37da824579d74984b4b71a225880416b" name="Schoolinformatiebord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_89a183c3e70745aab38b5bcdc11c75e3" body="Bord met informatie over de school."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6bc7db02c58947a1aee0caffbeb2714d" name="Snelheidbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e06ad32c1618445781ffc0ad381291a8" body="Een buurtbord dat weggebruikers iets meedeelt over de snelheid van voertuigen in de buurt, bijvoorbeeld dat het de wens is van buurtbewoners dat er maar vijftien kilometer per uur gereden wordt vanwege spelende kinderen op straat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f0d7c1c75edd4c978aafde2aee7b5522" name="Speelplaatsregelbord">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aeeff7698ccd4cfcbe060d4d60fdd263" body="Informatiebord dat aangeeft welke lokale (gedrags)regels gelden op een speelterrein."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_91168fa05d9843668fe59179395ad9fb" name="enum_CombimastVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c22736866a4d498f8d6232a6ab134e8d" name="Combimast OVL-VRI">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_09891e3bdbcb4f4cae37b8117c378f69" body="Een paal die een functie heeft voor het openbare verlichtingsnetwerk en een functie als drager van bewegwijzeringsborden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2364dc4e2dfa4aeda4350964f4087364" name="Combimast OVL-VRI-WW">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_577f60cef6a642b39a60a9232f874271" body="Een paal die zowel een functie heeft voor het openbare verlichtingsnetwerk als een functie als verkeersregelinstallatiepaal en drager van bewegwijzeringsborden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_89b7c1574d014298be81b5efabc19c00" name="Combimast OVL-WW">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_22a2c9c413924eff82276e7d6a09aa2f" body="Een paal die zowel een functie heeft voor het openbare verlichtingsnetwerk als een functie als verkeersregelinstallatiepaal."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b0a0a59bd2df43bab0ce416ec08223fb" name="Combimast VRI-WW">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3133d7b835234351aae18fff07be01b0" body="Een paal die een functie heeft als verkeersregelinstallatiepaal als en als drager van bewegwijzeringsborden."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_234dab5678054f4fb1fd6520898a48f4" name="enum_CombinatiebordBordcode">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_888d77d287954a02b6bcae92e4a6c7d6" name="B06OB503OB02f">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d3ab18c6282b4e1d8b3da77175729096" body="Verleen voorrang aan fietsers (in 2 richtingen) op kruisende weg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b89e4c7e1dd24f7ca336461882cb4781" name="D01_BB12r">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ff48350be6fd4b4f83a5f8ee0edf96cd" body="Rotonde, verplichte rijrichting."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f766e6c5832b4ec8a8b45baa99c0f02e" name="D01_BB16">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f149a08a3b214ae48c24bdfa003062b5" body="Schrikhek 2 smalle planken 3 palen plus bord D01."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2b790584abb34f569843e7843f21bb9e" name="D01_BB18-1r">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0b79540871bb4c07800454bb1df8ab64" name="D01_BB18-2r">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_90de7f077f524268bada01e865852a3c" body="Schrikhek 2 planken 2 palen pijlen naar rechts en bord D01."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_686b600430a8447caf6d48fc902c1e38" name="D01f_BB12r">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c11ecf81dfd340548891b42942aab814" body="Fluorescerende versie van D01 in rotondeportaal D01_BB12r."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0a3f8ffa3f73460a89c6354821762e09" name="D02lo_BB22">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b11d15f359544c2891cfd7127b79bef8" body="Uitzonderlijke pijl naar links variant van D02ro_BB22."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b27d23d678e248e581bd819ae57bda0a" name="D02ro_BB22">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ef1bedf47fde476caa19159b3fca2b8e" body="Gebod voor alle bestuurders het bord voorbij te gaan aan de zijde die de pijl aangeeft op een zeskantig gele zuil."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5ec1a008206d4a378a8eccb9ad47bf54" name="D02ro_BB22_lolly">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_78ae5c8520a04913b22942afab2e1752" body="Een gele verkeerszuil waarbij het bordmontagedeel samen met de stam een gestroomlijnde vorm heeft. Met het bord D02ro (Gebod voor alle bestuurders het bord voorbij te gaan aan de zijde die de pijl aangeeft (rechts))."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_72c6709829b4445284d291e6c40d5ec1" name="D02ro_BB22_paneel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_165ffe9e19b047389a7327509291a5ac" body="Een gele verkeerszuil waarbij het bordmontagedeel samen met de stam een bestaat uit een platte plaat. Met het bord D02ro (Gebod voor alle bestuurders het bord voorbij te gaan aan de zijde die de pijl aangeeft (rechts))."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e3014f72f7f142818917ea0248d70535" name="D03_BB22">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9eb45e080bfa42f1bd12a49597741df7" body="Bord dat aangeeft dat het aan beide zijden voorbij mag worden gegaan op een zeskantig gele zuil."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5ca5367f6ee74a43bd8d767bc64f6609" name="E06_OB309">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_33beb243db1a4957873ea56d1fc93365" body="Aanduiding voor de aanwezigheid van een mindervalidenparkeerplaats met specificatie van kenteken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f64a8e5a469545a994772bae4a786b36" name="F03_OB206ps">

          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a4e244057ebe46e692c4ea66649e51eb" body="Een langgerekte verlaging in het terrein van natuurlijke of kunstmatige oorsprong die permanent of periodiek stromend water bevat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_412d8c69515746ddbe7126e47d5d5b6b" name="Secundair">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ee407ec9abbb48ee9309988828ed3246" body="Oppervlaktewater dat van beperkt belang is voor de waterbeheersing."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e31b39378a1a4161a0d79b1c04a60e64" name="Tertiair">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9f429269900f41c4bc74052a2fa876a3" body="Alle andere watergangen dan primaire of secundaire watergangen, bijvoorbeeld scheisloten en binnensloten."/>
        </ownedLiteral>

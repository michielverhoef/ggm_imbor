        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_07ec44fc9fa74dad820ad3e857ed967b" name="Outputcontact">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_05f58afaee4d4312a95b3cbcc0f7d810" body="Elektrisch uitgangspunt voor het koppelen van handmatige bedieningsmogelijkheden."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_8e38fc1164ec4088bbf23da84f237301" name="enum_ContainerTypeAfval">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_783030ca8abc4386a51df75504bc2c26" name="Batterijen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3993aab69c6c40b386c447abbdd15dc0" body="Het bedoelde door het afvalbergende object ingezamelde afval zijn opslagelementen voor elektriciteit."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7892b0c258f04d5c916809157f3c97ce" name="Bedrijfsafval">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_88fefc2bbb44432593740cbea98a7803" body="Diverse soorten bedrijfsspecifiek afval, dat dikwijls afzonderlijk opgehaald en apart verwerkt moet worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_98e1f340ba664c098af454be11cb0ab2" name="Bont glas">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c73085b78f3f4f7a833ce369aab305ca" body="Het bedoelde door het afvalbergende object ingezamelde afval zijn gekleurde glazen - dat wil zeggen al het glas behalve wit glas."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_be978af7f92740aea4e6d2ce00ef0fd9" name="Bruin glas">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ed947fe220b84f708b4690407e237920" body="Het bedoelde door het afvalbergende object ingezamelde afval zijn bruine glazen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a62ece845d964d6b82ab7703cd3be786" name="GFT-afval">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b27231e5f9c84d64b0eb7b688997c8d6" body="Etensresten zoals overblijfselen van groente en fruit en tuinafval, zoals kleine takken, gras en onkruid."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_13a8b717db874936b134cfc1b899288a" name="Glasafval">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2c52417e26954e43bd238fdd724f40d6" body="Glasresten en consumptieverpakkingen van huishoudelijke oorsprong."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_22f862b533ca4be68a49860bd67d0677" name="Groen glas">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f5a201dae5414be7bde990f2bee67ee3" body="Het bedoelde door het afvalbergende object ingezamelde afval zijn groene glazen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1915fa2bddb34bde833630c2bdea54c8" name="Kleine elektrische apparaten">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0782f37fb01843c798b454578c2c2068" body="Het bedoelde door het afvalbergende object ingezamelde afval zijn apparaten van geringen omvang zoals opladers, telefoons, headsets etc."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_36320941a130493298f31e49d92bc60e" name="Luiers en incontinentiemateriaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0f1afa6c97a64b788255b54db9ee9015" body="Afval in de vorm van incontinentieafval van kinderen die gescheiden ingezameld worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3eeca666d3d442898b408edd701e4f68" name="Papier">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b3f4a298a1c34349bfa61c8484a1c153" body="Afval bestaande uit papier of karton, materialen die gebruikt worden voor o.a. schrijfwaar en verpakkingsmateriaal."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f961dfa5ad734756ab8586ff0ad69d1b" name="PMD">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b22dc50bfd97414e827e3eceb7073001" body="Het afval van plastic flessen en flacons, metalen verpakkingen en drankkartons of plastic verpakkingen, metalen verpakkingen en drinkpakken"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ccce4547d7f14dc1b187e90e4cceb53d" name="Restafval">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ce8db33cf8ec4a838bdd8bf39d739f3d" body="Alle niet-recyclebare resten van huishoudelijk afval."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fe5c85e689a24b448c8a0b7c8aff8542" name="Textielafval">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6aa693aacc0c4c8e900ee2b140fc446d" body="Als afval opgegeven kledingstukken en schoeisel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_59229a49a4fb4ee786967db16d2045e4" name="Wit glas">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_49b4f88597a44400b1cc13c9bbd07a60" body="Het bedoelde door het afvalbergende object ingezamelde afval zijn witte glazen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_026c5163543f4da08f90871f416f1a0f" name="Zwerfafval">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a8a0456f87a64aed8077697642e881a0" body="Afval dat onachtzaam op willekeurige plekken in de openbare ruimte is gedeponeerd of zou worden zonder het bestaan van deze afvalbakken of containers."/>
        </ownedLiteral>
      </packagedElement>

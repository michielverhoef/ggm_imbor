        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_35a3721fcbf44d81b8172811f37d2630" name="Regionale stroomweg: type I - 2x1">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_45c27ec035724ba9b64dc47deb675a91" body="Altijd bubeko (buiten de bebouwde kom)."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4b98e7aaf2154d6689eb9421d5b53e1e" name="Verbindingsweg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e22ab58dc8164e1e80eb41b4ea4bbc2a" body="Bij een autosnelweg, autoweg, lokale weg en een regionale weg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f9be9b9e7cdb4ebcbd3cdf99ac7919ab" name="Verbindingsweg - afrit">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1dfadb6c84ab49f39d52a30c1e3fd6ca" body="Een afrit is een type verbindingsweg met beperkte lengte waarop bestuurders snelheid kunnen minderen om de hoofdweg te verlaten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1ac89240fed14047afb4448e56c1578e" name="Verbindingsweg - toerit">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0951311d87144181bf8465a28382d806" body="Een toerit is een type verbindingsweg; Verbindingsweg heeft 2 typen: Afrit en Toerit."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7c7d637b4656479a93b8340886dff6be" name="Woonstraat">

          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6b056877110b43a3b45efb69f999d150" body="Een boom waarop beheer van toepassing waarbij inheemse flora en fauna centraal staan."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5ff2b651855a41ff81f459bb91d52c2d" name="Ecologisch waardevol">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_12a39db7afdd4451978278f5360d0133" body="Boom of boomstructuur die een hoog potentieel aan bijzondere soorten vertoont en een positief effect heeft op de plaatselijke ecologie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ed516b3f61984a32b3d23c876c77d89f" name="Faunavoorziening in boom">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b5745ce0cee045f8a3e65d06f0ecfad3" body="Specifiek boomkenmerk voor gebruik binnen het Handboek Bomen om aan te geven dat er een faunavoorziening in de boom aanwezig is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f92a0243290c49ee95cbf7abe8b28b40" name="Herdenkingsboom">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e566c633562943d4bebd0b91a67c01c8" body="Boom aangeplant ter gelegenheid van een bepaalde gebeurtenis."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8ab8a3d6b5194c84923d8ed37bae65ab" name="Jaarrond beschermd nest">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_609f0a777c744b9887e7312ca4250ea4" body="De boom of bomenstructuur bevat een nest van gevogelte waarvan het volgens de Wet natuurbescherming gedurende elk jaargetijde verboden is om te beschadigen of te vernielen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c13d895696054018b9d60560901965a8" name="Klimboom">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b6a25958a49846d882ae61f295d76c24" body="Boom die lokaal wordt gebruikt om in te spelen en klimmen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6ef45d5a872546b9ab52d97549dab53c" name="Lijst waardevolle bomen">

        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3d9f685f31644594ad8d59e36acc8ece" name="Nationale stroomweg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_864a8238171044beaca041ffdfc555e1" body="De wegen van de hoogste orde. Deze wegen voorzien primair in verplaatsingen tussen landsdelen en bijbehorende economische en culturele centra. Ze sluiten bovendien aan op de hoofdwegennetten van de buurlanden, zodat ze ook voor internationale verplaatsing"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d4be577e8bb448f8b06855ab3af9d7cb" name="Regionale stroomweg: type I - 1x2">

      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_8e68bc6ad4354fc49081fcb416e4c4d1" name="enum_LijnmarkeringMarkeringToepassing">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0d8444486b464777826c4172b8310635" name="Bij nadering voorrangsweg voorrangskruispunt of -splitsing">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6d95ff4267c84e4095939edef5f76ad3" body="De wegmarkering wordt gebruikt als aanduiding van het begin van een voorrangsweg voorrangskruispunt of -splitsing."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_45669b1bc4bb4c76bfd1c7a7426cc27b" name="Combinatie van as- of deelstreep met waarschuwingsstreep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5aeeb3758cd544ce9d5f934d51f48228" body="Een wegmarkering die een combinatie is van een asstreep, een wegmarkering in het midden van de rijbaan die de twee verkeersrichtingen van elkaar scheidt, of een deelstreep, een wegmarkering in de vorm van een streep die verschillende rijstroken in dezelfd"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_dbed23203fcf41a496b5253a62da406d" name="Divergentielijn (brom)fietsers">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_16fa3ef458954a888b4293a932170746" body="Wegmarkering in de lengterichting die (brom)fietsers naar een andere rijbaan geleidt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2aaa721d3fad412892af9b3ce02f454d" name="Dubbele asstreep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_990854bf23784037afb7c1c45763f1b9" body="Wegmarkering in lengterichting die rijstroken voor verkeer in tegengestelde richtingen scheidt, uitgevoerd als dubbele strepen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d1df743884254b37a7396e7d44b366a2" name="Dubbele deelstreep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1bb47962cb5843488b83558d481765ed" body="Wegmarkering in lengterichting die rijstroken voor verkeer in dezelfde richting scheidt, uitgevoerd als twee onderbroken of doorgetrokken strepen"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fe3494f3f7934b4ab45fc89cdaa9d222" name="Dubbele kantstreep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f85c9d8d131b4c36bc032b594128775d" body="Wegmarkering in lengterichting die de verkeersbaan scheidt in een deel bestemd voor rijdend verkeer en een deel niet bestemd voor rijdend verkeer, uitgevoerd als twee doorgetrokken strepen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_53bca071dd9c4bdd952e9b7538c442d1" name="Dubbele stopstreep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_99e199fc38a34751b4ac7dd9960de1d8" body="Wegmarkering in dwarsrichting waarvoor gestopt moet worden indien dat geboden is, uitgevoerd als dubbele verkeersstreep."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f0fff365b8304f51898a1036c09811b9" name="Dubbele zonestreep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f61daec6a43c426e9f8f87b7703e036b" body="Wegmarkering in dwarsrichting welke het begin of einde van een verkeerszone aangeeft, uitgevoerd als dubbele strepen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f440d54fd1314524b3ad9de3819cdc47" name="Enkele asstreep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f0a08580527e483da450b6eb640a9e29" body="Wegmarkering in lengterichting die rijstroken voor verkeer in tegengestelde richtingen scheidt, uitgevoerd als enkele streep."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_33bccc50a39641dea9c7fef5653fea56" name="Enkele deelstreep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a18db1ab5b684d02930123b3e083f1b2" body="Wegmarkering in lengterichting die rijstroken voor verkeer in dezelfde richting scheidt, uitgevoerd als enkele onderbroken of doorgetrokken streep."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ac08ef0e8554466b8402b1b231c2ddc9" name="Enkele kantstreep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_65a81dd708ee4d88af2e0d39bd28088b" body="Wegmarkering in lengterichting die de verkeersbaan scheidt in een deel bestemd voor rijdend verkeer en een deel niet bestemd voor rijdend verkeer, uitgevoerd als doorgetrokken streep."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_33176a2c04b247648570eb347a82f0a2" name="Enkele stopstreep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2987532ebab84a4d96dffd555ca53b83" body="Wegmarkering in dwarsrichting waarvoor gestopt moet worden indien dat geboden is, uitgevoerd als enkele verkeersstreep."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3ae170babe72423ebf37b4c80068e062" name="Enkele zonestreep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4dd0da23416e48948aa6d803a1d8801e" body="Wegmarkering in dwarsrichting welke het begin of einde van een verkeerszone aangeeft, uitgevoerd als enkele streep."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7f86789efd514ac1a1bab01dc7fbeca8" name="Geleidenlijn">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cf42bb35d4e94932aaacfdc2f8b9372a" body="Een markering met een reliëf dat slechtzienden en blinden informatie verschaft over een looproute of verkeerssituatie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6ee56f13c5ba42028c485f83d2cdd37d" name="Kanalisatiestreep voor voetgangers en/of (brom)fietsers">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_35f72a26f94f46ae9d070b9c7e16833a" body="Wegmarkering in dwarsrichting ter geleiding van overstekende voetgangers en/of (brom)fietsers, uitgevoerd als onderbroken verkeersstrepen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_788d9d3233e04e09ba430f6af2f2f06f" name="Oversteekplaats voor (brom)fietsers in de voorrang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_70132ef46b4f49afb05db37b01a2a63e" body="De wegmarkering fungeert als aanduiding voor een oversteekplaats waar (brom)fietsers in de voorrang zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_633a97957e6c470c8ed180774320bd8b" name="Parkeerverbod">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a3659525dae84d46a524a39c2d7d5219" body="Wegmarkering die aanduidt dat er langs een lijn of in een vlak niet geparkeerd mag worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7f79f0ef73bc4f14bc2ec683e068e59b" name="Parkeren met beperkte tijdsduur">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_16f9f7104e4840f19dfc13a8793e9df9" body="Wegmarkering die aangeeft dat er langs een lijn of in een vlak slechts met een beperkte tijdsduur geparkeerd mag worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ba7a44ae79fe45f384503c4bf94fd28e" name="Psycho bremse">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f172eb6f96324d4f9cd88fc9fe79d96d" body="Wegmarkering op de rijstrook welke tot doel heeft op het attenderen van het volgende verkeersaspect en een remmende werking heeft"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_701dfca4b67a419aaa8407b6a00f6464" name="Streep bij inleiding bebouwde kom">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4580f28992c24228b60af54b781de41e" body="De wegmarkering wordt gebruikt als streep die het begin of einde van de bebouwde kom aanduidt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6d2e0cbabfc247bda77cb07b267d3b3f" name="Waarschuwingsstreep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_505ff7ddeef24037a0fbe8a10399e5b1" body="Een wegmarkering met als functie het waarschuwen van naderende weggebruikers voor een kort op de strepen volgend potentieel gevaarlijke wegsituatie."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_f938ca8cf4f44811a21010e89ed70ae8" name="enum_LijnmarkeringVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f829f49d9ff44d2bbab45182bfc2c0f5" name="Blokmarkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_67c2def1cdb848a0acf370254db92f7b" body="Wegmarkering bestaande uit in een lijnpatroon aangebrachte blokken met een breedte van meer dan 0,25m."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_05d50c7fadc940adbf76e1a55c89dc0f" name="Doorgetrokken streep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f873b9a72e4d461cbaca47bf6967aad8" body="Verkeersstreep in de lengterichting van de weg, die over ten minste 20m niet is onderbroken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_82145a1618704077805329acb51f6db3" name="Driehoeksmarkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_344d15e9b2ad4ad8a49a133fe9d3c9ea" body="Wegmarkering in dwarsrichting die aangeeft dat men een voorrangsweg of voorrangskruispunt nadert, uitgevoerd als driehoekige vlakken in een lijnpatroon."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d9d64375a71f49c9bd0b5b949bdb15c7" name="Onderbroken streep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a84bd52a7f4d4e7983748acae1d02563" body="Reeks in elkaars verlengde gelegen verkeersstrepen die elk langer zijn dan 9m."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_8b9446370538497687414d0f535afc83" name="enum_LiningTypeLining">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_05b7684b95e0427ba2bbd6b631dd4fd0" name="Close fit lining">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9ca2a4cb6749437aa09643ee90da83e6" body="Nieuwe, zeer nauw op de bestaande leiding aansluitende bekleding of geheel nieuwe leiding die in een bestaande leiding wordt aangebracht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_90d1a1a78e4b4af799e9ec3c57c58483" name="Gesegmenteerde lining">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c7b81ee9145d478ba579b30d4b78b048" body="Nieuwe bekleding of een geheel nieuwe leiding die in een bestaande leiding wordt aangebracht bestaande uit meerdere segmenten die afzonderlijk worden aangebracht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_29abfed8c0cb4c18a1aa0175234aaed4" name="Lining aangebracht tijdens fabricage">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9b0293f075ab4fb980c2f55c48c22d5d" body="Bekleding of een gehele leiding die reeds in een bestaande leiding wordt aangebracht tijden fabricage."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_24c3e6e2cc5442f69ad9828a0259b64d" name="Lining met afzonderlijke buizen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6540d429ef0842ffb9f12256e4db32ce" body="Lining door middel van een geheel nieuwe buisleiding bestaande uit meerdere stukken, die in een bestaande leiding worden aangebracht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f030ff50b4274ccd92f700c73acb18a9" name="Lining met een doorlopende buis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_06cdafc6983940369313b537af279413" body="Lining door middel van een geheel nieuwe buisleiding bestaande uit één stuk, die in een bestaande leiding wordt aangebracht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5f2038905d1847019832d224dff6b2d2" name="Opgespoten lining">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_85505b321bc74db1b9310bbe7d2a7bbb" body="Nieuwe bekleding die in een bestaande leiding wordt aangebracht door middel van het spuiten van het materiaal van de lining tegen de wanden van de bestaande leiding."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0db3c3b037a449e5bddb2306cee13723" name="Spiraalvormige omwonden Iining">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_054141a72cbf41bb87ba0d85042c01a3" body="Nieuwe bekleding met de vorm van een spiraal die in de bestaande leiding omwonden wordt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ab8f089dee934224b5b6bb40ec1cd70c" name="Strak aansluitende lining">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cdcb102a7f6c4c36ac1f6f2c7eee0027" body="Spiraalvormige omwonden lining hernoemen in Wikkelbuis relining."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1a1116d4372d44b29c7063e3eece53dc" name="Ter plaatse uitgeharde lining">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_73c91e592df3454a97f58772d6975388" body="Nieuwe bekleding of een geheel nieuwe leiding, van een materiaal dat ter plaatse uithardt tegen de randen van de buitenste leiding, die in een bestaande leiding wordt aangebracht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_56a704784a9848549e999d3f4e5b0789" name="Wikkelbuis relining">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ade97ec766ec4951878c41eff14d42be" body="Een relining techniek waarbij een dunne holle buis wordt afgewikkeld van een haspel en tegen de binnenwand van de leiding wordt gespannen op spiraalvormige wijze."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_e26487ea50904a5fa78e63fba0511711" name="enum_LoofbosVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_250510d0c603450db85e9c5e1edfa8c1" name="Broekbos">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6d127198dbcb44f380dedd9dbb50b95a" body="Bos waarvan de vegetatie sterk wordt bepaald door de (hoge) stand van het (grond)water, meestal is er sprake van kwel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7ee047f8694c47348ccf9fa83eb5d041" name="Griend en hakhout">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_55e6bd70aa5a4ab4b7135c7f28496571" body="Gesloten beplanting waarvan de boom- en/of struikvormende soorten regelmatig worden ingekort tot aan de wortelstronk. (Bron: RWS)"/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c725720e399e468a875829905e5dd793" name="enum_MaterieMateriefase">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fc908244d6f0487cb46a468e82fb3817" name="Fase 0">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1387c67bdfcc41ccb0fd0abcd112fdbe" body="De materie van het object betreft een nieuw materiaal."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_03e407edd44b499d8980524c2a6945e5" name="Fase 1">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a45f473b7d204774b9aceb216d28b21f" body="De materie van het object betreft een materiaal dat voor het eerst is hergebruikt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8ef9c76fa8454a1eb8edcec519338ba0" name="Fase 2">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_de2fa9e5d92d4716a19e32009fa01acf" body="De materie van het object betreft een materiaal dat voor de tweede keer is hergebruikt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_023fab66ab6a4cb1a05e6b32af2c3440" name="Fase 3">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fcbb1d16289c4e79909532bf4fe7458c" body="De materie van het object betreft een materiaal dat voor de derde keer is hergebruikt."/>
        </ownedLiteral>
      </packagedElement>

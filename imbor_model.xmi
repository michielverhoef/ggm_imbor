        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8ade349a90c44d8492bb2d6976630acf" name="Voetpad (geofunctie)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8335891034b641b6bd8eefe7f904c150" body="Wegdeel waar voetgangers gebruik van moeten maken. (bron: BGT)"/>
        </ownedLiteral>

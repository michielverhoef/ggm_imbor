      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_90afaec0ab094830b8a64a78cf534d4a" name="enum_BegroeiingGewenstSluitingspercentage">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_dd474f6f06ee4c14bee1abd2e01fcc13" name="Niet van toepassing">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5cda8b572227415ea96a285b1692c799" body="Waarde waarmee aangegeven kan worden dat een attribuut niet geldt voor een bepaald object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_af85e20fd6104b0d9db9ff442d622c09" name="Sluiting &lt; 70%">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0c3d798c545b42b3b46eef97113ad442" body="Klasse voor de bedekking met de beoogde beplanting van het beplantingsvak in bovengrens voorzien door, maar exclusief, het zeventigste percentiel van het beplantingsvak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9d5706d25a9d4e7598fb88fa8059f745" name="Sluiting &gt;= 70% en &lt; 90%">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aacb0b1ba6774e9d8976c33912b63136" body="Klasse voor de bedekking met de beoogde beplanting van het beplantingsvak in ondergrens voorzien door, en inclusief, het zeventigste percentiel van het beplantingsvak en in bovengrens voorzien door, maar exclusief, het negentigste percentiel van het bepla"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_601454bf1f214abc8a0e9cda3592822e" name="Sluiting &gt;= 90%">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_feca99439bd74653b904582c75f0bc2d" body="Klasse voor de bedekking met de beoogde beplanting van het beplantingsvak, in ondergrens voorzien door, en inclusief, het negentigste percentiel van het beplantingsvak."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_e3c02ada6213473b97a2333e003eab6f" name="enum_BegroeiingOndergroei">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_909d2ff265684168ad6fa157e4f0816c" name="Geen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dc4bf9c0863f4d6d800533de95736878" body="De waarden uit de suggestielijst of vaste lijst van het attribuut zijn niet van toepassing bij dit specifieke object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_822afc80681842a3b6ef0fc79a61e1f0" name="Kruidachtig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_90b5af5059d64cfb8918af9bc404a9a1" body="Onderbegroeiing van onverhoute vaatplanten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3b928e6dac6f45a9ab28a03ac054e1c2" name="Natuurlijk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6a68c2d3911648ddb3f0939ff39fa3f5" body="Van nature opgekomen onderbegroeiing."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f94d0c3ed24141f39c8807fd61dfc07e" name="Ondergroei met bodembedekkers">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0753ef21dde0409eb9145850ce850f97" body="Heesters met een maximale hoogte van 0,60 meter die door hun natuurlijke groeiwijze (horizontaal) de bodem volledig bedekken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_929a2656687449b2b045467b62991d1f" name="Vaste planten">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_34eaf3f654644a5ab17b651bc27b6767" body="Type van planten. Planten die langer dan twee jaar leven, in het voorjaar uitlopen, in de regel ’s zomers bloeien, in de herfst afsterven terwijl wortels overblijven om weer in het voorjaar uit te lopen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_5d08e46191e84db895bd821368080586" name="enum_BehendigheidstoestelVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_de52b2092410433d9d51611f36fdd823" name="Balanceerbal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_29c4c15acb514d939c6d7638cb2a7636" body="Een behendigheidstoestel bestaande uit een bal om het evenwicht op te bewaren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2e09e3df0a7a447898281bd24cff3369" name="Balanceerblok">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c521dddd598e495699ebda186fade2a2" body="Een behendigheidstoestel bestaande uit een blok om het evenwicht op te bewaren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4ed72421390e4cbdb9ecc603162859ef" name="Balanceercombinatie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_897b244ba72f4e16bd433987e315eddb" body="Een behendigheidstoestel bestaande uit meerdere elementen die zijn bedoeld om het evenwicht op te bewaren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_91c4b5bb229d4747b90abf197b6ff39c" name="Balanceernet">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_10731e2c65ae4254b1dedb1a1d795aec" body="Een behendigheidstoestel bestaande uit een kunststof net, of een net gemaakt van touw, dat bedoeld is om het evenwicht op te bewaren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d6997e30c0354f348495c3693f360f57" name="Ballenpaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7441f103b8294a67ae37728dc2597abd" body="Een paal met daarop een vorm die bedoeld is om een bal in te werpen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9e0b48cc12ae4bb7bebb6f499d9e4f14" name="Ballentrechter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_35640fee7d134e4694ef339353882f05" body="Een paal met daarop een kuip of een trechter die bedoeld is om een bal in te werpen en de bal via een opening weer vrijlaat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8085b80efd38470a8935cc46b2b7874e" name="Bandenloop">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_99fc53ae0bc842b5af4a170ef67fdc6b" body="Een behendigheidstoestel bestaande uit een verzameling banden bedoeld om overheen te lopen en daarbij het evenwicht bewarend."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_144195ddbc0043f3be525c5b15e3e18b" name="Behendigheidsparcours">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_488cedab6b1440cab6480c574c3f4f55" body="Een behendigheidstoestel bestaande uit meerdere elementen bedoeld om achtereenvolgens te doorlopen, daarbij het evenwicht bewarend."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3717e7be27af42149251f589b7195cf6" name="Bokspringpaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1d793263da78439494d57bf97b6c016d" body="Een behendigheidstoestel waar men overheen dient te springen door met de benen wijd met twee handen tegen de kop van de paal af te zetten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d3ae9fa3ceea47c9993c68a77d122847" name="Draadcircus">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8858062076314c8baf2f58b00296f863" body="Een ruimtenet in een vorm gelijkende een circustent, waar men in kan klimmen en op de touwen kan balanceren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c2e0386e5d7d478d993b22bd59a69581" name="Driedubbele evenwichtsbalk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d03597f1175d4a35bf150f19024ea917" body="Drie balken die in elkaars verlengde liggen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_208719819cf944979586fd0560c00242" name="Dubbel looptouw met steuntouwen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f7d90f74e9d043ecbd01d034bf2b9bc7" body="Een behendigheidstoestel bestaande uit twee touwen om al balancerend over te lopen, met daarboven steuntouwen die met de handen vastgehouden kunnen worden tijdens het balanceren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_860b73d91c2c4192b259276b6f48b2c3" name="Dubbele evenwichtsbalk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ce811a6d792345babf4e6ee012458149" body="Twee balken die in elkaars verlengde liggen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2dc7011d4587439db6dea031c7691aaf" name="Enkel looptouw">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4bdee9247cb54316b21ef3ab6a28c806" body="Een balanceeruitdaging in de vorm van verbinding tussen twee punten bestaande uit een enkel touw."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d1130e5922da4182807b956e441d97e6" name="Evenwichtsbalk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b2b39c771bfb419faaa9d0f58db0b94b" body="Een langwerpig, horizontaal of licht hellend gepositioneerd behendigheidstoestel dat bedoeld is om balancerend over te steken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5455164b02684d9fae90b85f5515ab72" name="Evenwichtsbalk met hoge staanders">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_45d5fa1bc0184bfcbcd64adcb4a967e8" body="Een langwerpig, horizontaal of licht hellend, op hoge palen gepositioneerd behendigheidstoestel dat bedoeld is om balancerend over te steken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_46801af025d84bda9c2d4b125e2c9329" name="Evenwichtsbalk op veren">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e5168ce0438d4535a3733df3c83341a4" body="Een langwerpig, horizontaal of licht hellend, op springveren gepositioneerd behendigheidstoestel dat bedoeld is om balancerend over te steken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e5916851c930492c960515b1e1c28acd" name="Evenwichtsplateau op veren">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_12502fd2fd554a2ba0cb82c07942a4ea" body="Een plaat bevestigd op één of meer springveren waardoor het plateau een balansuitdaging is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c5e8d065c1894be9a0e45ecc45098a82" name="Gebogen evenwichtsbalk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_499d74e9d1134a8785fbbcce2b58fec0" body="Een langwerpig, horizontaal of licht hellend gepositioneerd behendigheidstoestel met minstens één buiging erin, dat bedoeld is om balancerend over te steken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8d33df3aaec9471b9fae14c3f448fd31" name="Hinkelbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4ca672c6cdcd44acb82201459c69a2ce" body="Een verzameling vakjes waarbij kinderen op een bepaalde manier van het ene naar het andere vakje springen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1c6d3e61a2f44aa993a963f25c92c254" name="Hinkelplein">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8290ea7ef28745c4a081c2c41de8b5fb" body="Een vlak met hinkelvormen in de vorm van een hinkelpad."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d764cad2ce12405eaa004f0d3f922de9" name="Kruipbuis">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_606bd44fbea14f80a95a22a122892f0f" body="Een behendigheidstoestel, bijvoorbeeld een mangroot betonnen leidingdeel, dat gebruikt wordt voor kinderen om doorheen te kruipen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1f7bb74eb2e64c128934276e05d8f2a8" name="Loopbrug speeltoestel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9ba67de4937d4ecbb4a382559514b7c5" body="Een behendigheidstoestel in de vorm van een brug waar gebruikers over kunnen lopen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2aa6116c4bf4413b9470b6376b71dbc8" name="Loopton">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f29ee9c6cd8944f89df8304f7348990f" body="Een speeltoestel tenminste bestaande uit een ton, waarbij het de behendigheidsuitdaging is om in of op de ton te blijven lopen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_99bb68a7039c4051bd7aaecfe2b2540e" name="Loopton om in te lopen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d0fbda6ecd9d4d1592359b90d5153815" body="Een speeltoestel bestaande uit een om een horizontale as draaiende ton, waarbij het de uitdaging is om in de draaiende top te blijven lopen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_dd25ef02a65648d1835f230453c92a40" name="Loopton om op te lopen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_830717f4fe0d4a29bab724a309fe1576" body="Een speeltoestel bestaande uit twee palen met bovenop elk een handgreep en tussen de palen een om een horizontale as draaiende ton, waarbij het de uitdaging is om op de draaiende top te blijven lopen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_16ca6780bfc942c9a53b44eacc43c573" name="Loopvlonder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7e2b2c79baea491e8b1caa105ea289bc" body="Een vlonder (houten steigerachtige constructie) die wordt gebruikt als voetpad."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_247dab2117634d9cbc1687e20da5bc30" name="Om lengteas draaiende evenwichtsbalk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_45658f49e4d64e5bb4a838837b6166a5" body="Een langwerpig, horizontaal of licht hellend gepositioneerd behendigheidstoestel dat draaibaar is lang de lengteas, bedoeld om balancerend over te steken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c5ee0b31f74e4c3ea64d7db21db149b2" name="Palen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a7fc511e615c48d79108c7977e801c14" body="Een behendigheidsparcours bestaande uit een verzameling nabijgelegen langweprige, cilindervormige elementen van variabele hoogte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4b3d227a7d7542d59bf5ea9fa1774093" name="Pleinplakker">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6808f4b054184d468c794488005a18a8" body="Educatieve of recreatieve en slijtvaste stickers op een verharding."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_727411ad017d4e9d9120396334a3472e" name="Slalompalen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_33cbcbe65be34f908e8ba09665b71bbd" body="Een behendigheidsparcours bestaande uit een verzameling palen, waarbij het de bedoeling is om elke paal aan de buitenzijde te passeren, waardoor de af te leggen weg een slangachtige vorm heeft."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0d4cd5df9e3641dab1d09cb5478f9e6b" name="Stammenstapel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ad1012e0405a434e8e0459e04d4b23d4" body="Een speeltoestel in de vorm van een stapel boomstammen die als behendigheidsuitdaging dienen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ea32a4ea84774aff9841ae991e6e3be8" name="Stammentrap">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_df53419dc3e7419489d1582ea0f0aa83" body="Een verzameling grofweg evenwijdige boomstammen die gebruikt kunnen worden als treden van een trap."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3481aa0eb6b84d6c9fe2858ec289c736" name="Stammentrap als losse trap">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8d8e78349f9f45e7b78a86d120d3142b" body="Een verzameling grofweg evenwijdige boomstammen die niet op de helling van een talud liggen en die gebruikt kunnen worden als treden van een trap."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0f1fca3a62184014b1be0a22e3201b8a" name="Stammentrap liggend in een talud">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2ef7e49dcde44ff2ab4e9be2a763b35a" body="Een verzameling grofweg evenwijdige boomstammen die liggen op de helling van een talud die gebruikt kunnen worden als treden van een trap."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1dcbc88b48de40f5b8cfeb05ee43d6a1" name="Stappaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aa080d38cea145efa74a9dbb752a536e" body="Een behendigheidstoestel in de vorm van een paal van variabele hoogte, bedoeld als balanceeruitdaging."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_936d028686dc42aeac0d73166235717a" name="Stappalen oversteek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c8ece02a78cb4b7d97643fe63bcc89f3" body="In de grond bevestigde stappalen die een behendigheidsuitdaging vormen met daarlangs een tussen twee palen gespannen touw, bedoeld voor houvast bij het gebruik van de stappalen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e8e9f1222e834cf5b58d1134bd0f2fe6" name="Stelten">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b64b83fd301146f6a39443548cd5c049" body="Een behendigheidsparcours bestaande uit een verzameling langwerpige palen met daaraan bevestigd voetsteunen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7450d36e03d04d2e8eaeaed0526486f6" name="Touw tornado">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cad418c078eb47c3a4bddc61043c936a" body="Een geautomatiseerde touwtje-spring-machine."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3e486faa501d4fd88fcd241a63624d2c" name="Touwbalans">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_175051426a3c428d848a18f455d8a250" body="Een netwerk van touwen bedoeld als behendigheidsuitdaging."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6499713ca75247af90d4003f9f61ffa1" name="Touwbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f4ce676edddb4569a062b72fdc46fa5b" body="Een hangende brug waarvan de leuningen gemaakt zijn van touw en het dek is vervangen door sporten van touw, een enkel touw of door een erg robuust touw."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_12eb54c68c7647bba261b27ac320fc24" name="Tractorband">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e7c5d111eb3542629c1464e7648812ae" body="Een (gebruikte) band van een landbouwvoertuig die is opgesteld als speeltoestel om op te klimmen en rondom te spelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_26be911c08f8499ca8d6b9b1f5a0de9d" name="Turnbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8fba0ed8cdae49e4b7a25bc91d0520d7" body="Een turntoestel bestaande uit twee (afstelbare) evenwijdige staven die op de palen van een frame op de grond rustend frame zijn bevestigd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_aafa6af612284926a3f9d8fcd70660c5" name="Wiebelplaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1a1ae1b5fa2d467d881bc279f7632113" body="Een op veren bevestigde plaat die een behendigheidsuitdaging vormt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a1afe5d112cb4c5fbed3bdd354f056a9" name="Wiebeltol met mast">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_395ee0c0d38e4475bf1c64f2f40fb092" body="Een om een verticale, diagonaal verbredende as draaiend toestel waar een paal uitsteekt die als houvast voor de gebruiker dient."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0b9b59ba589b43b697e59725e690ca82" name="Windsurfer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e34679e31e914c8dbd0f6eb575ce4ae0" body="Een op veren bevestigde plaat met een mast lijkend op de mast en het zeil van een windsurfplank."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5989d1c2a4e44a7ab93b7b60da48526c" name="Zit- en stappalen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_39c18d4867f84b1fb45c4efbd0b32c5e" body="Een behendigheidstoestel bestaande uit meerdere palen van variabele hoogte die in elkaars nabijheid geplaatst zijn, waarbij de palen niet alleen geschikt zijn om van de ene naar de te stappen, maar ook om op te zitten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_20ed943977e746a491be41d67e1836a4" name="Zwevende evenwichtsbalk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_68529af17f804065814d8d73cfb3c156" body="Een langwerpig, horizontaal of licht hellend gepositioneerd behendigheidstoestel dat bedoeld is om balancerend over te steken en op een bepaalde manier is opgehangen, bijvoorbeeld met behulp van kettingen, waardoor de balk boven de grond hangt."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_e25ce929b685466687b3d8de8585a1cc" name="enum_BenoemdePlaatsVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e5e8055ef6af4a5eb4c365110805913e" name="Drijvend object">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d266f6ad87ad4163816078f3a79f91e2" body="Constructief zelfstandig object dat met het water kan meebewegen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_adb195a0b998466fb023635b7dfa9e0a" name="Mobiel object">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0adfd5e33d1c410ea0929f2185cff391" body="Constructief zelfstandig object dat in zijn geheel kan worden verplaatst."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0ed8d8622c9e4a689d100f385206e75f" name="Onbemensd tankstation">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_640f663522d840e2b30dd901a5eaca89" body="Geheel van installaties bedoeld voor de verkoop van brandstoffen of energie voor voertuigen, waarbij zich geen bij deze installaties betrokken gebouw bevindt."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c51f52a7531f4dd1883197f72cd2195c" name="enum_BeregeningsinstallatieVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_989c5b89c4ce4e2c9b9a2f95e78daad9" name="Buizenframe">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9101ba45e28d41c4b2fd579c09693c96" body="Stelling van holle, water geleidende buizen die het doeloppervlak beregenen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1bf8c6fc3f934998836712ba606c4708" name="Grote sproeier">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4d67413f0e534e2c8746d0d133d7b54c" body="Een apparaat van bovengemiddelde grootte het toevoeren en in stralen verspreiden van water in plaats van of in aanvulling op de natuurlijke regenval."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_57d933b31ab64a159ce38154c4b180ee" name="Kleine sproeier">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4139e1f922844c2aa7ef3282737ed83d" body="Een apparaat van ondergemiddelde grootte het toevoeren en in stralen verspreiden van water in plaats van of in aanvulling op de natuurlijke regenval."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a467176e7d864d2e83f513fbca0ac824" name="Waterdruppelinstallatie">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8653067ff5db4caa807902e0334e165b" body="Installatie voor het toevoeren van water in plaats van of in aanvulling op de natuurlijke regenval waarbij waterdruppels direct rondom de wortels van planten worden aangeleverd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0611f591fd0a4eadb9b8e2fa9a317661" name="Waterkanon">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1fd9fba751aa4172914cda7207aff7af" body="Een beregeningsinstallatie die waterstralen afvoert om een akker met gewas van water te voorzien."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c8daad9198aa4772995c64babc212437" name="enum_Bereikbaarheid-InformatieBereikbaarheid">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a66a87fbb03047f7a0b22b6ffc89aa3d" name="Bereikbaarheid met beperkingen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fa39cbea938c42e28afdbcb9377c6034" body="Op de toegankelijkheid van het desbetreffende object zijn versperringen of andere moeilijkheden van toepassing."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8263bcbf7a404b6b8aee357f488c3939" name="Bereikbaarheid zonder beperkingen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8f1913929c09437c99bb7b69717104f3" body="Het desbetreffende object is toegankelijk zonder dat hierbij versperrende of andere moeilijkheden te pas komen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f580628e497247618da73e0a1841b768" name="Onbekend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_315186f8b9e1427f93346d158cc75ce6" body="Bij deze waarde moet nader onderzoek uitwijzen of welke attribuutwaarde van toepassing is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e50f12f2ab6b4851847285bb16e392f6" name="Onbereikbaar">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_70cb00c6d5824bf1bdd58e2b445d893a" body="De actuele toestand van de boom is dat de gewenste takvrije stam niet bereikbaar is."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_cd5ebc1428e941e3a21a62a7fd299a55" name="enum_Bereikbaarheid-InformatieBereikbaarheidGedetailleerd">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e8ee0654b0634f74963f9bd954a0abf3" name="Actiewagen verplicht">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3867a8fe7aa94d4f9943ff2b572c049c" body="Voor de toegankelijkheid van het betreffende object is het noodzakelijk een informatievoorziening te gebruiken bestaande uit een (aanhang)wagen met daarop een informatiepaneel en mogelijk een bord om weggebruikers in te lichten over plaatselijke werkzaamh"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bd157b3943404f26a4c30874d5db3017" name="Actiewagen verplicht 9u t/m 16u">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bf7047c2f01f4c3cb0622ee1d67756e8" body="Voor de toegankelijkheid van het betreffende object is het van 09:00 &apos;s ochtends tot 16:00 &apos;s middags noodzakelijk een informatievoorziening te gebruiken bestaande uit een (aanhang)wagen met daarop een informatiepaneel en mogelijk een bord om weggebruiker"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b6a612f34d58400894685b2bb4b2d1d4" name="Beperking aan de maximaal toegestane aslast">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_63a1bb33e7e04ba0980c7f499dbfdbe8" body="Er geldt een verkeerskundige of praktische beperking aan het gewicht dat rust op de assen van het assenstel van een voortuig, een gewicht dat doorwerkt op de bereden verharding."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c099b88b6dc5445e9920e5eb826dd85c" name="Beperking aan de maximale doorrijhoogte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cb9b322f7c4c4804a536a509638977b3" body="Er geldt een verkeerskundige of praktische beperking aan de ruimtelijke omvang in de hoogterichting van vervoersmiddelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_308e2b85d506464ba2076a7c00b8e378" name="Beperking aan de maximale voertuigbreedte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a1358268b6814082a269a241ff698e6e" body="Er geldt een verkeerskundige of praktische beperking aan de ruimtelijke omvang in de breedterichting, veelal loodrecht op de wegas, van vervoersmiddelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9d6dae6a2fbd4a19a1d51b9e0e3f8d4d" name="Beperking door verhoogde ligging object">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_656dbb9d183a4c7c8f7fa857cf67b4d9" body="Om het object te bereiken moeten moeilijkheden omtrent de hogere plaatsing van de locatie van het te bereiken object ten opzichte van de rest van de omgeving getrotseerd worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_219d1d4f55e141529fc5d82d5f9c9267" name="Bereikbaarheidsvoorziening toepassen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_44c370b636b740c48508d3b1df74a99b" body="Toepassing van steigers, kranen, e.d. als maatwerkoplossing om toegang te leveren voor werk aangaande het te bereiken object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_99473ee9132641cbb28083a225d54b60" name="Binnendijks">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ade470c8ff5644e98be2800c644be38b" body="De toegankelijkheid van het object is beperkt door het feit dat het object aan de inwendige zijde van het door een dijk beveiligde gebied ligt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8c5f96f38082401a89ca732f2fe2fe79" name="Buitendijks">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d1a23393934f47e69e44c5a2e01fbdd2" body="De toegankelijkheid van het object is beperkt door het feit dat het object uitwendig aan het door de dijk beschermde gebied ligt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_424f8fe066f74da8bdf57c48aa1f6666" name="Duiken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e5bb92dd9d43400c9fc4a76f763e5a8f" body="Om het object te bereiken moet de volgende actie verricht worden: het langdurig verblijf onder water, meestal met hulpmiddelen zoals een ademluchtfles."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d4d6f8834a2c447d970beae813a7c10b" name="Geen schouwpad aanwezig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c47e2db4f91a49c8b116a3fa6956c559" body="Er is geen aanwezige ondergond ingericht voor het gebruik als schouwpad."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1b50fe434be14021a18f1716c61ff0f5" name="Grote zuiger gebruiken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e999b40cd8be4d05860ac6a3ad50a1ac" body="Voor het schoonmaken van putten, kolken en andere voorzieningen aan het wegoppervlak moet een zuiger van een grote maat gebruikt worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cc5e563471a248b29c05f8bc2b4fa7b6" name="Hoogwerker 10 meter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_61692906f19143f7add12138215120ac" body="Om het object te bereiken moet een machine gebruikt worden die toelaat om op een veilige manier te werken aan hoger gelegen installaties door de uitvoerend werker te verheffen tot de benodigde hoogte van maximaal 10 meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_12198b0a4ba8452ba7df28ab3d3d011d" name="Hoogwerker 12 meter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_dc6efd3d401d4425ba79bd22c955c436" body="Om het object te bereiken moet een machine gebruikt worden die toelaat om op een veilige manier te werken aan hoger gelegen installaties door de uitvoerend werker te verheffen tot de benodigde hoogte van maximaal 12 meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_deeae7ce3ba04288b75ad940d1e00833" name="Hoogwerker 18 meter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3e1ae04629ee4b4c90cf89a2713923eb" body="Om het object te bereiken moet een machine gebruikt worden die toelaat om op een veilige manier te werken aan hoger gelegen installaties door de uitvoerend werker te verheffen tot de benodigde hoogte van maximaal 18 meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5b2af91970be47faaf2d64d4f2d406e6" name="Hoogwerker 22 meter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_eace1599353d405f833569daeed01b34" body="Om het object te bereiken moet een machine gebruikt worden die toelaat om op een veilige manier te werken aan hoger gelegen installaties door de uitvoerend werker te verheffen tot de benodigde hoogte van maximaal 22 meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2ffc32fc25b44be2b312ed90b8865887" name="Hoogwerker 8 meter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0f0a03b1ba6a423f9dfd63fcdd303d04" body="Om het object te bereiken moet een machine gebruikt worden die toelaat om op een veilige manier te werken aan hoger gelegen installaties door de uitvoerend werker te verheffen tot de benodigde hoogte van maximaal 8 meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_067e134eb9f94ac2878e16382defaca9" name="Hoogwerker gebruiken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6b3390bccc45452db9b3e5e8b9de6fd1" body="Om het object te bereiken moet een machine gebruikt worden die toelaat om op een veilige manier te werken aan hoger gelegen installaties door de uitvoerend werker te verheffen tot de benodigde hoogte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bf941d44923749cb8a2a7df907088361" name="Industriële omgeving">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8b6afe8cb436478fa23d086ba4ceabfa" body="Bepaalde aspecten van een industrieel bedrijventerrein vormen een beperking voor de bereikbaarheid van het object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c2bfb001d6ff48cc90a2d0e91a3719bc" name="Kleine zuiger gebruiken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2567b99af7f342c4885af5f4c340e72e" body="Voor het schoonmaken van putten, kolken en andere voorzieningen aan het wegoppervlak moet een zuiger van een kleine maat gebruikt worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1fc860119aea48cda2bd7080f411dcad" name="Klimmen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_16bc3a929f4d4d6c9e0b4741bac85420" body="Om het object te bereiken moet de volgende actie verricht worden: het omhoog bewegen langs verhogingen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_078d4da47a9c42359305e2cc87c4296c" name="Laagwerker gebruiken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_86b1c614d76d4bfdbd9a9a1b64885bad" body="Om het object te bereiken moet een machine gebruikt worden die toelaat om op een veilige manier te werken aan lager gelegen installaties door de uitvoerend werker af te laten dalen tot de benodigde hoogte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ff95c9738c2e4282bb4cdfd809e9bfce" name="Ladder gebruiken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_52a8e9c4237a40ae96b41a693bea833e" body="Om het object te bereiken moet er een hoogte getrotseerd worden met behulp van klimgereedschap bestaande uit een paar spijlen met daartussen meerdere sporten voor voetondersteuning."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8da52ddee98447aab7d28700e8d9265b" name="Lichte machines gebruiken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2089a3890f2041fd95f1f03333c84bda" body="Aanduiding dat het voor de toegankelijkheid van het object van belang is om apparaten met een gering gewicht te gebruiken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e0c50860cee448a5a1c2f6a80c46c66e" name="Maaiboot gebruiken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4fd066b644ae4844ba6c3acef51e16b2" body="Aanduiding dat voor de toegankelijkheid van het object een kleine boot gebruikt moet worden, ten behoeve van het onderhoud van watergangen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cc001cf3601048ac826420bf2f3fa40b" name="Maaikorven met giek groter dan 12 meter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_70a7aa8991884b88bc81e057c83b0827" body="Aanduiding dat voor de toegankelijkheid van het object een kleine boot gebruikt moet worden, ten behoeve van het onderhoud van watergangen, waarvan de giek, de beweegbare arm van de maaiboot, langer is dan twaalf meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3e433803998b473ea42f271dcb17bfd9" name="Maaikorven met giek kleiner dan 6 meter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_eca8eba6f394481c980363f4c98bc078" body="Aanduiding dat voor de toegankelijkheid van het object een kleine boot gebruikt moet worden, ten behoeve van het onderhoud van watergangen, waarvan de giek, de beweegbare arm van de maaiboot, korter is dan zes meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d912606645a74a63b571fbce90541711" name="Maaikorven met giek tussen 6 en 12 meter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_21b58a35a7534318addee18e29ca7384" body="Aanduiding dat voor de toegankelijkheid van het object een kleine boot gebruikt moet worden, ten behoeve van het onderhoud van watergangen, waarvan de giek, de beweegbare arm van de maaiboot, langer is dan zes meter, maar korter dan twaalf meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fe89cf7f44b84012b334d0788e4d62ac" name="Mini hoogwerker">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e4f3fd634644429396c5214de3b850b7" body="Om het object te bereiken moet een kleine variant van het type apparatuur gebruikt worden dat toelaat om op een veilige manier te werken aan hoger gelegen installaties door de uitvoerend werker te verheffen tot de benodigde hoogte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_85c94b39a9854960b46a6b7ef0940c2d" name="Niet bereikbaar voor hoogwerker">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_28bcaa8185d0436098b1468fd4d42e2c" body="Een hoogwerker is niet geschikt om toegang te bieden tot het object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_39e380e2ddb942aaa54608615a66d257" name="Op een dijk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_17220063b9bb479fa33782958672768e" body="De toegankelijkheid van het object is beperkt door het feit dat het object op een door mensen aangelegde waterkering van verhoogde grond ligt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8adc43180f2f41d981c560c09cbf24d6" name="&apos;s nachts werken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_74d3606f86514c15b229e716db05eac3" body="Aanduiding dat er &apos;s nachts gewerkt moet worden om het object te bereiken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b0e1aa3b2e4a4c2d933d66af94e14921" name="Schaarlift 12 meter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f6344f5c104442c6aad5ddca8d5c580c" body="Om het object te bereiken moet een lift op wielen gebruikt worden die toelaat om op een veilige manier te werken aan hoger gelegen installaties door een platform, met daarop de uitvoerend werker, op een zich uitvouwend frame, gelijkend een schaar of een a"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0ff66b27dd0a4614b731ae4dea8c7936" name="Sleutel nodig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fe77411f1a9d4579bcda34d342175916" body="Om het object te bereiken is er een sleutel vereist voor het openen van een bepaald hekwerk, een pand, een bouwwerk etc."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a324affdfe8c48fdb52739315537e114" name="Verkeersmaatregelen noodzakelijk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3bff02d3651844c38496a81653093470" body="Om het object te bereiken zijn maatregelen omtrent het wegverkeer noodzakelijk."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ae87253d734c415087f1ba91a931dc4f" name="Waadpak gebruiken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fed6fcb59cf04a3b9e26161f8dab4782" body="Om het object te bereiken moet men lopend door ondiep oppervlaktewater gebruikmakend van een waterdicht pak&apos;."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ff5745322d404f7ba678a3c39511ff09" name="Wegafzetting nodig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2148092525b0417e8003105776f69178" body="Voor de toegankelijkheid van het betreffende object is het noodzakelijk een blokkade van de weg te organiseren, vaak met inbegrip van bewegwijzering voor omleidingen, waarschuwingspionnen, -hekken en actiewagens."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a0c726cc73d54a0abf656beb80c2741a" name="Werk vanaf aanliggend perceel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_11968c35b03242548b4274b56fc42002" body="Om het object te bereiken moet het werk vanaf nabijgelegen aanliggende perceel uitgevoerd worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_953107038b114999992f6e7e23762c55" name="Werk vanaf water">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c9e5d4d8b5264429a67ee5398d89e6a1" body="Om het object te bereiken moet het werk vanaf nabijgelegen oppervlaktewater uitgevoerd worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_87472738431a4b15bbc509b8478c3274" name="Werkzaamheden op particulier terrein">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1260ed8d17534450a2adf745c648875c" body="Voor de toegankelijkheid van het object is het noodzakelijk grond te betreden die eigendom is van individuele rechtspersonen, niet zijnde een bedrijf."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_24d46d9a07cd4354a9d3851a5a06f94f" name="Zware machines gebruiken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_88f1ab9b61e046a895f17f124ba7f447" body="Aanduiding dat het voor de toegankelijkheid van het object van belang is om apparaten met een fors gewicht te gebruiken."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_e986bbff53d841428d61f432ff894cd8" name="enum_BeschermdGebiedVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c3bca547a78b47dd9a0fbfe75f1857e3" name="Beschermd gebied grondwaterinwinning">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6c4eb2c1314c40d39d0764cea065c8e1" body="Een gebied dat onder bescherming van een organisatie staat vanwege de grondwaterwinning voor menselijke consumptie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6c243a46ec6541bba9c60566872f330a" name="Habitatrichtlijn gebied">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_77370e9cd2ca4bf085e00489ecd37904" body="Een beschermd waterbeheergebied die valt onder de Habitatrichtlijn van 1992, een vaststelling van te beschermen plantensoorten, diersoorten (excl. vogels, omdat die onder de vogelrichtlijn vallen) en habitats."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9c712fd0ff23415aa4e98ada8d713bad" name="Schelpdierwater">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_91dbbe90df424514bcb98d26e0a24dc4" body="Een waterbeheergebied dat beschermd is vanwege de soorten schelpdieren die er in voorkomen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f0269d51da9f4257bf3f6a93d28cd83d" name="Vogelrichtlijngebied">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0cb8f426a7aa48379fd598e148cbe122" body="Een gebied dat vanwege het herbergen (jaarrond of als overwintering) van zeldzame of bedreigde vogelsoorten, zoals opgenomen in De Vogelrichtlijn van 2 april 1979, aangewezen is als speciale beschermingszone."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_a35f0b0181ab46ba8061a635f9c197ff" name="enum_BeschoeiingBoven-OfOnderwater">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_86d3c01cc03d421fa55912b771b54050" name="Bovenwater">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b93ac411786a4e78834daec401209693" body="Aanduiding van de locatie van de beschoeiing wanneer deze zich boven het wateroppervlak bevindt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a6f2344d3cd449b68eb3912c7ff1fedd" name="Onderwater">
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_4708a76b71e64ad5b33e895d08d9f461" name="enum_BeschoeiingVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cf65b7c1782e48b7b4a2230fa1957478" name="Betuining">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_998892a945eb45f9b661e217047479fe" body="Een houten omheining van een oeverzijde om het onderwatertalud te beschermen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4fdb575f149f49e4b2f600fdb2399933" name="Matten beschoeiing">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_41794ccdcd364bbaac958c5991b410a1" body="Een nagenoeg verticale wand tot kering van grond om afkalving van water te voorkomen, bestaande uit een oppervlak van gevlochten matten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3850366fb1704e1ca6352dc2eb490d75" name="Perkoenpalen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e6d7c5c5f9b14ba095a3ad2bb7675dde" body="Rij aaneengesloten ronde palen van dennen- of eikenhout of van kunststof."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_936d7d03d3744b699c314164d3c3d0ed" name="Plankenbeschoeiing">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6eecf6c3c53a44cf9a45efa0c008c551" body="Een nagenoeg verticale wand tot kering van grond om afkalving van water te voorkomen, bestaande uit plankvormige elementen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1fe2099cd953474dac890a73d95cab04" name="Wiepenbeschoeiing">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f9f7b579bb384550b8254ac5100f42d8" body="Een beschoeiing die gemaakt is van bundels samengebonden takken."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_0ca49ff716e1402abd2707ef13196aaa" name="enum_BetonverhardingVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f781dd8b6d74445aa758a738485b1ae4" name="Betonplaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0e3ef7287bf64e17b2dd65620862d5c6" body="Een open verharding van betonelementen in de vorm van vlakke, dunne platen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7f3f67d329954daa99f6095912ec3434" name="Gewapend betonverharding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_29a3f56db51f484d8b825f99b6266435" body="Beton waarin een versterkende constructie, vaak in de vorm van een metalen raster, is aangebracht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5c1a5caf713f460d95fce8d76679eb2a" name="Ongewapend beton">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_275783b80a6d4bc1a2602509be0f5ead" body="Beton zonder wapening."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d626c8dac7a2401ebc26895a4214a761" name="Ongewapend nietverdeuveld beton">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7158bfa8854a4272911f9345ada18518" body="Betonverharding die niet is versterkt met metalen raamwerken of hechtingspinnen (deuvels). In de CROW Systematiek Wegbeheer wordt dit ‘onverdeuveld’ genoemd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ed94ab0b172e416b8b3cfdc1d8cb3d92" name="Ongewapend verdeuveld beton">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_feff45f4bc22418282fc28519795ff7a" body="Betonverharding die niet is versterkt met metalen raamwerken maar met hechtingspinnen (deuvels). In de CROW Systematiek Wegbeheer wordt dit ‘verdeuveld’ genoemd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8b3cd4a4a56147178682f0c0d8478ace" name="Oppervlakbehandeling beton">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_68b46a52b4844192b87b168d1f43b247" body="Verharding bestaand uit op het wegoppervlak aangebrachte laag bindmiddel die wordt afgestrooid met steenslag of fijn grind."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f771c27fbfde4e09b0d509031f0510ca" name="Printbeton">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d9a0b0c53ba04bfe97365c56300b2a50" body="Een speciaal soort betonvloer, een geprofileerde of gefigureerde vloer, wat wil zeggen dat de betonvloer gelegd kan worden met bepaalde, herkenbare figuren zoals die van kasseien, klinkers of vloertegels."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_127dcf45473a448dbf15528c159311c6" name="enum_BetonverhardingVoegvulling">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1f1efa174b9849bc915f8d90db20bd0d" name="Asbesthoudend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fe0f5f68a98442ad86c2952cc3ef19b5" body="Aanduiding voor de aanwezigheid van asbest in de constructielaag, de voegvulling of een ander object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a2264f4f9b864987ad5f6ac4a9d5fa76" name="Flexibel gebonden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c3369eaa527244b28d4bd679d4935d9a" body="Een licht gebonden, veegvaste voegvulling, bijvoorbeeld polymeer, polyurethaan, bitumineus."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0b05c813f75c4a1380d4169b01aa72b8" name="Gebonden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2b7d0c1e7a0d4bd1a489c3bd87eedb1e" body="Een aaneengevoegde, veegvaste voegvulling, bijvoorbeeld cement of epoxy."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4eda30fd732f42b1b40b40c06d116abf" name="Lichtgebonden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d376c39a73c34a809a3a713280cc4757" body="Een niet-veegvaste voegvulling, bijvoorbeeld mix split/slak, LD-mix, kalksteen, slakkenzand."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_40a0c3a3025e4e238583c96fd8ef31da" name="Ongebonden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8442e288e3bb4ab2a9c49c016b41b7b4" body="Een niet vastgehechte en niet-veegvaste voegvulling, bijvoorbeeld brekerzand, split, combinatie van brekerzand en split, straatzand."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_9c68a41db3c341f4bfc614180d8707ac" name="enum_BeweegbareBrugVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_64e1ba2a8c1a4b7eb086036f6fa2875e" name="Basculebrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_eeae7b9e62184ac1a70755590bedb5f0" body="Een beweegbare brug met een roterend brugdek dat opent door een draaiing rond een horizontale as die onder een hoek van negentig graden op de rijrichting staat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_dc6fee7b7e9e444a93e56928dc959794" name="Draaibrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f88dcc577aaa4558a1e8292fd4cbd349" body="Een beweegbare brug die opent en sluit door middel van rotatie om een verticale as."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d30d61e01e4e47b1a2bb037514a87de9" name="Dubbele basculebrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_aed7beeab9544f9a89104b6ca8f889b0" body="Een beweegbare brug waarvan het brugdek bestaat uit twee roterende delen die openen door een draaiing rond een horizontale as die onder een hoek van negentig graden op de rijrichting staat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bc9ce2343182454889343a189d272643" name="Dubbele draaibrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_40431d8d607548d3a70568647d8f53a2" body="Een beweegbare brug met een brugdek bestaande uit twee delen die beiden openen en sluiten door middel van rotatie om een verticale as."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ce5b36ab4f6c4e8482c94217f79d559d" name="Dubbele ophaalbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d89254d30677405b89c920b623025d90" body="Een beweegbare brug waarvan het brugdek bestaat uit twee delen die beiden openen, doordat ze zijn verbonden aan kabels of een ander mechanisme, door ze middels een gewicht op te halen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9cd22373dacb42b3af91674202fc0eb8" name="Hefbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e0e94f3fc9cb49049591d3c6d06c0f0f" body="Een beweegbare brug waarbij het te openen brugdek met behulp van liftvoorziening verticaal in de hoogte wordt bewogen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fe1ff990e50d4b52ace17ffa79e31882" name="Klapbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bbd002b7a4944077aa871071d761a418" body="Een beweegbare brug met een roterend brugdek zonder contragewicht dat opent door een draaiing rond een horizontale as die onder een hoek van negentig graden op de rijrichting staat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_aa07c9ed32dd44b5b76a7277d4745c4e" name="Ophaalbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5bebb490284f41ce8cfac1a33d9fad59" body="Een beweegbare brug die opent door het brugdek, dat is verbonden aan kabels of een ander mechanisme, door middel van een gewicht op te halen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c982e66c49f444a6854554907465e19f" name="Rolbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8b883113690249389316d41f8688b636" body="Een beweegbare brug waarbij een gedeelte van het brugdek door middel van een rollend mechanisme in de lengterichting van de brug het land op gerold kan worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_264fdadc0341407e8b457a7936a7628d" name="Vlotbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c5ff8934ebdf45bca8bf2eeb916781a2" body="Een drijvende, beweegbare brug die voor scheepvaart opengaat door horizontaal te bewegen. De brug bestaat uit aanbruggen vanaf beide oevers naar een vlot. Als de brug opengaat wordt dit vlot onder een aanbrug getrokken, of naar opzij weggedraaid zodat het"/>
        </ownedLiteral>
      </packagedElement>

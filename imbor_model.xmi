      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_14e7012a5bec46a0b0e4a3edb994a69a" name="enum_ConventioneleLampVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_120260394ef04439b33b8e611427b548" name="Halogeen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8fdc7c2b68dd4c6cbd7a3bc27c3ebc31" body="Een gloeilamp die zijn naam ontleent aan de broom of jodium die aan het inerte gas dat onder hoge druk staat in de lichtbron is toegevoegd."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_dec9916479424bca84b580a36fbc91c1" name="HIE-CE/S-od">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f37ae03d0b8e4aa3ad04104ba45f4c22" body="Elliptische ‘outdoor range’ metaalhalidelamp voor natriumballasten met keramische brander en een enkel eindstuk. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: ME."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2abd6ef576c9485e9f5db2bf6ee06a33" name="HIE-S">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1c15434a3335452683de5a54579f4b05" body="Elliptische metaalhalidelamp met een enkele dubbele buis en een enkel eindstuk. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: ME."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fe9815cedeff4d128477a69da5d506dc" name="HIPAR">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0021c77d796e4082a8d89317c672055f" body="Paraboolvormige, gealuminiseerde metaalhalidereflectorlamp. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a99bb6c1a7d449f9a7b9cba6202c1e8c" name="HIT">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_86c641870b2048b0b960c7c6db7db0bc" body="Buisvormige metaalhalidelamp met een enkel eindstuk. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: MT."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3808db9593d04b4992a81afe973f8a45" name="HIT-CE">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_384d398c3cb045cf8bccc7ca6e5f5958" body="Buisvormige metaalhalidelamp met keramische brander en een enkel eindstuk. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: MT."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_515be72dd8fc4671b7803c6c48469d51" name="HIT-CE/S-od">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_860ae401e979475597b68ee52af34475" body="Buisvormige ‘outdoor range’ metaalhalidelamp voor natriumballasten met keramische brander en een enkel eindstuk. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: MT."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fe89e8e53bdf4ab394cbf318aa019e34" name="HIT-CE-od">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fbc4737a16fb46b9b6d80b3822e0e8a4" body="Buisvormige ‘outdoor range’ metaalhalidelamp met keramische brander en een enkel eindstuk. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: MT."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a7fe1e2b59954a9bbcba41d2cdcbf3eb" name="HIT-DE-CE">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c3b7134c819b4bb5b0e7e1bf135056e2" body="Buisvormige metaalhalidelamp met keramische brander en twee eindstukken. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: MT."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4b4be066bdb942dd97345bade1dec08e" name="HIT-DE-h45">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a60fdc9f003d4eeebbca0fdc3fd6f845" body="Buisvormige metaalhalidelamp met twee eindstukken, een horizontale brandpositie en een diameter van 45 mm. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: MD."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_91a20bfd83db4d0890680c7d2a2d4e91" name="HIT-TC-CE G8.5">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_addb670ff0744904b5058676456f35b9" body="Buisvormige compacte metaalhalidelamp met keramische brander, fittingtype G8.5 en drie eindstukken. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: MT."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_233ca2859b3a4b9685d2424e4a003b05" name="HIT-TC-CE GU6.5">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_217d418342ad46f3937b630b5825899e" body="Buisvormige compacte metaalhalidelamp met keramische brander, fittingtype GU6.5 en drie eindstukken. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: MT."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f6b78302ea014fce97ac71b0337b546e" name="HME">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6bccde6cfa9e4bcf8ac9b29e9ce68d4d" body="Hogedruk kwikgasontladingslamp. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: QE."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2e1429f54543449eaed68ad86839298a" name="HSE">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6d7902a88107465491e0866705e0b95e" body="Elliptische hogedruk natriumlamp met een enkel eindstuk. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: SE."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_81ab48c3bbfb43118aa79b200808058a" name="HSE LL">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_47c129bd15ae44d5aecbe9cf77551f48" body="Elliptische hogedruk natriumlamp met een enkel eindstuk. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: SE."/>

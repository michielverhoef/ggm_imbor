        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_08d7df2062d9497295d3a2a3001fb6de" name="Fietssnelweg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0819c527d4184f3081ecd0130bfc81e7" body="Een fietspad dat bedoeld is voor langeafstandsverkeer en effectief de doorstroming van fietsverkeer verbetert."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6113d999618b4461858acb19bdfd8f5b" name="Fietsstraat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2641e1abdb51464c8bc2b6ed6b3046f9" body="Een straat die ingericht is als fietsroute, waarin auto&apos;s toegestaan maar te gast zijn en waar voor gemotoriseerd verkeer de maximumsnelheid van 30 kilometer per uur geldt."/>

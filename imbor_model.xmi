        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_568ae78ab03b4e8e9ecb532fb0b12940" name="Woordmarkering: woonzone">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1c512c1e26d14a738ca7cbb12be7b212" body="Wegmarkering die het begin van een woonzone aangeeft."/>

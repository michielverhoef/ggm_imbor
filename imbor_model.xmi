        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_99f57c19c51346aa810c570d8a34a3cc" name="Niet van toepassing">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_11bca1f322164426b8a4297696e073b9" body="Waarde waarmee aangegeven kan worden dat een attribuut niet geldt voor een bepaald object."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_51c5e9ac4d744dd18e0c56a84de8a5fc" name="Onbekend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_69c6cf6a39e4408aa24e8d17aa4fe8a9" body="Bij deze waarde moet nader onderzoek uitwijzen of welke attribuutwaarde van toepassing is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_911782b1456149dcbf1706eedc16ffbe" name="R">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d75b7347bae84a2988a84dd3f6ace4cf" body="Rechts."/>

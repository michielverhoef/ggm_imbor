      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_598fd2256c7b4eb2b368f2313a53ce51" name="enum_ConstructieWegtype">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1f9cf20b22ac458b8faf4cab308e85ea" name="1 - Hoofdwegennet">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0024838d451a4d5182c7dd3ea0f46f5e" body="Netwerk van wegen die een belangrijke functie vervullen voor gemotoriseerd doorgaand verkeer en (economische) centra en/of landsdelen met elkaar en/of met het buitenland verbinden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5ef59bd3ea744bef8c889ad06237ef62" name="2 - Zwaar belaste weg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8c8000ca413d41d9abd64198ea2efebe" body="Categorie 2 conform de CROW Wegbeheersystematiek 2019 voor wegen die veel gebruikt worden met als gebruiksfuncties: stadsautowegen, provinciale wegen en drukke waterschapswegen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d61edb5f6f764c20bcbfe8365248d8a8" name="3 - Gemiddeld belaste weg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_da8bed70251b4d0d863cf1d1b7f3ee8c" body="Categorie 3 conform de CROW Wegbeheersystematiek 2019 voor wegen die normaal gebruikt worden met als gebruiksfuncties: stadsontsluitingswegen, industriewegen en busbanen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2af34695427d4004b37d408516aa2f35" name="4 - Licht belaste weg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_903ad9a43dda44c08544a8920b566bc6" body="Categorie 4 conform de CROW Wegbeheersystematiek 2019 voor wegen die weinig gebruikt worden met als gebruiksfuncties: rustige waterschapswegen, buurtontsluitingswegen, parallelwegen en landbouwweg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_293ccbb71bef48bbb94ed640d839d8b3" name="5 - Weg in woongebied">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a289a42a393a441ab34912375241994e" body="Categorie 5 conform de CROW Wegbeheersystematiek 2019 voor wegen die in gebieden met als functie wonen liggen en met als gebruiksfuncties: woonstraten, woonerven, parkeerterreinen en wijkstraten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d7d6bb1ed56a4a0aa9fc8dddb973c073" name="6 - Weg in verblijfsgebied">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3d2776a9dd28476c873c11db449aa2fe" body="Categorie 6 conform de CROW Wegbeheersystematiek 2019 voor wegen die in een gebied met als functie tijdelijk verblijf liggen en met als gebruiksfuncties: winkelerven en pleinen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_580794037db34d4aa32119af80d44998" name="7 - Fietspaden">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_614444159aea42b79217a960e29e67c9" body="Categorie 7 conform de CROW Wegbeheersystematiek 2019 voor wegen die geschikt zijn voor fietsers met als gebruiksfuncties: fietspaden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_afdb5ab59dc14d869dce9686422c59be" name="Onbekend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3483311f174f437297eed3d6d8a7ab01" body="Bij deze waarde moet nader onderzoek uitwijzen of welke attribuutwaarde van toepassing is."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_56ecb99f04c14cc1b2da57f8d3e539f6" name="enum_ContactVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ba97960ca92b489584c22a23aae23bb7" name="Inputcontact">

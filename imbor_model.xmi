          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ec5cb30af85d4699a2fa46463e1b5845" body="Het gehele bodemoppervlak van het waterobject dient bewerkt te worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9c250de977cb41d6b71730addd0751c5" name="50% deel van bodem">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0d1c6f9cba534a90a9a16d3a3ea15e99" body="Het helft van het bodemoppervlak van het waterobject dient bewerkt te worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d24e103a479048e39c91730f50be511a" name="80% deel van bodem">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9ce1ca77844f4de39a2f22319cf6e926" body="Het acht tienden deel van het bodemoppervlak van het waterobject dient bewerkt te worden."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_fdfc01cd0a9c42e089d7e2d6967745c7" name="enum_WatergangDimensioneringBewerkingspercentageklasseTalud">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_501ad482a59c47d48c2d334940b63d99" name="2 m. en groter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c9d76cfca29e40fcb6e9d76663c053ea" body="Klasse in ondergrens voorzien door de ruimtelijk strekkende hoeveelheid van twee meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f387aca6e8cb47788fff23568db09bc0" name="Tot 2 m.">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e542a32e135c41c1a68217b34ce038ca" body="Klasse in bovengrens voorzien door de ruimtelijk strekkende hoeveelheid van twee meter."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_8391098aa84541309d2dcd0c0e4a1ebc" name="enum_WatergangDimensioneringLengteklasseDroogTalud">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_dd31578463464b5e9ecad555f3799a0f" name="100% geheel talud">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_48943c7384194007b111773f26062e11" body="Het gehele taludoppervlak van het waterobject dient bewerkt te worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_21874c4768a249a6943d929a1ef06644" name="50% van het talud">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_311db8d254ce407fbfc8d07d04904a2c" body="Het helft van het taludoppervlak van het waterobject dient bewerkt te worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4b9e6b599a7b418986e76b1fc67b18c9" name="80% van het talud">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_858d5a45f2f243df8d3932a20bdb907c" body="Het acht tienden deel van het taludoppervlak van het waterobject dient bewerkt te worden."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_690eb57189f94780a31ac89fb8bbc20e" name="enum_WatergangDimensioneringWerkbreedte">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c4902571131d45ebb59246e31e829a65" name="Geen werkbreedte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fa6db6e63c64432a944038087f6f0d21" body="Er is geen ruimte beschikbaar voor uitvoerend werk aan een zijde van het waterobject."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4d06d9f60ff84bd9b3c896444d727567" name="Werkbreedte groter dan 3 meter eenzijdig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_23cdadc656344a909a5adf83345c6086" body="De afgemeten, ruimtelijk strekkende hoeveelheid die overeenkomt met de hoeveelheid ruimte aan twee zijden van het object op de plek waar uitvoerend werk aangaande een waterobject moet plaatsvinden is meer dan drie meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7b1900d44d04478bb29af2ee4d52483e" name="Werkbreedte groter dan 3 meter tweezijdig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_00a72e972abf40b49c78f2058e952121" body="De afgemeten, ruimtelijk strekkende hoeveelheid die overeenkomt met de hoeveelheid ruimte aan één zijde van het object op de plek waar uitvoerend werk aangaande een waterobject moet plaatsvinden is meer dan drie meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_15ffee8f73ed4d8ebb88c1b18c6ef67f" name="Werkbreedte tot 3 meter eenzijdig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_26723eaaf8104c648c3928da886ffbec" body="De afgemeten, ruimtelijk strekkende hoeveelheid die overeenkomt met de hoeveelheid ruimte aan één zijde van het object op de plek waar uitvoerend werk aangaande een waterobject moet plaatsvinden is minder dan drie meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9df84e8ff7614a08ab68644a84ca58fa" name="Werkbreedte tot 3 meter tweezijdig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ebe1e32edd014d32b6193fb616db030b" body="De afgemeten, ruimtelijk strekkende hoeveelheid die overeenkomt met de hoeveelheid ruimte aan twee zijden van het object op de plek waar uitvoerend werk aangaande een waterobject moet plaatsvinden is minder dan drie meter."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c62d1805402d40908202c64ce0532a5d" name="enum_WatergangSchouwwijze">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6e201856bc444e939aece29c3a838b50" name="Eenzijdig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9b1292a6daaa4ff39bffbbdca1d2333e" body="Aanduiding dat de schouw van het waterobject vanaf één enkele zijde plaatsvindt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_adf366873ca64f84bd42bb10a1af71da" name="Tweezijdig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5599923f61a048e0801ba93e08f280b8" body="Aanduiding dat de schouw van het waterobject vanaf twee zijden plaatsvindt."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_df083a54bfab4df7afbf41884954d5cb" name="enum_WatergangTypeWatergang">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_de504f2c7c674227ba2d07504ea741da" name="A-watergang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_be11dcd57fea4611b12b9f34bebdeba4" body="A-wateren: de belangrijkste wateren van de regio, zoals grotere sloten, beken en waterplassen, die belangrijk zijn voor een goede waterhuishouding. Deze wateren worden door of namens het waterschap onderhouden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_95b63d6dd1ca4d679903318fa05bb24b" name="B-watergang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d3d3d2e14d9041ab93bcf19e2fd2a16a" body="B-wateren: bijvoorbeeld een (klein) kavelslootje tussen twee perceeleigenaren. Zodra een oppervlaktewaterlichaam een maatgevende afvoer heeft van meer dan 10 liter per seconde en het is geen A-water, dan spreken we van een B-water."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e1f792259cd8488baa036c3a2f820d54" name="C-watergang">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3ce2791aa32c4315a817f0af0e7a475c" body="C-wateren: bijvoorbeeld een poel of zakslootje (een slootje waar het regenwater wordt verzameld en kan infiltreren)."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_d3a3a429073f4bada30e4157c9023963" name="enum_WaterkeringVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3173da4c2b57435db62667fb3b997687" name="Boezemkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e87d165ebf074f03a91e1cf71450184c" body="Het langs een boezemwater gelegen grondlichaam, dat enerzijds de lager gelegen poldergebieden beschermd tegen hoger liggend boezemwater en anderzijds de boezem in stand houdt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4a272d9c775c4cd48eeb19a38df3e681" name="Compartimenteringskering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_63bed1eb06ec46bd83221dbef1fa8ef4" body="Een regionale waterkering die als zodanig geen direct waterkerende functie heeft, tenzij in geval van doorbraak of overstroming van de primaire waterkering."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_29f4a394563c42d2af263d109d7915a9" name="Hoogwaterkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5eb6021437994f9d8452a8046a40676b" body="Natuurlijke of kunstmatige begrenzing of afscheiding die het hoogwater dient tegen te houden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bbb88e079f064462809e42d76d7c8f7e" name="Primaire waterkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b7086ecd1fd64078839a018834249d38" body="Waterkering die beveiliging biedt tegen overstroming door buitenwater."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d000661867fa4d30a3ff92e1ab241de0" name="Regionale waterkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b732aa10ec7d48eba13bf99f09eaca66" body="Een waterkering zoals aangegeven in de Verordening en in de legger, die beveiliging biedt tegen overstroming anders dan door buitenwater."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d0cf56ad73e0468ea1b9669093b8d103" name="Stormvloedkering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9ea09bc4bf584f25a93fdead685b6609" body="Een waterbouwkundige constructie die bij stormvloed of springtij moet verhinderen dat er grote hoeveelheden water de monding van een rivier of zeearm instromen en stroomopwaarts tot overstromingen leiden."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_9f1b2aa186004a2399a28fc4af78636b" name="enum_WaterniveaumeterVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_88a0646dc2ea454bbac8821a128ebcf6" name="Datalogger">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0bede14414a64832bf69dde7560e8470" body="Een waterniveaumeter die gegevens over het waterniveau opslaat in relatie tot tijd of locatie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d157562fa28a4007b4d276fe5525deb8" name="Vlotter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3f757a4ae34e4871837bffb420a8d252" body="Een waterniveaumeter die op het water drijft en een signaal afgeeft als het waterpeil verandert."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_08df0c9fd3de46b9bc4203283ddf0942" name="enum_WaterspeeltoestelVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ca4a20f0111941dcb7fd10a493e69e4b" name="Archimedesspiraal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_58032ea95ee54da1995edee6ee3b46fd" body="Een speeltoestel aangedreven door rotatie die mogelijk gemaakt is door spierkracht om water mee omhoog te bewegen in de vorm van een metalen stang met een spiraalprofiel. Het toestel is vernoemd naar Archimedes, die in zijn boek &quot;Spiralen&quot; over de meetkun"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4b4312a1e68347f7a4573165479630ad" name="Archimedesspiraal met bassin en opvanggoot">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_141b048e2d8e4f3bb587a10342711ece" body="Een speeltoestel aangedreven door rotatie die mogelijk gemaakt is door spierkracht om water mee omhoog te bewegen in de vorm van een metalen stang met een spiraalprofiel. Het toestel is vernoemd naar Archimedes, die in zijn boek &quot;Spiralen&quot; over de meetkun"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_46bd1f49404d49d5828ec386966d0ea6" name="Dubbele kliedertafel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9d7c915451db438aa87bebf243409698" body="Twee aaneengeschakelde tafels om met water op te spelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_cf064be1fc7d48f18a72734d7515a936" name="Gaffel met verdeler met uitloop">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_eec97a16cf924c5697fa719d8605b27f" body="Een vertakkende en langwerpige waterbak met een beweegbaar verdeelelement (een flipper die een stroomrichting blokkeert) en met aan het uiteinde een verbreding of niet overdekte verlenging."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_02a7503d043f45958b7e8e6534b6cb93" name="Gegaffelde goot">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_11260608267c4815b50efdaac5a73b86" body="Een goot als zelfstandig watertoestel die gegaffeld vertakt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_713f39c5b4154881a0d62b708e024b57" name="Goot met stuwen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_afbaf7b6851747438e77136282a91cc2" body="Een waterspeeltoestel bestaande uit een water geleidende goot en een constructie om water voort te drijven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2c4d39eb34ed4238a21803fa042b42e4" name="Goot met uitloop">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3d9e3d70e9e844db877322b931e1b5b6" body="Een waterspeeltoestel bestaande uit een water geleidende goot met een verbreding of open verlenging aan het lager gelegen uiteinde."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a461e8eb1f7d490fbb04fb28913fc21d" name="Goot V-vorm">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b429ff210fae425cbc47efc60a9c77b7" body="Een waterspeeltoestel bestaande uit een water geleidende goot met een V-vormig bodemvlak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_059598c8fd9a457d85c36ed4225737b1" name="Grondwaterpomp">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a8e11db58a6748c5a989b98cc469d132" body="Een pomp die, aangedreven door handbewegingen, water uit de grond kan onttrekken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_44297866a1bc42cfaeff7844bf306f8d" name="Grondwaterpomp met beugel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e9f5efe9dd734137ac4462a1077a86d8" body="Een pomp die, aangedreven door handbewegingen aan een beugel, water uit de grond kan onttrekken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_577bf290dc63462897bfc17d66b7b05c" name="In water eindigende glijbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1e0034afe7a84432ab6ab90f56e14277" body="Een speeltoestel tenminste bestaande uit een langgerekte, naar het water toegerichte bak, bedoeld om langs te glijden, al dan niet bevestig aan een platform of ladder."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6cf032763f134c8fa459418f2af6fc4f" name="In water staande glijbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e82265dd0f8347a982e21965434fb6e4" body="Een in het water liggend speeltoestel tenminste bestaande uit een langgerekte, naar het water toegerichte bak, bedoeld om langs te glijden, al dan niet bevestig aan een platform of ladder."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_97e0d9c4341a4c588f373ead7f650065" name="Kliedertafel">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f02e1ba8a8ce4112add91964d68a58e9" body="Een laag bij de grond geplaatst oppervlak op poten, soms met een opstaande rand om substanties zoals water of zand vast te kunnen houden, bedoeld voor kinderen om hun fantasie op uit te leven."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0a0c43cff603445e9b1c335916d2791e" name="Kliedertafel met schuif">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8407c7ef5fcf4f8d93ab35679be4386e" body="Een laag bij de grond geplaatst oppervlak op poten, soms met een opstaande rand om substanties zoals water of zand vast te kunnen houden, en een beweegbaar verticaal vlak waarmee de substantie in open stand van de tafel af kan stromen en in dichte stand s"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_203997707b7e400b8383ac5b052abd8d" name="Kliedertafel met stuwen">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_74f6a412540049f3a9738afef9d037be" body="Een laag bij de grond geplaatst oppervlak op poten, soms met een opstaande rand om substanties zoals water of zand vast te kunnen houden, en met een mechaniek om de substantie voort te duwen op de tafel, bedoeld voor kinderen om hun fantasie op uit te lev"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6c5377f4fd5d47cd80c70311aee5e9fe" name="Kliedertafel met verdeler">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ec57b04191c8400798ef07f7da0cb374" body="Een laag bij de grond geplaatst oppervlak op poten, soms met een opstaande rand om substanties zoals water of zand vast te kunnen houden, en een voorziening om (stromend) water te verdelen over meerdere richtingen, bedoeld voor kinderen om hun fantasie op"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0c28d292ce37444dae93bd19411dadb0" name="Pontje">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e3be8366f5ec4d758775664bfc70afaf" body="Een waterspeeltoestel in de vorm van een vlot dat is bevestigd aan een kabel of een touw die gespannen is tussen twee wallen. Met behulp van spierkracht kan men langs de kabel of het touw het vlot van wal tot wal verplaatsen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_45e8e3a157784326a6ec662c3c6c7e03" name="Speelgoot">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_108b33599cd2495590ed39df31cabd78" body="Een speeltoestel in de vorm van een langgerekte bakvormige of halfronde constructie die water kan vervoeren."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_32a945f826a34555a583b583d6d6653a" name="Vlakke goot">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fd89ff8b500e4b11b0b3f61181fb9241" body="Een waterspeeltoestel bestaande uit een watergeleidende goot met een plat bodemvlak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_fffb30b132a14db99a45d04688495a9e" name="Vlot">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bc3f2a67dfce41298c33e336d66e7a26" body="Een op het water drijvende constructie dat als (beweegbaar) waterspeeltoestel gebruikt wordt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6f0a8b7e8e144feca526d93a3ad982c7" name="Waterparcours">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e3fb4cd3666f4cf8941b12f4b4d9ffb7" body="Een behendigheidstoestel dat zich in het water bevindt en een combinatie is van meerdere af te leggen onderdelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2bca499a2a3d49bdb32e08325ec07127" name="Waterpomp">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fac8c518144e4ad6a2dbfa9dd751b706" body="Een pomp die, aangedreven door handbewegingen, water kan verplaatsen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1a04dd2582884316a6c310b6dd56007e" name="Waterpomp met waterbak">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bc2fab8db7004a4897d045bb5f3fd7d0" body="Een pomp die, aangedreven door handbewegingen, water kan verplaatsen en is voorzien van een bak om dit water in op te vangen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8966b3bee58b4086abfdfa94785d662a" name="Waterrad">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c022d58c115742758492ff162237fbe8" body="Een waterspeeltoestel dat bestaat uit een rond frame met schoepen die water kunnen opscheppen of lozen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8203f06a69a8496b984002d25e15e2e7" name="Waterspuiter">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4ad469828a1a4e98a97fa12681e6bfc8" body="Een waterspeeltoestel dat water op kan nemen en vervolgens af kan vuren, vaak mogelijk gemaakt door een handmatig aangedreven pomp."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9df123b524ce423887a86449e1963aa7" name="Waterwip">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_855e44d24bea4667bfe9909737191d3b" body="Een horizontaal kantelende balk met daarin een goot om het water aan de linkerkant dan wel aan de rechterkant te laten lopen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ccd890d6a2bc4d7a9a5c93bf46ea54c2" name="Wildwaterbaan">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6b12136650e94a1ea59a6eb8db449a25" body="Een waterspeeltoestel dat bestaat uit een langwerpige bak waar water doorheen stroomt, soms met obstakels of hoogteverschillen."/>
        </ownedLiteral>
      </packagedElement>

        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8e5fcf5d6069447fb7cb590cbbfb8058" name="Duikerbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_40d7bd686f6b48d1b1bb5ad7d8e788ed" body="Een type vaste brug die wordt gekenmerkt door het relatief gesloten karakter van de waterdoorgang."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ccdad0c1c1384f32ab8c63f2491533a8" name="Gewone normale vaste brug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_41bec12ce1ce43e7a127afe6dfa26b2c" body="Een vaste brug bestaande uit een niet beweegbaar brugdek waar geen verdere bijzonderheden op van toepassing zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a55cfb1480e644ea970afb7516882a0b" name="Hangbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_64b24bcaef2a4fa28dd6dc5655f1e88b" body="Een vaste brug die niet geheel op pijlers rust (vaak één of twee aan de uiteinden van de brug), maar het hangende brugdek met kabels of touwen spant."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ce8da16d872b446ea39651c52419c91f" name="Kraneschipbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_95c2fe7828f2442cad0ecab029673a38" body="Het is een unieke brug want het dek ligt op bootjes, het is de enige drijvende brug (pontonbrug) in Nederland."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bae4c55135284c31a35fee0c6aba1612" name="Liggerbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e87c7c5b4d2d4a31bcc5e34e47d64bbc" body="Uitvoering van een viaduct, met eenvoudige liggers van niet al te grote lengte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_60c38d84874c4512a15a3ecc661bcf65" name="Plaatbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c533c44a5aa34ee8b78ffcfdef660217" body="Een betonnen brug die bestaat uit een enkele betonnen plaat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b325ecba288849d0a06704ef051be711" name="Tuibrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_26ead7ecb1df409caf0c306a2e3f31ad" body="Een vaste brug met één of meerdere pijlers waarbij aan elke pijler een stuk brugdek door middel van kabels (de trekkers of tuikabels) opgehangen is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_476158f3109a4bc7b1d20a7c6570b1ea" name="Vakwerkbrug">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8fa4a6f5f81542dfbdf1b3de313a27f1" body="Een type brug bij middelgrote overspanningen. De brug ontleent zijn dragend vermogen aan een vakwerk, een in het algemeen stalen constructie aan beide zijden van het brugdek, die is opgebouwd uit driehoekige delen."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_6a683ddf1c4e4fbc8e174714df8dce36" name="enum_VeerVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2b0eebeda22a46e6bdad44189c63f7d6" name="Gierpont">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_696591ec303d4eff917b5d514a395b04" body="Een met een kabel aan het midden van de rivierbodem bevestigde pont waarbij de boot de overkant van de rivier kan bereiken door schuin op de stroming te varen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_056ab170f61f48f6921ab84e0d4717bc" name="Kabelpont">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_48b483bfaa514677af6f44b62d9f87c5" body="Een pont die met twee doorlopende kabels of kettingen aan beide oeverzijden bevestigd is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4f6df3d641fe4d85aa09dcbc986f412f" name="Motorveerpont">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1fb8409e4ba440638ef332e639b69748" body="Een platte boot die aangedreven is door verbrandingsmotoren en daarmee tussen de overliggende oevers vaart."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_2fc9b5a01d82492c88888c15156885e6" name="enum_VegetatiedakVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2241e052e22440da9f275fe0b7b65cb1" name="Dakakker">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_238cb745abb84e39bbfb40d3d5df5e86" body="Een dak waarop groenten, fruit en kruiden verbouwd worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ad93f95c733b40afbfe889512c32c1c9" name="Dakgras">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a8eb5c79c2964e3fa411e92cc409169b" body="Een dak bedekt met gras- en kruidachtigen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e898f1c86d004d1fb9419f82db94d797" name="Daktuin">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_89fd61e5504e4b2085aa1a60a927a56f" body="Een tuin die is aangelegd op het platte dak van een gebouw."/>
        </ownedLiteral>
      </packagedElement>

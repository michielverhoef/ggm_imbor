      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_d948e0f20a6b4b008af89802f2705862" name="enum_DetectielusVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2d4a827521064e64948c257c9af85662" name="Busdetectielus">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e473b59462824e04b270d860bb8eeb6d" body="Een detectielus die breed genoeg is om de druk op de weg van bussen te detecteren en dit te melden aan verkeersregelinstallaties, die de bus vervolgens met een bepaalde prioriteit af kunnen handelen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5548825706f94cd49d8c9e371caea005" name="Filelus">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e79b4e8547944f64ac20d41443d1d6a6" body="Een detectielus die filevorming detecteert."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1549e13561fa401cbab38ff2849d4d40" name="Koplus">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9e70a673be8c45aabf82304291c73e45" body="Een detectielus in de breedterichting van de rijstrook, direct gesitueerd voor het stoplicht, die een rol speelt voor het geven van een rood of oranje lichtsignaal door dat stoplicht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f5c08c8b33d4415b8bacdbd0adce704d" name="Lange lus">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7fb5b815a63e4a2799045dd610639b06" body="Een detectielus in de lengterichting van de rijstrook, gesitueerd in de aanloop naar een stoplicht, maar niet vlak voor dat stoplicht, die een rol speelt voor het geven van een rood of oranje lichtsignaal door het stoplicht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e7f3838678cf403a87fb3af38a3f4aba" name="Tellus">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fc855d8e7ccd4f2cabcfed94a84919b6" body="Een ondergrondse detectielus die het aantal passanten telt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d63b03739e6f46d78cffb6e8154c241b" name="Tramdetectielus">
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_3c1bafea64e049a5bb64d0353a75acfb" name="enum_DeurToegangssoort">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_574b408156e94626a7d63701e6ff4710" name="Directe toegang vanaf eigen terrein">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b028b9288b7a40f2b0317d5b3547daa7" body="Toegangsdeur bevindt zich op een erf, in een tuin of een andere specifiek terrein dat behoort bij het gebouw."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1111fc45c79844d78589c6c89e84d985" name="Directe toegang vanaf openbare weg">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c9bbf9732da043618367b6ab87e8b32a" body="Toegangsdeur bevindt zich direct aan een voor iedereen toegankelijke weg."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_18b226b6566845558ea5cc20e7789cc6" name="Toegang vanaf gemeenschappelijke verkeersruimte">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e0ecd10e8c154362a95369a47ecf7b4d" body="Toegangsdeur bevindt zich aan een inpandige ruimte die bedoeld is voor verplaatsingen door een gebouw door de verschillende gebruikers van dit gebouw."/>
        </ownedLiteral>
      </packagedElement>

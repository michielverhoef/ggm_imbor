        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1750d83140514802b38790b94ceeed44" name="Speciale bank">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3a4515516b1a4b46ab2c39924a543f88" body="Een bank met een speciaal uiterlijk (bijvoorbeeld een mozaïekbank) of een speciale functie."/>

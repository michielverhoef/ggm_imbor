        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a0aa1e5f4d2948ea961ef04f7ab3b46c" name="Debietmeting">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f7b1fd6e76324ba882b0553cac013b03" body="Meetwaarden afkomstig van een instrument dat de (afvoer)capaciteit van de volumestroom meet."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_336f96bb14b2475a8d8c76a162579644" name="Drinkwaterverbruik">

          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_feda5ed4845f4b22800d8be6f4efe15d" body="Categorie BV."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_79b8e706ce5c4e7ebba4d0e603a97aa1" name="NBd-bewegwijzeringsbord">

      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_47cb680ab5eb4b439e7eb6f0a57312f2" name="enum_KunstobjectVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5e60cac176ae46ae83080d289c5ddf1d" name="Buste">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_f7be3615e22344e8849b455e538e0dbf" body="Een beeldhouwwerk dat enkel het hoofd, de borst en de schouders toont."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3e351191f8104b30b7e0cb311b423a67" name="Fotografisch kunstobject">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1ce029ebd90244e0b4f8181260bac401" body="Een op een plat vlak aangebrachte afbeelding die door middel van fotografie is verwezenlijkt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c0d27ef490a24b5a9fe0b8e29b43a950" name="Mozaïekkunstobject">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bbb7404a0c46469fafc315c7fec4c02b" body="Een kunstvorm waarbij een afbeelding wordt vervaardigd uit een groot aantal kleine gekleurde steentjes. Een mozaïek komt dikwijls voor als muuroppervlak, maar kan ook driedimensionale vormen aannemen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e57ac9c97bc646659074736b7bff3284" name="Omgevingskunstwerk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_83f04afd75344c7ba98bdc6ebe783381" body="Een kunstobject dat samenhangt met de omliggende context die de nabije omgeving de artistieke uiting geeft."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0878baec22c04d7a90c8e62eb6fd4cd7" name="Plaquette">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0f12086b9ea242429683e5835664bbd3" body="Een afbeelding of tekst in ondiep reliëf op een platte beelddrager"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5ad0af5b89a54664bea8b7b276e909dc" name="Reliëf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2aee8dee2b464fc496c604caee59e282" body="Een driedimensionale beeldhouwkundige afbeelding in een verticaal vlak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8659d1bb070947e1ab690d5941792728" name="Schildering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_e58ebde425084f2aadf4fa351202df27" body="Een in de openbare ruimte gesitueerde afbeelding die met verf gecreëerd is, bijvoorbeeld op een muur, gevel, paneel of een doek."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5057550442b343ad9d6ef668f7126f91" name="Sculptuur">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4ce004bf8f72432c92cbb26ceec6f807" body="Een ruimtelijk beeldhouwwerk dat vormgegeven is door materiaal te verwijderen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_03f884ae19b24389afa2e75f9305b36f" name="Toegepaste kunst">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5bfc6f27c3db446291f94e01fc70ee36" body="Een kunstobject waarvan de esthetische vormgeving is gebaseerd op het gebruik, hergebruik of hervormen van functionele objecten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d3135f29817146bd83931f33e23a4801" name="Vloermozaïek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3640d95b93494ffb88f4b9710c9d335d" body="Een kunstvorm waarbij een afbeelding wordt vervaardigd uit een groot aantal kleine gekleurde steentjes. Het mozaïek is uitgevoerd als vloeroppervlak."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_84ec80602fcc466782c9ae7c5245de7e" name="Vrijstaand beeld">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2b226f4e4c774010924e06d3d3c813f1" body="Een beeld, niet zijnde een sculptuur, dat zonder verbinding met andere objecten in de openbare ruimte staat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_34042180e757428b9c74327e868b9aa6" name="Wandplastiek">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_82cfefd8b84c45a59c412666b8e3e207" body="Een variant binnen de beeldhouwkunst die tot stand komt door het toevoegen van materialen aan een wandoppervlak."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_19b0809ebad247ee8077899eb399b8b3" name="enum_KunststofverhardingLengteklasseKunstgras">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_068ecc6248a841178708180bab0edcf5" name="40 mm.">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ea69079ea6494a26a11f2e5f87b74c23" body="De afgemeten, ruimtelijk strekkende hoeveelheid van veertig duizendsten van een meter."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d363c558b42742c6a541a7fe02311c7c" name="60 mm">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0351b2be9dc34f02b2ba3de95d1b13b8" body="De afgemeten, ruimtelijke hoeveelheid van zestig duizendsten van een meter."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_8b941e9546384c609e552c5662a4cdb2" name="enum_KunststofverhardingVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_39c8d92ead274bbda1406d9866ceaec1" name="Doorlopende synthetische oppervlakteafwerking">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_75ebc6cd285b423aad36c860728f2ce6" body="Een kunststof vloer die bestaat een samengesteld materiaal en zodanig is aangebracht dat het materiaal zonder naden het gehele oppervlak bedekt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_22296ae4cb984effbf0aa8d4b80ba61b" name="Gesmeerde insitu rubbervloer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_cf8e23ee41a84b918c74fff1f332c18c" body="Een veiligheidsondergrond gemaakt van rubber dat door machinale bewerkingen makkelijk vervormbaar is en dat verkrijgbaar is in vele kleuren en waarop speelse patronen en dergelijke te realiseren zijn."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5979d238b3b64ceaa8c13c946654c54f" name="Gesmeerde rubberschorsvloer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ec65211c296745a8ade50abedf509177" body="Een veiligheidsondergrond gemaakt van kunstmatige stukken rubberschors die door machinale smeerbewerkingen ingedikt en platgestreken is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3fbe87fe3bb94baea4cc5b0ee6f1e96d" name="Grasplaat">
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f0f1d5837308467d8a7d237b89019ad8" name="Hybride kunstgras">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c75d9f9f8dce42888dde7b3d023beb2c" body="Een combinatie van kunstgras en natuurgras."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_abc6bbb7eb9d413798491fec6977a56c" name="Kunstgras">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0e1d1aa8efc84dce958beba5f274ddbd" body="Een als gras aanziend of aandoend, kunstmatig product van uiteenlopend, synthetisch materiaal."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_03329664c2f445d4a9724697d1a45aeb" name="Kunstgras semi-water">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b68287e8266149989dadd818639a8088" body="Een als gras aanziend of aandoend, kunstmatig product van uiteenlopend, synthetisch materiaal dat ter onderhoud wordt beregend en daarna wordt ingestrooid met zand."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2ebdfc6fe43546dfba24b9aacd72048d" name="Kunstgras water">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9a5f4056ba0047d19e379ea6817fe75c" body="Een als gras aanziend of aandoend, kunstmatig product van uiteenlopend, synthetisch materiaal dat ter onderhoud wordt beregend."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_95b6778ef4ba4406bc4d69d052db8823" name="Kunststof vloer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4079a56670b7438c8be8ffb297fd8ca9" body="Een horizontaal en constructief element in een gebouw of in de openbare ruimte gemaakt van een door de mens vervaardigde stof."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ff02b7238eb94d0b9480a464b238a4c7" name="Rubber gietvloer">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a66deded45d74bed9d1a3984c96fcfb9" body="Een kunststof vloer die gemaakt is van op locatie in een vorm gegoten rubber, dat vervolgens tot een egaal oppervlak is uitgehakt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_05a80099368a47f6af75a9caffc2daee" name="Rubberen mat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_20f73a48830942b981315ad37532d7b4" body="Verhardingsobject van het materiaal rubber bestaande uit een vlak van matten."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6bbf02bb8dc94b4989f8d23a78178ab8" name="Rubberen plaat">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_99a4a703a246447e92f920316ece3ae2" body="Verhardingsobject van het materiaal rubber bestaande uit een vlak van platen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_43009d6d61e34e618c02eaa25d5e708e" name="Valdempend kunstgras">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_23b9b825f4dd4040a6682a4f5dc67580" body="Een als gras aanziend of aandoend, kunstmatig product van uiteenlopend, synthetisch materiaal dat als eigenschap heeft de val voor spelende of sportende gebruikers te verzachten."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_bc736886dfb748d882cbb5745c73d29e" name="enum_KunststofverhardingVulmateriaalKunstgras">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_80c5f149601d4c3395ac8a17b2b51521" name="Gecoate rubberkorrels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4d9333a904a2419d8300784c252d7acc" body="Rubber waarop een coating is aangebracht in vorm van korrels."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_253ca6f78121452db5392924c3932763" name="Geen vulmateriaal">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d9fb5995c8144c23ae3f53b1d1bd3333" body="Kunstgras waar geen materiaal ter vulling tussen is aangebracht."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_afc26acf9fca48f6acb5cce1d13ce8b9" name="Kurkkorrels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_bda0a965ef864d4daee0bb3ac3325294" body="en licht, elastisch materiaal, dat wordt gemaakt van de schors van de kurkeik, in de vorm van korrels."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3cf4b64e5fb245d1836fd35d920ed210" name="Rubberkorrels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2a7aaa57b5a44f76b5b99e9dcee29180" body="Een polymeer dat voorkomt als een emulsie in het sap van een aantal plantensoorten, zoals de rubberbomen, in de vorm van korrels."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1290f8f6b0584f24b06100f3b40c1f88" name="TPE rubberkorrels">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b6300a0de8664097a31c9328d8968357" body="Thermoplastisch elastomeer is een verzamelnaam voor kunststoffen die bij kamertemperatuur elastisch en bij verhitting thermoplastisch zijn, in de vorm van korrels."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d8c5d089be07483498e7a3aa110e3d5b" name="Zand">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d7b9b8a8ec144e9caca3bd995f0f8ea0" body="Onverhard object bestaande uit zeer kleine stukjes steenl korrels die in grootte variëren tussen 63 micrometer en 2 millimeter. Het is een zacht, hard, los of korrelig materiaal en een van de meest voorkomende natuurlijke stoffen op aarde."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_92269b550540407b9f47e9960d73067b" name="enum_KunstwerkOriëntatie">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bfdc85d4e02b469b9e75f1226761d86d" name="Boven">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1fdc228b0e144f2a848e835bfded5c73" body="Zich op een hoger gelegen plaats dan iets anders bevindend."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_9656220d7407450eb4200e4eae32042a" name="In">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9112cedbf1e44e7698e117d97b2de473" body="Omvat door iets anders."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1250abd6fe204b89b513cc52d30906e6" name="Links">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_4bd68be2447149199341b5377ef415ec" body="Richting tegengesteld aan rechts; de richting waar op een klok het cijfer 9 staat."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0d74bd65c3c041a5a1d99d0df5796750" name="Onder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c20b495ccd65474faecea68817778d19" body="Zich op een lager gelegen plaats dan iets anders bevindend."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_6a29913146d14698908cf60be00f50ca" name="Op">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d6859e328d4242f0ba6a080660b78a99" body="Zich aan de bovenzijde van iets anders bevindend."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7428bf92adf0473bb8a4591b4bf375d1" name="Rechts">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9b72b418f4ce4796954d15b49e133ba0" body="Richting tegengesteld aan links; de richting waar op een klok het cijfer 3 staat."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_5fdf038996254de4a019357741428ede" name="enum_KunstwerkTypeAfsluiting">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d275f787d5d34fb9840c0aaae1085dba" name="Niet afsluitbaar">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0409795f40244d369216d0c53fca8b1f" body="Waarde die aanduidt dat het object niet af te sluiten valt."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0b5780d9d6d4411b92380c35f7119aef" name="Onbekend">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2f0738a8da6449d1946a42100880fe7e" body="Bij deze waarde moet nader onderzoek uitwijzen of welke attribuutwaarde van toepassing is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_875f6369c6e54c049c3787770ae57669" name="Schotbalk">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_47faf0ca06f74862b1710a5a307b0b49" body="Balken die in of in de buurt van een coupure, stuw of sluis waarmee de doorgang afgesloten kan worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_136b8389e6ca4047b258e20714d99f68" name="Schotbalk sponning">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_43bce824af7c49fbb85cd4f6eb52f257" body="Een uitgezaagd, gefreesd of anderzijds gemaakte inham in een coupure, stuw of sluis waar schotbalken ingeschoven kunnen worden ten behoeve van de afsluiting van de kunstwerken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_32248318f78940cbb5f860e0068b7ac7" name="Schutdeur">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_87759c152e2845b7bb8baea6674d7f47" body="Beweegbaar deel van sommige stuwen, stormvloedkeringen en ander woord voor schutdeur."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_92cca66f47b8498e878c5837f6974113" name="Toegangsdeur">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1db0e73c6c4e424d915c33b73bc82f04" body="Een beweegbaar, vaak langwerpig, element dat toegang geeft tot een ruimte."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f3a0e43d099b405e92f2ba1b359da9fc" name="Tolklep">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8b68aa4eb31846a3955bf4b1e5af172a" body="Een technisch onderdeel dat bestaat uit een om een horizontale as draaiende klep die wordt aangedreven door een draaiende pin verticaal door het midden van de klep."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5728b219151442298b4bebae08dec0c3" name="Verticale schuif">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_13b441b16e6b44c8b90af325d6febdd0" body="Een verticaal wijzende ijzeren staaf waarmee een bewegend onderdeel van een object afgesloten kan worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4d3e7199e2154b4981420e3a13c414bc" name="Zandzakken">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_6cd70105d99a4ae28b94e3e1148826f1" body="Het object is afgesloten door een opstapeling van zakken die gevuld zijn met zand."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_6c9e5fdbbafb47b1b0c968bb209b6a18" name="enum_KunstwerkVorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_78a03800486447728b85a262806579e0" name="Anders (vorm)">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_92cb465016444373938bc176d6660bbd" body="Als de vorm van het object niet rechthoekig of rond is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_96ffed1842a6409a9af078873065a6e6" name="Rechthoekig">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1cfa590a18724848a57ca49f823111da" body="Een vierhoek met louter rechte hoeken."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ddeb281f717e4f838af2420e9bfd5266" name="Rond">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_79684840f15046b0b119c6e708e1e799" body="Cirkelvormig en zonder hoeken."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_d517df44bc8f491d9a6c85f51f9b866a" name="enum_KwaliteitsniveauVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d992266742d84e5ab89445e610ccbcb3" name="A">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_8e0392b865d6459e8df9cf34612e3989" body="Van goede kwaliteit."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_14d9035d77db4cfeac7b1029f43a9c4e" name="A+">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0a4a924e3c09411c8000cbef0fde46fa" body="Van perfecte of uitstekende kwaliteit."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_93e8235cef39435e972a1a60fa62ea06" name="B">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_22ba70ab61844b5395eaa4a0a07daefe" body="Van gemiddelde kwaliteit."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c9eebefe9b954f36aa868341f4561e39" name="C">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7a6305a70d8a41cca7fc6062f05f5902" body="Van matige kwaliteit."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_b3b3193b2a0b46829fe10522938a097f" name="D">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fb49a927f0df4a9ab16ffe37e855b361" body="Van slechte tot uiterst slechte kwaliteit."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_9e4e6828256b4dcab5dd6e94d7db8364" name="enum_LaadpleinVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d455222ce49d45b0bf4d50690bafac41" name="Master-slave laadplein">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c27e836aa1934208b5a0174ea98b88d9" body="Eén laadpaal (de master) heeft een netaansluiting en is direct aangesloten op het backofficesysteem. Alle andere laadpalen (slaves) zijn aangesloten op de master. De master bepaalt de laadsnelheiden communiceert met de backoffice."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_c98d4f4d628c43e3bed48c1f52141902" name="Systeem-straatkast laadplein">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_24caff2100104a3bb3685cf180117bcc" body="Hoofdaansluiting waarop andere laadpalen zijn aangesloten. Een systeemstraatkast kan zowel op DC (gelijkstroom – snelladen) als AC (wisselstroom – regulier laden) zijn aangesloten."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_6d0ac440e0c34f64b082eb64acdf8cb4" name="enum_LaadportaalVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_49050cce687b47ecaac36016985714af" name="Geïntegreerd pantograaflaadpunt">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_1a10e9701ea14058ad9ec6eb36bd8b4c" body="Een laadportaal waarvoor geldt dat de pantograaf een integraal onderdeel uitmaakt van de technische constructie en daardoor neerwaarts daalt naar het elektrische voertuig en daarop aansluit."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_2c3a634abded4b71b277180393915ee6" name="Laadpunt voor gemonteerde pantograaf">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b00c19d1175c4f98ae8f1eb286617b61" body="Een laadportaal waarvoor geldt dat de pantograaf op het elektrische voertuig gemonteerd is. Als zodanig reikt die pantograaf richting de aansluiting voor de externe pantograaf, welke onderdeel uitmaakt van het laadportaal."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_d3e6c799e1754237afa51e5bf586efb1" name="enum_LaadpuntTypeLaadinfrastructuur">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0b213f89aa014fb7b7c84400eaf4784f" name="AC-laadinfrastructuur">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_b0fd6ae4d03a47a190e0fb573625b47f" body="De laadinfrastructuur die het meest in het straatbeeld is te zien is: AC-laadpalen tot 22 kW, die via het standaard elektriciteitsnet wordt geleverd zoals dat ook wordt gedaan aan huishoudens en industrie."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_8d1b2279f29e42018d111c69c15cfce0" name="DC-laadinfrastructuur">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_47242671649a4adbbcadf5e185caaf55" body="De laadinfrastructuur waarbij, in tegenstelling tot de AC-laadinfrastructuur, de wisselstroom van het elektriciteitsnet wordt omgezet in gelijkstroom in de laadpaal in plaats van in het aangesloten voertuig. DC-laadpalen hebben over het algemeen een vermo"/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_df5b17c253fd40e2a592c9263b6f1c9d" name="enum_LaadpuntTypeLaadpunt">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_26124c5d30974aab9cbb9584ca3b2259" name="Privaat laadpunt">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_2c36f0201e3b4705b26b9b8b8f8ec9e5" body="Private laadpunten: Laadpunten op een (afgesloten) bedrijfsterrein of bij de gebruiker. Het voordeel voor bedrijven is dat er zekerheid is over de beschikbaarheid van dit laadpunt en de stroomtarieven voor bedrijven veelal lager zijn. Deze laadinfrastruct"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_a12411517c984c5d9ad2d1ebfbc173fd" name="Publiek laadpunt">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_af15f977d0e048b7a8684d0748278912" body="Publieke laadpunten: Laadpunten op openbaar terrein. Het voordeel is dat deze voor iedereen toegankelijk zijn. Een nadeel is dat stroomkosten doorgaans hoger zijn en dat beschikbaarheid onzekerder is. Publieke laadpunten worden vooralsnog deels door gemee"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_e065d0ef50ce49719038458921a87236" name="Semi-publiek laadpunt">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0ed68616fcd84269b66d9e5e1ad7b74f" body="Semi-publieke laadpunten: Semi-publieke laadpunten zijn onder voorwaarden toegankelijk voor derden (bijvoorbeeld achter een slagboom). Zo kan een logistiek bedrijf vrachtwagens van andere logistieke bedrijven laten laden op zijn terrein (gastgebruik). Ook"/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_8b1998b0816e4e948cdc90f76b55c673" name="enum_LaadpuntVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_43f969ab7e1e4a4e856d537274c550a0" name="Inductielaadpunt">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_baf43907275140ffa571c4354cddeb21" body="Een ondergronds laadpunt onder een laadvak dat een magnetisch veld opwekt tussen een spoel die onderdeel is van het laadpunt en een spoel die onderdeel uitmaakt van een elektrisch voertuig voor de overdracht van elektrische stroom."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_37b12d355b9642dc92423738d46c3f1e" name="Magnetisch laadpunt voor veerponten">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_a6740aecb5e645c493fc252106cda041" body="Een laadpunt aan een oever van een veerverbinding dat door middel van een magnetisch oppervlak voorziet in de overdracht van elektriciteit naar het magnetische oppervlak dat deel uitmaakt van een veerboot."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_71b0fa1293eb4b6c9a2c0c3d16486056" name="Reguliere lader">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9e0e8c49ca6645ab9d5a9a7bc621fac9" body="Een laadpunt met een lagere laadsnelheid dan bij gelijkstroom en daarom wordt het gebruikt op plekken waar de auto langer staat: thuis, op werk of publieke parkeerplaatsen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_63bed839aec747e592a4349f9cf4f617" name="Snellader">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0de543422fa94881a80bfb3074b17e6f" body="De term ‘snelladen’ wordt gebruikt voor de techniek waarmee in korte tijd veel vermogen kan worden toegevoegd aan elektrische voertuigen. Dit gebeurt op speciale laadpunten langs de weg en is bedoeld om langere ritten mogelijk te maken en tijd te besparen"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3d43164d720a4310b960a6a2377e52db" name="Thuislader">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c1de3ec61c7e4fa185acc40e8552edc6" body="Laadpunt die op een woonadres aanwezig is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_69306df8f44d46e89d4c6d5d14777e15" name="Ultrasnelle lader">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_7b0cc49a653e4fc4be3fd85d4c5bff3f" body="Een laadpunt waarmee een elektrisch voertuig binnen 10 tot 60 minuten opgeladen kan worden en zijn vooral geschikt voor tankstations, vergaderlocaties of wegrestaurants."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_638ab93483e74a59a8bb96ccd469de14" name="enum_LandschappelijkGebiedVerschijningsvorm">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_96855cdc535743c087c2c84b26c9c893" name="Bosgebied">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d6d627b9e0f44254a81cb59f32b4b96b" body="Gebied dat overwegend met bos begroeid is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5e4d75e3deec40b18404c0d3ad625e87" name="Cultuurlandschap">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_ce0fd3d053754935824b4c2d3d7b0dab" body="Gebied dat overwegend een agrarisch gebruik kent."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_38e4007437bd43d5a1aef6e64f94c0c3" name="Duingebied">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_9b3a2cba83ca479f977635ee0b864dc2" body="Gebied bestaande uit verhogingen of heuvels van zand of fijne losse aarde opgeworpen door wind die grenzen aan zeestranden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_f85dc350a245448cb0d56b2fd0bc1efc" name="Eiland">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3d9d2852211642f4996e7de9400799ff" body="Landoppervlak dat aan alle kanten omringd is door water."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_bf7c113d9b4944bcac73e367bb6d927f" name="Heidegebied">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_99abc39df877483683af89efe99b1fc6" body="Gebied dat overwegend met heide begroeid is."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_da71b0346fac4ca08e5ec7ad53941205" name="Landgoed">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_c746eb1c261148d580d5821ae3294fb6" body="Aaneengesloten en samenhangend gebied met akkerlanden, graslanden, bossen en of tuinen en gebouwen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_1db7cc5fe891478e945133c41dbea6ba" name="Polder">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_0b7235582ba04c8694891afb690af3f0" body="Gebied dat door één of meerdere waterkeringen is omgeven en waarvan de waterstand kunstmatig geregeld kan worden."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_5371ad040b4f44478ed4eb439e7ec5b7" name="Stuifzandgebied">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5de3ee3c50a44d20a94b429a0cfc14be" body="Een stuifzandgebied, ook wel zandverstuiving genoemd, is een gebied waar zand door de wind wordt verplaatst. Dit gebeurt vaak op open plekken in heidevelden of duinen, waar de begroeiing ontbreekt of beschadigd is, waardoor het zand vrij kan komen te ligg"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_632556ed45e2477cbd5fe5e144e362f8" name="Watergebied">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d2b730544961448f862100bf1109a473" body="Gebied dat overwegend met water bedekt is."/>
        </ownedLiteral>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="enum_c0bf8ad5d5ec425380329b2254939ee7" name="enum_LeidingOntgravingsmethode">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_4e28ac51ee094d87989e0603c4a8dc65" name="Geboorde leiding">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_3adf282510404d0c92d808446e473a59" body="De leiding is aangelegd door middel van een het boren van een gat met behulp van aangestuurd materieel."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_7c46c313e93f412eb8ac31dc1d734af8" name="Persing">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_d5eb57e1423f4677860ee3553f4c1cb8" body="Een ondergrondse, horizontale boring voor het leggen van leidingen en buizen."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_3af93a3a10044057b9113dfbcb894fdb" name="Sleuf met bronnering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5f547c3b8c0a40b682420faddd6f4f9c" body="Een ontgravingsmethode waarbij een geul wordt gegraven en grondwaterspiegelverlaging wordt toegepast."/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_d67b6ac638b04207a673d37010a9cceb" name="Sleuf zonder bronnering">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_5dc5964d7b1241af98e709ec7f55dfb2" body="Een ontgravingsmethode waarbij een geul wordt gegraven zonder dat grondwaterspiegelverlaging wordt toegepast."/>
        </ownedLiteral>
      </packagedElement>

        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_0b707b2f8a014dfeb8b86dee74a3b5cf" name="Stadsbos">
          <ownedComment xmi:type="uml:Comment" xmi:id="cmt_fd89f15db3fc48fc9ae3af080d69381b" body="Een stadsbos is een bosgebied dat zich binnen of direct grenzend aan een stedelijke omgeving bevindt. Het is meer dan alleen een bos in een stad, het is een gebied met bomen en bijbehorende vegetatie dat actief deel uitmaakt van de stad en wordt gebruikt "/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="lit_ffcbefb6a96b48989597554a9cd5d23d" name="Verblijfplaats vleermuizen">
